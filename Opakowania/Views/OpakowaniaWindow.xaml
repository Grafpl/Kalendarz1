<Window x:Class="Kalendarz1.Opakowania.Views.OpakowaniaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Opakowania Zwrotne"
        WindowState="Maximized"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#ECF0F1"
        FontFamily="Segoe UI"
        WindowStyle="None"
        AllowsTransparency="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/OpakowaniaStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding OdswiezCommand}"/>
        <KeyBinding Key="G" Modifiers="Ctrl" Command="{Binding ToggleGrupowanieCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EksportExcelCommand}"/>
        <KeyBinding Key="P" Modifiers="Ctrl" Command="{Binding DrukujCommand}"/>
        <KeyBinding Key="Escape" Command="{x:Null}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="colDiag" Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- LEWA STRONA - glowna zawartosc -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- PASEK TYTULU -->
            <Border Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1B5E20" Offset="0"/>
                        <GradientStop Color="#2E7D32" Offset="0.5"/>
                        <GradientStop Color="#43A047" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Height="50">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                        <TextBlock Text="&#x1F4E6;" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="OPAKOWANIA ZWROTNE" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{Binding NazwaHandlowca}" FontSize="11" Foreground="#CCFFFFFF"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#x1F5D5;" Style="{StaticResource WindowButtonStyle}" Click="MinimizeButton_Click" FontSize="14"/>
                        <Button Content="&#x1F5D6;" Style="{StaticResource WindowButtonStyle}" Click="MaximizeButton_Click" FontSize="14"/>
                        <Button Content="&#x2715;" Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- TOOLBAR -->
            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="12,12,12,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Gorny rzad: Toggle + Filtry + Przyciski -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <!-- Toggle View Mode -->
                            <Border Background="#E8F5E9" CornerRadius="8" Padding="4" Margin="0,0,15,0">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="rbWszystkieTypy" Content="Wszystkie typy"
                                                 IsChecked="{Binding IsWszystkieTypy, Mode=OneWay}"
                                                 Checked="RbWszystkieTypy_Checked"
                                                 Style="{StaticResource ToggleRadioStyle}" Margin="0,0,2,0"/>
                                    <RadioButton x:Name="rbPerTyp" Content="Per typ"
                                                 IsChecked="{Binding IsPerTyp, Mode=OneWay}"
                                                 Checked="RbPerTyp_Checked"
                                                 Style="{StaticResource ToggleRadioStyle}"/>
                                </StackPanel>
                            </Border>

                            <!-- Daty -->
                            <StackPanel Margin="0,0,15,0"
                                        Visibility="{Binding IsPerTyp, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="DATA OD" Style="{StaticResource LabelTextStyle}" FontSize="9"/>
                                <DatePicker SelectedDate="{Binding DataOd, Mode=TwoWay}"
                                            Style="{StaticResource ModernDatePickerStyle}" Width="120"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,15,0">
                                <TextBlock Text="STAN NA DZIEN" Style="{StaticResource LabelTextStyle}" FontSize="9"/>
                                <DatePicker SelectedDate="{Binding DataDo, Mode=TwoWay}"
                                            Style="{StaticResource ModernDatePickerStyle}" Width="120"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,15,0">
                                <TextBlock Text="SZYBKI FILTR" Style="{StaticResource LabelTextStyle}" FontSize="9"/>
                                <ComboBox ItemsSource="{Binding FiltryDat}" SelectedItem="{Binding WybranyFiltrDaty}"
                                          DisplayMemberPath="Nazwa" Style="{StaticResource ModernComboBoxStyle}" Width="140"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,15,0"
                                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="HANDLOWIEC" Style="{StaticResource LabelTextStyle}" FontSize="9"/>
                                <ComboBox ItemsSource="{Binding ListaHandlowcow}" SelectedItem="{Binding WybranyHandlowiec}"
                                          Style="{StaticResource ModernComboBoxStyle}" Width="160"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,15,0">
                                <TextBlock Text="SZUKAJ" Style="{StaticResource LabelTextStyle}" FontSize="9"/>
                                <TextBox x:Name="txtSzukaj" Text="{Binding FiltrTekstowy, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBoxStyle}" Width="200" Height="32"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding OdswiezCommand}" Margin="0,0,6,0"
                                    Background="#2E7D32" Padding="10,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F504;" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="Odswiez" FontSize="11"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource InfoButtonStyle}" Command="{Binding EksportPDFCommand}" Margin="0,0,6,0"
                                    Background="#66BB6A" Padding="10,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4C4;" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="PDF" FontSize="11"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource InfoButtonStyle}" Command="{Binding EksportExcelCommand}" Margin="0,0,6,0"
                                    Background="#81C784" Padding="10,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4CA;" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="Excel" FontSize="11"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource InfoButtonStyle}" Command="{Binding DrukujCommand}"
                                    Background="#A5D6A7" Padding="10,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F5A8;" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="Drukuj" FontSize="11"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Dolny rzad: Podsumowanie sald (tylko WszystkieTypy) -->
                    <Border Grid.Row="1" Margin="0,10,0,0"
                            Visibility="{Binding IsWszystkieTypy, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- E2 -->
                            <Border Grid.Column="0" Background="#E8F5E9" CornerRadius="6" Padding="10,6" Margin="0,0,6,0" BorderBrush="#2E7D32" BorderThickness="0,0,0,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4E6;" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <StackPanel>
                                        <TextBlock Text="E2" FontSize="9" FontWeight="SemiBold" Foreground="#4CAF50"/>
                                        <TextBlock Text="{Binding SumaE2, Converter={StaticResource SaldoToTextConverter}}"
                                                   FontSize="16" FontWeight="Bold"
                                                   Foreground="{Binding SumaE2, Converter={StaticResource SaldoToColorConverter}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- H1 -->
                            <Border Grid.Column="1" Background="#C8E6C9" CornerRadius="6" Padding="10,6" Margin="0,0,6,0" BorderBrush="#388E3C" BorderThickness="0,0,0,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F3A8;" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <StackPanel>
                                        <TextBlock Text="H1" FontSize="9" FontWeight="SemiBold" Foreground="#43A047"/>
                                        <TextBlock Text="{Binding SumaH1, Converter={StaticResource SaldoToTextConverter}}"
                                                   FontSize="16" FontWeight="Bold"
                                                   Foreground="{Binding SumaH1, Converter={StaticResource SaldoToColorConverter}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- EURO -->
                            <Border Grid.Column="2" Background="#E8F5E9" CornerRadius="6" Padding="10,6" Margin="0,0,6,0" BorderBrush="#2E7D32" BorderThickness="0,0,0,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F7E9;" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <StackPanel>
                                        <TextBlock Text="EURO" FontSize="9" FontWeight="SemiBold" Foreground="#27AE60"/>
                                        <TextBlock Text="{Binding SumaEURO, Converter={StaticResource SaldoToTextConverter}}"
                                                   FontSize="16" FontWeight="Bold"
                                                   Foreground="{Binding SumaEURO, Converter={StaticResource SaldoToColorConverter}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- PCV -->
                            <Border Grid.Column="3" Background="#F3E8FF" CornerRadius="6" Padding="10,6" Margin="0,0,6,0" BorderBrush="#9B59B6" BorderThickness="0,0,0,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F7EA;" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <StackPanel>
                                        <TextBlock Text="PCV" FontSize="9" FontWeight="SemiBold" Foreground="#9B59B6"/>
                                        <TextBlock Text="{Binding SumaPCV, Converter={StaticResource SaldoToTextConverter}}"
                                                   FontSize="16" FontWeight="Bold"
                                                   Foreground="{Binding SumaPCV, Converter={StaticResource SaldoToColorConverter}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- DREW -->
                            <Border Grid.Column="4" Background="#FEF3C7" CornerRadius="6" Padding="10,6" Margin="0,0,6,0" BorderBrush="#F39C12" BorderThickness="0,0,0,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F7EB;" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <StackPanel>
                                        <TextBlock Text="DREW" FontSize="9" FontWeight="SemiBold" Foreground="#F39C12"/>
                                        <TextBlock Text="{Binding SumaDREW, Converter={StaticResource SaldoToTextConverter}}"
                                                   FontSize="16" FontWeight="Bold"
                                                   Foreground="{Binding SumaDREW, Converter={StaticResource SaldoToColorConverter}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Kontrahenci -->
                            <Border Grid.Column="5" Background="#E3F2FD" CornerRadius="6" Padding="10,6" BorderBrush="#1976D2" BorderThickness="0,0,0,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F465;" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Kontrahenci" FontSize="9" FontWeight="SemiBold" Foreground="#1976D2"/>
                                        <TextBlock Text="{Binding LiczbaKontrahentow}" FontSize="16" FontWeight="Bold" Foreground="#1565C0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- WYBOR TYPU OPAKOWANIA (tylko PerTyp) -->
            <Border Grid.Row="2" Style="{StaticResource CardPanel}" Margin="12,0,12,6" Padding="12"
                    Visibility="{Binding IsPerTyp, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="btnE2" Style="{StaticResource PackageButtonStyle}"
                                Command="{Binding WybierzTypOpakowaniCommand}" CommandParameter="E2"
                                ToolTip="Pojemnik Drobiowy E2">
                            <StackPanel>
                                <Border Width="48" Height="48" Background="#EBF5FF" CornerRadius="10" Margin="0,0,0,6">
                                    <TextBlock Text="&#x1F4E6;" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="E2" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" Foreground="#3498DB"/>
                                <TextBlock Text="Pojemnik" FontSize="10" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnH1" Style="{StaticResource PackageButtonStyle}"
                                Command="{Binding WybierzTypOpakowaniCommand}" CommandParameter="H1"
                                ToolTip="Paleta H1">
                            <StackPanel>
                                <Border Width="48" Height="48" Background="#FFF7ED" CornerRadius="10" Margin="0,0,0,6">
                                    <TextBlock Text="&#x1F3A8;" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="H1" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" Foreground="#E67E22"/>
                                <TextBlock Text="Paleta" FontSize="10" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnEURO" Style="{StaticResource PackageButtonStyle}"
                                Command="{Binding WybierzTypOpakowaniCommand}" CommandParameter="EURO"
                                ToolTip="Paleta EURO">
                            <StackPanel>
                                <Border Width="48" Height="48" Background="#E8F5E9" CornerRadius="10" Margin="0,0,0,6">
                                    <TextBlock Text="&#x1F7E9;" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="EURO" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" Foreground="#27AE60"/>
                                <TextBlock Text="Paleta" FontSize="10" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnPCV" Style="{StaticResource PackageButtonStyle}"
                                Command="{Binding WybierzTypOpakowaniCommand}" CommandParameter="PCV"
                                ToolTip="Paleta Plastikowa">
                            <StackPanel>
                                <Border Width="48" Height="48" Background="#F3E8FF" CornerRadius="10" Margin="0,0,0,6">
                                    <TextBlock Text="&#x1F7EA;" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="PCV" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" Foreground="#9B59B6"/>
                                <TextBlock Text="Plastikowa" FontSize="10" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnDREW" Style="{StaticResource PackageButtonStyle}"
                                Command="{Binding WybierzTypOpakowaniCommand}" CommandParameter="DREW"
                                ToolTip="Paleta Drewniana">
                            <StackPanel>
                                <Border Width="48" Height="48" Background="#FEF3C7" CornerRadius="10" Margin="0,0,0,6">
                                    <TextBlock Text="&#x1F7EB;" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="DREW" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" Foreground="#F39C12"/>
                                <TextBlock Text="Drewniana" FontSize="10" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Statystyki Per Typ -->
                    <Border Grid.Column="1" Background="#F8F9FA" CornerRadius="10" Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Kontrahenci" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding LiczbaKontrahentowPerTyp}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryGreenBrush}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Potwierdzen" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding LiczbaPotwierdzen}" FontSize="22" FontWeight="Bold" Foreground="#27AE60"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- CONTENT - przylaczane Visibility -->
            <Grid Grid.Row="3" Margin="12,0,12,12">
                <!-- DataGrid WszystkieTypy -->
                <Border Visibility="{Binding IsWszystkieTypy, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#E8F5E9" CornerRadius="8" Padding="10,6" Margin="0,0,0,8">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4CB;" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Salda Wszystkich Opakowan" FontSize="13" FontWeight="Bold"
                                               Foreground="#1B5E20" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <CheckBox Content="Tylko swoi" IsChecked="{Binding PokazujTylkoSwoich}"
                                              Style="{StaticResource ModernCheckBoxStyle}" Margin="0,0,15,0" FontSize="11"/>
                                    <Button Style="{StaticResource InfoButtonStyle}" Command="{Binding ToggleGrupowanieCommand}"
                                            Background="#43A047" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding TekstGrupowania}" FontSize="10" Foreground="White"/>
                                    </Button>
                                    <TextBlock Text="PPM = Opcje | 2x klik = Szczegoly" FontSize="9"
                                               Foreground="{StaticResource TextMutedBrush}" FontStyle="Italic"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" BorderBrush="#2E7D32" BorderThickness="2" CornerRadius="8" ClipToBounds="True">
                            <DataGrid x:Name="dataGridSalda"
                                      ItemsSource="{Binding SaldaView}"
                                      SelectedItem="{Binding WybraneSaldo}"
                                      Style="{StaticResource ModernDataGridStyle}"
                                      CellStyle="{StaticResource ModernDataGridCellStyle}"
                                      MouseDoubleClick="DataGridSalda_MouseDoubleClick">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernDataGridColumnHeaderStyle}">
                                        <Setter Property="Background" Value="#2E7D32"/>
                                        <Setter Property="BorderBrush" Value="#1B5E20"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRowStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SaldoCalkowite, Converter={StaticResource ThresholdConverter}, ConverterParameter=Critical}" Value="True">
                                                <Setter Property="Background" Value="#FFEBEE"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SaldoCalkowite, Converter={StaticResource ThresholdConverter}, ConverterParameter=Warning}" Value="True">
                                                <Setter Property="Background" Value="#FFF3E0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Szczegoly kontrahenta" Click="MenuSzczegolyWszystkie_Click" FontWeight="SemiBold"/>
                                        <Separator/>
                                        <MenuItem Header="Zadzwon" Click="MenuZadzwon_Click"/>
                                        <MenuItem Header="Wyslij email" Click="MenuWyslijEmail_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Eksport PDF" Click="MenuEksportPDF_Click"/>
                                        <MenuItem Header="Eksport Excel" Click="MenuEksportExcel_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <Border Background="#E8F5E9" Padding="8,4" CornerRadius="4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Handlowiec: " FontWeight="SemiBold" Foreground="#2E7D32"/>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#1B5E20"/>
                                                        <TextBlock Text=" (" Foreground="#666"/>
                                                        <TextBlock Text="{Binding ItemCount}" FontWeight="Bold" Foreground="#1565C0"/>
                                                        <TextBlock Text=")" Foreground="#666"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </DataGrid.GroupStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Kontrahent" Binding="{Binding Kontrahent}" Width="*" MinWidth="200"/>
                                    <DataGridTextColumn Header="Handlowiec" Binding="{Binding Handlowiec}" Width="120"/>
                                    <DataGridTemplateColumn Header="E2" Width="90" SortMemberPath="SaldoE2">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SaldoE2}" FontWeight="SemiBold" HorizontalAlignment="Right"
                                                           Foreground="{Binding SaldoE2, Converter={StaticResource SaldoToColorConverter}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="H1" Width="90" SortMemberPath="SaldoH1">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SaldoH1}" FontWeight="SemiBold" HorizontalAlignment="Right"
                                                           Foreground="{Binding SaldoH1, Converter={StaticResource SaldoToColorConverter}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="EURO" Width="90" SortMemberPath="SaldoEURO">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SaldoEURO}" FontWeight="SemiBold" HorizontalAlignment="Right"
                                                           Foreground="{Binding SaldoEURO, Converter={StaticResource SaldoToColorConverter}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="PCV" Width="90" SortMemberPath="SaldoPCV">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SaldoPCV}" FontWeight="SemiBold" HorizontalAlignment="Right"
                                                           Foreground="{Binding SaldoPCV, Converter={StaticResource SaldoToColorConverter}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="DREW" Width="90" SortMemberPath="SaldoDREW">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SaldoDREW}" FontWeight="SemiBold" HorizontalAlignment="Right"
                                                           Foreground="{Binding SaldoDREW, Converter={StaticResource SaldoToColorConverter}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="RAZEM" Width="110" SortMemberPath="SaldoCalkowite">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding SaldoCalkowite, Converter={StaticResource SaldoCardBackgroundConverter}}"
                                                        CornerRadius="6" Padding="8,2" Margin="-4,0">
                                                    <TextBlock Text="{Binding SaldoCalkowite}" FontWeight="Bold" HorizontalAlignment="Center"
                                                               Foreground="{Binding SaldoCalkowite, Converter={StaticResource SaldoToColorConverter}}"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Akcje" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource SmallButtonStyle}" Click="BtnSzczegolyWszystkie_Click"
                                                        ToolTip="Zobacz szczegoly" Padding="8,4" Background="#2E7D32">
                                                    <TextBlock Text="&#x1F441;" FontSize="14"/>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>

                <!-- DataGrid PerTyp -->
                <Border Visibility="{Binding IsPerTyp, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#E8F5E9" CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4CB;" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Zestawienie Sald" FontSize="15" FontWeight="Bold"
                                               Foreground="#2E7D32" VerticalAlignment="Center"/>
                                    <TextBlock Text=" - " Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Text="{Binding TytulTypuOpakowania}" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Style="{StaticResource AccentButtonStyle}" Command="{Binding GenerujZestawieniePDFCommand}" Margin="0,0,8,0"
                                            Padding="8,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x1F4C4;" FontSize="12" Margin="0,0,4,0"/>
                                            <TextBlock Text="PDF Zest." FontSize="10"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SuccessButtonStyle}" Command="{Binding GenerujPDFiWyslijCommand}"
                                            Padding="8,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x1F4E7;" FontSize="12" Margin="0,0,4,0"/>
                                            <TextBlock Text="PDF+Wyslij" FontSize="10"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" BorderBrush="{StaticResource PrimaryGreenBrush}" BorderThickness="2"
                                CornerRadius="10" ClipToBounds="True">
                            <DataGrid x:Name="dataGridZestawienie"
                                      ItemsSource="{Binding ZestawienieFiltrowane}"
                                      SelectedItem="{Binding WybranyKontrahentPerTyp}"
                                      Style="{StaticResource ModernDataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                                      CellStyle="{StaticResource ModernDataGridCellStyle}"
                                      RowStyle="{StaticResource ModernDataGridRowStyle}"
                                      MouseDoubleClick="DataGridZestawienie_MouseDoubleClick">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Szczegoly kontrahenta" Click="MenuSzczegolyPerTyp_Click" FontWeight="SemiBold"/>
                                        <MenuItem Header="Dodaj potwierdzenie" Click="MenuDodajPotwierdzenie_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Eksport do Excel" Click="MenuEksportExcel_Click"/>
                                        <MenuItem Header="Eksport do PDF" Click="MenuEksportPDF_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Kontrahent" Binding="{Binding Kontrahent}" Width="*" MinWidth="200"/>
                                    <DataGridTextColumn Header="Handlowiec" Binding="{Binding Handlowiec}" Width="120"/>
                                    <DataGridTemplateColumn Header="Saldo" Width="120" SortMemberPath="IloscDrugiZakres">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding IloscDrugiZakres, Converter={StaticResource SaldoToTextConverter}}"
                                                           Foreground="{Binding IloscDrugiZakres, Converter={StaticResource SaldoToColorConverter}}"
                                                           FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Potwierdzone" Width="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="8" Padding="6,3" HorizontalAlignment="Center"
                                                        Background="{Binding JestPotwierdzone, Converter={StaticResource PotwierdzenieToBackgroundConverter}}">
                                                    <TextBlock Text="{Binding DataPotwierdzeniaTekst}" HorizontalAlignment="Center"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Ostatni dok." Binding="{Binding TowarZDokumentu}" Width="100"/>
                                    <DataGridTextColumn Header="Data ost." Binding="{Binding DataOstatniegoDokumentu, StringFormat=dd.MM.yyyy}" Width="90"/>
                                    <DataGridTemplateColumn Header="Akcje" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource SmallButtonStyle}" Click="BtnSzczegolyPerTyp_Click"
                                                            ToolTip="Szczegoly" Padding="6,4" Margin="0,0,4,0">
                                                        <TextBlock Text="&#x1F441;" FontSize="12"/>
                                                    </Button>
                                                    <Button Style="{StaticResource SmallButtonStyle}" Click="BtnPotwierdzeniePerTyp_Click"
                                                            ToolTip="Potwierdz" Padding="6,4" Background="#27AE60">
                                                        <TextBlock Text="&#x2705;" FontSize="12"/>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- STOPKA -->
            <Border Grid.Row="4" Background="White" BorderBrush="#C8E6C9"
                    BorderThickness="0,1,0,0" Padding="12,8">
                <Grid>
                    <TextBlock Text="F5: Odswiez | Ctrl+G: Grupuj | Ctrl+E: Excel | Ctrl+P: Drukuj | ESC: Zamknij"
                               FontSize="10" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Zamknij" Style="{StaticResource SecondaryButtonStyle}" Click="CloseButton_Click" Padding="12,6" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- LOADING OVERLAY -->
            <Grid Grid.RowSpan="5" Background="#80FFFFFF"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Background="White" CornerRadius="12" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0" Color="#000" Opacity="0.2" BlurRadius="20"/>
                    </Border.Effect>
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="6" Foreground="#2E7D32"/>
                        <TextBlock Text="Ladowanie danych..." FontSize="14" Foreground="#2E7D32"
                                   HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- PRAWA STRONA - PANEL DIAGNOSTYKI -->
        <Border Grid.Column="1" Background="#1A1A2E" BorderBrush="#16213E" BorderThickness="1,0,0,0">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#16213E" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x26A1;" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="DIAGNOSTYKA" FontSize="14" FontWeight="Bold" Foreground="#00D9FF"/>
                        </StackPanel>
                        <TextBlock Text="Monitoring wydajnosci" FontSize="10" Foreground="#888" Margin="26,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="#16213E" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="METRYKI" FontSize="10" Foreground="#666" FontWeight="Bold" Margin="0,0,0,6"/>

                        <!-- Aktywny tryb -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Aktywny tryb:" Foreground="#AAA" FontSize="10"/>
                            <TextBlock x:Name="txtAktywnyTryb" Grid.Column="1" Text="--" Foreground="#00D9FF" FontWeight="Bold" FontSize="10"/>
                        </Grid>

                        <!-- Czas calkowity -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Czas calkowity:" Foreground="#AAA" FontSize="10"/>
                            <TextBlock x:Name="txtLastLoadTime" Grid.Column="1" Text="-- ms" Foreground="#00FF88" FontWeight="Bold" FontSize="10"/>
                        </Grid>

                        <!-- Czas SQL -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="  SQL/Cache:" Foreground="#888" FontSize="10"/>
                            <TextBlock x:Name="txtSqlTime" Grid.Column="1" Text="-- ms" Foreground="#FFD700" FontWeight="Bold" FontSize="10"/>
                        </Grid>

                        <!-- Czas UI -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="  UI/Render:" Foreground="#888" FontSize="10"/>
                            <TextBlock x:Name="txtUiTime" Grid.Column="1" Text="-- ms" Foreground="#FF8C00" FontWeight="Bold" FontSize="10"/>
                        </Grid>

                        <!-- Rekordow -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Rekordow:" Foreground="#AAA" FontSize="10"/>
                            <TextBlock x:Name="txtLiczbaRekordow" Grid.Column="1" Text="0" Foreground="#FFF" FontWeight="Bold" FontSize="10"/>
                        </Grid>

                        <!-- Zrodlo -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Zrodlo:" Foreground="#AAA" FontSize="10"/>
                            <TextBlock x:Name="txtZrodloDanych" Grid.Column="1" Text="--" Foreground="#00D9FF" FontWeight="Bold" FontSize="10"/>
                        </Grid>

                        <Border Height="1" Background="#333" Margin="0,6"/>

                        <!-- Cache hit rate -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cache hit rate:" Foreground="#AAA" FontSize="10"/>
                            <TextBlock x:Name="txtCacheHitRate" Grid.Column="1" Text="-- %" Foreground="#FFD700" FontWeight="Bold" FontSize="10"/>
                        </Grid>

                        <!-- Operacji -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Operacji:" Foreground="#AAA" FontSize="10"/>
                            <TextBlock x:Name="txtTotalOperations" Grid.Column="1" Text="0" Foreground="#FFF" FontWeight="Bold" FontSize="10"/>
                        </Grid>

                        <!-- Status cache -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Status cache:" Foreground="#AAA" FontSize="10"/>
                            <TextBlock x:Name="txtCacheStatus" Grid.Column="1" Text="--" Foreground="#00D9FF" FontWeight="Bold" FontSize="10"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="#16213E" CornerRadius="8" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="LOG OPERACJI" FontSize="10" Foreground="#666" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="txtDiagLog"
                                     FontFamily="Consolas" FontSize="10"
                                     Foreground="#DCDCDC" Background="Transparent"
                                     BorderThickness="0" IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     Text="Oczekiwanie na dane..."/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="3" Margin="0,10,0,0">
                    <Button x:Name="btnRunTest" Content="&#x26A1; SZYBKI TEST" Click="BtnRunTest_Click"
                            Background="#5C2D91" Foreground="White" FontWeight="Bold" FontSize="10"
                            Padding="8,8" Cursor="Hand" BorderThickness="0" Margin="0,0,0,6">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="btnFullTest" Content="&#x1F9EA; PELNY TEST (oba tryby)" Click="BtnFullTest_Click"
                            Background="#1565C0" Foreground="White" FontWeight="Bold" FontSize="10"
                            Padding="8,8" Cursor="Hand" BorderThickness="0" Margin="0,0,0,6">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnCopyDiag" Content="Kopiuj" Click="BtnCopyDiag_Click"
                                Background="#107C10" Foreground="White" FontWeight="Bold" FontSize="10"
                                Padding="8,6" Cursor="Hand" BorderThickness="0" Margin="0,0,4,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="btnResetDiag" Grid.Column="1" Content="Reset" Click="BtnResetDiag_Click"
                                Background="#D83B01" Foreground="White" FontWeight="Bold" FontSize="10"
                                Padding="8,6" Cursor="Hand" BorderThickness="0" Margin="4,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <TextBlock x:Name="txtLastUpdate" Text="Aktualizacja: --"
                               Foreground="#555" FontSize="9" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
