<Window x:Class="Kalendarz1.Opakowania.Views.DodajPotwierdzenieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Potwierdzenie salda"
        Width="520" Height="580"
        MinWidth="420" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="White"
        FontFamily="Segoe UI"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="SingleBorderWindow">

    <DockPanel Margin="0">

        <!-- Stopka -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="16,10">
            <DockPanel>
                <Button DockPanel.Dock="Right" Click="BtnZapisz_Click" Content="Zapisz potwierdzenie"
                        Width="180" Height="36" FontSize="13" FontWeight="Bold" Cursor="Hand"
                        Background="#16A34A" Foreground="White" BorderThickness="0"/>
                <Button DockPanel.Dock="Right" Click="BtnAnuluj_Click" Content="Anuluj"
                        Width="80" Height="36" FontSize="12" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding Info}" FontSize="11" Foreground="#94A3B8"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Treść -->
        <StackPanel Margin="20,16,20,10">

            <!-- Kontrahent + data -->
            <TextBlock Text="{Binding KontrahentNazwa}" FontSize="15" FontWeight="Bold"
                       Foreground="#1E293B" TextWrapping="Wrap" Margin="0,0,0,4"/>
            <DockPanel Margin="0,0,0,16">
                <TextBlock Text="Stan na dzień:" FontSize="12" Foreground="#64748B"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding DataPotwierdzenia}" FontSize="12"
                            VerticalAlignment="Center" Width="140"/>
            </DockPanel>

            <!-- Tabela -->
            <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="44"/>
                    </Grid.RowDefinitions>

                    <!-- Nagłówki -->
                    <Border Grid.Row="0" Grid.ColumnSpan="4" Background="#F1F5F9"/>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Opakowanie" FontSize="11" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="W systemie" FontSize="11" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Potwierdzone" FontSize="11" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Różnica" FontSize="11" FontWeight="Bold" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <!-- Separatory poziome -->
                    <Border Grid.Row="0" Grid.ColumnSpan="4" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"/>
                    <Border Grid.Row="1" Grid.ColumnSpan="4" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1"/>
                    <Border Grid.Row="2" Grid.ColumnSpan="4" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1"/>
                    <Border Grid.Row="3" Grid.ColumnSpan="4" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1"/>
                    <Border Grid.Row="4" Grid.ColumnSpan="4" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1"/>

                    <!-- E2 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="E2 Pojemnik" FontSize="12" FontWeight="SemiBold" Foreground="#3B82F6" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SysE2}" FontSize="16" FontWeight="Bold" Foreground="#334155" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding PotwE2, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" Width="90" Padding="4,3" BorderBrush="#CBD5E1"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding RozE2Txt}" FontSize="13" FontWeight="Bold" Foreground="{Binding RozE2Color}" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <!-- H1 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="H1 Paleta" FontSize="12" FontWeight="SemiBold" Foreground="#F97316" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SysH1}" FontSize="16" FontWeight="Bold" Foreground="#334155" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBox   Grid.Row="2" Grid.Column="2" Text="{Binding PotwH1, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" Width="90" Padding="4,3" BorderBrush="#CBD5E1"/>
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding RozH1Txt}" FontSize="13" FontWeight="Bold" Foreground="{Binding RozH1Color}" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <!-- EURO -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="EURO Paleta" FontSize="12" FontWeight="SemiBold" Foreground="#10B981" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SysEURO}" FontSize="16" FontWeight="Bold" Foreground="#334155" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBox   Grid.Row="3" Grid.Column="2" Text="{Binding PotwEURO, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" Width="90" Padding="4,3" BorderBrush="#CBD5E1"/>
                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding RozEUROTxt}" FontSize="13" FontWeight="Bold" Foreground="{Binding RozEUROColor}" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <!-- PCV -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="PCV Plastik." FontSize="12" FontWeight="SemiBold" Foreground="#8B5CF6" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SysPCV}" FontSize="16" FontWeight="Bold" Foreground="#334155" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBox   Grid.Row="4" Grid.Column="2" Text="{Binding PotwPCV, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" Width="90" Padding="4,3" BorderBrush="#CBD5E1"/>
                    <TextBlock Grid.Row="4" Grid.Column="3" Text="{Binding RozPCVTxt}" FontSize="13" FontWeight="Bold" Foreground="{Binding RozPCVColor}" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <!-- DREW -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="DREW Drewn." FontSize="12" FontWeight="SemiBold" Foreground="#F59E0B" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SysDREW}" FontSize="16" FontWeight="Bold" Foreground="#334155" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBox   Grid.Row="5" Grid.Column="2" Text="{Binding PotwDREW, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" Width="90" Padding="4,3" BorderBrush="#CBD5E1"/>
                    <TextBlock Grid.Row="5" Grid.Column="3" Text="{Binding RozDREWTxt}" FontSize="13" FontWeight="Bold" Foreground="{Binding RozDREWColor}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Skan / załącznik -->
            <Border Background="White" CornerRadius="4" Padding="10" Margin="0,14,0,0"
                    BorderBrush="#CBD5E1" BorderThickness="1">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Wybierz plik..." Click="BtnWybierzSkan_Click"
                            Width="100" Height="28" FontSize="11" Margin="8,0,0,0" Cursor="Hand"/>
                    <TextBlock Text="Skan potwierdzenia:" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"
                               DockPanel.Dock="Left"/>
                    <TextBlock x:Name="txtSkan" Text="{Binding SkanNazwa}" FontSize="11"
                               Foreground="#334155" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>

            <!-- Uwagi -->
            <TextBox Text="{Binding Uwagi}" Margin="0,10,0,0" FontSize="11"
                     TextWrapping="Wrap" AcceptsReturn="True" Height="50"
                     VerticalContentAlignment="Top" Padding="8,6"
                     BorderBrush="#CBD5E1" Foreground="#475569">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Top">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="  Uwagi (opcjonalnie)" FontSize="11" Foreground="#94A3B8" Margin="6,6,0,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </StackPanel>
    </DockPanel>
</Window>
