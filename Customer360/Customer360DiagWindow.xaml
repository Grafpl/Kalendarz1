<Window x:Class="Kalendarz1.Customer360.Customer360DiagWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🐛 Customer 360 — Diagnostyka"
        Width="1000" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#0B1021"
        FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#111827" Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🐛 PEŁNA DIAGNOSTYKA CUSTOMER 360" Foreground="#F87171"
                           FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock x:Name="LblStan" Text="" Foreground="#9CA3AF" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Output -->
        <TextBox Grid.Row="1" x:Name="TxtOut"
                 Background="#0B1021" Foreground="#E5E7EB"
                 FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12"
                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 BorderThickness="0" Padding="14,10"
                 Text="Uruchamiam diagnostykę…"/>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="#111827" Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnRerun" Content="🔄 Uruchom ponownie" Click="BtnRerun_Click"
                        Padding="14,8" Margin="0,0,10,0" Cursor="Hand"
                        Background="#1F2937" Foreground="#E5E7EB" BorderThickness="0"/>
                <Button x:Name="BtnSave" Content="💾 Zapisz do pliku" Click="BtnSave_Click"
                        Padding="14,8" Margin="0,0,10,0" Cursor="Hand"
                        Background="#1F2937" Foreground="#E5E7EB" BorderThickness="0"/>
                <Button x:Name="BtnCopy" Content="📋 KOPIUJ DO SCHOWKA" Click="BtnCopy_Click"
                        Padding="18,8" Cursor="Hand" FontWeight="Bold"
                        Background="#2563EB" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
