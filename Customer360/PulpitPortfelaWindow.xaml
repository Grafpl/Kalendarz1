<Window x:Class="Kalendarz1.Customer360.PulpitPortfelaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 Pulpit Portfela Klientów"
        Width="1400" Height="900" WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="#F5F7FA" FontFamily="Segoe UI" FontSize="12" UseLayoutRounding="True"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="Border" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="14" ShadowDepth="2" Color="#0F172A" Opacity="0.08"/>
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            <Setter Property="MinHeight" Value="86"/>
        </Style>
        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>
        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="ColumnHeaderHeight" Value="36"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFBFC"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="📊 Pulpit Portfela Klientów" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock x:Name="LblStan" Text="" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Border Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="8,0" Margin="0,0,8,0" VerticalAlignment="Center" Height="38">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔎" FontSize="13" VerticalAlignment="Center" Margin="2,0,6,0"/>
                        <TextBox x:Name="TxtSzukaj" Width="200" BorderThickness="0" VerticalAlignment="Center"
                                 VerticalContentAlignment="Center" Background="Transparent" FontSize="12"
                                 TextChanged="TxtSzukaj_TextChanged" ToolTip="Filtruj po nazwie klienta lub handlowcu"/>
                    </StackPanel>
                </Border>
                <Button x:Name="BtnEksport" Content="📥 Eksport" Click="BtnEksport_Click" Padding="14,8" Margin="0,0,8,0" Cursor="Hand" Background="#F1F5F9" BorderThickness="0"/>
                <Button x:Name="BtnMapa" Content="🗺 Mapa klientów" Click="BtnMapa_Click" Padding="14,8" Margin="0,0,8,0" Cursor="Hand" Background="#EFF6FF" Foreground="#1E40AF" BorderThickness="0"/>
                <Button x:Name="BtnOdswiez" Content="🔄 Odśwież" Click="BtnOdswiez_Click" Padding="14,8" Cursor="Hand" Background="#F1F5F9" BorderThickness="0"/>
            </StackPanel>
        </Grid>

        <!-- KPI -->
        <UniformGrid Grid.Row="1" Columns="6" Rows="1" Margin="0,0,0,14">
            <Border Style="{StaticResource KpiCard}" Margin="0,0,6,0">
                <StackPanel><TextBlock Text="KLIENTÓW AKTYWNYCH" Style="{StaticResource KpiLabel}"/><TextBlock x:Name="KpiKlienci" Text="—" Style="{StaticResource KpiValue}"/></StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Margin="3,0">
                <StackPanel><TextBlock Text="OBRÓT PORTFELA 12M" Style="{StaticResource KpiLabel}"/><TextBlock x:Name="KpiObrot" Text="—" Style="{StaticResource KpiValue}" Foreground="#1E40AF"/></StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Margin="3,0">
                <StackPanel><TextBlock Text="PRZETERMINOWANE Σ" Style="{StaticResource KpiLabel}"/><TextBlock x:Name="KpiPrzeterm" Text="—" Style="{StaticResource KpiValue}" Foreground="#DC2626"/></StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Margin="3,0">
                <StackPanel><TextBlock Text="Z PRZETERMINOWANYMI" Style="{StaticResource KpiLabel}"/><TextBlock x:Name="KpiLiczbaPrzeterm" Text="—" Style="{StaticResource KpiValue}" Foreground="#DC2626"/></StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Margin="3,0">
                <StackPanel><TextBlock Text="PRZEKROCZONY LIMIT" Style="{StaticResource KpiLabel}"/><TextBlock x:Name="KpiLimit" Text="—" Style="{StaticResource KpiValue}" Foreground="#F59E0B"/></StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Margin="6,0,0,0">
                <StackPanel><TextBlock Text="CHURN — ZAGROŻENI" Style="{StaticResource KpiLabel}"/><TextBlock x:Name="KpiChurn" Text="—" Style="{StaticResource KpiValue}" Foreground="#F59E0B"/></StackPanel>
            </Border>
        </UniformGrid>

        <!-- Sekcje -->
        <TabControl x:Name="Tabs" Grid.Row="2" Background="Transparent" BorderThickness="0" SelectionChanged="Tabs_SelectionChanged">
            <TabItem Header="🚨 Alerty kredytowe">
                <DataGrid x:Name="GridAlerty" MouseDoubleClick="Grid_DoubleClick" LoadingRow="Grid_LoadingRow" Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Klient" Binding="{Binding Nazwa}" Width="*"/>
                        <DataGridTextColumn Header="Handlowiec" Binding="{Binding Handlowiec}" Width="130"/>
                        <DataGridTextColumn Header="Przeterminowane" Binding="{Binding Przeterminowane, StringFormat={}{0:N0} zł}" Width="140"/>
                        <DataGridTextColumn Header="Max dni" Binding="{Binding MaxDniOpoznienia}" Width="80"/>
                        <DataGridTextColumn Header="Do zapłaty" Binding="{Binding DoZaplaty, StringFormat={}{0:N0} zł}" Width="120"/>
                        <DataGridTextColumn Header="Limit" Binding="{Binding Limit, StringFormat={}{0:N0} zł}" Width="120"/>
                        <DataGridTextColumn Header="Wykorzystanie" Binding="{Binding WykorzystanieLimitProc, StringFormat={}{0:N0}%}" Width="110"/>
                        <DataGridTextColumn Header="Obrót 12M" Binding="{Binding Obrot12M, StringFormat={}{0:N0} zł}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="📉 Churn — zagrożeni">
                <DataGrid x:Name="GridChurn" MouseDoubleClick="Grid_DoubleClick" LoadingRow="Grid_LoadingRow" Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Klient" Binding="{Binding Nazwa}" Width="*"/>
                        <DataGridTextColumn Header="Handlowiec" Binding="{Binding Handlowiec}" Width="130"/>
                        <DataGridTextColumn Header="Dni od ost. faktury" Binding="{Binding DniOdOstatniej}" Width="150"/>
                        <DataGridTextColumn Header="Ostatnia faktura" Binding="{Binding OstatniaFaktura, StringFormat=dd.MM.yyyy}" Width="140"/>
                        <DataGridTextColumn Header="Obrót 12M" Binding="{Binding Obrot12M, StringFormat={}{0:N0} zł}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="🏆 Top klienci">
                <DataGrid x:Name="GridTop" MouseDoubleClick="Grid_DoubleClick" Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="40"/>
                        <DataGridTextColumn Header="Klient" Binding="{Binding Klient.Nazwa}" Width="*"/>
                        <DataGridTextColumn Header="Handlowiec" Binding="{Binding Klient.Handlowiec}" Width="130"/>
                        <DataGridTextColumn Header="Obrót 12M" Binding="{Binding Klient.Obrot12M, StringFormat={}{0:N0} zł}" Width="150"/>
                        <DataGridTextColumn Header="Udział %" Binding="{Binding UdzialProc, StringFormat={}{0:N1}%}" Width="100"/>
                        <DataGridTextColumn Header="Przeterminowane" Binding="{Binding Klient.Przeterminowane, StringFormat={}{0:N0} zł}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
