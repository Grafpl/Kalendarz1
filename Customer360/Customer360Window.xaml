<Window x:Class="Kalendarz1.Customer360.Customer360Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="👤 Karta Klienta 360°"
        Width="1400" Height="900"
        MinWidth="1200" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="12"
        UseLayoutRounding="True"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#1E40AF"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#1E3A8A"/>
        <SolidColorBrush x:Key="Border" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Success" Color="#16A34A"/>
        <SolidColorBrush x:Key="Warning" Color="#F59E0B"/>
        <SolidColorBrush x:Key="Danger" Color="#DC2626"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="14" ShadowDepth="2" Color="#0F172A" Opacity="0.08"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="MinHeight" Value="92"/>
        </Style>

        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>

        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="KpiSubvalue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP SELECTOR — wyszukiwarka klienta -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="👤 Karta Klienta 360°" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <Button Grid.Column="1" x:Name="BtnPickKlient" Click="BtnPickKlient_Click" Cursor="Hand" MinHeight="40" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" Foreground="#1E40AF">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14,8">
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="LblPickKlient" Text="Wybierz klienta..." FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Style="{StaticResource GhostButton}" Content="🔄 Odśwież" Click="BtnRefresh_Click" Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- HEADER klienta -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="20,16">
            <StackPanel x:Name="HeaderContent">
                <!-- Initial state: brak klienta -->
                <Grid x:Name="HeaderEmpty" Visibility="Visible">
                    <TextBlock Text="🔍 Wybierz klienta z wyszukiwarki powyżej, aby zobaczyć kartę 360°"
                               FontSize="14" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,40"/>
                </Grid>

                <!-- Loaded state -->
                <Grid x:Name="HeaderLoaded" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="LblNazwa" Text="—" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <Border x:Name="ChipKategoria" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="6" Padding="8,3" Margin="14,8,0,0" VerticalAlignment="Center" Visibility="Collapsed">
                                <TextBlock x:Name="LblKategoria" Text="A" FontSize="11" FontWeight="Bold" Foreground="#1E40AF"/>
                            </Border>
                            <Border x:Name="ChipChurn" CornerRadius="6" Padding="8,3" Margin="8,8,0,0" VerticalAlignment="Center" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="LblChurnIcon" Text="✅" FontSize="11" Margin="0,0,4,0"/>
                                    <TextBlock x:Name="LblChurnLevel" Text="OK" FontSize="11" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0">
                                <Run Text="🏢 NIP:" Foreground="#94A3B8" FontSize="11"/>
                                <Run x:Name="LblNip" Text="—" FontSize="11" FontWeight="SemiBold" Foreground="#475569"/>
                            </TextBlock>
                            <TextBlock Grid.Column="1" Margin="16,0,0,0">
                                <Run Text="📍" Foreground="#94A3B8" FontSize="11"/>
                                <Run x:Name="LblAdres" Text="—" FontSize="11" Foreground="#475569"/>
                            </TextBlock>
                            <TextBlock Grid.Column="2" Margin="16,0,0,0">
                                <Run Text="📞" Foreground="#94A3B8" FontSize="11"/>
                                <Run x:Name="LblTelefon" Text="—" FontSize="11" Foreground="#475569"/>
                            </TextBlock>
                            <TextBlock Grid.Column="3" Margin="16,0,0,0">
                                <Run Text="✉" Foreground="#94A3B8" FontSize="11"/>
                                <Run x:Name="LblEmail" Text="—" FontSize="11" Foreground="#475569"/>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="10" Padding="14,8" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Handlowiec" FontSize="10" Foreground="#1E40AF" FontWeight="SemiBold"/>
                            <TextBlock x:Name="LblHandlowiec" Text="—" FontSize="14" FontWeight="Bold" Foreground="#1E40AF"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- BODY: Tabs -->
        <TabControl Grid.Row="2" x:Name="MainTabs" Margin="0" Background="Transparent" BorderThickness="0">

            <!-- Tab 1: PRZEGLĄD (KPI + wykres) -->
            <TabItem Header="📊 Przegląd">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <StackPanel>
                        <!-- KPI Cards row 1: Obrót, Marża, Zamówienia, Średni odstęp -->
                        <UniformGrid Columns="4" Rows="1" Margin="0,0,0,12">
                            <Border Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="OBRÓT 12 MIES" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="KpiObrot" Text="—" Style="{StaticResource KpiValue}" Foreground="#1E40AF" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="KpiObrotYoY" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="MARŻA 12 MIES" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="KpiMarza" Text="—" Style="{StaticResource KpiValue}" Foreground="{StaticResource Success}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="KpiMarzaKg" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="ZAMÓWIENIA 12 MIES" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="KpiLiczbaZam" Text="—" Style="{StaticResource KpiValue}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="KpiSumaKg" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="OSTATNIE ZAMÓWIENIE" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="KpiOstatnie" Text="—" Style="{StaticResource KpiValue}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="KpiSredniOdstep" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- KPI Cards row 2: Limit, Do zapłaty, Przeterminowane, Reklamacje -->
                        <UniformGrid Columns="4" Rows="1" Margin="0,0,0,12">
                            <Border Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="LIMIT KREDYTOWY" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="KpiLimit" Text="—" Style="{StaticResource KpiValue}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="KpiLimitWyk" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="DO ZAPŁATY" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="KpiDoZap" Text="—" Style="{StaticResource KpiValue}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="KpiFaktur" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="PRZETERMINOWANE" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="KpiPrzeterm" Text="—" Style="{StaticResource KpiValue}" Foreground="{StaticResource Danger}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="KpiMaxDni" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="REKLAMACJE 12 MIES" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="KpiReklamacje" Text="—" Style="{StaticResource KpiValue}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="KpiReklamacjeProc" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Wykres miesięczny (placeholder dla bar chart) -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" MinHeight="280">
                            <StackPanel>
                                <TextBlock Text="📈 Obrót miesięczny — ostatnie 12 mies" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,12"/>
                                <Grid x:Name="ChartMonthly" Height="220"/>
                            </StackPanel>
                        </Border>

                        <!-- Top 5 towarów -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="🏆 Top 5 najczęściej kupowanych towarów" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                                <DataGrid x:Name="GridTopTowary" AutoGenerateColumns="False" IsReadOnly="True"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          GridLinesVisibility="Horizontal" RowHeight="56" ColumnHeaderHeight="32"
                                          BorderThickness="0" Background="Transparent">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="40"/>
                                        <DataGridTemplateColumn Header="Towar" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="56"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="48" Height="48" CornerRadius="6" ClipToBounds="True" Background="#F1F5F9" VerticalAlignment="Center" Margin="0,0,10,0">
                                                            <Grid>
                                                                <Image Source="{Binding Image}" Stretch="UniformToFill" Visibility="{Binding HasImageVisibility}"/>
                                                                <TextBlock Text="🍗" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding PlaceholderVisibility}"/>
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="{Binding Nazwa}" FontSize="12" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N0}" Width="100"/>
                                        <DataGridTextColumn Header="Wartość zł" Binding="{Binding Wartosc, StringFormat=N0}" Width="120"/>
                                        <DataGridTextColumn Header="Średnia cena" Binding="{Binding SredniaCena, StringFormat={}{0:N2} zł}" Width="110"/>
                                        <DataGridTextColumn Header="Liczba zam." Binding="{Binding LiczbaZamowien}" Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: ZAMÓWIENIA -->
            <TabItem Header="🛒 Zamówienia">
                <Border Padding="20,16">
                    <DataGrid x:Name="GridZamowienia" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal" Background="White"
                              RowHeight="34" ColumnHeaderHeight="36"
                              AlternatingRowBackground="#FAFBFC" BorderBrush="{StaticResource Border}" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Data zamówienia" Binding="{Binding DataZamowienia, StringFormat=dd.MM.yyyy}" Width="130"/>
                            <DataGridTextColumn Header="Data uboju" Binding="{Binding DataUboju, StringFormat=dd.MM.yyyy}" Width="110"/>
                            <DataGridTextColumn Header="Data wydania" Binding="{Binding DataWydania, StringFormat=dd.MM.yyyy}" Width="120"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                            <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N0}" Width="100"/>
                            <DataGridTextColumn Header="Pozycji" Binding="{Binding LiczbaPozycji}" Width="80"/>
                            <DataGridTextColumn Header="Wartość" Binding="{Binding Wartosc, StringFormat={}{0:N2} zł}" Width="130"/>
                            <DataGridTextColumn Header="Handlowiec" Binding="{Binding Handlowiec}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- Tab 3: FINANSE (faktury z HANDEL) -->
            <TabItem Header="💰 Faktury">
                <Border Padding="20,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                                CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
                            <TextBlock x:Name="FakturyDiag" Foreground="#1E40AF" FontSize="13"
                                       Text="Ładowanie faktur…"/>
                        </Border>
                    <DataGrid Grid.Row="1" x:Name="GridFakturyDetail" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal" Background="White"
                              RowHeight="34" ColumnHeaderHeight="36"
                              AlternatingRowBackground="#FAFBFC" BorderBrush="{StaticResource Border}" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Numer" Binding="{Binding NumerFaktury}" Width="160"/>
                            <DataGridTextColumn Header="Typ" Binding="{Binding TypDk}" Width="60"/>
                            <DataGridTextColumn Header="Wystawiona" Binding="{Binding DataWystawienia, StringFormat=dd.MM.yyyy}" Width="110"/>
                            <DataGridTextColumn Header="Termin" Binding="{Binding TerminPlatnosci, StringFormat=dd.MM.yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Poz." Binding="{Binding LiczbaPozycji}" Width="60"/>
                            <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N0}" Width="100"/>
                            <DataGridTextColumn Header="Netto" Binding="{Binding Netto, StringFormat={}{0:N2} zł}" Width="120"/>
                            <DataGridTextColumn Header="Brutto" Binding="{Binding Brutto, StringFormat={}{0:N2} zł}" Width="120"/>
                            <DataGridTextColumn Header="Zapłacone" Binding="{Binding Zaplacone, StringFormat={}{0:N2} zł}" Width="120"/>
                            <DataGridTextColumn Header="Saldo" Binding="{Binding Saldo, StringFormat={}{0:N2} zł}" Width="120"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Tab 4: WERYFIKACJA — zamówienia × faktury -->
            <TabItem Header="⚖ Weryfikacja">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <StackPanel>
                        <!-- Banner diagnostyczny gdy brak faktur -->
                        <Border x:Name="VerBannerDiag" Visibility="Collapsed" Background="#FEF3C7" BorderBrush="#FCD34D" BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock x:Name="VerDiagTitle" Text="⚠ Brak faktur w HANDEL" FontWeight="Bold" FontSize="13" Foreground="#92400E"/>
                                <TextBlock x:Name="VerDiagText" Text="" FontSize="11" Foreground="#92400E" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- KPI row 1: Sumy -->
                        <UniformGrid Columns="4" Rows="1" Margin="0,0,0,12">
                            <Border Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="ZAMÓWIONE KG" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="VerKpiZamKg" Text="—" Style="{StaticResource KpiValue}" Foreground="#1E40AF" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="VerKpiZamLZ" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="ZAFAKTUROWANE KG" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="VerKpiFakKg" Text="—" Style="{StaticResource KpiValue}" Foreground="#15803D" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="VerKpiFakLF" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="RÓŻNICA KG" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="VerKpiRoznicaKg" Text="—" Style="{StaticResource KpiValue}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="VerKpiZgodnoscProc" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="RÓŻNICA WARTOŚCI" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="VerKpiRoznicaWart" Text="—" Style="{StaticResource KpiValue}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="VerKpiSumaWart" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- KPI row 2: Liczniki problematycznych pozycji -->
                        <UniformGrid Columns="4" Rows="1" Margin="0,0,0,12">
                            <Border Style="{StaticResource KpiCard}" Background="#F0FDF4" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="✅ ZGODNE" Style="{StaticResource KpiLabel}" Foreground="#15803D"/>
                                    <TextBlock x:Name="VerKpiZgodne" Text="0" Style="{StaticResource KpiValue}" Foreground="#15803D" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" Background="#FEF3C7" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="✂ UCIĘTE" Style="{StaticResource KpiLabel}" Foreground="#92400E"/>
                                    <TextBlock x:Name="VerKpiUciete" Text="0" Style="{StaticResource KpiValue}" Foreground="#92400E" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" Background="#DBEAFE" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="➕ DODANE" Style="{StaticResource KpiLabel}" Foreground="#1E40AF"/>
                                    <TextBlock x:Name="VerKpiDodane" Text="0" Style="{StaticResource KpiValue}" Foreground="#1E40AF" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource KpiCard}" Background="#FEE2E2" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="⚠ BRAK FAKTURY" Style="{StaticResource KpiLabel}" Foreground="#991B1B"/>
                                    <TextBlock x:Name="VerKpiBrakFak" Text="0" Style="{StaticResource KpiValue}" Foreground="#991B1B" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Tabela porównawcza per towar -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="📋 Porównanie per towar (zamówienia LibraNet × faktury HANDEL)" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                                <DataGrid x:Name="GridWeryfikacja" AutoGenerateColumns="False" IsReadOnly="True"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          GridLinesVisibility="Horizontal" Background="White"
                                          RowHeight="32" ColumnHeaderHeight="34"
                                          AlternatingRowBackground="#FAFBFC" BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130"/>
                                        <DataGridTextColumn Header="Towar" Binding="{Binding Nazwa}" Width="*"/>
                                        <DataGridTextColumn Header="Zamówione kg" Binding="{Binding ZamowioneKg, StringFormat=N0}" Width="120"/>
                                        <DataGridTextColumn Header="Zafakturowane kg" Binding="{Binding ZafakturowaneKg, StringFormat=N0}" Width="140"/>
                                        <DataGridTextColumn Header="Różnica kg" Binding="{Binding RoznicaKg, StringFormat={}{0:+#,##0;-#,##0;0}}" Width="100"/>
                                        <DataGridTextColumn Header="Zgodność" Binding="{Binding ZgodnoscProc, StringFormat={}{0:N1}%}" Width="90"/>
                                        <DataGridTextColumn Header="Zamówiona wartość" Binding="{Binding ZamowionaWartosc, StringFormat={}{0:N0} zł}" Width="140"/>
                                        <DataGridTextColumn Header="Zafakturowana wartość" Binding="{Binding ZafakturowanaWartosc, StringFormat={}{0:N0} zł}" Width="160"/>
                                        <DataGridTextColumn Header="Różnica zł" Binding="{Binding RoznicaWartosci, StringFormat={}{0:+#,##0;-#,##0;0} zł}" Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 5: ANULOWANE -->
            <TabItem Header="❌ Anulowane">
                <Border Padding="20,16">
                    <StackPanel>
                        <Border Style="{StaticResource CardStyle}" Background="#FEF3C7" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock x:Name="AnulHeader" Text="Anulowane zamówienia w ostatnich 12 mies" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock x:Name="AnulSummary" Text="—" FontSize="11" Foreground="#92400E" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <DataGrid x:Name="GridAnulowane" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  GridLinesVisibility="Horizontal" Background="White"
                                  RowHeight="34" ColumnHeaderHeight="36"
                                  AlternatingRowBackground="#FAFBFC" BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="Data zamówienia" Binding="{Binding DataZamowienia, StringFormat=dd.MM.yyyy}" Width="140"/>
                                <DataGridTextColumn Header="Data przyjazdu" Binding="{Binding DataPrzyjazdu, StringFormat=dd.MM.yyyy}" Width="130"/>
                                <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="Wartość" Binding="{Binding Wartosc, StringFormat={}{0:N2} zł}" Width="130"/>
                                <DataGridTextColumn Header="Handlowiec" Binding="{Binding Handlowiec}" Width="120"/>
                                <DataGridTextColumn Header="Anulował" Binding="{Binding AnulowanePrzez}" Width="120"/>
                                <DataGridTextColumn Header="Data anulowania" Binding="{Binding DataAnulowania, StringFormat=dd.MM.yyyy HH:mm}" Width="160"/>
                                <DataGridTextColumn Header="Powód / Uwagi" Binding="{Binding Powod}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
