<Window x:Class="Kalendarz1.Customer360.Customer360Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="👤 Karta Klienta 360°"
        Width="1400" Height="900"
        MinWidth="1200" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="12"
        UseLayoutRounding="True"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#1E40AF"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#1E3A8A"/>
        <SolidColorBrush x:Key="Border" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Success" Color="#16A34A"/>
        <SolidColorBrush x:Key="Warning" Color="#F59E0B"/>
        <SolidColorBrush x:Key="Danger" Color="#DC2626"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="14" ShadowDepth="2" Color="#0F172A" Opacity="0.08"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="MinHeight" Value="92"/>
        </Style>

        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>

        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="KpiSubvalue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP SELECTOR — wyszukiwarka klienta -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="👤 Karta Klienta 360°" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnPickKlient" Click="BtnPickKlient_Click" Cursor="Hand" MinHeight="40" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" Foreground="#1E40AF">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14,8">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="LblPickKlient" Text="Wybierz klienta..." FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- Filtr aktywnej tabeli -->
                    <Border Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="8,0" Margin="12,0,0,0" VerticalAlignment="Center" Height="40">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🔎" FontSize="13" VerticalAlignment="Center" Margin="2,0,6,0"/>
                            <TextBox x:Name="TxtSzukajGrid" Width="200" BorderThickness="0" VerticalAlignment="Center"
                                     VerticalContentAlignment="Center" Background="Transparent" FontSize="12"
                                     TextChanged="TxtSzukajGrid_TextChanged"
                                     ToolTip="Filtruj wiersze aktywnej zakładki (faktury, asortyment, zamówienia…)"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Nawigacja między klientami -->
                    <Button x:Name="BtnPrev" Style="{StaticResource GhostButton}" Content="◀" Click="BtnPrev_Click"
                            ToolTip="Poprzedni klient (Ctrl+←)" Margin="0,0,2,0" IsEnabled="False"/>
                    <TextBlock x:Name="LblNawPozycja" Text="" FontSize="11" Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" MinWidth="46" TextAlignment="Center"/>
                    <Button x:Name="BtnNext" Style="{StaticResource GhostButton}" Content="▶" Click="BtnNext_Click"
                            ToolTip="Następny klient (Ctrl+→)" Margin="2,0,0,0" IsEnabled="False"/>
                    <ComboBox x:Name="CmbOkres" Width="120" Height="34" Margin="12,0,0,0" VerticalContentAlignment="Center"
                              SelectionChanged="CmbOkres_SelectionChanged" ToolTip="Okres analizy dla list i wykresów">
                        <ComboBoxItem Content="Cała historia" IsSelected="True"/>
                        <ComboBoxItem Content="Ostatnie 12M"/>
                        <ComboBoxItem Content="Ostatnie 6M"/>
                        <ComboBoxItem Content="Ostatnie 3M"/>
                    </ComboBox>
                    <Button x:Name="BtnPorownaj" Style="{StaticResource GhostButton}" Content="⚖ Porównaj" Click="BtnPorownaj_Click" Margin="8,0,0,0"
                            ToolTip="Porównaj tego klienta z innym (KPI obok siebie)"/>
                    <Button x:Name="BtnOstatni" Style="{StaticResource GhostButton}" Content="🕘 Ostatni" Click="BtnOstatni_Click" Margin="8,0,0,0"
                            ToolTip="Ostatnio otwierani klienci"/>
                    <Button x:Name="BtnEksport" Style="{StaticResource GhostButton}" Content="📥 CSV" Click="BtnEksport_Click" Margin="8,0,0,0"
                            ToolTip="Eksportuj dane aktywnej zakładki do CSV/Excel"/>
                    <Button x:Name="BtnEksportPdf" Style="{StaticResource GhostButton}" Content="📄 PDF" Click="BtnEksportPdf_Click" Margin="8,0,0,0"
                            ToolTip="Eksportuj całą kartę klienta do PDF (Ctrl+E)"/>
                    <Button Style="{StaticResource GhostButton}" Content="🐛 Debug" Click="BtnDebug_Click" Margin="8,0,0,0"
                            Background="#FEF2F2" Foreground="#B91C1C"/>
                    <Button Style="{StaticResource GhostButton}" Content="🔄 Odśwież" Click="BtnRefresh_Click" Margin="8,0,0,0"
                            ToolTip="Odśwież dane / przelicz scoring (F5 lub Ctrl+R)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- HEADER klienta -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="20,16">
            <StackPanel x:Name="HeaderContent">
                <!-- Initial state: brak klienta -->
                <Grid x:Name="HeaderEmpty" Visibility="Visible">
                    <TextBlock Text="🔍 Wybierz klienta z wyszukiwarki powyżej, aby zobaczyć kartę 360°"
                               FontSize="14" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,40"/>
                </Grid>

                <!-- Loaded state -->
                <Grid x:Name="HeaderLoaded" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="LblNazwa" Text="—" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <Border x:Name="ChipKategoria" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="6" Padding="8,3" Margin="14,8,0,0" VerticalAlignment="Center" Visibility="Collapsed">
                                <TextBlock x:Name="LblKategoria" Text="A" FontSize="11" FontWeight="Bold" Foreground="#1E40AF"/>
                            </Border>
                            <Border x:Name="ChipChurn" CornerRadius="6" Padding="8,3" Margin="8,8,0,0" VerticalAlignment="Center" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="LblChurnIcon" Text="✅" FontSize="11" Margin="0,0,4,0"/>
                                    <TextBlock x:Name="LblChurnLevel" Text="OK" FontSize="11" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="ChipScoring" CornerRadius="6" Padding="8,3" Margin="8,8,0,0" VerticalAlignment="Center" Background="#6B7280" Visibility="Collapsed">
                                <TextBlock x:Name="LblScoringChip" Text="⭐ —" FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <!-- Sparkline 6 ostatnich miesiecy obrotu (z faktur) — szybki sygnal trendu w toolbarze -->
                            <Border x:Name="ChipSparkline" CornerRadius="4" Padding="6,4" Margin="8,8,0,0"
                                    VerticalAlignment="Center" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                    Visibility="Collapsed">
                                <Canvas Width="90" Height="22" ClipToBounds="True">
                                    <Polyline x:Name="SparklineLine" Stroke="#2563EB" StrokeThickness="1.5"/>
                                </Canvas>
                            </Border>
                        </StackPanel>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0">
                                <Run Text="🏢 NIP:" Foreground="#94A3B8" FontSize="11"/>
                                <Run x:Name="LblNip" Text="—" FontSize="11" FontWeight="SemiBold" Foreground="#475569"/>
                            </TextBlock>
                            <TextBlock Grid.Column="1" Margin="16,0,0,0">
                                <Run Text="📍" Foreground="#94A3B8" FontSize="11"/>
                                <Run x:Name="LblAdres" Text="—" FontSize="11" Foreground="#475569"/>
                            </TextBlock>
                            <TextBlock Grid.Column="2" Margin="16,0,0,0">
                                <Run Text="📞" Foreground="#94A3B8" FontSize="11"/>
                                <Run x:Name="LblTelefon" Text="—" FontSize="11" Foreground="#475569"/>
                            </TextBlock>
                            <TextBlock Grid.Column="3" Margin="16,0,0,0">
                                <Run Text="✉" Foreground="#94A3B8" FontSize="11"/>
                                <Run x:Name="LblEmail" Text="—" FontSize="11" Foreground="#475569"/>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Szybkie akcje -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Button x:Name="BtnKopiujNip" Click="BtnKopiujNip_Click" ToolTip="Kopiuj NIP do schowka"
                                    Content="📋 NIP" Padding="9,6" Margin="0,0,6,0" Cursor="Hand"
                                    Background="#F1F5F9" Foreground="#475569" BorderThickness="0" FontSize="11"/>
                            <Button x:Name="BtnZadzwon" Click="BtnZadzwon_Click" ToolTip="Zadzwoń"
                                    Content="📞" Padding="9,6" Margin="0,0,6,0" Cursor="Hand"
                                    Background="#F1F5F9" Foreground="#475569" BorderThickness="0" FontSize="11"/>
                            <Button x:Name="BtnEmail" Click="BtnEmail_Click" ToolTip="Wyślij email"
                                    Content="✉" Padding="9,6" Cursor="Hand"
                                    Background="#F1F5F9" Foreground="#475569" BorderThickness="0" FontSize="11"/>
                        </StackPanel>
                        <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="10" Padding="14,8" VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Handlowiec" FontSize="10" Foreground="#1E40AF" FontWeight="SemiBold"/>
                                <TextBlock x:Name="LblHandlowiec" Text="—" FontSize="14" FontWeight="Bold" Foreground="#1E40AF"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- BODY: Tabs -->
        <TabControl Grid.Row="2" x:Name="MainTabs" Margin="0" Background="Transparent" BorderThickness="0" SelectionChanged="MainTabs_SelectionChanged">

            <!-- Tab 1: PRZEGLĄD (dashboard) -->
            <TabItem Header="📊 Przegląd">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <StackPanel>
                        <!-- Banner bledow ladowania — widoczny gdy rendery rzucily wyjatki -->
                        <Border x:Name="ErrorBanner" Visibility="Collapsed"
                                Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1"
                                CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
                            <DockPanel>
                                <Button x:Name="BtnRetry" Content="🔄 Spróbuj ponownie" DockPanel.Dock="Right"
                                        Click="BtnRetry_Click" Padding="10,4" Margin="10,0,0,0"
                                        Cursor="Hand" Background="#FBBF24" Foreground="#78350F" BorderThickness="0"
                                        FontWeight="SemiBold"/>
                                <TextBlock x:Name="ErrorBannerText" Foreground="#92400E" FontSize="12" TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <!-- ════ HERO: Scoring + składniki + churn + rekomendacja ════ -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Kółko scoringu -->
                                <Border Grid.Column="0" x:Name="ScoringBadge" Width="116" Height="116" CornerRadius="58"
                                        Background="#6B7280" VerticalAlignment="Center">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock x:Name="ScoringLitera" Text="?" FontSize="42" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,-4"/>
                                        <TextBlock x:Name="ScoringPunkty" Text="—/100" FontSize="13" Foreground="White" Opacity="0.92" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Składniki scoringu (5 pasków) -->
                                <StackPanel Grid.Column="1" Margin="24,0,24,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="ScoringKategoria" Text="Ocena klienta" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                                    <StackPanel x:Name="ScoringBary"/>
                                </StackPanel>

                                <!-- Churn + rekomendacja -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" MinWidth="240" MaxWidth="280">
                                    <TextBlock Text="RYZYKO ODEJŚCIA (CHURN)" Style="{StaticResource KpiLabel}"/>
                                    <Border x:Name="ChurnBadge" CornerRadius="6" Padding="10,5" Margin="0,5,0,8" HorizontalAlignment="Left" Background="#6B7280">
                                        <TextBlock x:Name="ChurnText" Text="—" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                    </Border>
                                    <TextBlock x:Name="ChurnReason" Text="" FontSize="11" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                    <Border Background="#EFF6FF" CornerRadius="6" Padding="10,7" Margin="0,8,0,0">
                                        <StackPanel>
                                            <TextBlock Text="💡 REKOMENDOWANY LIMIT" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource Primary}"/>
                                            <TextBlock x:Name="ScoringRekomendacja" Text="—" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Primary}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ════ CHIPY RYZYKA ════ -->
                        <UniformGrid Columns="4" Rows="1" Margin="0,0,0,12">
                            <Border x:Name="ChipLimit" Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="WYKORZYSTANIE LIMITU" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="ChipLimitVal" Text="—" Style="{StaticResource KpiValue}" Margin="0,4,0,0"/>
                                    <ProgressBar x:Name="ChipLimitBar" Height="6" Minimum="0" Maximum="100" Value="0" Margin="0,6,0,0" Foreground="{StaticResource Success}" Background="#E2E8F0" BorderThickness="0"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="ChipPrzeterm" Style="{StaticResource KpiCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="PRZETERMINOWANE" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="ChipPrzetermVal" Text="—" Style="{StaticResource KpiValue}" Foreground="{StaticResource Danger}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="ChipPrzetermSub" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="ChipOstatnie" Style="{StaticResource KpiCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="OD OSTATNIEGO ZAMÓWIENIA" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="ChipOstatnieVal" Text="—" Style="{StaticResource KpiValue}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="ChipOstatnieSub" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="ChipReklamacje" Style="{StaticResource KpiCard}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="KpiReklamacjeLabel" Text="REKLAMACJE 12 MIES" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="KpiReklamacje" Text="—" Style="{StaticResource KpiValue}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="KpiReklamacjeProc" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- ════ KPI FINANSOWE ════ -->
                        <UniformGrid Columns="4" Rows="1" Margin="0,0,0,12">
                            <Border x:Name="TileObrot" Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock x:Name="KpiObrotLabel" Text="OBRÓT 12 MIES" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="KpiObrot" Text="—" Style="{StaticResource KpiValue}" Foreground="#1E40AF" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="KpiObrotYoY" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="TileSrFaktura" Style="{StaticResource KpiCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="ŚR. WARTOŚĆ FAKTURY" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="KpiSrFaktura" Text="—" Style="{StaticResource KpiValue}" Foreground="{StaticResource Success}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="KpiSrFakturaSub" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="TileLiczbaZam" Style="{StaticResource KpiCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock x:Name="KpiLiczbaZamLabel" Text="ZAMÓWIENIA 12 MIES" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="KpiLiczbaZam" Text="—" Style="{StaticResource KpiValue}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="KpiSumaKg" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="TileLimit" Style="{StaticResource KpiCard}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="LIMIT / DO ZAPŁATY" Style="{StaticResource KpiLabel}"/>
                                    <TextBlock x:Name="KpiLimit" Text="—" Style="{StaticResource KpiValue}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="KpiDoZap" Text="—" Style="{StaticResource KpiSubvalue}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- ════ WYKRES TRENDU ════ -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" MinHeight="300">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="📈 Obrót miesięczny (faktury, brutto)" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TrendKierunek" Text="" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <lvc:CartesianChart x:Name="ChartMonthly" Height="240"
                                                    TooltipPosition="Top" ZoomMode="None"/>
                            </StackPanel>
                        </Border>

                        <!-- ════ DWIE KOLUMNY: Top towary | Alerty ════ -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Top towary -->
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="🏆 Top 5 kupowanych towarów" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                                    <DataGrid x:Name="GridTopTowary" AutoGenerateColumns="False" IsReadOnly="True"
                                              CanUserAddRows="False" CanUserDeleteRows="False"
                                              GridLinesVisibility="Horizontal" RowHeight="56" ColumnHeaderHeight="32"
                                              BorderThickness="0" Background="Transparent">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="32"/>
                                            <DataGridTemplateColumn Header="Towar" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="56"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="48" Height="48" CornerRadius="6" ClipToBounds="True" Background="#F1F5F9" VerticalAlignment="Center" Margin="0,0,10,0">
                                                                <Grid>
                                                                    <Image Source="{Binding Image}" Stretch="UniformToFill" Visibility="{Binding HasImageVisibility}"/>
                                                                    <TextBlock Text="🍗" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding PlaceholderVisibility}"/>
                                                                </Grid>
                                                            </Border>
                                                            <TextBlock Grid.Column="1" Text="{Binding Nazwa}" FontSize="12" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N0}" Width="90"/>
                                            <DataGridTextColumn Header="Wartość" Binding="{Binding Wartosc, StringFormat=N0}" Width="100"/>
                                            <DataGridTextColumn Header="Śr. cena" Binding="{Binding SredniaCena, StringFormat={}{0:N2}}" Width="80"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- Alerty operacyjne -->
                            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="🔔 Alerty i sygnały" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                                    <StackPanel x:Name="AlertyPanel"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ GRUPA: SPRZEDAŻ ═══ -->
            <TabItem Header="💰 Sprzedaż">
              <TabControl Background="Transparent" BorderThickness="0" Padding="0">

            <!-- Tab 2: ZAMÓWIENIA -->
            <TabItem Header="🛒 Zamówienia">
                <Border Padding="20,16">
                    <DataGrid x:Name="GridZamowienia" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal" Background="White"
                              RowHeight="34" ColumnHeaderHeight="36"
                              AlternatingRowBackground="#FAFBFC" BorderBrush="{StaticResource Border}" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Data zamówienia" Binding="{Binding DataZamowienia, StringFormat=dd.MM.yyyy}" Width="130"/>
                            <DataGridTextColumn Header="Data uboju" Binding="{Binding DataUboju, StringFormat=dd.MM.yyyy}" Width="110"/>
                            <DataGridTextColumn Header="Data wydania" Binding="{Binding DataWydania, StringFormat=dd.MM.yyyy}" Width="120"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                            <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N0}" Width="100"/>
                            <DataGridTextColumn Header="Pozycji" Binding="{Binding LiczbaPozycji}" Width="80"/>
                            <DataGridTextColumn Header="Wartość" Binding="{Binding Wartosc, StringFormat={}{0:N2} zł}" Width="130"/>
                            <DataGridTextColumn Header="Handlowiec" Binding="{Binding Handlowiec}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- Tab 3: FINANSE (faktury z HANDEL) -->
            <TabItem Header="💰 Faktury">
                <Border Padding="20,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                                CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
                            <TextBlock x:Name="FakturyDiag" Foreground="#1E40AF" FontSize="13"
                                       Text="Ładowanie faktur…"/>
                        </Border>
                    <DataGrid Grid.Row="1" x:Name="GridFakturyDetail" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal" Background="White"
                              RowHeight="34" ColumnHeaderHeight="36"
                              AlternatingRowBackground="#FAFBFC" BorderBrush="{StaticResource Border}" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Numer" Binding="{Binding NumerFaktury}" Width="160"/>
                            <DataGridTextColumn Header="Typ" Binding="{Binding TypDk}" Width="60"/>
                            <DataGridTextColumn Header="Wystawiona" Binding="{Binding DataWystawienia, StringFormat=dd.MM.yyyy}" Width="110"/>
                            <DataGridTextColumn Header="Termin" Binding="{Binding TerminPlatnosci, StringFormat=dd.MM.yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Poz." Binding="{Binding LiczbaPozycji}" Width="60"/>
                            <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N0}" Width="100"/>
                            <DataGridTextColumn Header="Netto" Binding="{Binding Netto, StringFormat={}{0:N2} zł}" Width="120"/>
                            <DataGridTextColumn Header="Brutto" Binding="{Binding Brutto, StringFormat={}{0:N2} zł}" Width="120"/>
                            <DataGridTextColumn Header="Zapłacone" Binding="{Binding Zaplacone, StringFormat={}{0:N2} zł}" Width="120"/>
                            <DataGridTextColumn Header="Saldo" Binding="{Binding Saldo, StringFormat={}{0:N2} zł}" Width="120"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Tab 4: WERYFIKACJA — zamówienia × faktury -->
            <TabItem Header="⚖ Weryfikacja">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <StackPanel>
                        <!-- Banner diagnostyczny gdy brak faktur -->
                        <Border x:Name="VerBannerDiag" Visibility="Collapsed" Background="#FEF3C7" BorderBrush="#FCD34D" BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock x:Name="VerDiagTitle" Text="⚠ Brak faktur w HANDEL" FontWeight="Bold" FontSize="13" Foreground="#92400E"/>
                                <TextBlock x:Name="VerDiagText" Text="" FontSize="11" Foreground="#92400E" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- ═══ WERDYKT: realizacja zamówień fakturami ═══ -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Kółko realizacji % -->
                                <Border Grid.Column="0" x:Name="VerKolo" Width="116" Height="116" CornerRadius="58" Background="#6B7280" VerticalAlignment="Center" Margin="0,0,20,0">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock x:Name="VerProc" Text="—" FontSize="30" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="realizacji" FontSize="11" Foreground="White" Opacity="0.9" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <!-- Werdykt + pasek zam→fak -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="VerVerdict" Text="—" FontSize="17" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="VerVerdictSub" Text="" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,10" TextWrapping="Wrap"/>
                                    <!-- Pasek: zamówione (tło) z wypełnieniem zafakturowane -->
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Zamówione" FontSize="11" Foreground="#1E40AF" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Height="22" CornerRadius="5" Background="#DBEAFE">
                                            <TextBlock x:Name="VerZamLbl" Text="" FontSize="11" FontWeight="SemiBold" Foreground="#1E40AF" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Border>
                                    </Grid>
                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Zafakturowane" FontSize="11" Foreground="#15803D" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Height="22" CornerRadius="5" Background="#EEF2F7">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition x:Name="VerFakFill" Width="*"/>
                                                    <ColumnDefinition x:Name="VerFakRest" Width="0*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" x:Name="VerFakBar" CornerRadius="5" Background="#16A34A">
                                                    <TextBlock x:Name="VerFakLbl" Text="" FontSize="11" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Filtr-chipy (klik = filtruj listę) -->
                        <StackPanel x:Name="VerChips" Orientation="Horizontal" Margin="0,0,0,12"/>

                        <!-- Wykres niedotrzymania: zamówione vs zafakturowane kg miesięcznie -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" MinHeight="300">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="📊 Niedotrzymanie: zamówione vs zafakturowane kg / miesiąc" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Border Width="11" Height="11" CornerRadius="2" Background="#3B82F6" VerticalAlignment="Center"/>
                                        <TextBlock Text="zamówione" FontSize="10" Foreground="#64748B" Margin="4,0,12,0" VerticalAlignment="Center"/>
                                        <Border Width="11" Height="11" CornerRadius="2" Background="#16A34A" VerticalAlignment="Center"/>
                                        <TextBlock Text="zafakturowane" FontSize="10" Foreground="#64748B" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock x:Name="PorownanieInfo" Text="" FontSize="11" Foreground="#64748B" Margin="0,0,0,8"/>
                                <Grid x:Name="ChartPorownanie" Height="240"/>
                            </StackPanel>
                        </Border>

                        <!-- Lista pozycji — wizualne porównanie zam vs fak per towar -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock x:Name="VerListaTytul" Text="📋 Pozycje — kliknij chip aby filtrować (BEZ korekt)" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                                <StackPanel x:Name="WeryfikacjaLista"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 5: ANULOWANE -->
            <TabItem Header="❌ Anulowane">
                <Border Padding="20,16">
                    <StackPanel>
                        <Border Style="{StaticResource CardStyle}" Background="#FEF3C7" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock x:Name="AnulHeader" Text="Anulowane zamówienia w ostatnich 12 mies" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock x:Name="AnulSummary" Text="—" FontSize="11" Foreground="#92400E" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <DataGrid x:Name="GridAnulowane" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  GridLinesVisibility="Horizontal" Background="White"
                                  RowHeight="34" ColumnHeaderHeight="36"
                                  AlternatingRowBackground="#FAFBFC" BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="Data zamówienia" Binding="{Binding DataZamowienia, StringFormat=dd.MM.yyyy}" Width="140"/>
                                <DataGridTextColumn Header="Data przyjazdu" Binding="{Binding DataPrzyjazdu, StringFormat=dd.MM.yyyy}" Width="130"/>
                                <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="Wartość" Binding="{Binding Wartosc, StringFormat={}{0:N2} zł}" Width="130"/>
                                <DataGridTextColumn Header="Handlowiec" Binding="{Binding Handlowiec}" Width="120"/>
                                <DataGridTextColumn Header="Anulował" Binding="{Binding AnulowanePrzez}" Width="120"/>
                                <DataGridTextColumn Header="Data anulowania" Binding="{Binding DataAnulowania, StringFormat=dd.MM.yyyy HH:mm}" Width="160"/>
                                <DataGridTextColumn Header="Powód / Uwagi" Binding="{Binding Powod}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </TabItem>

              </TabControl>
            </TabItem>
            <!-- ═══ GRUPA: KLIENT ═══ -->
            <TabItem Header="👤 Klient">
              <TabControl Background="Transparent" BorderThickness="0" Padding="0">

            <!-- Tab 6: DANE / EDYCJA -->
            <TabItem Header="✏️ Dane">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <StackPanel MaxWidth="900" HorizontalAlignment="Left">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="📇 Dane podstawowe (z HANDEL — tylko podgląd)" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nazwa:" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="EdNazwa" Text="—" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="NIP:" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="EdNip" Text="—" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Adres:" Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="EdAdres" Text="—"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="✏️ Dane handlowca (edytowalne — zapis do LibraNet)" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="EdStatus" Text="" FontSize="11" Foreground="{StaticResource Success}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Osoba kontaktowa" Style="{StaticResource KpiLabel}" Margin="0,0,0,3"/>
                                        <TextBox x:Name="EdOsoba" Padding="6,5" Margin="0,0,0,10"/>
                                        <TextBlock Text="Telefon" Style="{StaticResource KpiLabel}" Margin="0,0,0,3"/>
                                        <TextBox x:Name="EdTelefon" Padding="6,5" Margin="0,0,0,10"/>
                                        <TextBlock Text="Email" Style="{StaticResource KpiLabel}" Margin="0,0,0,3"/>
                                        <TextBox x:Name="EdEmail" Padding="6,5" Margin="0,0,0,10"/>
                                        <TextBlock Text="Kategoria handlowa" Style="{StaticResource KpiLabel}" Margin="0,0,0,3"/>
                                        <ComboBox x:Name="EdKategoria" Padding="6,5" Margin="0,0,0,10">
                                            <ComboBoxItem Content="A — kluczowy"/>
                                            <ComboBoxItem Content="B — ważny"/>
                                            <ComboBoxItem Content="C — standard"/>
                                            <ComboBoxItem Content="D — okazjonalny"/>
                                        </ComboBox>
                                        <TextBlock Text="Trasa logistyczna" Style="{StaticResource KpiLabel}" Margin="0,0,0,3"/>
                                        <TextBox x:Name="EdTrasa" Padding="6,5" Margin="0,0,0,10"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Preferowany dzień dostawy" Style="{StaticResource KpiLabel}" Margin="0,0,0,3"/>
                                        <TextBox x:Name="EdDzien" Padding="6,5" Margin="0,0,0,10"/>
                                        <TextBlock Text="Preferowana godzina dostawy" Style="{StaticResource KpiLabel}" Margin="0,0,0,3"/>
                                        <TextBox x:Name="EdGodzina" Padding="6,5" Margin="0,0,0,10"/>
                                        <TextBlock Text="Adres dostawy (inny niż domyślny)" Style="{StaticResource KpiLabel}" Margin="0,0,0,3"/>
                                        <TextBox x:Name="EdAdresDostawy" Padding="6,5" Margin="0,0,0,10"/>
                                        <TextBlock Text="Preferencje pakowania" Style="{StaticResource KpiLabel}" Margin="0,0,0,3"/>
                                        <TextBox x:Name="EdPrefPakowanie" Padding="6,5" Margin="0,0,0,10"/>
                                        <TextBlock Text="Preferencje jakości" Style="{StaticResource KpiLabel}" Margin="0,0,0,3"/>
                                        <TextBox x:Name="EdPrefJakosc" Padding="6,5" Margin="0,0,0,10"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Notatki" Style="{StaticResource KpiLabel}" Margin="0,4,0,3"/>
                                <TextBox x:Name="EdNotatki" Padding="6,5" Height="70" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                                <Button x:Name="BtnZapiszDane" Content="💾 Zapisz dane" Click="BtnZapiszDane_Click"
                                        Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,12,0,0" Padding="20,8"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 7: KONTAKTY -->
            <TabItem Header="👥 Kontakty">
                <Border Padding="20,16">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <Button x:Name="BtnDodajKontakt" Content="➕ Dodaj kontakt" Click="BtnDodajKontakt_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                            <Button x:Name="BtnEdytujKontakt" Content="✏️ Edytuj" Click="BtnEdytujKontakt_Click" Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                            <Button x:Name="BtnUsunKontakt" Content="🗑 Usuń" Click="BtnUsunKontakt_Click" Style="{StaticResource GhostButton}"/>
                        </StackPanel>
                        <DataGrid Grid.Row="1" x:Name="GridKontakty" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single"
                                  GridLinesVisibility="Horizontal" Background="White" RowHeight="34" ColumnHeaderHeight="36"
                                  AlternatingRowBackground="#FAFBFC" BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Typ" Binding="{Binding TypKontaktu}" Width="130"/>
                                <DataGridTextColumn Header="Imię" Binding="{Binding Imie}" Width="120"/>
                                <DataGridTextColumn Header="Nazwisko" Binding="{Binding Nazwisko}" Width="140"/>
                                <DataGridTextColumn Header="Stanowisko" Binding="{Binding Stanowisko}" Width="150"/>
                                <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" Width="120"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                                <DataGridTextColumn Header="Notatka" Binding="{Binding Notatka}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Grid.Row="1" x:Name="EmptyKontakty" Visibility="Collapsed"
                                   Text="👥 Brak zapisanych kontaktów. Kliknij ➕ Dodaj kontakt, aby dodać osoby (księgowość, magazyn, właściciel…)."
                                   Foreground="#94A3B8" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center"/>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Tab: NOTATKI handlowca — dziennik klienta -->
            <TabItem Header="📝 Notatki">
                <Grid Margin="20,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Pasek dodawania -->
                    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                        <DockPanel>
                            <Button x:Name="BtnDodajNotatke" Content="➕ Dodaj"
                                    DockPanel.Dock="Right" Click="BtnDodajNotatke_Click"
                                    Padding="14,7" Margin="10,0,0,0" Cursor="Hand"
                                    Background="#2563EB" Foreground="White" BorderThickness="0"
                                    FontWeight="SemiBold"/>
                            <TextBox x:Name="TxtNowaNotatka"
                                     MinHeight="64" MaxHeight="120" AcceptsReturn="True"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     FontSize="13" Padding="10,8"
                                     ToolTip="Notatka z rozmowy/spotkania (Ctrl+Enter = zapisz)"/>
                        </DockPanel>
                    </Border>

                    <TextBlock Grid.Row="1" x:Name="LblNotatkiCount" Text="" FontSize="11"
                               Foreground="#64748B" Margin="0,0,0,8"/>

                    <!-- Lista notatek -->
                    <ItemsControl Grid.Row="2" x:Name="ListNotatki">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                        CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Tresc}" TextWrapping="Wrap" FontSize="13"
                                                       Foreground="#0F172A"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock Text="{Binding CreatedAtPl}" FontSize="11" Foreground="#64748B"/>
                                                <TextBlock Text=" · " FontSize="11" Foreground="#94A3B8"/>
                                                <TextBlock Text="{Binding AutorId}" FontSize="11" Foreground="#64748B" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="🗑" Tag="{Binding Id}" Click="BtnUsunNotatke_Click"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                VerticalAlignment="Top" Padding="6,2"
                                                ToolTip="Usuń notatkę"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </TabItem>

              </TabControl>
            </TabItem>
            <!-- ═══ GRUPA: ANALIZA ═══ -->
            <TabItem Header="📈 Analiza">
              <TabControl Background="Transparent" BorderThickness="0" Padding="0">

            <!-- Tab 8: SCORING -->
            <TabItem Header="⭐ Scoring">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <StackPanel x:Name="ScoringDetalPanel"/>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 9: HISTORIA ZMIAN -->
            <TabItem Header="📜 Historia">
                <Border Padding="20,16">
                    <Grid>
                        <DataGrid x:Name="GridHistoria" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  GridLinesVisibility="Horizontal" Background="White" RowHeight="32" ColumnHeaderHeight="36"
                                  AlternatingRowBackground="#FAFBFC" BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data" Binding="{Binding DataZmiany, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                                <DataGridTextColumn Header="Operacja" Binding="{Binding TypOperacji}" Width="90"/>
                                <DataGridTextColumn Header="Pole" Binding="{Binding PoleNazwa}" Width="160"/>
                                <DataGridTextColumn Header="Stara wartość" Binding="{Binding StaraWartosc}" Width="*"/>
                                <DataGridTextColumn Header="Nowa wartość" Binding="{Binding NowaWartosc}" Width="*"/>
                                <DataGridTextColumn Header="Użytkownik" Binding="{Binding UzytkownikNazwa}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock x:Name="EmptyHistoria" Visibility="Collapsed"
                                   Text="📜 Brak historii zmian. Każda edycja danych w zakładce ✏️ Dane zostanie tu zapisana (kto, co, kiedy)."
                                   Foreground="#94A3B8" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="440" TextAlignment="Center"/>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Tab 10: TRANSPORT -->
            <TabItem Header="🚚 Transport">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <StackPanel>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                            <TextBlock x:Name="TransportHeader" Text="🚚 Analiza transportu" FontWeight="SemiBold" FontSize="13"/>
                        </Border>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="👷 Top kierowcy" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <StackPanel x:Name="TransportKierowcy"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Text="🚛 Top pojazdy" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <StackPanel x:Name="TransportPojazdy"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="🗺 Top trasy" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <StackPanel x:Name="TransportTrasy"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 11: ASORTYMENT -->
            <TabItem Header="📦 Asortyment">
                <Border Padding="20,16">
                  <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="🥧 Struktura asortymentu — udział w obrocie (top 8)" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                            <lvc:PieChart x:Name="ChartAsortyment" Height="280" LegendPosition="Right" MinWidth="400"/>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1">
                    <DataGrid x:Name="GridAsortyment" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal" Background="White" RowHeight="32" ColumnHeaderHeight="36"
                              AlternatingRowBackground="#FAFBFC" BorderBrush="{StaticResource Border}" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kod" Binding="{Binding ProduktKod}" Width="80"/>
                            <DataGridTextColumn Header="Towar" Binding="{Binding ProduktNazwa}" Width="*"/>
                            <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N0}" Width="110"/>
                            <DataGridTextColumn Header="Wartość" Binding="{Binding SumaWartosc, StringFormat={}{0:N0} zł}" Width="130"/>
                            <DataGridTextColumn Header="Śr. cena" Binding="{Binding SredniaCena, StringFormat={}{0:N2} zł}" Width="100"/>
                            <DataGridTextColumn Header="Faktur" Binding="{Binding LiczbaFaktur}" Width="80"/>
                            <DataGridTextColumn Header="Ostatnia sprzedaż" Binding="{Binding OstatniaSprzedaz, StringFormat=dd.MM.yyyy}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="EmptyAsortyment" Visibility="Collapsed"
                               Text="📦 Brak danych o asortymencie. Klient nie ma pozycji na fakturach w analizowanym okresie."
                               Foreground="#94A3B8" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center"/>
                    </Grid>
                  </Grid>
                </Border>
            </TabItem>
              </TabControl>
            </TabItem>

        </TabControl>

        <!-- Overlay ładowania — przykrywa całe okno -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#B0FFFFFF" Visibility="Collapsed">
            <Border Background="White" CornerRadius="12" Padding="28,22" HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" Effect="{StaticResource CardShadow}">
                <StackPanel MinWidth="220">
                    <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LoadingText" Text="Ładuję dane klienta…" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <ProgressBar IsIndeterminate="True" Height="4" Width="180" Margin="0,12,0,0"
                                 Foreground="{StaticResource Primary}" Background="#E2E8F0" BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
