<Window x:Class="Kalendarz1.Customer360.SzczegolyMiesiacaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Szczegóły miesiąca" Width="1100" Height="720"
        WindowStartupLocation="CenterOwner" Background="#F5F7FA" FontFamily="Segoe UI" FontSize="12">
    <Window.Resources>
        <SolidColorBrush x:Key="Border" Color="#E2E8F0"/>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowHeight" Value="30"/>
            <Setter Property="ColumnHeaderHeight" Value="34"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFBFC"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="LblTytul" Text="Szczegóły" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
        <TextBlock Grid.Row="1" x:Name="LblPodsumowanie" Text="" FontSize="12" Foreground="#64748B" Margin="0,4,0,12"/>

        <Border Grid.Row="2" Background="White" CornerRadius="8" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="LblFaktury" Text="💰 Faktury" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" x:Name="GridFaktury">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Numer" Binding="{Binding NumerFaktury}" Width="160"/>
                        <DataGridTextColumn Header="Typ" Binding="{Binding TypDk}" Width="60"/>
                        <DataGridTextColumn Header="Wystawiona" Binding="{Binding DataWystawienia, StringFormat=dd.MM.yyyy}" Width="110"/>
                        <DataGridTextColumn Header="Termin" Binding="{Binding TerminPlatnosci, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Poz." Binding="{Binding LiczbaPozycji}" Width="55"/>
                        <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N0}" Width="90"/>
                        <DataGridTextColumn Header="Netto" Binding="{Binding Netto, StringFormat={}{0:N2} zł}" Width="110"/>
                        <DataGridTextColumn Header="Brutto" Binding="{Binding Brutto, StringFormat={}{0:N2} zł}" Width="110"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="White" CornerRadius="8" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="LblZamowienia" Text="🛒 Zamówienia" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" x:Name="GridZamowienia">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Data zam." Binding="{Binding DataZamowienia, StringFormat=dd.MM.yyyy}" Width="110"/>
                        <DataGridTextColumn Header="Ubój" Binding="{Binding DataUboju, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Wydanie" Binding="{Binding DataWydania, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Poz." Binding="{Binding LiczbaPozycji}" Width="55"/>
                        <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N0}" Width="90"/>
                        <DataGridTextColumn Header="Wartość" Binding="{Binding Wartosc, StringFormat={}{0:N0} zł}" Width="110"/>
                        <DataGridTextColumn Header="Handlowiec" Binding="{Binding Handlowiec}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
