<Window x:Class="Kalendarz1.HDI.HdiDiagWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🐛 HDI — Live diagnostyka"
        Width="1100" Height="700"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="Manual"
        Background="#0F172A"
        FontFamily="Cascadia Mono, Consolas, Courier New" FontSize="11"
        UseLayoutRounding="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP TOOLBAR -->
        <Border Grid.Row="0" Background="#1E293B" Padding="10,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🐛 Live diagnostyka HDI" Foreground="#F87171" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblCount" Text="0 wpisów" Foreground="#94A3B8" FontSize="10" Margin="14,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <CheckBox x:Name="ChkAutoScroll" Content="Auto-scroll" IsChecked="True"
                              Foreground="#CBD5E1" FontSize="10" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkSqlOnly" Content="Tylko SQL" IsChecked="False"
                              Foreground="#CBD5E1" FontSize="10" VerticalAlignment="Center" Margin="0,0,12,0"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="ChkErrOnly" Content="Tylko błędy" IsChecked="False"
                              Foreground="#CBD5E1" FontSize="10" VerticalAlignment="Center"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnCopy" Content="📋 Kopiuj wszystko" Click="BtnCopy_Click"
                            Background="#2563EB" Foreground="White" BorderThickness="0"
                            Padding="10,5" FontSize="11" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,6,0"/>
                    <Button x:Name="BtnClear" Content="🗑 Wyczyść" Click="BtnClear_Click"
                            Background="#374151" Foreground="White" BorderThickness="0"
                            Padding="10,5" FontSize="11" Cursor="Hand" Margin="0,0,6,0"/>
                    <Button x:Name="BtnClose" Content="✕" Click="BtnClose_Click"
                            Background="#DC2626" Foreground="White" BorderThickness="0"
                            Padding="8,5" FontSize="11" FontWeight="Bold" Cursor="Hand" Width="30"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LOG LIST -->
        <ScrollViewer Grid.Row="1" x:Name="ScrollView" VerticalScrollBarVisibility="Auto" Background="#0F172A">
            <ItemsControl x:Name="LogList" Padding="6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding RowBg}" Padding="6,2" Margin="0,0,0,1" CornerRadius="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="85"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding TimeStr}" Foreground="#64748B"/>
                                <TextBlock Grid.Column="1" Text="{Binding Level}" Foreground="{Binding LevelBrush}" FontWeight="Bold"/>
                                <TextBlock Grid.Column="2" Text="{Binding Source}" Foreground="#A5B4FC"/>
                                <TextBlock Grid.Column="3" Text="{Binding Message}" Foreground="#E5E7EB" TextWrapping="Wrap"/>
                                <TextBlock Grid.Column="4" Text="{Binding ElapsedStr}" Foreground="#FBBF24" FontWeight="SemiBold" Margin="8,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#1E293B" Padding="10,5">
            <TextBlock x:Name="LblStatus" Text="Otwarte. Wykonaj akcje w HDI → zobaczysz logi tutaj na żywo."
                       Foreground="#94A3B8" FontSize="10"/>
        </Border>
    </Grid>
</Window>
