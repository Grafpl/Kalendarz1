<Window x:Class="Kalendarz1.HDI.WyborZamowieniaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📦 Wybierz zamówienie do HDI"
        Width="900" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8"
        FontFamily="Segoe UI" FontSize="11"
        UseLayoutRounding="True">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Wybierz zamówienie z danego dnia (DataUboju)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="📅 Data uboju:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <DatePicker x:Name="DpDate" Width="140" VerticalAlignment="Center"/>
            <TextBox x:Name="TxtFilter" Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center"
                     TextChanged="TxtFilter_TextChanged"
                     ToolTip="Filtruj po nazwie klienta, ID, numerze faktury…"/>
            <Button Grid.Column="3" Content="🔍 Szukaj" Margin="6,0,0,0" Padding="10,4" Click="BtnSearch_Click"/>
        </Grid>

        <DataGrid x:Name="GridZam" Grid.Row="2" AutoGenerateColumns="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="True"
                  IsReadOnly="True" SelectionMode="Single"
                  MouseDoubleClick="GridZam_MouseDoubleClick"
                  Background="White" RowHeight="26">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"           Binding="{Binding Id}"           Width="60"/>
                <DataGridTextColumn Header="Klient"       Binding="{Binding Klient}"       Width="*" MinWidth="200"/>
                <DataGridTextColumn Header="Handlowiec"   Binding="{Binding Handlowiec}"   Width="140"/>
                <DataGridTextColumn Header="Kg"           Binding="{Binding IloscKg, StringFormat='N0'}"  Width="80"/>
                <DataGridTextColumn Header="Faktura"      Binding="{Binding NumerFaktury}" Width="120"/>
                <DataGridTextColumn Header="Data uboju"   Binding="{Binding DataUboju, StringFormat='dd.MM.yyyy'}" Width="100"/>
                <DataGridCheckBoxColumn Header="Zafakt."  Binding="{Binding CzyZafakturowane}"  Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="LblStatus" VerticalAlignment="Center" Foreground="#6B7280"/>
            <Button Grid.Column="1" Content="Anuluj" Padding="14,6" Margin="0,0,6,0" Click="BtnCancel_Click"/>
            <Button Grid.Column="2" Content="✓ Wybierz" Padding="14,6" Background="#1E40AF" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Click="BtnPick_Click"/>
        </Grid>
    </Grid>
</Window>
