<Window x:Class="Kalendarz1.HDI.HdiListaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📋 HDI — Lista dokumentów"
        Width="1200" Height="720"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F4F6F8"
        FontFamily="Segoe UI" FontSize="12"
        UseLayoutRounding="True"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#1E40AF"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#1E3A8A"/>
        <SolidColorBrush x:Key="Border" Color="#D1D5DB"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B7280"/>
        <SolidColorBrush x:Key="Danger" Color="#DC2626"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="📋 Handlowe Dokumenty Identyfikacyjne" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Lista wszystkich HDI z auto-numeracją per rok. Generowanie PDF do druku." FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource GhostButton}" Content="🔢 Ustaw nr początkowy"
                            Click="BtnSetStartNumber_Click" Margin="0,0,8,0"
                            ToolTip="Ustaw od jakiego numeru ma się liczyć HDI dla bieżącego roku (np. gdy poprzednie były wystawiane ręcznie)"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="➕ Nowy HDI" Click="BtnNew_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="24,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔍 Szukaj klienta:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="TxtSearch" Width="240" Padding="8,6" MinHeight="32" VerticalContentAlignment="Center" KeyUp="TxtSearch_KeyUp"/>
                <TextBlock Text="Rok:" VerticalAlignment="Center" Margin="20,0,8,0"/>
                <ComboBox x:Name="CmbRok" Width="100" MinHeight="32" SelectionChanged="CmbRok_SelectionChanged"/>
                <Button Style="{StaticResource GhostButton}" Content="🔄 Odśwież" Click="BtnRefresh_Click" Margin="16,0,0,0"/>
                <TextBlock x:Name="LblCount" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" x:Name="GridList" Margin="24,16,24,16"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1"
                  GridLinesVisibility="Horizontal" RowHeight="40" ColumnHeaderHeight="38"
                  AlternatingRowBackground="#FAFBFC" MouseDoubleClick="GridList_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nr" Binding="{Binding NumerPelny}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#1E40AF"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Data" Binding="{Binding DataWystawienia, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Klient" Binding="{Binding KlientNazwa}" Width="*"/>
                <DataGridTextColumn Header="Towar" Binding="{Binding OpisTowaru}" Width="*"/>
                <DataGridTextColumn Header="Waga (kg)" Binding="{Binding WagaNetto, StringFormat=N0}" Width="100"/>
                <DataGridTextColumn Header="Opak." Binding="{Binding LiczbaOpakowan}" Width="70"/>
                <DataGridTextColumn Header="Autor" Binding="{Binding UtworzonoPrzez}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                <DataGridTemplateColumn Header="Akcje" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="📄 PDF" Click="BtnPdf_Click" Padding="8,4" Margin="2,0" Background="#EFF6FF" BorderThickness="0" Cursor="Hand"/>
                                <Button Content="✏️" Click="BtnEdit_Click" Width="32" Height="28" Margin="2,0" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                <Button Content="🗑" Click="BtnDelete_Click" Width="32" Height="28" Margin="2,0" Background="Transparent" BorderThickness="0" Foreground="#DC2626" Cursor="Hand"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="24,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" FontSize="11" Text="Double-click wiersz aby edytować."/>
                <Button Grid.Column="1" Style="{StaticResource GhostButton}" Content="Zamknij" Click="BtnClose_Click" MinWidth="100"/>
            </Grid>
        </Border>
    </Grid>
</Window>
