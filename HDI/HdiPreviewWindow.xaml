<Window x:Class="Kalendarz1.HDI.HdiPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📄 Podgląd HDI"
        Width="900" Height="900"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="#1F2937"
        FontFamily="Segoe UI" FontSize="11"
        UseLayoutRounding="True"
        KeyDown="Window_KeyDown">
    <Window.InputBindings>
        <KeyBinding Key="P" Modifiers="Control" Command="{Binding PrintCmd, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCmd, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Key="Escape" Command="{Binding CloseCmd, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Key="OemPlus" Command="{Binding ZoomInCmd, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Key="OemMinus" Command="{Binding ZoomOutCmd, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Key="D0" Command="{Binding ZoomFitCmd, RelativeSource={RelativeSource AncestorType=Window}}"/>
        <KeyBinding Key="W" Command="{Binding ZoomFitWidthCmd, RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Window.InputBindings>
    <Window.Resources>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4B5563"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="Background" Value="#2563EB"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E40AF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="Background" Value="#DC2626"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#991B1B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP TOOLBAR -->
        <Border Grid.Row="0" Background="#111827" Padding="14,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📄" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="LblTitle" Text="HDI — Podgląd" FontSize="14" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="LblSubtitle" Text="" FontSize="10" Foreground="#9CA3AF"/>
                    </StackPanel>
                </StackPanel>

                <!-- Zoom controls (center) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button Content="🔍−" Style="{StaticResource ToolBtn}" Click="BtnZoomOut_Click" ToolTip="Pomniejsz (−)" Width="40"/>
                    <Border Background="#374151" CornerRadius="4" Padding="10,6" Margin="0,0,4,0" MinWidth="60">
                        <TextBlock x:Name="LblZoom" Text="100%" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <Button Content="🔍+" Style="{StaticResource ToolBtn}" Click="BtnZoomIn_Click" ToolTip="Powiększ (+)" Width="40"/>
                    <Border Width="1" Background="#374151" Margin="6,2,6,2"/>
                    <Button Content="📏 Szer." Style="{StaticResource ToolBtn}" Click="BtnZoomFitWidth_Click" ToolTip="Dopasuj do szerokości (W)"/>
                    <Button Content="⊡ 100%" Style="{StaticResource ToolBtn}" Click="BtnZoomFit_Click" ToolTip="100% (0)"/>
                </StackPanel>

                <!-- Actions (right) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnPrint" Content="🖨️ Drukuj" Style="{StaticResource PrimaryBtn}" Click="BtnPrint_Click" ToolTip="Drukuj (Ctrl+P)"/>
                    <Button x:Name="BtnSaveAs" Content="💾 Zapisz" Style="{StaticResource ToolBtn}" Click="BtnSaveAs_Click" ToolTip="Zapisz PDF (Ctrl+S)"/>
                    <Button x:Name="BtnOpenExternal" Content="↗ Zewn." Style="{StaticResource ToolBtn}" Click="BtnOpenExternal_Click" ToolTip="Otwórz w domyślnej aplikacji"/>
                    <Border Width="1" Background="#374151" Margin="4,2,4,2"/>
                    <Button x:Name="BtnClose" Content="✕" Style="{StaticResource DangerBtn}" Click="BtnClose_Click" ToolTip="Zamknij (Esc)" Width="34"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BODY: thumbnails sidebar + preview -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColThumbs" Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- THUMBNAILS sidebar -->
            <Border Grid.Column="0" Background="#111827" BorderBrush="#0F172A" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ThumbsList" Padding="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Background="White" Cursor="Hand"
                                        BorderBrush="#475569" BorderThickness="2"
                                        MouseLeftButtonDown="Thumb_Click"
                                        Tag="{Binding PageIndex}">
                                    <StackPanel>
                                        <Image Source="{Binding Image}" Stretch="Uniform" Height="160"/>
                                        <Border Background="#1F2937" Padding="4,2">
                                            <TextBlock Text="{Binding Label}" Foreground="White"
                                                       FontSize="10" HorizontalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- PREVIEW main -->
            <ScrollViewer Grid.Column="1" x:Name="ScrollPreview"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#374151">
                <ItemsControl x:Name="PagesList" Padding="24">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Margin="0,0,0,18" HorizontalAlignment="Center"
                                    Tag="{Binding PageIndex}" Loaded="PageBorder_Loaded">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="6" Color="Black" Opacity="0.5"/>
                                </Border.Effect>
                                <Image Source="{Binding Image}" Stretch="None"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#0F172A" Padding="14,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LblStatus" Text="✓ Gotowe" Foreground="#9CA3AF" FontSize="10" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⌨ Ctrl+P drukuj · Ctrl+S zapisz · +/− zoom · W szer · 0 reset · Esc zamknij"
                               Foreground="#6B7280" FontSize="9" Margin="0,0,12,0"/>
                    <TextBlock x:Name="LblPages" Text="" Foreground="#9CA3AF" FontSize="10"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
