<Window x:Class="Kalendarz1.HDI.TowarPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kalendarz1.HDI"
        Title="🥩 Wybierz towar do HDI"
        Width="980" Height="700"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8"
        FontFamily="Segoe UI" FontSize="11"
        UseLayoutRounding="True">
    <Window.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVisConverter"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="🥩" FontSize="22" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Wybierz towar" FontSize="15" FontWeight="Bold" Foreground="#111827"/>
                <TextBlock Text="Klikni miniaturę lub dwukrotnie wiersz żeby wybrać · Esc anuluje" FontSize="10" Foreground="#6B7280"/>
            </StackPanel>
        </StackPanel>

        <!-- FILTRY -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" BorderBrush="#D1D5DB" BorderThickness="1" Padding="10,6" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton x:Name="RbWszystkie" Content="Wszystkie" IsChecked="True"
                                 GroupName="Filter" Margin="0,0,12,0" VerticalContentAlignment="Center"
                                 Checked="Filter_Changed"/>
                    <RadioButton x:Name="RbSwieze" Content="🍖 Świeże" GroupName="Filter"
                                 Margin="0,0,12,0" VerticalContentAlignment="Center" Foreground="#16A34A"
                                 Checked="Filter_Changed"/>
                    <RadioButton x:Name="RbMrozone" Content="❄ Mrożone" GroupName="Filter"
                                 Margin="0,0,12,0" VerticalContentAlignment="Center" Foreground="#2563EB"
                                 Checked="Filter_Changed"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="TxtSearch" Padding="6,4" MinHeight="28" Width="280" VerticalContentAlignment="Center"
                             TextChanged="Search_TextChanged"
                             ToolTip="Filtruj po nazwie lub kodzie"/>
                </StackPanel>
                <TextBlock x:Name="LblCount" Grid.Column="2" VerticalAlignment="Center" Foreground="#6B7280" FontSize="10"/>
            </Grid>
        </Border>

        <!-- LISTA towarów -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Background="White">
            <ItemsControl x:Name="ListTowary" Padding="6">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="220" Margin="0,0,6,6" CornerRadius="8" BorderThickness="2" Background="White"
                                BorderBrush="#E5E7EB" Cursor="Hand" Padding="8"
                                MouseLeftButtonDown="Card_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#2563EB"/>
                                            <Setter Property="Background" Value="#EFF6FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <!-- Miniatura 48x48 -->
                                <Border Width="48" Height="48" CornerRadius="6" ClipToBounds="True"
                                        BorderBrush="#E5E7EB" BorderThickness="1" VerticalAlignment="Center"
                                        Margin="0,0,8,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FAFCF7" Offset="0"/>
                                            <GradientStop Color="#F0F4EB" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <TextBlock Text="📦" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="#94A3B8"
                                                   Visibility="{Binding Image, Converter={StaticResource NullToVisConverter}}"/>
                                        <Image Source="{Binding Image}" Stretch="Uniform"/>
                                    </Grid>
                                </Border>
                                <StackPanel VerticalAlignment="Center" Width="148">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="11"
                                               TextWrapping="Wrap" MaxHeight="34" TextTrimming="WordEllipsis"/>
                                    <Border Margin="0,3,0,0" Padding="4,1" CornerRadius="3" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#DCFCE7"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMrozone}" Value="True">
                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding KategoriaBadge}" FontSize="9" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- BUTTONS -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="LblStatus" VerticalAlignment="Center" Foreground="#6B7280" FontSize="10"/>
            <Button Grid.Column="1" Content="Anuluj" Padding="16,6" Click="BtnCancel_Click"/>
        </Grid>
    </Grid>
</Window>
