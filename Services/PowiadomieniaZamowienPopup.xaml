<Window x:Class="Kalendarz1.Services.PowiadomieniaZamowienPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zamówienie po godzinie"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">
    <Border Background="White" CornerRadius="14" BorderBrush="#E2E8F0" BorderThickness="1" MinWidth="400" MaxWidth="440">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Color="#0F172A" Opacity="0.22"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Side accent stripe — kolor zależny od akcji (Render() w code-behind) -->
            <Border x:Name="SideAccentStripe" Grid.Column="0" Background="#F59E0B" CornerRadius="14,0,0,14"/>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

            <!-- Header (orange gradient) -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" Padding="16,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#F59E0B"/>
                        <GradientStop Offset="1" Color="#D97706"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="⚠" FontSize="28" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Zamówienie po cut-off" FontSize="14" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="LblHeaderSub" Text="" FontSize="11" Foreground="#FEF3C7" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Click="BtnClose_Click" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="6">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="✕" FontSize="14" Foreground="White" FontWeight="Bold"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="16,12,16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Klient" FontSize="10" Foreground="#64748B" FontWeight="SemiBold"/>
                        <TextBlock x:Name="LblKlient" Text="—" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="4" Padding="6,2" Margin="8,2,0,0" VerticalAlignment="Top">
                        <TextBlock x:Name="LblZamId" Text="#0" FontSize="11" FontWeight="Bold" Foreground="#475569" FontFamily="Consolas"/>
                    </Border>
                </Grid>

                <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Margin="0,10,0,10"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Zdjęcie towaru (BLOB z TowarZdjecia) — większe 64×64 + miękki cień -->
                    <Border Width="64" Height="64" CornerRadius="10" ClipToBounds="True" Background="#F1F5F9" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#0F172A" Opacity="0.20"/>
                        </Border.Effect>
                        <Grid>
                            <Image x:Name="ImgTowar" Stretch="UniformToFill" Visibility="Collapsed"/>
                            <TextBlock x:Name="LblTowarEmoji" Text="🍗" FontSize="34" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <TextBlock Grid.Column="1" x:Name="LblAkcjaIkona" Text="📈" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock x:Name="LblAkcja" Text="—" FontSize="12" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock x:Name="LblTowar" Text="—" FontSize="11" Foreground="#64748B" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>

                <Border x:Name="ZmianaBox" Background="#FEF3C7" BorderBrush="#FDE68A" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,4,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="LblZmianaTytul" Text="Zmiana ilości" FontSize="10" Foreground="#92400E" FontWeight="SemiBold"/>
                            <TextBlock x:Name="LblStaraNowa" Text="—" FontSize="11" Foreground="#92400E" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" x:Name="LblZmianaKg" Text="0 kg" FontSize="36" FontWeight="Bold" Foreground="#92400E" VerticalAlignment="Center" LineHeight="40"/>
                    </Grid>
                </Border>

                <!-- Lista zmian — tylko w trybie zbiorczym (gdy >=2 zmian od tego samego usera dla tego zamówienia) -->
                <Border x:Name="MultiListBox" Visibility="Collapsed" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="8,6" Margin="0,6,0,0">
                    <StackPanel>
                        <TextBlock Text="Lista zmian:" FontSize="10" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ItemsControl x:Name="ListaZmian">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Ikona}" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Opis}" FontSize="11" Foreground="#0F172A" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Kg}" FontSize="11" FontWeight="Bold" Foreground="{Binding Kolor}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Handlowiec: avatar (22x22 koło) + imię -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Handlowiec: " FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"/>
                        <Border Width="22" Height="22" CornerRadius="11" ClipToBounds="True" Background="#E5E7EB" Margin="6,0,0,0" VerticalAlignment="Center">
                            <Grid>
                                <Image x:Name="ImgHandlowiecAvatar" Stretch="UniformToFill" Visibility="Collapsed"/>
                                <TextBlock x:Name="LblHandlowiecInicjal" Text="?" FontSize="10" FontWeight="Bold" Foreground="#475569" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="LblHandlowiec" Text="—" FontSize="11" Foreground="#475569" FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                    </StackPanel>
                    <!-- Dzień uboju: dzień tyg + data + (relatywne dzisiaj/za N dni) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📅 " FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LblDataUboju" Text="—" FontSize="11" Foreground="#0F172A" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LblDataUbojuRelatywne" Text="" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Zmienił/Dodał: avatar autora zmiany + imię -->
                <Border Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="6" Padding="8,5" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="LblZmienilAkcja" Text="✏️ Zmienił:" FontSize="11" Foreground="#3730A3" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Border Width="26" Height="26" CornerRadius="13" ClipToBounds="True" Background="#C7D2FE" VerticalAlignment="Center">
                            <Grid>
                                <Image x:Name="ImgAutorAvatar" Stretch="UniformToFill" Visibility="Collapsed"/>
                                <TextBlock x:Name="LblAutorInicjal" Text="?" FontSize="11" FontWeight="Bold" Foreground="#3730A3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="LblAutor" Text="—" FontSize="12" Foreground="#1E1B4B" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,14,0" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Progress bar — wizualny licznik do auto-close (30s/45s) -->
                    <Border Grid.Row="0" Height="3" Background="#E5E7EB" CornerRadius="0">
                        <Border x:Name="ProgressFill" Background="#F59E0B" HorizontalAlignment="Left" Width="0" CornerRadius="0">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ProgressScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                        </Border>
                    </Border>
                    <Grid Grid.Row="1" Margin="16,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LblCzas" Text="przed chwilą" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Click="BtnDismiss_Click" Cursor="Hand" Padding="14,6" Background="#4F46E5" Foreground="White" FontSize="11" FontWeight="SemiBold" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="OK, widziałem"/>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
