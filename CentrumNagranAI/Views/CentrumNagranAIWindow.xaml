<Window x:Class="Kalendarz1.CentrumNagranAI.Views.CentrumNagranAIWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Centrum nagrań AI"
        Width="1280" Height="820"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F8FAFC">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="Surface" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Surface2" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="Border" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="Text" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextDim" Color="#64748B"/>
        <SolidColorBrush x:Key="Accent" Color="#DC2626"/>
        <SolidColorBrush x:Key="AccentDark" Color="#991B1B"/>
        <SolidColorBrush x:Key="Score80" Color="#16A34A"/>
        <SolidColorBrush x:Key="Score50" Color="#CA8A04"/>
        <SolidColorBrush x:Key="Score20" Color="#94A3B8"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <!-- Hover effect dla przycisków bordered (ghost buttons) -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="🎥" FontSize="32" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock Text="Centrum nagrań AI" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Wyszukiwanie zdarzeń w nagraniach CCTV po polskim opisie"
                           Foreground="{StaticResource TextDim}" FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <!-- Pole wyszukiwania + filtry -->
        <Border Grid.Row="1" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="1"
                CornerRadius="8" Padding="16">
            <StackPanel>
                <TextBlock Text="Zapytanie po polsku:" Margin="0,0,0,6" FontSize="12"
                           Foreground="{StaticResource TextDim}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="QueryBox" Grid.Column="0"
                             FontSize="14" Padding="10,8"
                             Background="{StaticResource Bg}"
                             Foreground="{StaticResource Text}"
                             BorderBrush="{StaticResource Border}"
                             BorderThickness="1"
                             KeyDown="QueryBox_KeyDown"
                             Text="osoba bez czepka w pakowalni"/>
                    <Button x:Name="SearchBtn" Grid.Column="1"
                            Content="🔍 Szukaj" Padding="20,8" Margin="8,0,0,0"
                            Background="{StaticResource Accent}"
                            Foreground="White" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand"
                            Click="SearchBtn_Click"/>
                </Grid>

                <!-- Filtry: zakres dat + chipy kamer -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Od:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextDim}" FontSize="12" Margin="0,0,6,0"/>
                    <DatePicker Grid.Column="1" x:Name="FromDatePicker" Width="130"/>
                    <TextBox Grid.Column="2" x:Name="FromTimeBox" Width="68" Margin="4,0,0,0"
                             Text="00:00" FontSize="12"
                             Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
                             BorderBrush="{StaticResource Border}" BorderThickness="1"/>

                    <TextBlock Grid.Column="3" Text="Do:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextDim}" FontSize="12" Margin="14,0,6,0"/>
                    <DatePicker Grid.Column="4" x:Name="ToDatePicker" Width="130"/>
                    <TextBox Grid.Column="5" x:Name="ToTimeBox" Width="68" Margin="4,0,0,0"
                             Text="23:59" FontSize="12"
                             Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
                             BorderBrush="{StaticResource Border}" BorderThickness="1"/>

                    <Button Grid.Column="6" x:Name="ClearDateBtn" Content="✕"
                            Margin="6,0,0,0" Padding="8,2" FontSize="11"
                            Background="Transparent" Foreground="{StaticResource TextDim}"
                            BorderBrush="{StaticResource Border}" BorderThickness="1"
                            Cursor="Hand" Click="ClearDateBtn_Click"
                            ToolTip="Wyczyść filtr dat"/>

                    <!-- Chipy kamer (#9) -->
                    <ItemsControl Grid.Column="7" x:Name="CameraChipsList" Margin="14,0,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton Content="{Binding Label}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Margin="3" Padding="12,6" FontSize="12"
                                              Cursor="Hand"
                                              Tag="{Binding}">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Background" Value="#F1F5F9"/>
                                            <Setter Property="Foreground" Value="{StaticResource Text}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Wyniki -->
        <Border Grid.Row="2" Margin="0,16,0,0"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <!-- Pusty stan -->
                <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                    <TextBlock Text="🔍" FontSize="56" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextDim}" Opacity="0.5"/>
                    <TextBlock x:Name="EmptyText" FontSize="15" Margin="0,12,0,0"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Foreground="{StaticResource TextDim}" TextWrapping="Wrap"
                               MaxWidth="500"
                               Text="Wpisz polskie zapytanie i kliknij Szukaj. Wyniki pokażą się tu - z miniaturką, opisem AI, score i przyciskiem ▶ Odtwórz."/>
                </StackPanel>

                <!-- Lista wyników -->
                <ScrollViewer x:Name="ResultsScroller" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" Padding="12">
                    <ItemsControl x:Name="ResultsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12" Padding="12"
                                        Background="{StaticResource Surface2}"
                                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                                        CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Miniaturka -->
                                        <Border Grid.Column="0" Width="240" Height="135"
                                                Background="Black" CornerRadius="4"
                                                ClipToBounds="True">
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="UniformToFill"/>
                                        </Border>

                                        <!-- Meta + reason -->
                                        <StackPanel Grid.Column="1" Margin="16,0,16,0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Rank, StringFormat='#{0}'}"
                                                           FontWeight="Bold" FontSize="14"
                                                           Foreground="{StaticResource Text}"
                                                           Margin="0,0,12,0"/>
                                                <TextBlock Text="{Binding CameraDisplayName}"
                                                           FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                                                <TextBlock Text="{Binding TimeLabel}"
                                                           Foreground="{StaticResource TextDim}"
                                                           Margin="12,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Reason}"
                                                       Foreground="{StaticResource Text}"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Margin="0,8,0,0"/>
                                        </StackPanel>

                                        <!-- Score badge -->
                                        <Border Grid.Column="2" Width="64" Height="64"
                                                CornerRadius="32" VerticalAlignment="Center"
                                                Background="{Binding ScoreColor}">
                                            <TextBlock Text="{Binding Score}"
                                                       Foreground="White"
                                                       FontSize="22" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Buttons -->
                                        <StackPanel Grid.Column="3" Orientation="Vertical"
                                                    VerticalAlignment="Center" Margin="12,0,0,0">
                                            <Button Content="▶ Odtwórz"
                                                    Padding="14,6" Margin="0,0,0,4"
                                                    Background="{StaticResource AccentDark}"
                                                    Foreground="White" FontWeight="Bold"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Tag="{Binding}"
                                                    Click="PlayBtn_Click"/>
                                            <Button Content="🔍 Podobne"
                                                    Padding="14,4" FontSize="11" Margin="0,0,0,4"
                                                    Background="Transparent"
                                                    Foreground="{StaticResource TextDim}"
                                                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                                                    Cursor="Hand"
                                                    Tag="{Binding}"
                                                    Click="SimilarBtn_Click"
                                                    ToolTip="Pokaż klatki wizualnie podobne (bez kosztu)"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="👍" FontSize="14" Padding="8,3" Margin="0,0,4,0"
                                                        Background="Transparent" Foreground="{StaticResource Text}"
                                                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                                                        Cursor="Hand" Tag="{Binding}" Click="FeedbackUp_Click"
                                                        ToolTip="Trafny wynik - F1 ground truth"/>
                                                <Button Content="👎" FontSize="14" Padding="8,3"
                                                        Background="Transparent" Foreground="{StaticResource Text}"
                                                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                                                        Cursor="Hand" Tag="{Binding}" Click="FeedbackDown_Click"
                                                        ToolTip="Nietrafny - pomóż systemowi zmierzyć dokładność"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Loader overlay -->
                <Grid x:Name="LoaderOverlay" Visibility="Collapsed"
                      Background="#CCFFFFFF">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="LoaderText" Text="Wyszukuję..."
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text}"
                                   HorizontalAlignment="Center"/>
                        <ProgressBar IsIndeterminate="True" Width="280" Height="8"
                                     Margin="0,16,0,0" Foreground="{StaticResource Accent}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Vertical">
                <TextBlock x:Name="LeftStatus" Foreground="{StaticResource TextDim}" FontSize="11"/>
                <TextBlock x:Name="RightStatus" Foreground="{StaticResource TextDim}" FontSize="11"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="GuardBtn" Content="🛡️ Strażnik" Padding="10,4" Margin="6,0,0,0"
                        Background="Transparent" Foreground="{StaticResource Text}"
                        BorderBrush="{StaticResource Accent}" BorderThickness="1"
                        FontSize="11" Cursor="Hand" Click="GuardBtn_Click"
                        ToolTip="Reguły alertów, anomalie, dzienne briefy"/>
                <Button x:Name="PlatesBtn" Content="🚗 Tablice" Padding="10,4" Margin="6,0,0,0"
                        Background="Transparent" Foreground="{StaticResource TextDim}"
                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                        FontSize="11" Cursor="Hand" Click="PlatesBtn_Click"
                        ToolTip="Wyszukiwarka tablic rejestracyjnych z kamer rampy/bramy"/>
                <Button x:Name="HeatmapBtn" Content="🌡️ Heatmapa" Padding="10,4" Margin="6,0,0,0"
                        Background="Transparent" Foreground="{StaticResource TextDim}"
                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                        FontSize="11" Cursor="Hand" Click="HeatmapBtn_Click"
                        ToolTip="Wizualizacja aktywności kamera×godzina (ostatnie 7 dni)"/>
                <Button x:Name="NvrBtn" Content="🎥 NVR-y" Padding="10,4" Margin="6,0,0,0"
                        Background="Transparent" Foreground="{StaticResource TextDim}"
                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                        FontSize="11" Cursor="Hand" Click="NvrBtn_Click"
                        ToolTip="Dodaj/edytuj NVR-y i kanały kamer (z testem połączenia)"/>
                <Button x:Name="SettingsBtn" Content="⚙ Ustawienia" Padding="10,4" Margin="6,0,0,0"
                        Background="Transparent" Foreground="{StaticResource TextDim}"
                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                        FontSize="11" Cursor="Hand" Click="SettingsBtn_Click"
                        ToolTip="Nazwy kamer, retencja, interwał klatek, OCR"/>
                <Button x:Name="AuditBtn" Content="📂 Audit" Padding="10,4" Margin="6,0,0,0"
                        Background="Transparent" Foreground="{StaticResource TextDim}"
                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                        FontSize="11" Cursor="Hand" Click="AuditBtn_Click"
                        ToolTip="Otwiera folder z logami audytu"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
