<Window x:Class="Kalendarz1.CentrumNagranAI.Views.ClipPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Odtwarzanie klipu"
        Width="1100" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="Surface" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Border" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="Text" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextDim" Color="#64748B"/>
        <SolidColorBrush x:Key="Accent" Color="#DC2626"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock x:Name="HeaderText" FontSize="18" FontWeight="Bold"/>
            <TextBlock x:Name="MetaText" FontSize="12"
                       Foreground="{StaticResource TextDim}"
                       Margin="16,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Player area -->
        <Border Grid.Row="1" Background="Black" CornerRadius="6" ClipToBounds="True">
            <Grid>
                <!-- Kontener LibVLC (na 8) -->
                <vlc:VideoView x:Name="VideoView" Visibility="Collapsed"/>

                <!-- Fallback / placeholder: same JPEG klatki, gdy VLC niedostępny -->
                <Image x:Name="FrameImage" Stretch="Uniform"/>

                <!-- Status overlay -->
                <Grid x:Name="StatusOverlay" Background="#A0000000"
                      VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                      Visibility="Collapsed">
                    <TextBlock x:Name="StatusOverlayText"
                               Margin="16,8" Foreground="White" FontSize="12"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Reason -->
        <Border Grid.Row="2" Margin="0,12,0,0"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="1"
                CornerRadius="6" Padding="12">
            <StackPanel>
                <TextBlock Text="Dlaczego AI uznała że pasuje:"
                           FontSize="11" Foreground="{StaticResource TextDim}"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="ReasonText" FontSize="13" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Controls -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="PlayClipBtn" Content="⏮ Klip ±15s (z nagrania)"
                        Padding="14,8" Background="{StaticResource Accent}"
                        Foreground="White" FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand" Click="PlayClip_Click"
                        ToolTip="Odtwarza nagranie z dysku NVR z momentu zdjęcia (±15s)"/>
                <Button x:Name="PlayLiveBtn" Content="▶ Live z kamery"
                        Margin="8,0,0,0" Padding="14,8"
                        Background="Transparent" Foreground="{StaticResource Text}"
                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                        Cursor="Hand" Click="PlayLive_Click"
                        ToolTip="Otwiera live stream tej kamery (aktualny obraz, nie nagranie)"/>
            </StackPanel>
            <TextBlock x:Name="StatusText" Grid.Column="1" Margin="16,0"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextDim}"
                       FontSize="12"/>
            <Button Grid.Column="2" Content="Zamknij" Padding="14,8"
                    Background="Transparent"
                    Foreground="{StaticResource TextDim}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1" Cursor="Hand"
                    Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>
