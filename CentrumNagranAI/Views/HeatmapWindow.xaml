<Window x:Class="Kalendarz1.CentrumNagranAI.Views.HeatmapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🌡️ Heatmapa aktywności"
        Width="1200" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A">

    <Window.Resources>
        <SolidColorBrush x:Key="Surface" Color="#1E293B"/>
        <SolidColorBrush x:Key="Border" Color="#334155"/>
        <SolidColorBrush x:Key="Text" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextDim" Color="#94A3B8"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🌡️ Heatmapa aktywności (ostatnie 7 dni)"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="11"
                   Foreground="{StaticResource TextDim}" Margin="0,0,0,16"
                   Text="Każda komórka pokazuje średnią zmianę między klatkami w tej godzinie. Ciemny = spokój, jasny = duży ruch. Pomaga zobaczyć rytm dobowy zakładu."/>

        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Grid x:Name="HeatmapGrid"/>
        </ScrollViewer>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="🔄 Odśwież" Padding="12,6"
                    Background="Transparent" Foreground="{StaticResource Text}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                    Click="Refresh_Click"/>
            <TextBlock x:Name="LegendText" Grid.Column="1" Margin="20,0" VerticalAlignment="Center"
                       Foreground="{StaticResource TextDim}" FontSize="11"/>
            <Button Grid.Column="2" Content="Zamknij" Padding="12,6" Click="Close_Click"
                    Background="Transparent" Foreground="{StaticResource TextDim}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1"/>
        </Grid>
    </Grid>
</Window>
