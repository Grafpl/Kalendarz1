<Window x:Class="Kalendarz1.CentrumNagranAI.Views.StrazneiAlertyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡️ Strażnik AI"
        Width="1100" Height="780"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A">

    <Window.Resources>
        <SolidColorBrush x:Key="Surface" Color="#1E293B"/>
        <SolidColorBrush x:Key="Surface2" Color="#243349"/>
        <SolidColorBrush x:Key="Border" Color="#334155"/>
        <SolidColorBrush x:Key="Text" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextDim" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Accent" Color="#EF4444"/>
        <SolidColorBrush x:Key="Danger" Color="#DC2626"/>
        <SolidColorBrush x:Key="Ok" Color="#16A34A"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource Surface2}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#334155"/>
            <Setter Property="RowBackground" Value="{StaticResource Surface2}"/>
            <Setter Property="AlternatingRowBackground" Value="#1E293B"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🛡️ Strażnik AI" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

        <TabControl Grid.Row="1" Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Border}" Foreground="{StaticResource Text}">
            <!-- ====== REGUŁY ====== -->
            <TabItem Header="📋 Reguły">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Lista -->
                    <Grid Grid.Column="0" Margin="0,0,8,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="RulesGrid" Grid.Row="0" AutoGenerateColumns="False" CanUserAddRows="False"
                                  IsReadOnly="True" SelectionMode="Single"
                                  SelectionChanged="RulesGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Próg" Binding="{Binding Threshold}" Width="50"/>
                                <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="40"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="➕ Nowa" Padding="10,4" Click="NewRule_Click"
                                    Background="{StaticResource Ok}" Foreground="White" BorderThickness="0"/>
                            <Button Content="🗑️ Usuń" Padding="10,4" Margin="6,0,0,0" Click="DeleteRule_Click"
                                    Background="{StaticResource Danger}" Foreground="White" BorderThickness="0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Edytor -->
                    <Border Grid.Column="1" Background="{StaticResource Surface2}"
                            BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="14">
                        <StackPanel x:Name="EditorPanel" IsEnabled="False">
                            <TextBlock Text="Nazwa reguły:" Margin="0,0,0,4" FontSize="11" Foreground="{StaticResource TextDim}"/>
                            <TextBox x:Name="RuleNameBox" Margin="0,0,0,10"/>

                            <TextBlock Text="Pytanie po polsku (co AI ma sprawdzać):" Margin="0,0,0,4" FontSize="11" Foreground="{StaticResource TextDim}"/>
                            <TextBox x:Name="RulePromptBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Próg score (0-100):" FontSize="11" Foreground="{StaticResource TextDim}"/>
                                    <TextBox x:Name="RuleThresholdBox"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Cooldown [min]:" FontSize="11" Foreground="{StaticResource TextDim}"/>
                                    <TextBox x:Name="RuleCooldownBox"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Wymagane potwierdzenia (anty-szum):" FontSize="11" Foreground="{StaticResource TextDim}"/>
                                    <TextBox x:Name="RuleConfirmsBox" ToolTip="Ile kolejnych klatek musi potwierdzić zanim alert. 1=natychmiast, 2-3=mniej fałszywych alarmów"/>
                                </StackPanel>
                            </Grid>

                            <CheckBox x:Name="RuleEnabledChk" Content="Aktywna" Foreground="{StaticResource Text}" Margin="0,0,0,4"/>
                            <CheckBox x:Name="RuleSmsChk" Content="📱 Wyślij SMS przy alercie (Twilio)" Foreground="{StaticResource Text}" Margin="0,0,0,12"
                                      ToolTip="Wymaga konfiguracji Twilio w secrets.json (sekcja Twilio: AccountSid, AuthToken, From, To)"/>

                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="SaveRuleBtn" Content="💾 Zapisz regułę"
                                        Padding="14,6"
                                        Background="{StaticResource Accent}" Foreground="White"
                                        BorderThickness="0" FontWeight="Bold"
                                        Click="SaveRule_Click"/>
                                <Button x:Name="TestRuleBtn" Content="🧪 Test na ostatnich 100"
                                        Padding="14,6" Margin="8,0,0,0"
                                        Background="Transparent" Foreground="{StaticResource Text}"
                                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                                        Click="TestRule_Click"
                                        ToolTip="Sprawdź ile razy reguła by zadziałała na ostatnich 100 klatkach (dry-run, bez efektów)"/>
                            </StackPanel>
                            <TextBlock x:Name="TestStatus" Margin="0,8,0,0" TextWrapping="Wrap" FontSize="11"
                                       Foreground="{StaticResource TextDim}"/>

                            <TextBlock Margin="0,16,0,0" FontSize="11" Foreground="{StaticResource TextDim}"
                                       TextWrapping="Wrap"
                                       Text="Przykłady pytań: 'Czy widać osobę bez czepka?', 'Czy jest pojazd na rampie?', 'Czy hala uboju jest pusta?'. Bądź konkretny - im węższe pytanie, tym mniej fałszywych alarmów."/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ====== ALERTY ====== -->
            <TabItem Header="🚨 Alerty">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="🔄 Odśwież" Padding="10,4" HorizontalAlignment="Left"
                            Margin="0,0,0,8" Background="Transparent" Foreground="{StaticResource Text}"
                            BorderBrush="{StaticResource Border}" BorderThickness="1"
                            Click="RefreshAlerts_Click"/>
                    <DataGrid x:Name="AlertsGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Czas" Binding="{Binding TimeLabel}" Width="140"/>
                            <DataGridTextColumn Header="Reguła" Binding="{Binding RuleName}" Width="*"/>
                            <DataGridTextColumn Header="Kamera" Binding="{Binding CameraDisplayName}" Width="160"/>
                            <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="60"/>
                            <DataGridTextColumn Header="Powód" Binding="{Binding Reason}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ====== ANOMALIE ====== -->
            <TabItem Header="⚠ Anomalie">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap"
                               Foreground="{StaticResource TextDim}" FontSize="11"
                               Text="Detekcja odstępstw od wzorca: dla każdej kamery × godziny dnia liczymy 'normalny' obraz na podstawie ostatnich 7 dni. Klatka która znacząco różni się od średniej → anomalia."/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="🔄 Przebuduj baseline (z 7 dni)" Padding="10,4"
                                Background="{StaticResource Accent}" Foreground="White" BorderThickness="0"
                                Click="RebuildBaseline_Click" x:Name="RebuildBtn"/>
                        <Button Content="🔄 Odśwież listę" Padding="10,4" Margin="6,0,0,0"
                                Background="Transparent" Foreground="{StaticResource Text}"
                                BorderBrush="{StaticResource Border}" BorderThickness="1"
                                Click="RefreshAnomalies_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="AnomaliesGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Czas" Binding="{Binding TimeLabel}" Width="140"/>
                            <DataGridTextColumn Header="Kamera" Binding="{Binding CameraDisplayName}" Width="200"/>
                            <DataGridTextColumn Header="Dystans (im wyższy, tym dziwniejsze)" Binding="{Binding DistanceLabel}" Width="240"/>
                            <DataGridTextColumn Header="Plik" Binding="{Binding FilePath}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ====== JAKOŚĆ (Feedback statystyki) ====== -->
            <TabItem Header="📊 Jakość">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap"
                               Foreground="{StaticResource TextDim}" FontSize="11"
                               Text="Statystyki ground truth (👍/👎 z wyników wyszukiwania). Im więcej feedbacku, tym lepsza miara dokładności."/>

                    <Border Grid.Row="1" Background="{StaticResource Surface2}"
                            BorderBrush="{StaticResource Border}" BorderThickness="1"
                            CornerRadius="4" Padding="14" Margin="0,0,0,8">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Łącznie ocen" FontSize="11" Foreground="{StaticResource TextDim}"/>
                                    <TextBlock x:Name="StatTotalText" FontSize="22" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="👍 trafne" FontSize="11" Foreground="{StaticResource TextDim}"/>
                                    <TextBlock x:Name="StatCorrectText" FontSize="22" FontWeight="Bold" Foreground="#16A34A"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="👎 nietrafne" FontSize="11" Foreground="{StaticResource TextDim}"/>
                                    <TextBlock x:Name="StatIncorrectText" FontSize="22" FontWeight="Bold" Foreground="#DC2626"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="Precision" FontSize="11" Foreground="{StaticResource TextDim}"/>
                                    <TextBlock x:Name="StatPrecisionText" FontSize="22" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                            <Button x:Name="RefreshFeedbackBtn" Content="🔄 Odśwież statystyki"
                                    Margin="0,12,0,0" Padding="12,4" HorizontalAlignment="Left"
                                    Background="Transparent" Foreground="{StaticResource Text}"
                                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                                    Click="RefreshFeedback_Click"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="FeedbackGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Zapytanie" Binding="{Binding Query}" Width="*"/>
                            <DataGridTextColumn Header="Łącznie" Binding="{Binding Total}" Width="100"/>
                            <DataGridTextColumn Header="Trafne" Binding="{Binding Correct}" Width="100"/>
                            <DataGridTextColumn Header="Precision" Binding="{Binding PrecisionLabel}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ====== BRIEFY ====== -->
            <TabItem Header="📰 Briefy">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="3*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="GenerateBriefBtn" Content="✨ Generuj brief dnia (TERAZ)"
                                Padding="14,6" Background="{StaticResource Accent}" Foreground="White"
                                BorderThickness="0" FontWeight="Bold" Click="GenerateBrief_Click"/>
                        <Button Content="🔄 Odśwież" Padding="10,4" Margin="6,0,0,0"
                                Background="Transparent" Foreground="{StaticResource Text}"
                                BorderBrush="{StaticResource Border}" BorderThickness="1"
                                Click="RefreshBriefs_Click"/>
                        <TextBlock x:Name="BriefStatus" Margin="14,0,0,0" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextDim}" FontSize="11"/>
                    </StackPanel>

                    <DataGrid x:Name="BriefsGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              SelectionMode="Single" SelectionChanged="BriefsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dzień" Binding="{Binding Day}" Width="120"/>
                            <DataGridTextColumn Header="Wygenerowany" Binding="{Binding CreatedLabel}" Width="160"/>
                            <DataGridTextColumn Header="Koszt" Binding="{Binding CostLabel}" Width="80"/>
                            <DataGridTextColumn Header="Próbka" Binding="{Binding SampleSize}" Width="80"/>
                            <DataGridTextColumn Header="Pierwsze zdanie" Binding="{Binding Preview}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Margin="0,8,0,0" Background="{StaticResource Surface2}"
                            BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="14">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="BriefDetailText" TextWrapping="Wrap" FontSize="13"
                                       Text="Wybierz brief z listy żeby zobaczyć pełną treść."/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
