<Window x:Class="Kalendarz1.CentrumNagranAI.Views.NvrEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Konfiguracja NVR-ów i kamer"
        Width="1100" Height="780"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">

    <Window.Resources>
        <SolidColorBrush x:Key="Surface" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Surface2" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="Border" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="Text" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextDim" Color="#64748B"/>
        <SolidColorBrush x:Key="Accent" Color="#DC2626"/>
        <SolidColorBrush x:Key="Ok" Color="#16A34A"/>
        <SolidColorBrush x:Key="Danger" Color="#DC2626"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🎥 Konfiguracja NVR-ów i kamer"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="11"
                   Foreground="{StaticResource TextDim}" Margin="0,0,0,16"
                   Text="Dodawaj/edytuj NVR-y. Hasła zapisywane w secrets.json (POZA repo Git). Przed zapisaniem - 'Test połączenia' sprawdza czy NVR odpowiada przez ONVIF + RTSP."/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEWA: lista NVR -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListBox x:Name="NvrList" Grid.Row="0" SelectionChanged="NvrList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" Margin="2">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                                               Foreground="{StaticResource Text}"/>
                                    <TextBlock Foreground="{StaticResource TextDim}" FontSize="11">
                                        <Run Text="{Binding Host, Mode=OneWay}"/>
                                        <Run Text=":"/>
                                        <Run Text="{Binding RtspPort, Mode=OneWay}"/>
                                        <Run Text=" • "/>
                                        <Run Text="{Binding ChannelsLabel, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="➕ Nowy NVR" Padding="10,4"
                            Background="{StaticResource Ok}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="NewNvr_Click"/>
                    <Button Content="🗑️ Usuń" Padding="10,4" Margin="6,0,0,0"
                            Background="{StaticResource Danger}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="DeleteNvr_Click"/>
                </StackPanel>
            </Grid>

            <!-- PRAWA: edytor wybranego NVR -->
            <Border Grid.Column="1" Background="{StaticResource Surface2}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                    CornerRadius="4" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="EditorPanel" IsEnabled="False">

                        <TextBlock Text="Nazwa (np. NVR2-Zewnętrzny):" FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,0,0,3"/>
                        <TextBox x:Name="NameBox" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Host (IP):" FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,0,0,3"/>
                                <TextBox x:Name="HostBox"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Port RTSP:" FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,0,0,3"/>
                                <TextBox x:Name="PortBox"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Login:" FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,0,0,3"/>
                                <TextBox x:Name="UserBox"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Hasło:" FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,0,0,3"/>
                                <PasswordBox x:Name="PasswordBox"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Kanały (np. 1,2,3,4 lub 1-4 lub 1,5,8-12):"
                                   FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,0,0,3"/>
                        <TextBox x:Name="ChannelsBox" Margin="0,0,0,12"/>

                        <TextBlock Text="Domyślny stream:" FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,0,0,3"/>
                        <ComboBox x:Name="StreamCombo" Margin="0,0,0,12" Padding="6,4" Background="#0F172A" Foreground="{StaticResource Text}">
                            <ComboBoxItem Content="0 - main (zawsze dostępny, ~2-4 Mbps)" IsSelected="True"/>
                            <ComboBoxItem Content="1 - sub (lżejszy, ~256 kbps; nie każdy kanał ma)"/>
                        </ComboBox>

                        <Border Background="#0F172A" BorderBrush="{StaticResource Border}" BorderThickness="1"
                                CornerRadius="4" Padding="10" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Test połączenia" FontWeight="Bold" Margin="0,0,0,6"/>
                                <Button x:Name="TestBtn" Content="🔌 Sprawdź NVR (ONVIF + 1 klatka)"
                                        Padding="14,8" HorizontalAlignment="Left"
                                        Background="{StaticResource Accent}" Foreground="White"
                                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                        Click="Test_Click"/>
                                <TextBlock x:Name="TestStatus" Margin="0,8,0,0" TextWrapping="Wrap" FontSize="11"
                                           Foreground="{StaticResource TextDim}"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="ApplyBtn" Content="💾 Zastosuj zmiany w tym NVR"
                                Margin="0,16,0,0" Padding="14,8" HorizontalAlignment="Left"
                                Background="{StaticResource Ok}" Foreground="White"
                                FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                Click="Apply_Click"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="BottomStatus" Grid.Column="0" VerticalAlignment="Center"
                       Foreground="{StaticResource TextDim}" FontSize="11"/>
            <Button Grid.Column="1" Content="Anuluj" Padding="14,8" Margin="0,0,8,0"
                    Background="Transparent" Foreground="{StaticResource TextDim}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                    Click="Cancel_Click"/>
            <Button Grid.Column="2" Content="💾 Zapisz wszystko"
                    Padding="14,8"
                    Background="{StaticResource Accent}" Foreground="White"
                    FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                    Click="SaveAll_Click"/>
        </Grid>
    </Grid>
</Window>
