<Window x:Class="Kalendarz1.Reklamacje.UzupelnijReklamacjeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uzupelnij reklamacje"
        Width="1100" Height="820"
        MinWidth="850" MinHeight="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F6FA"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#95A5A6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Padding="20,12" Background="#E67E22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txtHeader" Text="UZUPELNIJ REKLAMACJE #0"
                               FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="txtSubheader" Text=""
                               FontSize="11" Foreground="#FDEBD0" Margin="0,2,0,0"/>
                </StackPanel>
                <!-- Avatar handlowca -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Grid Width="38" Height="38" HorizontalAlignment="Center">
                        <Border x:Name="avatarHandlowiec" Width="38" Height="38" CornerRadius="19"
                                Background="#FDEBD0">
                            <TextBlock x:Name="txtAvatarHandlowiec" Text="?"
                                       Foreground="#E67E22" FontWeight="Bold" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Ellipse x:Name="ellipseAvatarHandlowiec" Width="38" Height="38" Visibility="Collapsed">
                            <Ellipse.Fill>
                                <ImageBrush x:Name="imgBrushAvatarHandlowiec" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                    <TextBlock x:Name="txtHandlowiecNazwa" Text="" FontSize="8.5"
                               Foreground="#FDEBD0" HorizontalAlignment="Center" Margin="0,2,0,0"
                               MaxWidth="100" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== INFO BAR ===== -->
        <Border Grid.Row="1" Background="White" Padding="16,10" BorderThickness="0,0,0,1" BorderBrush="#E8E8E8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Avatar kontrahenta -->
                <Grid Grid.Column="0" Width="40" Height="40" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Border x:Name="avatarKontrahent" Width="40" Height="40" CornerRadius="20" Background="#3498DB">
                        <TextBlock x:Name="txtAvatarKontrahent" Text="?"
                                   Foreground="White" FontWeight="Bold" FontSize="15"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- Kontrahent -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock x:Name="txtKontrahent" FontSize="13" FontWeight="SemiBold"
                               Foreground="#2C3E50" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="txtNrDok" FontSize="10.5" Foreground="#7F8C8D"/>
                </StackPanel>

                <!-- Separator -->
                <Border Grid.Column="2" Width="1" Background="#E8E8E8" Margin="0,4"/>

                <!-- Typ -->
                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="TYP" FontSize="8" Foreground="#BDC3C7" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtTyp" FontSize="11" Foreground="#2C3E50"/>
                </StackPanel>

                <!-- Status -->
                <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="STATUS" FontSize="8" Foreground="#BDC3C7" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtStatus" FontSize="11" Foreground="#2C3E50" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Separator -->
                <Border Grid.Column="5" Width="1" Background="#E8E8E8" Margin="0,4"/>

                <!-- Waga / Wartosc -->
                <StackPanel Grid.Column="6" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock FontSize="10.5" Foreground="#2C3E50">
                        <Run x:Name="txtWaga" Text="0,00 kg" FontWeight="SemiBold"/>
                        <Run Text="  |  " Foreground="#BDC3C7"/>
                        <Run x:Name="txtWartosc" Text="0,00 zl" FontWeight="Bold" Foreground="#E67E22"/>
                    </TextBlock>
                    <TextBlock FontSize="9" Foreground="#95A5A6">
                        <Run x:Name="txtDataZgloszenia" Text=""/>
                        <Run Text="  "/>
                        <Run x:Name="txtDniOdZgloszenia" Text="" Foreground="#E67E22"/>
                    </TextBlock>
                </StackPanel>

                <!-- Priorytet -->
                <Border Grid.Column="7" Margin="16,0,0,0" VerticalAlignment="Center"
                        Background="#FAFAFA" CornerRadius="5" BorderBrush="#E8E8E8" BorderThickness="1">
                    <ComboBox x:Name="cmbPriorytet" FontSize="12" Padding="6,4" BorderThickness="0"
                              MinWidth="120">
                        <ComboBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#4caf50" Margin="0,0,6,0"/>
                                <TextBlock Text="Niski"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem IsSelected="True">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#2196f3" Margin="0,0,6,0"/>
                                <TextBlock Text="Normalny"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#ff9800" Margin="0,0,6,0"/>
                                <TextBlock Text="Wysoki"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#f44336" Margin="0,0,6,0"/>
                                <TextBlock Text="Krytyczny"/>
                            </StackPanel>
                        </ComboBoxItem>
                    </ComboBox>
                </Border>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="2" Margin="16,12,16,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOWARY -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Style="{StaticResource SectionLabel}">
                    <Run Text="TOWARY W REKLAMACJI"/>
                    <Run x:Name="txtTowaryCount" Text="" FontWeight="Normal" Foreground="#BDC3C7"/>
                </TextBlock>
                <Border Background="White" CornerRadius="6" BorderBrush="#E8E8E8" BorderThickness="1" Padding="1">
                    <DataGrid x:Name="dgTowary" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="0" Background="Transparent"
                              RowBackground="White" AlternatingRowBackground="#FAFBFC"
                              HorizontalGridLinesBrush="#F0F0F0"
                              CanUserSortColumns="True" CanUserResizeColumns="True"
                              MinHeight="60" MaxHeight="280"
                              FontSize="11" RowHeight="26"
                              SelectionMode="Single" SelectionUnit="FullRow">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8F9FA"/>
                                <Setter Property="Foreground" Value="#7F8C8D"/>
                                <Setter Property="FontSize" Value="9.5"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="BorderBrush" Value="#E8E8E8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="110"/>
                            <DataGridTextColumn Header="Nazwa towaru" Binding="{Binding Nazwa}" Width="*"/>
                            <DataGridTextColumn Header="Waga [kg]" Binding="{Binding Waga, StringFormat={}{0:#\,##0.00}}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0,0,6,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Cena [zl/kg]" Binding="{Binding Cena, StringFormat={}{0:#\,##0.00}}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0,0,6,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Wartosc [zl]" Binding="{Binding Wartosc, StringFormat={}{0:#\,##0.00}}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0,0,6,0"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Przyczyna" Binding="{Binding PrzyczynaReklamacji}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
                <!-- Podsumowanie -->
                <Border x:Name="borderPodsumowanie" Background="#FFF8E1" CornerRadius="0,0,6,6"
                        BorderBrush="#FFE082" BorderThickness="1,0,1,1" Padding="10,5" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="txtPodsumowaniePozycji" FontSize="10.5" Foreground="#795548"
                                   VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <TextBlock FontSize="10.5" Foreground="#795548" VerticalAlignment="Center">
                            <Run Text="Suma: "/>
                            <Run x:Name="txtSumaKgTowarow" Text="" FontWeight="Bold" Foreground="#E65100"/>
                            <Run Text="   |   "/>
                            <Run x:Name="txtSumaWartoscTowarow" Text="" FontWeight="Bold" Foreground="#E65100"/>
                            <Run Text="   |   sr. "/>
                            <Run x:Name="txtSredniaCena" Text="" FontWeight="Bold" Foreground="#E65100"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- OPIS + ZDJECIA -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Opis -->
                <DockPanel Grid.Column="0">
                    <TextBlock DockPanel.Dock="Top" Text="OPIS - CO BYLO NIE TAK?" Style="{StaticResource SectionLabel}"/>
                    <Border Background="White" CornerRadius="6" BorderBrush="#E8E8E8" BorderThickness="1">
                        <TextBox x:Name="txtOpis" AcceptsReturn="True" TextWrapping="Wrap"
                                 FontSize="12" Padding="10,8"
                                 BorderThickness="0" VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </DockPanel>

                <!-- Zdjecia -->
                <DockPanel Grid.Column="2">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="ZDJECIA" Style="{StaticResource SectionLabel}" Margin="0"/>
                        <TextBlock Text="  (przeciagnij lub kliknij Dodaj)" FontSize="9" Foreground="#BDC3C7"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Background="White" CornerRadius="6" BorderBrush="#E8E8E8" BorderThickness="1"
                            Padding="8"
                            AllowDrop="True" Drop="ZdjeciaPanel_Drop"
                            DragEnter="ZdjeciaPanel_DragEnter" DragLeave="ZdjeciaPanel_DragLeave"
                            DragOver="ZdjeciaPanel_DragOver">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Lista -->
                            <Border Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                                    Margin="0,0,0,6" ClipToBounds="True" MaxHeight="90">
                                <ListBox x:Name="listZdjecia" BorderThickness="0" Background="Transparent"
                                         SelectionChanged="ListZdjecia_SelectionChanged" MinHeight="36"/>
                            </Border>

                            <!-- Podglad -->
                            <Border Grid.Row="1" BorderBrush="#E67E22" BorderThickness="1" CornerRadius="4"
                                    Background="#FAFAFA" ClipToBounds="True" MinHeight="80">
                                <Grid>
                                    <Image x:Name="imgPodglad" Stretch="Uniform" Margin="4"/>
                                    <TextBlock x:Name="txtBrakZdjecia" Text="Brak zdjecia"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="10" Foreground="#BDC3C7" FontStyle="Italic"/>
                                </Grid>
                            </Border>

                            <!-- Drop overlay -->
                            <Border x:Name="dropOverlay" Grid.RowSpan="3" Background="#40E67E22" CornerRadius="4"
                                    BorderBrush="#E67E22" BorderThickness="2" Visibility="Collapsed"
                                    IsHitTestVisible="False">
                                <TextBlock Text="Upusc pliki tutaj" FontSize="13" FontWeight="SemiBold"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Przyciski -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="+ Dodaj" Padding="10,5" FontSize="10" Style="{StaticResource RoundBtn}"
                                        Click="BtnDodajZdjecia_Click" Background="#E67E22" Foreground="White"/>
                                <Button x:Name="btnUsunZdjecie" Content="- Usun" Padding="10,5" FontSize="10"
                                        Style="{StaticResource RoundBtn}" Click="BtnUsunZdjecie_Click"
                                        IsEnabled="False" Margin="6,0,0,0" Background="#95A5A6" Foreground="White"/>
                                <TextBlock x:Name="txtLicznikZdjec" Text="" FontSize="10" Foreground="#95A5A6"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DockPanel>
            </Grid>
        </Grid>

        <!-- ===== FOOTER ===== -->
        <Border Grid.Row="3" Padding="16,10" Background="#F0F0F5" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
            <Grid>
                <TextBlock x:Name="txtError" Foreground="#E74C3C" FontSize="11" VerticalAlignment="Center"
                           Visibility="Collapsed" TextWrapping="Wrap" MaxWidth="500"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Zapisz" Click="BtnZapisz_Click" Style="{StaticResource RoundBtn}"
                            Width="120" Height="34" FontSize="12" FontWeight="SemiBold"
                            Foreground="White" Background="#E67E22"/>
                    <Button Content="Anuluj" Click="BtnAnuluj_Click" Style="{StaticResource RoundBtn}"
                            Width="80" Height="34" FontSize="12" Foreground="White" Background="#95A5A6"
                            Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
