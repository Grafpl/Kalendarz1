<Window x:Class="Kalendarz1.Reklamacje.FormPanelReklamacjiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Panel Reklamacji - Zarzadzanie"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#ECF0F1"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- PRZYCISKI -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.15" BlurRadius="8"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C0392B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#A93226"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.15" BlurRadius="8"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#219A52"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoButton" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.15" BlurRadius="8"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button">
            <Setter Property="Background" Value="#F39C12"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.15" BlurRadius="8"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D68910"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- KARTA -->
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="0" Color="#000000" Opacity="0.08" BlurRadius="15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TEXTBOX -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#E74C3C"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DATAGRID -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#C0392B"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="12,8">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFEBEE"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#ECF0F1" Offset="0"/>
                <GradientStop Color="#E0E6E8" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>


            <!-- KOMPAKTOWY TOOLBAR — wszystko w jednej linii -->
            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- STATUS -->
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Status" FontSize="9" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="2,0,0,2"/>
                        <ComboBox x:Name="cmbStatus" Width="115" Height="30" FontSize="11" SelectionChanged="CmbStatus_SelectionChanged" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                            <ComboBoxItem Content="Zgloszona"/>
                            <ComboBoxItem Content="W analizie"/>
                            <ComboBoxItem Content="Zasadna"/>
                            <ComboBoxItem Content="Odrzucona"/>
                            <ComboBoxItem Content="Powiazana"/>
                            <ComboBoxItem Content="Zamknieta"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- TYP -->
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="Typ" FontSize="9" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="2,0,0,2"/>
                        <ComboBox x:Name="cmbTyp" Width="135" Height="30" FontSize="11" SelectionChanged="CmbTyp_SelectionChanged" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                            <ComboBoxItem Content="Jakosc produktu"/>
                            <ComboBoxItem Content="Ilosc / Brak towaru"/>
                            <ComboBoxItem Content="Uszkodzenie w transporcie"/>
                            <ComboBoxItem Content="Termin waznosci"/>
                            <ComboBoxItem Content="Niezgodnosc z zamowieniem"/>
                            <ComboBoxItem Content="Temperatura"/>
                            <ComboBoxItem Content="Ciala obce"/>
                            <ComboBoxItem Content="Faktura korygujaca"/>
                            <ComboBoxItem Content="Inne"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- PRIORYTET -->
                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                        <TextBlock Text="Priorytet" FontSize="9" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="2,0,0,2"/>
                        <ComboBox x:Name="cmbPriorytet" Width="100" Height="30" FontSize="11" SelectionChanged="CmbPriorytet_SelectionChanged" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                            <ComboBoxItem Content="Niski"/>
                            <ComboBoxItem Content="Normalny"/>
                            <ComboBoxItem Content="Wysoki"/>
                            <ComboBoxItem Content="Krytyczny"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- HANDLOWIEC -->
                    <StackPanel Grid.Column="3" Margin="0,0,8,0">
                        <TextBlock Text="Handlowiec" FontSize="9" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="2,0,0,2"/>
                        <ComboBox x:Name="cmbHandlowiec" Width="125" Height="30" FontSize="11" SelectionChanged="CmbHandlowiec_SelectionChanged"
                                  IsEditable="True" IsTextSearchEnabled="True" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Wszyscy" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- SZUKAJ -->
                    <StackPanel Grid.Column="4" Margin="0,0,8,0">
                        <TextBlock Text="Szukaj" FontSize="9" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="2,0,0,2"/>
                        <Border Background="White" CornerRadius="6" BorderBrush="#BDC3C7" BorderThickness="1" Padding="8,5" Height="30">
                            <Grid Width="240">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔍" FontSize="11" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#7F8C8D"/>
                                <TextBox x:Name="txtSzukaj" Grid.Column="1" BorderThickness="0" Background="Transparent"
                                         FontSize="11" VerticalAlignment="Center" TextChanged="TxtSzukaj_TextChanged"
                                         ToolTip="Szukaj po: numerze dokumentu, nazwie kontrahenta, opisie, typie reklamacji"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Pole zachowane dla kompatybilnosci kodu -->
                    <TextBlock Grid.Column="5" x:Name="txtSzukajPlaceholder" Visibility="Collapsed"/>
                    <TextBlock Grid.Column="5" x:Name="txtSzukajHint" Visibility="Collapsed"/>

                    <!-- STATYSTYKI MINI (DO AKCJI / PRZYJETE / ZAMKNIETE) -->
                    <Border Grid.Column="6" Background="#FDEDEC" CornerRadius="6" Padding="8,4" Margin="0,12,4,0" BorderBrush="#F5B7B1" BorderThickness="1" VerticalAlignment="Bottom" Height="30"
                            ToolTip="DO AKCJI">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="A:" FontSize="10" FontWeight="Bold" Foreground="#C0392B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="txtStatNowe" Text="0" FontSize="13" FontWeight="Bold" Foreground="#E74C3C" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="7" Background="#FFF8E1" CornerRadius="6" Padding="8,4" Margin="0,12,4,0" BorderBrush="#FFE082" BorderThickness="1" VerticalAlignment="Bottom" Height="30"
                            ToolTip="PRZYJETE">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="P:" FontSize="10" FontWeight="Bold" Foreground="#E67E22" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="txtStatWTrakcie" Text="0" FontSize="13" FontWeight="Bold" Foreground="#F39C12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="8" Background="#E8F5E9" CornerRadius="6" Padding="8,4" Margin="0,12,8,0" BorderBrush="#A5D6A7" BorderThickness="1" VerticalAlignment="Bottom" Height="30"
                            ToolTip="ZAMKNIETE">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Z:" FontSize="10" FontWeight="Bold" Foreground="#2E7D32" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="txtStatZaakceptowane" Text="0" FontSize="13" FontWeight="Bold" Foreground="#27AE60" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Razem -->
                    <Border Grid.Column="9" Background="#FFEBEE" CornerRadius="6" Padding="8,4" Margin="0,12,8,0" VerticalAlignment="Bottom" Height="30"
                            ToolTip="Lacznie wynik">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtLiczbaReklamacji" Text="0" FontSize="13" FontWeight="Bold" Foreground="#E74C3C" VerticalAlignment="Center"/>
                            <TextBlock Text=" rekl." FontSize="10" Foreground="#C62828" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- NOWA REKLAMACJA (split) -->
                    <Grid Grid.Column="10" Margin="0,12,6,0" VerticalAlignment="Bottom" Height="30">
                        <Button x:Name="btnNowaSplit" Click="BtnNowaSplit_Click"
                                Padding="12,4" FontSize="11" FontWeight="Bold"
                                Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"
                                ToolTip="Wybierz typ nowej reklamacji">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="+ NOWA" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Text=" ▾" FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center" Opacity="0.85"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#C0392B"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Popup x:Name="popupNowa" PlacementTarget="{Binding ElementName=btnNowaSplit}" Placement="Bottom"
                               StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="White" CornerRadius="8" BorderBrush="#E74C3C" BorderThickness="1" Padding="6">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="3" Color="#000000" Opacity="0.25" BlurRadius="14"/>
                                </Border.Effect>
                                <StackPanel Width="320">
                                    <Button Click="MenuNowa_DoFaktury_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="12,10" HorizontalContentAlignment="Left">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📄" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                        <StackPanel>
                                                            <TextBlock Text="Do istniejacej faktury" FontSize="13" FontWeight="Bold" Foreground="#2C3E50"/>
                                                            <TextBlock Text="Wybierz kontrahenta i jedna z jego faktur" FontSize="10.5" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#F8F9FA"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Click="MenuNowa_DoKorekty_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="12,10" HorizontalContentAlignment="Left">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="✏" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                        <StackPanel>
                                                            <TextBlock Text="Do istniejacej korekty" FontSize="13" FontWeight="Bold" Foreground="#2C3E50"/>
                                                            <TextBlock Text="Wybierz korekte z Symfonii (FKS / FKSB / FWK)" FontSize="10.5" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#F8F9FA"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Click="MenuNowa_BezFaktury_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="12,10" HorizontalContentAlignment="Left">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="❓" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                        <StackPanel>
                                                            <TextBlock Text="Bez faktury (jeszcze niewystawionej)" FontSize="13" FontWeight="Bold" Foreground="#2C3E50"/>
                                                            <TextBlock Text="Zglos prewencyjnie - faktura zostanie podpieta pozniej" FontSize="10.5" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#F8F9FA"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- EXCEL + STATYSTYKI + ODSWIEZ + admin -->
                    <StackPanel Grid.Column="11" Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Bottom">
                        <Button x:Name="btnExportExcel" Click="BtnExportExcel_Click" Padding="10,4" Margin="0,0,4,0" FontSize="11" Height="30"
                                Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Eksport Excel">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="Excel" FontSize="11" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#229954"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="btnStatystyki" Click="BtnStatystyki_Click" Padding="10,4" Margin="0,0,4,0" FontSize="11" Height="30"
                                Background="#9B59B6" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Statystyki reklamacji">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="Stat" FontSize="11" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#8E44AD"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Style="{StaticResource InfoButton}" Click="BtnOdswiez_Click" Padding="10,4" Margin="0,0,4,0" Height="30"
                                ToolTip="Odswiez liste reklamacji">
                            <TextBlock Text="↻" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="btnUstawieniaSync" Click="BtnUstawieniaSync_Click" Padding="8,4" Margin="0,0,2,0" FontSize="13" Height="30"
                                Background="#7F8C8D" Foreground="White" BorderThickness="0" Cursor="Hand" Visibility="Collapsed" ToolTip="Ustawienia sync (admin)">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="⚙" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#566573"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="btnDebugSync" Click="BtnDebugSync_Click" Padding="8,4" FontSize="13" Height="30"
                                Background="#7F8C8D" Foreground="White" BorderThickness="0" Cursor="Hand" Visibility="Collapsed" ToolTip="Debug sync (admin)">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="🐞" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#566573"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Stare przyciski - ukryte, kompatybilnosc kodu -->
                        <Button x:Name="btnNowaBezFaktury" Click="BtnNowaBezFaktury_Click" Visibility="Collapsed"/>
                        <Button x:Name="btnNowaReklamacja" Click="BtnNowaReklamacja_Click" Visibility="Collapsed"/>
                        <!-- Ukryte kontrolki dla kompatybilnosci kodu -->
                        <TextBlock x:Name="txtStatOdrzucone" Text="0" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtStatZamkniete" Text="0" Visibility="Collapsed"/>
                        <DatePicker x:Name="dpDataOd" Visibility="Collapsed" SelectedDateChanged="DpData_SelectedDateChanged"/>
                        <DatePicker x:Name="dpDataDo" Visibility="Collapsed" SelectedDateChanged="DpData_SelectedDateChanged"/>
                    </StackPanel>
                </Grid>
            </Border>


            <!-- TABELA REKLAMACJI -->
            <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Pasek zakladek workflow V2 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                        <Button x:Name="tabDoAkcji" Click="TabDoAkcji_Click" Cursor="Hand" BorderThickness="0" Padding="0"
                                Background="Transparent" Margin="0,0,10,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="tabBorder" Background="#E74C3C" CornerRadius="10" Padding="18,11">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="DO AKCJI" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                            <Border Background="#FFFFFF" CornerRadius="10" Padding="9,2" Margin="10,0,0,0">
                                                <TextBlock x:Name="txtCntDoAkcji" Text="0" FontSize="11" FontWeight="Bold" Foreground="#E74C3C"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="tabWToku" Click="TabWToku_Click" Cursor="Hand" BorderThickness="0" Padding="0"
                                Background="Transparent" Margin="0,0,10,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="tabBorder" Background="#ECEFF1" CornerRadius="10" Padding="18,11">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="PRZYJETE" FontSize="12" FontWeight="Bold" Foreground="#546E7A" VerticalAlignment="Center"/>
                                            <Border Background="#546E7A" CornerRadius="10" Padding="9,2" Margin="10,0,0,0">
                                                <TextBlock x:Name="txtCntWToku" Text="0" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="tabZamkniete" Click="TabZamkniete_Click" Cursor="Hand" BorderThickness="0" Padding="0"
                                Background="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="tabBorder" Background="#ECEFF1" CornerRadius="10" Padding="18,11">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="ZAMKNIETE" FontSize="12" FontWeight="Bold" Foreground="#546E7A" VerticalAlignment="Center"/>
                                            <Border Background="#546E7A" CornerRadius="10" Padding="9,2" Margin="10,0,0,0">
                                                <TextBlock x:Name="txtCntZamkniete" Text="0" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock x:Name="txtOpisZakladki" Text="Wymagaja akcji dzialu jakosci" FontSize="11.5" FontStyle="Italic"
                                   Foreground="#7F8C8D" VerticalAlignment="Center" Margin="20,0,0,0"/>
                    </StackPanel>

                    <!-- Tytul + Density toggle -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" x:Name="txtTytulListy" Text="Lista reklamacji" FontSize="13" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>

                        <!-- Density toggle -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Gestosc:" FontSize="9" FontWeight="SemiBold" Foreground="#7F8C8D" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Border CornerRadius="4" BorderBrush="#BDC3C7" BorderThickness="1" Padding="0">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="btnDensityCompact" Click="DensityCompact_Click" ToolTip="Kompaktowa (28px)" Padding="6,2" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <TextBlock Text="≡" FontSize="14" FontWeight="Bold" Foreground="#7F8C8D"/>
                                    </Button>
                                    <Button x:Name="btnDensityNormal" Click="DensityNormal_Click" ToolTip="Normalna (40px)" Padding="6,2" Background="#3498DB" BorderThickness="0" Cursor="Hand">
                                        <TextBlock Text="☰" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                    </Button>
                                    <Button x:Name="btnDensitySpacious" Click="DensitySpacious_Click" ToolTip="Wygodna (52px)" Padding="6,2" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <TextBlock Text="≣" FontSize="14" FontWeight="Bold" Foreground="#7F8C8D"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2" BorderBrush="#E74C3C" BorderThickness="2" CornerRadius="10" ClipToBounds="True">
                        <DataGrid x:Name="dgReklamacje"
                                  Style="{StaticResource ModernDataGrid}"
                                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                                  CellStyle="{StaticResource DataGridCellStyle}"
                                  SelectionChanged="DgReklamacje_SelectionChanged"
                                  MouseDoubleClick="DgReklamacje_MouseDoubleClick">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding JestZagrozonySLA}" Value="True">
                                            <Setter Property="Background" Value="#FFF8E1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding JestKrytycznySLA}" Value="True">
                                            <Setter Property="Background" Value="#FFEBEE"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data" Binding="{Binding DataZgloszenia, StringFormat=yyyy-MM-dd}" Width="90"/>
                                <DataGridTemplateColumn Header="Nr dokumentu" Width="SizeToCells" MinWidth="120" SortMemberPath="NumerDokumentu">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding NumerDokumentu}" FontWeight="SemiBold" FontSize="11"/>
                                                <TextBlock FontSize="9" Foreground="#F39C12" FontStyle="Italic"
                                                           Visibility="{Binding FakturaBazowaVis}">
                                                    <Run Text="↳ do: "/>
                                                    <Run Text="{Binding NumerFakturyOryginalnej, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Kontrahent" Binding="{Binding NazwaKontrahenta}" Width="130" MinWidth="100"/>
                                <!-- Zrodlo zgloszenia -->
                                <DataGridTemplateColumn Header="Zrodlo" Width="SizeToCells" MinWidth="100" SortMemberPath="ZrodloZgloszenia">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="10,3" HorizontalAlignment="Center"
                                                    Background="{Binding ZrodloBgBrush}" Margin="4,0">
                                                <TextBlock Text="{Binding ZrodloIkona}" FontWeight="SemiBold" FontSize="10.5"
                                                           Foreground="{Binding ZrodloFgBrush}"
                                                           HorizontalAlignment="Center"
                                                           ToolTip="{Binding ZrodloZgloszenia}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Handlowiec z avatarem -->
                                <DataGridTemplateColumn Header="Handlowiec" Width="155">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                        Visibility="{Binding HandlowiecVis}">
                                                <Grid Width="26" Height="26" Margin="0,0,6,0">
                                                    <Border Width="26" Height="26" CornerRadius="13"
                                                            Background="{Binding HandlowiecAvatarBrush}">
                                                        <TextBlock Text="{Binding HandlowiecInitials}" Foreground="White"
                                                                   FontWeight="Bold" FontSize="9"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Ellipse Width="26" Height="26" Visibility="{Binding HandlowiecAvatarPhotoVis}">
                                                        <Ellipse.Fill>
                                                            <ImageBrush ImageSource="{Binding HandlowiecAvatar}" Stretch="UniformToFill"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding Handlowiec}" VerticalAlignment="Center"
                                                           FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Typ" Binding="{Binding TypReklamacji}" Width="180"/>
                                <!-- Powiazanie -->
                                <DataGridTemplateColumn Header="Powiazanie" Width="95" SortMemberPath="MaPowiazanie">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="powBorder" CornerRadius="10" Padding="6,2" HorizontalAlignment="Center"
                                                    Background="#FFEBEE">
                                                <TextBlock x:Name="powText" Text="{Binding TekstPowiazania}" FontWeight="SemiBold" FontSize="9.5"
                                                           HorizontalAlignment="Center" Foreground="#C62828"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding MaPowiazanie}" Value="True">
                                                    <Setter TargetName="powBorder" Property="Background" Value="#E8F5E9"/>
                                                    <Setter TargetName="powText" Property="Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- DOWODY: 3 mini-zdjecia inline -->
                                <DataGridTemplateColumn Header="Dowody" Width="135" SortMemberPath="LiczbaZdjec">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ToolTip="{Binding ZdjeciaTooltip}">
                                                <!-- Brak zdjec — placeholder -->
                                                <Border Visibility="{Binding BrakZdjecVis}" Background="#FAFAFA" BorderBrush="#E0E5E8" BorderThickness="1" CornerRadius="4" Padding="6,3">
                                                    <TextBlock Text="bez zdjec" FontSize="9" Foreground="#95A5A6" FontStyle="Italic"/>
                                                </Border>
                                                <!-- Miniaturka 1 -->
                                                <Border Visibility="{Binding Miniatura1Vis}" Width="34" Height="34" CornerRadius="3" Margin="0,0,2,0" BorderBrush="#3498DB" BorderThickness="1.5" ClipToBounds="True">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding Miniatura1}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                                <!-- Miniaturka 2 -->
                                                <Border Visibility="{Binding Miniatura2Vis}" Width="34" Height="34" CornerRadius="3" Margin="0,0,2,0" BorderBrush="#BDC3C7" BorderThickness="1" ClipToBounds="True">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding Miniatura2}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                                <!-- Miniaturka 3 -->
                                                <Border Visibility="{Binding Miniatura3Vis}" Width="34" Height="34" CornerRadius="3" Margin="0,0,2,0" BorderBrush="#BDC3C7" BorderThickness="1" ClipToBounds="True">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding Miniatura3}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                                <!-- +N nadmiar -->
                                                <Border Visibility="{Binding WiecejZdjecVis}" Background="#34495E" CornerRadius="10" Padding="5,2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding WiecejZdjecText}" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Kg" Binding="{Binding SumaKg, StringFormat=N2}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Status" Width="130" SortMemberPath="StatusV2">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="statusBorder" CornerRadius="10" Padding="10,4" HorizontalAlignment="Center" Background="#ECEFF1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock x:Name="statusText" Text="{Binding StatusV2Etykieta}" FontWeight="Bold" FontSize="10" Foreground="#546E7A" VerticalAlignment="Center"/>
                                                    <Ellipse Width="8" Height="8" Margin="6,0,0,0" Fill="{Binding PriorytetKropkaKolor}" VerticalAlignment="Center" ToolTip="{Binding PriorytetTooltip}"/>
                                                </StackPanel>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding StatusV2}" Value="ZGLOSZONA">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#FDEDEC"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#C0392B"/>
                                                </DataTrigger>
                                                <!-- Oczekuje = ZGLOSZONA + WymagaUzupelnienia (fioletowo-pomaranczowy) -->
                                                <DataTrigger Binding="{Binding StatusV2Etykieta}" Value="Oczekuje">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#FFE0B2"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#E65100"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusV2}" Value="W_ANALIZIE">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#FFF8E1"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#E67E22"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusV2}" Value="ZASADNA">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#E8F5E9"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusV2}" Value="ODRZUCONA">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#FFEBEE"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#C62828"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusV2}" Value="POWIAZANA">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#F3E5F5"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#7B1FA2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusV2}" Value="ZAMKNIETA">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#ECEFF1"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#546E7A"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- ZGLASZAJACY -->
                                <DataGridTemplateColumn Header="Zglaszajacy" Width="135">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Grid Width="24" Height="24" Margin="0,0,5,0">
                                                    <Border Width="24" Height="24" CornerRadius="12" Background="{Binding ZglaszajacyAvatarBrush}">
                                                        <TextBlock Text="{Binding ZglaszajacyInitials}" Foreground="White" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Ellipse Width="24" Height="24" Visibility="{Binding ZglaszajacyAvatarPhotoVis}">
                                                        <Ellipse.Fill><ImageBrush ImageSource="{Binding ZglaszajacyAvatar}" Stretch="UniformToFill"/></Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding Zglaszajacy}" VerticalAlignment="Center" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- ROZPATRUJE -->
                                <DataGridTemplateColumn Header="Rozpatruje" Width="135">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Visibility="{Binding RozpatrujacyVis}">
                                                <Grid Width="24" Height="24" Margin="0,0,5,0">
                                                    <Border Width="24" Height="24" CornerRadius="12" Background="{Binding RozpatrujacyAvatarBrush}">
                                                        <TextBlock Text="{Binding RozpatrujacyInitials}" Foreground="White" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Ellipse Width="24" Height="24" Visibility="{Binding RozpatrujacyAvatarPhotoVis}">
                                                        <Ellipse.Fill><ImageBrush ImageSource="{Binding RozpatrujacyAvatar}" Stretch="UniformToFill"/></Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding OsobaRozpatrujaca}" VerticalAlignment="Center" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- ZAKONCZYL -->
                                <DataGridTemplateColumn Header="Zakonczyl" Width="155" SortMemberPath="UserZakonczenia">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Visibility="{Binding ZakonczylVis}" ToolTip="{Binding ZakonczylTooltip}">
                                                <Grid Width="24" Height="24" Margin="0,0,5,0">
                                                    <Border Width="24" Height="24" CornerRadius="12" Background="{Binding ZakonczylAvatarBrush}">
                                                        <TextBlock Text="{Binding ZakonczylInitials}" Foreground="White" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Ellipse Width="24" Height="24" Visibility="{Binding ZakonczylAvatarPhotoVis}">
                                                        <Ellipse.Fill><ImageBrush ImageSource="{Binding ZakonczylAvatar}" Stretch="UniformToFill"/></Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding UserZakonczenia}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding ZakonczylDecyzja}" FontSize="9" Foreground="#7F8C8D" FontStyle="Italic"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Szczegoly reklamacji" Click="BtnSzczegoly_Click" FontWeight="SemiBold"/>
                                    <MenuItem Header="Zmien status" Click="BtnZmienStatus_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Eksportuj do Excel" Click="BtnExportExcel_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <!-- BULK ACTION BAR - widoczny gdy zaznaczono N>0 wierszy checkboxem -->
            <Border x:Name="bulkActionBar" Grid.Row="2" Visibility="Collapsed"
                    Background="#34495E" CornerRadius="10" Padding="14,8" Margin="6,0,6,4">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.3" BlurRadius="10"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#3498DB" CornerRadius="12" Padding="8,2" Margin="0,0,8,0">
                            <TextBlock x:Name="txtBulkCount" Text="0" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <TextBlock Text="zaznaczonych reklamacji" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Click="BulkExport_Click" Padding="10,5" Margin="0,0,6,0" FontSize="11" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Eksportuj zaznaczone do Excel">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="📊 Eksport" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Click="BulkZamknij_Click" Padding="10,5" Margin="0,0,6,0" FontSize="11" Background="#546E7A" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Zamknij zaznaczone reklamacje">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="🏁 Zamknij wszystkie" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Click="BulkPriorytet_Click" Padding="10,5" Margin="0,0,6,0" FontSize="11" Background="#F39C12" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Zmien priorytet zaznaczonych">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="⚡ Priorytet" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Click="BulkOdznacz_Click" Padding="10,5" FontSize="11" Background="Transparent" BorderBrush="White" BorderThickness="1" Foreground="White" Cursor="Hand" ToolTip="Odznacz wszystkie">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="✕ Odznacz" FontSize="11" Foreground="White"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- STOPKA Z PRZYCISKAMI - PANEL HANDLOWCA + PANEL JAKOSCI -->
            <Border Grid.Row="3" Style="{StaticResource CardPanel}" Padding="16,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Informacje o zaznaczeniu -->
                    <TextBlock Grid.Row="0" x:Name="txtZaznaczenie" Text="Wybierz reklamacje z listy"
                               FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,8"/>

                    <!-- Dwa panele obok siebie -->
                    <Grid Grid.Row="1" x:Name="paneleAkcji">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ============ PANEL HANDLOWCA ============ -->
                        <Border Grid.Column="0" Background="#EBF5FB" CornerRadius="10" Padding="12,10" BorderBrush="#3498DB" BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2,0,0,8">
                                    <Border Background="#3498DB" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                        <TextBlock Text="PANEL HANDLOWCA" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="podglad zgloszenia + edycja danych" FontSize="10.5" FontStyle="Italic" Foreground="#5D6D7E" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="(dostepne dla wszystkich uzytkownikow)" FontSize="9" FontStyle="Italic" Foreground="#85929E" Margin="2,-4,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <!-- PODGLAD = otwórz okno szczegółów (do oglądania, zdjęć, historii) -->
                                    <Button x:Name="btnSzczegoly" Click="BtnSzczegoly_Click" IsEnabled="False" Margin="0,0,8,0"
                                            Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"
                                            Width="135" Height="50">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="PODGLAD - tylko zobacz" FontWeight="Bold" FontSize="13" Foreground="#2980B9" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Text="Otwiera szczegolowy widok zgloszenia: opis, towary, partie, ZDJECIA, HISTORIA zmian, komentarze. Niczego tu nie zmieniasz - tylko ogladasz."/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="👁" FontSize="14" Foreground="White" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="PODGLAD" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="zobacz wszystko" FontSize="9" Foreground="#D6EAF8" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#2980B9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- EDYTUJ = otwórz okno do dopisania/poprawy danych -->
                                    <Button x:Name="btnUzupelnij" Click="BtnUzupelnij_Click" IsEnabled="False" Margin="0,0,8,0"
                                            Background="#F39C12" Foreground="White" BorderThickness="0" Cursor="Hand"
                                            Width="135" Height="50">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="EDYTUJ DANE - dopisz / popraw" FontWeight="Bold" FontSize="13" Foreground="#D68910" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Text="Otwiera FORMULARZ EDYCJI - mozesz dopisac brakujace pola, dodac towary, dodac zdjecia. Uzywaj gdy zgloszenie nie ma jeszcze pelnych informacji (np. korekta z Symfonii bez opisu)."/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="✏" FontSize="14" Foreground="White" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="EDYTUJ DANE" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="popraw / dopisz" FontSize="9" Foreground="#FCEBC8" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#D68910"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Handlowiec: zglos pelna reklamacje do korekty z Symfonii -->
                                    <Button x:Name="btnZglosDoKorekty" Click="BtnZglosDoKorekty_Click"
                                            Visibility="Collapsed" Width="155" Height="50" Margin="0,0,8,0"
                                            Background="#1ABC9C" Foreground="White" BorderThickness="0" Cursor="Hand"
                                            ToolTip="Wypelnij szczegoly reklamacji dla tej korekty z Symfonii">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <TextBlock Text="Zglos do tej korekty" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="opisz powod korekty" FontSize="9" Foreground="#D1F2EB" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#16A085"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Separator pionowy -->
                        <Border Grid.Column="1" Width="1" Background="#D6DBDF" Margin="12,4,12,4"/>

                        <!-- ============ PANEL JAKOSCI ============ -->
                        <Border x:Name="panelJakosci" Grid.Column="2" Background="#F4ECF7" CornerRadius="10" Padding="12,10" BorderBrush="#9B59B6" BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2,0,0,8">
                                    <Border Background="#9B59B6" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                        <TextBlock Text="PANEL JAKOSCI" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="rozpatrywanie reklamacji — krok po kroku" FontSize="10.5" FontStyle="Italic" Foreground="#5B2C6F" VerticalAlignment="Center"/>
                                    <!-- Pole zachowane dla kompatybilnosci kodu, niewidoczne -->
                                    <Border x:Name="txtJakoscBrakUprawnien" Visibility="Collapsed" Width="0" Height="0"/>
                                </StackPanel>
                                <TextBlock Text="(dostepne dla wszystkich uzytkownikow)" FontSize="9" FontStyle="Italic" Foreground="#9580A8" Margin="2,-4,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <!-- KROK 1: PRZYJMIJ - jakosc zaczyna rozpatrywac, bez komentarza -->
                                    <Button x:Name="btnPrzekazAnaliza" Click="BtnPrzekazAnaliza_Click" IsEnabled="False"
                                            Width="115" Height="50" Margin="0,0,6,0"
                                            Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="KROK 1: PRZYJMIJ" FontWeight="Bold" FontSize="13" Foreground="#2980B9" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Text="Przyjmujesz nowe zgloszenie do rozpatrzenia. Status zmienia sie ze ZGLOSZONA na W ANALIZIE. Dopiero potem mozesz wybrac ZATWIERDZ lub ODRZUC."/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="①" FontSize="13" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="PRZYJMIJ" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="do rozpatrzenia" FontSize="9" Foreground="#DCEBF7" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#2980B9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- KROK 2a: ZATWIERDZ - z polami przyczyna + akcje naprawcze -->
                                    <Button x:Name="btnZasadna" Click="BtnZasadna_Click" IsEnabled="False"
                                            Width="115" Height="50" Margin="0,0,6,0"
                                            Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="KROK 2a: ZATWIERDZ" FontWeight="Bold" FontSize="13" Foreground="#229954" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Text="Reklamacja jest ZASADNA - klient ma racje. Otworzy sie okno gdzie wpisujesz: PRZYCZYNE GLOWNA (dlaczego doszlo do bledu) + AKCJE NAPRAWCZE (co robimy zeby sie nie powtorzylo)."/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="✓" FontSize="13" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="ZATWIERDZ" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="zasadna + naprawa" FontSize="9" Foreground="#D5F5E3" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#229954"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- KROK 2b: ODRZUC - z powodem -->
                                    <Button x:Name="btnNiezasadna" Click="BtnNiezasadna_Click" IsEnabled="False"
                                            Width="115" Height="50" Margin="0,0,6,0"
                                            Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="KROK 2b: ODRZUC" FontWeight="Bold" FontSize="13" Foreground="#C0392B" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Text="Reklamacja jest NIEZASADNA - klient nie ma racji. Wpisujesz POWOD odrzucenia, ktory jest pokazywany handlowcowi i klientowi."/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="✗" FontSize="13" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="ODRZUC" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="z podaniem powodu" FontSize="9" Foreground="#FADBD8" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#C0392B"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- KROK 3: POWIAZ Z KOREKTA -->
                                    <Button x:Name="btnPowiaz" Click="BtnPowiaz_Click" IsEnabled="False"
                                            Width="115" Height="50" Margin="0,0,6,0"
                                            Background="#8E44AD" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="KROK 3: POWIAZ z korekta" FontWeight="Bold" FontSize="13" Foreground="#7D3C98" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Text="Po wystawieniu w Symfonii faktury korygujacej (FKS/FKSB/FWK) powiazujesz ja z reklamacja. Aktywne tylko gdy zgloszenie jest typu KOREKTA i jeszcze nie polaczone."/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="🔗" FontSize="12" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="POWIAZ" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="z korekta Symfonii" FontSize="9" Foreground="#E8DAEF" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#7D3C98"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- KROK 4: ZAMKNIJ -->
                                    <Button x:Name="btnZamknij" Click="BtnZamknij_Click" IsEnabled="False"
                                            Width="115" Height="50" Margin="0,0,6,0"
                                            Background="#546E7A" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="KROK 4: ZAMKNIJ" FontWeight="Bold" FontSize="13" Foreground="#455A64" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Text="Sprawa zalatwiona - reklamacja przechodzi do ZAMKNIETE. Aktywne dopiero po POWIAZANIU z korekta lub po ZATWIERDZENIU/ODRZUCENIU."/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="🏁" FontSize="12" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="ZAMKNIJ" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="sprawa zalatwiona" FontSize="9" Foreground="#CFD8DC" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#455A64"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- USUN - tylko admin -->
                                    <Button x:Name="btnUsun" Click="BtnUsun_Click" IsEnabled="False"
                                            Visibility="Collapsed" Width="80" Height="50" Margin="0,0,0,0"
                                            Background="#922B21" Foreground="White" BorderThickness="0" Cursor="Hand"
                                            ToolTip="USUN reklamacje na stale (tylko admin UserID 11111)">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="8,6">
                                                    <StackPanel>
                                                        <TextBlock Text="🗑" FontSize="14" Foreground="White" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="USUN" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#7B241C"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <!-- Komunikat pomocniczy pod przyciskami -->
                                <TextBlock x:Name="txtJakoscBrakAkcji" Margin="2,6,0,0" Text="Wybierz reklamacje z listy aby zobaczyc co mozna z nia zrobic"
                                           FontSize="10.5" FontStyle="Italic" Foreground="#7D6608"/>
                            </StackPanel>
                        </Border>

                        <!-- Separator wizualny - kompatybilnosc kodu (nie uzywany w nowym layoucie) -->
                        <Border x:Name="sepWorkflow" Visibility="Collapsed" Width="0" Height="0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
