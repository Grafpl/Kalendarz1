<Window x:Class="Kalendarz1.Reklamacje.FormPanelReklamacjiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Panel Reklamacji - Zarzadzanie"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#ECF0F1"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- PRZYCISKI -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.15" BlurRadius="8"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C0392B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#A93226"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.15" BlurRadius="8"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#219A52"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoButton" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.15" BlurRadius="8"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button">
            <Setter Property="Background" Value="#F39C12"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.15" BlurRadius="8"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D68910"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- KARTA -->
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="0" Color="#000000" Opacity="0.08" BlurRadius="15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TEXTBOX -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#E74C3C"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DATAGRID -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#C0392B"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="12,8">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFEBEE"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#ECF0F1" Offset="0"/>
                <GradientStop Color="#E0E6E8" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- NAGLOWEK Z STATYSTYKAMI -->
            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Tytul i statystyki gorny wiersz -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo i tytul -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Background="#FFEBEE" CornerRadius="10" Padding="12,8" Margin="0,0,15,0">
                                <TextBlock Text="!" FontSize="24" FontWeight="Bold" Foreground="#E74C3C"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="PANEL REKLAMACJI" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
                                <TextBlock Text="Zarzadzanie reklamacjami - dla handlowcow i dzialu jakosci" FontSize="11" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Statystyki statusow -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Background="#E3F2FD" CornerRadius="8" Padding="15,8" Margin="5,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="12" Height="12" Fill="#3498DB" Margin="0,0,8,0"/>
                                    <TextBlock Text="Nowe: " FontSize="12" Foreground="#1976D2" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtStatNowe" Text="0" FontSize="16" FontWeight="Bold" Foreground="#3498DB" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FFF3E0" CornerRadius="8" Padding="15,8" Margin="5,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="12" Height="12" Fill="#F39C12" Margin="0,0,8,0"/>
                                    <TextBlock Text="Przyjete: " FontSize="12" Foreground="#EF6C00" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtStatWTrakcie" Text="0" FontSize="16" FontWeight="Bold" Foreground="#F39C12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#E8F5E9" CornerRadius="8" Padding="15,8" Margin="5,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="12" Height="12" Fill="#27AE60" Margin="0,0,8,0"/>
                                    <TextBlock Text="Zaakceptowane: " FontSize="12" Foreground="#2E7D32" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtStatZaakceptowane" Text="0" FontSize="16" FontWeight="Bold" Foreground="#27AE60" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FFEBEE" CornerRadius="8" Padding="15,8" Margin="5,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="12" Height="12" Fill="#E74C3C" Margin="0,0,8,0"/>
                                    <TextBlock Text="Odrzucone: " FontSize="12" Foreground="#C62828" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtStatOdrzucone" Text="0" FontSize="16" FontWeight="Bold" Foreground="#E74C3C" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#ECEFF1" CornerRadius="8" Padding="15,8" Margin="5,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="12" Height="12" Fill="#95A5A6" Margin="0,0,8,0"/>
                                    <TextBlock Text="Zamkniete: " FontSize="12" Foreground="#546E7A" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtStatZamkniete" Text="0" FontSize="16" FontWeight="Bold" Foreground="#95A5A6" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Przycisk odswiez -->
                        <Button Grid.Column="2" Style="{StaticResource InfoButton}" Click="BtnOdswiez_Click" Padding="20,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Odswiez" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Filtry -->
                    <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" Padding="12,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Filtr statusu -->
                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,15,0">
                                <TextBlock Text="Status:" FontSize="10" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                <ComboBox x:Name="cmbStatus" Width="130" FontSize="11" SelectionChanged="CmbStatus_SelectionChanged">
                                    <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                                    <ComboBoxItem Content="Nowa"/>
                                    <ComboBoxItem Content="Przyjeta"/>
                                    <ComboBoxItem Content="Zaakceptowana"/>
                                    <ComboBoxItem Content="Odrzucona"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Filtr typu -->
                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,15,0">
                                <TextBlock Text="Typ:" FontSize="10" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                <ComboBox x:Name="cmbTyp" Width="150" FontSize="11" SelectionChanged="CmbTyp_SelectionChanged">
                                    <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                                    <ComboBoxItem Content="Jakosc produktu"/>
                                    <ComboBoxItem Content="Ilosc / Brak towaru"/>
                                    <ComboBoxItem Content="Uszkodzenie w transporcie"/>
                                    <ComboBoxItem Content="Termin waznosci"/>
                                    <ComboBoxItem Content="Niezgodnosc z zamowieniem"/>
                                    <ComboBoxItem Content="Temperatura"/>
                                    <ComboBoxItem Content="Ciala obce"/>
                                    <ComboBoxItem Content="Faktura korygujaca"/>
                                    <ComboBoxItem Content="Inne"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Filtr priorytetu -->
                            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,15,0">
                                <TextBlock Text="Priorytet:" FontSize="10" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                <ComboBox x:Name="cmbPriorytet" Width="110" FontSize="11" SelectionChanged="CmbPriorytet_SelectionChanged">
                                    <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                                    <ComboBoxItem Content="Niski"/>
                                    <ComboBoxItem Content="Normalny"/>
                                    <ComboBoxItem Content="Wysoki"/>
                                    <ComboBoxItem Content="Krytyczny"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Filtr handlowca -->
                            <StackPanel Grid.Column="3" Grid.Row="0" Margin="0,0,15,0">
                                <TextBlock Text="Handlowiec:" FontSize="10" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                <ComboBox x:Name="cmbHandlowiec" Width="140" FontSize="11" SelectionChanged="CmbHandlowiec_SelectionChanged"
                                          IsEditable="True" IsTextSearchEnabled="True">
                                    <ComboBoxItem Content="Wszyscy" IsSelected="True"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Data od (ukryte - pokazujemy wszystkie) -->
                            <StackPanel Grid.Column="4" Grid.Row="0" Margin="0,0,10,0" Visibility="Collapsed">
                                <DatePicker x:Name="dpDataOd" Width="120" FontSize="11" SelectedDateChanged="DpData_SelectedDateChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="5" Grid.Row="0" Margin="0,0,15,0" Visibility="Collapsed">
                                <DatePicker x:Name="dpDataDo" Width="120" FontSize="11" SelectedDateChanged="DpData_SelectedDateChanged"/>
                            </StackPanel>

                            <!-- Wyszukiwanie -->
                            <StackPanel Grid.Column="6" Grid.Row="0" Margin="0,0,15,0">
                                <TextBlock Text="Szukaj:" FontSize="10" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                <Border Background="White" CornerRadius="6" BorderBrush="#BDC3C7" BorderThickness="1" Padding="8,6">
                                    <Grid Width="180">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Szukaj..." FontSize="11" Foreground="#BDC3C7" Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        <TextBox x:Name="txtSzukaj" Grid.Column="1" BorderThickness="0" Background="Transparent"
                                                 FontSize="11" VerticalAlignment="Center" TextChanged="TxtSzukaj_TextChanged"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- Przyciski eksportu -->
                            <StackPanel Grid.Column="7" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,15,0">
                                <Button x:Name="btnNowaBezFaktury" Content="Bez faktury" Click="BtnNowaBezFaktury_Click"
                                        Padding="14,8" Margin="0,0,10,0" FontSize="11" FontWeight="Bold"
                                        Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        ToolTip="Zgloszenie reklamacji bez wymogu faktury (dla handlowca/kierowcy/klienta)">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#2980B9"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button x:Name="btnNowaReklamacja" Content="+ Nowa reklamacja" Click="BtnNowaReklamacja_Click"
                                        Padding="14,8" Margin="0,0,10,0" FontSize="11" FontWeight="Bold"
                                        Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        ToolTip="Dodaj nowa reklamacje - wybierz fakture sprzedazy">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#C0392B"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button x:Name="btnExportExcel" Content="Eksport Excel" Click="BtnExportExcel_Click"
                                        Padding="12,8" Margin="0,0,10,0" FontSize="11"
                                        Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button x:Name="btnStatystyki" Content="Statystyki" Click="BtnStatystyki_Click"
                                        Padding="12,8" FontSize="11"
                                        Background="#9B59B6" Foreground="White" BorderThickness="0" Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button x:Name="btnUstawieniaSync" Content="Ustawienia sync" Click="BtnUstawieniaSync_Click"
                                        Padding="12,8" Margin="10,0,0,0" FontSize="11"
                                        Background="#8E44AD" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        Visibility="Collapsed">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button x:Name="btnDebugSync" Content="Debug sync" Click="BtnDebugSync_Click"
                                        Padding="12,8" Margin="10,0,0,0" FontSize="11"
                                        Background="#E67E22" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        Visibility="Collapsed">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- Suma reklamacji -->
                            <Border Grid.Column="8" Grid.Row="0" Background="#FFEBEE" CornerRadius="8" Padding="15,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Razem: " FontSize="12" Foreground="#C62828" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtLiczbaReklamacji" Text="0" FontSize="16" FontWeight="Bold" Foreground="#E74C3C" VerticalAlignment="Center"/>
                                    <TextBlock Text=" reklamacji" FontSize="12" Foreground="#C62828" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- TABELA REKLAMACJI -->
            <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Pasek zakladek workflow V2 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                        <Button x:Name="tabDoAkcji" Click="TabDoAkcji_Click" Cursor="Hand" BorderThickness="0" Padding="0"
                                Background="Transparent" Margin="0,0,10,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="tabBorder" Background="#E74C3C" CornerRadius="10" Padding="18,11">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="DO AKCJI" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                            <Border Background="#FFFFFF" CornerRadius="10" Padding="9,2" Margin="10,0,0,0">
                                                <TextBlock x:Name="txtCntDoAkcji" Text="0" FontSize="11" FontWeight="Bold" Foreground="#E74C3C"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="tabWToku" Click="TabWToku_Click" Cursor="Hand" BorderThickness="0" Padding="0"
                                Background="Transparent" Margin="0,0,10,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="tabBorder" Background="#ECEFF1" CornerRadius="10" Padding="18,11">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="PRZYJETE" FontSize="12" FontWeight="Bold" Foreground="#546E7A" VerticalAlignment="Center"/>
                                            <Border Background="#546E7A" CornerRadius="10" Padding="9,2" Margin="10,0,0,0">
                                                <TextBlock x:Name="txtCntWToku" Text="0" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="tabZamkniete" Click="TabZamkniete_Click" Cursor="Hand" BorderThickness="0" Padding="0"
                                Background="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="tabBorder" Background="#ECEFF1" CornerRadius="10" Padding="18,11">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="ZAMKNIETE" FontSize="12" FontWeight="Bold" Foreground="#546E7A" VerticalAlignment="Center"/>
                                            <Border Background="#546E7A" CornerRadius="10" Padding="9,2" Margin="10,0,0,0">
                                                <TextBlock x:Name="txtCntZamkniete" Text="0" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock x:Name="txtOpisZakladki" Text="Wymagaja akcji dzialu jakosci" FontSize="11.5" FontStyle="Italic"
                                   Foreground="#7F8C8D" VerticalAlignment="Center" Margin="20,0,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" x:Name="txtTytulListy" Text="Lista reklamacji" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,12"/>

                    <Border Grid.Row="2" BorderBrush="#E74C3C" BorderThickness="2" CornerRadius="10" ClipToBounds="True">
                        <DataGrid x:Name="dgReklamacje"
                                  Style="{StaticResource ModernDataGrid}"
                                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                                  CellStyle="{StaticResource DataGridCellStyle}"
                                  SelectionChanged="DgReklamacje_SelectionChanged"
                                  MouseDoubleClick="DgReklamacje_MouseDoubleClick">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding JestZagrozonySLA}" Value="True">
                                            <Setter Property="Background" Value="#FFF8E1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding JestKrytycznySLA}" Value="True">
                                            <Setter Property="Background" Value="#FFEBEE"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                <DataGridTextColumn Header="Data" Binding="{Binding DataZgloszenia, StringFormat=yyyy-MM-dd}" Width="90"/>
                                <DataGridTextColumn Header="Nr faktury" Binding="{Binding NumerDokumentu}" Width="100"/>
                                <DataGridTextColumn Header="Kontrahent" Binding="{Binding NazwaKontrahenta}" Width="*"/>
                                <!-- Zrodlo zgloszenia -->
                                <DataGridTemplateColumn Header="Zrodlo" Width="SizeToCells" MinWidth="100" SortMemberPath="ZrodloZgloszenia">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="10,3" HorizontalAlignment="Center"
                                                    Background="{Binding ZrodloBgBrush}" Margin="4,0">
                                                <TextBlock Text="{Binding ZrodloIkona}" FontWeight="SemiBold" FontSize="10.5"
                                                           Foreground="{Binding ZrodloFgBrush}"
                                                           HorizontalAlignment="Center"
                                                           ToolTip="{Binding ZrodloZgloszenia}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Handlowiec z avatarem -->
                                <DataGridTemplateColumn Header="Handlowiec" Width="155">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                        Visibility="{Binding HandlowiecVis}">
                                                <Grid Width="26" Height="26" Margin="0,0,6,0">
                                                    <Border Width="26" Height="26" CornerRadius="13"
                                                            Background="{Binding HandlowiecAvatarBrush}">
                                                        <TextBlock Text="{Binding HandlowiecInitials}" Foreground="White"
                                                                   FontWeight="Bold" FontSize="9"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Ellipse Width="26" Height="26" Visibility="{Binding HandlowiecAvatarPhotoVis}">
                                                        <Ellipse.Fill>
                                                            <ImageBrush ImageSource="{Binding HandlowiecAvatar}" Stretch="UniformToFill"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding Handlowiec}" VerticalAlignment="Center"
                                                           FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Typ" Binding="{Binding TypReklamacji}" Width="180"/>
                                <!-- Powiazanie -->
                                <DataGridTemplateColumn Header="Powiazanie" Width="95" SortMemberPath="MaPowiazanie">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="powBorder" CornerRadius="10" Padding="6,2" HorizontalAlignment="Center"
                                                    Background="#FFEBEE">
                                                <TextBlock x:Name="powText" Text="{Binding TekstPowiazania}" FontWeight="SemiBold" FontSize="9.5"
                                                           HorizontalAlignment="Center" Foreground="#C62828"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding MaPowiazanie}" Value="True">
                                                    <Setter TargetName="powBorder" Property="Background" Value="#E8F5E9"/>
                                                    <Setter TargetName="powText" Property="Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Priorytet z kolorami -->
                                <DataGridTemplateColumn Header="Priorytet" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="priorytetBorder" CornerRadius="10" Padding="8,3" HorizontalAlignment="Center">
                                                <TextBlock x:Name="priorytetText" Text="{Binding Priorytet}" FontWeight="SemiBold" FontSize="10"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Priorytet}" Value="Niski">
                                                    <Setter TargetName="priorytetBorder" Property="Background" Value="#E8F5E9"/>
                                                    <Setter TargetName="priorytetText" Property="Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priorytet}" Value="Normalny">
                                                    <Setter TargetName="priorytetBorder" Property="Background" Value="#E3F2FD"/>
                                                    <Setter TargetName="priorytetText" Property="Foreground" Value="#1976D2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priorytet}" Value="Wysoki">
                                                    <Setter TargetName="priorytetBorder" Property="Background" Value="#FFF3E0"/>
                                                    <Setter TargetName="priorytetText" Property="Foreground" Value="#EF6C00"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priorytet}" Value="Krytyczny">
                                                    <Setter TargetName="priorytetBorder" Property="Background" Value="#FFEBEE"/>
                                                    <Setter TargetName="priorytetText" Property="Foreground" Value="#C62828"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Kg" Binding="{Binding SumaKg, StringFormat=N2}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Status" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="statusBorder" CornerRadius="12" Padding="10,4" HorizontalAlignment="Center">
                                                <TextBlock x:Name="statusText" Text="{Binding Status}" FontWeight="Bold" FontSize="10"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Nowa">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#E3F2FD"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#1976D2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="W trakcie">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#FFF3E0"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#EF6C00"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Zaakceptowana">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#E8F5E9"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Odrzucona">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#FFEBEE"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#C62828"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Zamknieta">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#ECEFF1"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#546E7A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Przyjeta">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#E3F2FD"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#1565C0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="W analizie">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#FFF3E0"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#EF6C00"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="W trakcie realizacji">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#FFF3E0"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#D84315"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Oczekuje na dostawce">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#F3E5F5"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#7B1FA2"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Zglaszajacy z avatarem -->
                                <DataGridTemplateColumn Header="Zglaszajacy" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Grid Width="26" Height="26" Margin="0,0,6,0">
                                                    <Border Width="26" Height="26" CornerRadius="13"
                                                            Background="{Binding ZglaszajacyAvatarBrush}">
                                                        <TextBlock Text="{Binding ZglaszajacyInitials}" Foreground="White"
                                                                   FontWeight="Bold" FontSize="9"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Ellipse Width="26" Height="26" Visibility="{Binding ZglaszajacyAvatarPhotoVis}">
                                                        <Ellipse.Fill>
                                                            <ImageBrush ImageSource="{Binding ZglaszajacyAvatar}" Stretch="UniformToFill"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding Zglaszajacy}" VerticalAlignment="Center"
                                                           FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Rozpatrujacy z avatarem -->
                                <DataGridTemplateColumn Header="Rozpatruje" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                        Visibility="{Binding RozpatrujacyVis}">
                                                <Grid Width="26" Height="26" Margin="0,0,6,0">
                                                    <Border Width="26" Height="26" CornerRadius="13"
                                                            Background="{Binding RozpatrujacyAvatarBrush}">
                                                        <TextBlock Text="{Binding RozpatrujacyInitials}" Foreground="White"
                                                                   FontWeight="Bold" FontSize="9"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Ellipse Width="26" Height="26" Visibility="{Binding RozpatrujacyAvatarPhotoVis}">
                                                        <Ellipse.Fill>
                                                            <ImageBrush ImageSource="{Binding RozpatrujacyAvatar}" Stretch="UniformToFill"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding OsobaRozpatrujaca}" VerticalAlignment="Center"
                                                           FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Szczegoly reklamacji" Click="BtnSzczegoly_Click" FontWeight="SemiBold"/>
                                    <MenuItem Header="Zmien status" Click="BtnZmienStatus_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Eksportuj do Excel" Click="BtnExportExcel_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <!-- STOPKA Z PRZYCISKAMI -->
            <Border Grid.Row="2" Style="{StaticResource CardPanel}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Informacje o zaznaczeniu -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="txtZaznaczenie" Text="Wybierz reklamacje z listy" FontSize="12" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Przyciski akcji -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="btnSzczegoly" Content="Szczegoly" Style="{StaticResource InfoButton}"
                                Width="120" Click="BtnSzczegoly_Click" IsEnabled="False" Margin="0,0,10,0"/>
                        <Button x:Name="btnUzupelnij" Content="Uzupelnij" Style="{StaticResource WarningButton}"
                                Width="120" Click="BtnUzupelnij_Click" IsEnabled="False" Margin="0,0,10,0"/>

                        <!-- Workflow V2 - duze przyciski decyzyjne dzialu jakosci -->
                        <!-- PRZYJETE - jakosc zaczyna rozpatrywac, bez komentarza -->
                        <Button x:Name="btnPrzekazAnaliza" Click="BtnPrzekazAnaliza_Click"
                                Visibility="Collapsed" Width="160" Height="56" Margin="0,0,8,0"
                                Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"
                                ToolTip="Jakosc przyjmuje reklamacje do rozpatrzenia">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                        <StackPanel>
                                            <TextBlock Text="PRZYJETE" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                            <TextBlock Text="do rozpatrzenia" FontSize="9.5" Foreground="#DCEBF7" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#2980B9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- ZAAKCEPTOWANA - z polami przyczyna + akcje naprawcze -->
                        <Button x:Name="btnZasadna" Click="BtnZasadna_Click"
                                Visibility="Collapsed" Width="160" Height="56" Margin="0,0,8,0"
                                Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"
                                ToolTip="Reklamacja zasadna - podaj przyczyne glowna i akcje naprawcze">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                        <StackPanel>
                                            <TextBlock Text="ZAAKCEPTOWANA" FontSize="12.5" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                            <TextBlock Text="przyczyna + naprawa" FontSize="9.5" Foreground="#D5F5E3" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#229954"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- ODRZUCONA - z powodem -->
                        <Button x:Name="btnNiezasadna" Click="BtnNiezasadna_Click"
                                Visibility="Collapsed" Width="160" Height="56" Margin="0,0,8,0"
                                Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"
                                ToolTip="Reklamacja odrzucona - podaj powod">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                        <StackPanel>
                                            <TextBlock Text="ODRZUCONA" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                            <TextBlock Text="z podaniem powodu" FontSize="9.5" Foreground="#FADBD8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#C0392B"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Separator wizualny -->
                        <Border x:Name="sepWorkflow" Visibility="Collapsed" Width="1" Height="40" Background="#E0E0E0" Margin="4,0,12,0" VerticalAlignment="Center"/>

                        <!-- POWIAZ Z KOREKTA -->
                        <Button x:Name="btnPowiaz" Click="BtnPowiaz_Click"
                                Visibility="Collapsed" Width="140" Height="56" Margin="0,0,8,0"
                                Background="#8E44AD" Foreground="White" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                        <StackPanel>
                                            <TextBlock Text="POWIAZ" FontSize="12.5" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                            <TextBlock Text="z korekta Symfonii" FontSize="9.5" Foreground="#E8DAEF" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#7D3C98"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- ZAMKNIJ -->
                        <Button x:Name="btnZamknij" Click="BtnZamknij_Click"
                                Visibility="Collapsed" Width="130" Height="56" Margin="0,0,8,0"
                                Background="#546E7A" Foreground="White" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                        <StackPanel>
                                            <TextBlock Text="ZAMKNIJ" FontSize="12.5" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                            <TextBlock Text="sprawa zalatwiona" FontSize="9.5" Foreground="#CFD8DC" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#455A64"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="btnUsun" Content="Usun" Style="{StaticResource PrimaryButton}"
                                Width="100" Click="BtnUsun_Click" IsEnabled="False" Margin="10,0,0,0"
                                Visibility="Collapsed" Background="#E74C3C"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
