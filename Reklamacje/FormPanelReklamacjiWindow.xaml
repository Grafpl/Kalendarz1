<Window x:Class="Kalendarz1.Reklamacje.FormPanelReklamacjiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Panel Reklamacji - Zarzadzanie"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#ECF0F1"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- PRZYCISKI -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.15" BlurRadius="8"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C0392B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#A93226"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.15" BlurRadius="8"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#219A52"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoButton" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.15" BlurRadius="8"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button">
            <Setter Property="Background" Value="#F39C12"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.15" BlurRadius="8"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D68910"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- KARTA -->
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="0" Color="#000000" Opacity="0.08" BlurRadius="15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TEXTBOX -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#E74C3C"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DATAGRID -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#C0392B"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="12,8">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFEBEE"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#ECF0F1" Offset="0"/>
                <GradientStop Color="#E0E6E8" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>      <!-- Lewa: tabela + zakladki + paneleAkcji -->
                <ColumnDefinition Width="Auto"/>   <!-- Prawa: panel boczny szczegolow (cala wysokosc) -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="0"/>  <!-- USUNIETO: gorny pasek filtrow zlikwidowany — wszystko przeniesione do paska zakladek (Row=1) -->
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>


            <!-- (Gorny pasek filtrow usuniety — wszystko przeniesione do paska zakladek w Row=1) -->

            <!-- TABELA REKLAMACJI -->
            <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- pasek zakladek+filtry+guziki -->
                        <RowDefinition Height="*"/>      <!-- DataGrid -->
                    </Grid.RowDefinitions>

                    <!-- Pasek zakladek workflow V2 + FILTRY + GUZIKI w jednej linii -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- zakladki -->
                            <ColumnDefinition Width="*"/>      <!-- filtry + guziki -->
                        </Grid.ColumnDefinitions>

                        <!-- KOLUMNA 0: ZAKLADKI -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="tabDoAkcji" Click="TabDoAkcji_Click" Cursor="Hand" BorderThickness="0" Padding="0"
                                    Background="Transparent" Margin="0,0,4,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="tabBorder" Background="#E74C3C" CornerRadius="6" Padding="8,3">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="DO ZROBIENIA" FontSize="10" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                <Border Background="#FFFFFF" CornerRadius="8" Padding="5,1" Margin="6,0,0,0">
                                                    <TextBlock x:Name="txtCntDoAkcji" Text="0" FontSize="10" FontWeight="Bold" Foreground="#E74C3C"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="tabWToku" Click="TabWToku_Click" Cursor="Hand" BorderThickness="0" Padding="0"
                                    Background="Transparent" Margin="0,0,4,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="tabBorder" Background="#ECEFF1" CornerRadius="6" Padding="8,3">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="W TOKU" FontSize="10" FontWeight="Bold" Foreground="#546E7A" VerticalAlignment="Center"/>
                                                <Border Background="#546E7A" CornerRadius="8" Padding="5,1" Margin="6,0,0,0">
                                                    <TextBlock x:Name="txtCntWToku" Text="0" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="tabZamkniete" Click="TabZamkniete_Click" Cursor="Hand" BorderThickness="0" Padding="0"
                                    Background="Transparent">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="tabBorder" Background="#ECEFF1" CornerRadius="6" Padding="8,3">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="HISTORIA" FontSize="10" FontWeight="Bold" Foreground="#546E7A" VerticalAlignment="Center"/>
                                                <Border Background="#546E7A" CornerRadius="8" Padding="5,1" Margin="6,0,0,0">
                                                    <TextBlock x:Name="txtCntZamkniete" Text="0" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- KOLUMNA 1: FILTRY (kompakt — bez labelek nad kontrolkami, tooltipy zamiast nich) -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,10,0">
                            <ComboBox x:Name="cmbStatus" Width="90" Height="22" FontSize="10" Margin="0,0,4,0"
                                      SelectionChanged="CmbStatus_SelectionChanged" VerticalContentAlignment="Center" ToolTip="Status">
                                <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                                <ComboBoxItem Content="Zgloszona"/>
                                <ComboBoxItem Content="W analizie"/>
                                <ComboBoxItem Content="Zasadna"/>
                                <ComboBoxItem Content="Odrzucona"/>
                                <ComboBoxItem Content="Powiazana"/>
                                <ComboBoxItem Content="Zamknieta"/>
                            </ComboBox>
                            <ComboBox x:Name="cmbTyp" Width="115" Height="22" FontSize="10" Margin="0,0,4,0"
                                      SelectionChanged="CmbTyp_SelectionChanged" VerticalContentAlignment="Center" ToolTip="Typ reklamacji">
                                <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                                <ComboBoxItem Content="Jakosc produktu"/>
                                <ComboBoxItem Content="Ilosc / Brak towaru"/>
                                <ComboBoxItem Content="Uszkodzenie w transporcie"/>
                                <ComboBoxItem Content="Termin waznosci"/>
                                <ComboBoxItem Content="Niezgodnosc z zamowieniem"/>
                                <ComboBoxItem Content="Temperatura"/>
                                <ComboBoxItem Content="Ciala obce"/>
                                <ComboBoxItem Content="Faktura korygujaca"/>
                                <ComboBoxItem Content="Inne"/>
                            </ComboBox>
                            <ComboBox x:Name="cmbPriorytet" Width="85" Height="22" FontSize="10" Margin="0,0,4,0"
                                      SelectionChanged="CmbPriorytet_SelectionChanged" VerticalContentAlignment="Center" ToolTip="Priorytet">
                                <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                                <ComboBoxItem Content="Niski"/>
                                <ComboBoxItem Content="Normalny"/>
                                <ComboBoxItem Content="Wysoki"/>
                                <ComboBoxItem Content="Krytyczny"/>
                            </ComboBox>
                            <ComboBox x:Name="cmbHandlowiec" Width="110" Height="22" FontSize="10" Margin="0,0,4,0"
                                      SelectionChanged="CmbHandlowiec_SelectionChanged"
                                      IsEditable="True" IsTextSearchEnabled="True" VerticalContentAlignment="Center" ToolTip="Handlowiec">
                                <ComboBoxItem Content="Wszyscy" IsSelected="True"/>
                            </ComboBox>
                            <Border Background="White" CornerRadius="4" BorderBrush="#BDC3C7" BorderThickness="1" Padding="6,0" Height="22" Margin="0,0,8,0">
                                <Grid Width="140">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="🔍" FontSize="10" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#7F8C8D"/>
                                    <TextBox x:Name="txtSzukaj" Grid.Column="1" BorderThickness="0" Background="Transparent"
                                             FontSize="10" VerticalAlignment="Center" TextChanged="TxtSzukaj_TextChanged"
                                             ToolTip="Szukaj po: numerze dokumentu, nazwie kontrahenta, opisie, typie reklamacji"/>
                                </Grid>
                            </Border>
                            <!-- GUZIKI OBOK SZUKAJ (przeniesione z kolumny 2): + NOWA + ⚙ + Density -->
                            <Grid VerticalAlignment="Center" Margin="0,0,4,0">
                                <Button x:Name="btnNowaSplit" Click="BtnNowaSplit_Click"
                                        Padding="10,2" FontSize="10" FontWeight="Bold" Height="22"
                                        Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        ToolTip="Nowa reklamacja - wybierz klienta">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <TextBlock Text="+ NOWA" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Foreground="White"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#C0392B"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Popup x:Name="popupNowa" PlacementTarget="{Binding ElementName=btnNowaSplit}" Placement="Bottom"
                                       StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="White" CornerRadius="8" BorderBrush="#E74C3C" BorderThickness="1" Padding="6">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="3" Color="#000000" Opacity="0.25" BlurRadius="14"/>
                                        </Border.Effect>
                                        <StackPanel Width="320">
                                            <Button Click="MenuNowa_DoFaktury_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="12,10" HorizontalContentAlignment="Left">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="📄" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                                <StackPanel>
                                                                    <TextBlock Text="Do istniejacej faktury" FontSize="13" FontWeight="Bold" Foreground="#2C3E50"/>
                                                                    <TextBlock Text="Wybierz kontrahenta i jedna z jego faktur" FontSize="10.5" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#F8F9FA"/></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Click="MenuNowa_DoKorekty_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="12,10" HorizontalContentAlignment="Left">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="✏" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                                <StackPanel>
                                                                    <TextBlock Text="Do istniejacej korekty" FontSize="13" FontWeight="Bold" Foreground="#2C3E50"/>
                                                                    <TextBlock Text="Wybierz korekte z Symfonii (FKS / FKSB / FWK)" FontSize="10.5" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#F8F9FA"/></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Click="MenuNowa_BezFaktury_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="12,10" HorizontalContentAlignment="Left">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="❓" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                                <StackPanel>
                                                                    <TextBlock Text="Bez faktury (jeszcze niewystawionej)" FontSize="13" FontWeight="Bold" Foreground="#2C3E50"/>
                                                                    <TextBlock Text="Zglos prewencyjnie - faktura zostanie podpieta pozniej" FontSize="10.5" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#F8F9FA"/></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                            <Button x:Name="btnUstawieniaSync" Click="BtnUstawieniaSync_Click" Padding="6,2" Margin="0,0,4,0" FontSize="11" Height="22" VerticalAlignment="Center"
                                    Background="#7F8C8D" Foreground="White" BorderThickness="0" Cursor="Hand" Visibility="Collapsed" ToolTip="Ustawienia sync (admin)">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <TextBlock Text="⚙" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#566573"/></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Border CornerRadius="4" BorderBrush="#BDC3C7" BorderThickness="1" Padding="0" Height="22" VerticalAlignment="Center" ToolTip="Gestosc wierszy">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="btnDensityCompact" Click="DensityCompact_Click" ToolTip="Kompaktowa (28px)" Padding="5,0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <TextBlock Text="≡" FontSize="12" FontWeight="Bold" Foreground="#7F8C8D"/>
                                    </Button>
                                    <Button x:Name="btnDensityNormal" Click="DensityNormal_Click" ToolTip="Normalna (40px)" Padding="5,0" Background="#3498DB" BorderThickness="0" Cursor="Hand">
                                        <TextBlock Text="☰" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    </Button>
                                    <Button x:Name="btnDensitySpacious" Click="DensitySpacious_Click" ToolTip="Wygodna (52px)" Padding="5,0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <TextBlock Text="≣" FontSize="12" FontWeight="Bold" Foreground="#7F8C8D"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Hidden compatibility controls (potrzebne w code-behind) -->
                        <StackPanel Visibility="Collapsed">
                            <TextBlock x:Name="txtStatNowe" Text="0"/>
                            <TextBlock x:Name="txtStatWTrakcie" Text="0"/>
                            <TextBlock x:Name="txtStatZaakceptowane" Text="0"/>
                            <TextBlock x:Name="txtLiczbaReklamacji" Text="0"/>
                            <TextBlock x:Name="txtStatOdrzucone" Text="0"/>
                            <TextBlock x:Name="txtStatZamkniete" Text="0"/>
                            <TextBlock x:Name="txtSzukajPlaceholder"/>
                            <TextBlock x:Name="txtSzukajHint"/>
                            <TextBlock x:Name="txtTytulListy"/>
                            <TextBlock x:Name="txtOpisZakladki"/>
                            <DatePicker x:Name="dpDataOd" SelectedDateChanged="DpData_SelectedDateChanged"/>
                            <DatePicker x:Name="dpDataDo" SelectedDateChanged="DpData_SelectedDateChanged"/>
                            <Button x:Name="btnNowaBezFaktury" Click="BtnNowaBezFaktury_Click"/>
                            <Button x:Name="btnNowaReklamacja" Click="BtnNowaReklamacja_Click"/>
                            <!-- USUNIETE z paska: Excel/Stat/Odswiez/Debug/Profiler — handlers zachowane, code-behind moze nadal je referowac -->
                            <Button x:Name="btnExportExcel" Click="BtnExportExcel_Click"/>
                            <Button x:Name="btnStatystyki" Click="BtnStatystyki_Click"/>
                            <Button x:Name="btnDebugSync" Click="BtnDebugSync_Click"/>
                            <Button x:Name="btnProfiler" Click="BtnProfiler_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- (Tytul "Lista reklamacji" + duplikujacy Density toggle USUNIETE — density przeniesione do paska zakladek) -->
                    <!-- Panel boczny szczegolow przeniesiony do zewnetrznego Grida (Grid.Column=1, RowSpan=4) — cala wysokosc okna -->

                    <Border Grid.Row="1" BorderBrush="#E74C3C" BorderThickness="2" CornerRadius="10" ClipToBounds="True">
                        <DataGrid x:Name="dgReklamacje"
                                  Style="{StaticResource ModernDataGrid}"
                                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                                  CellStyle="{StaticResource DataGridCellStyle}"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  SelectionChanged="DgReklamacje_SelectionChanged"
                                  MouseDoubleClick="DgReklamacje_MouseDoubleClick">
                            <!-- Kolorowanie wierszy (SLA zagrozeniem/krytyczne) usuniete na zyczenie usera -->

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data" Binding="{Binding DataZgloszenia, StringFormat=yyyy-MM-dd}" Width="90"/>
                                <DataGridTemplateColumn Header="Nr dokumentu" Width="SizeToCells" MinWidth="140" SortMemberPath="NumerDokumentu">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding NumerDokumentu}" FontWeight="SemiBold" FontSize="11"/>
                                                <!-- Sub-info: numer korekty z ksiegowosci (gdy reklamacja ma partnera) -->
                                                <TextBlock Text="{Binding KorektaSubInfoText}" FontSize="9.5" Foreground="#27AE60"
                                                           FontWeight="SemiBold"
                                                           Visibility="{Binding KorektaSubInfoVis}"
                                                           ToolTip="Polaczona korekta z Symfonii"/>
                                                <!-- Stary fallback: faktura bazowa (gdy korekta odwoluje sie do faktury sprzedazy) -->
                                                <TextBlock FontSize="9" Foreground="#F39C12" FontStyle="Italic"
                                                           Visibility="{Binding FakturaBazowaVis}">
                                                    <Run Text="↳ do: "/>
                                                    <Run Text="{Binding NumerFakturyOryginalnej, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Kontrahent" Binding="{Binding NazwaKontrahenta}" Width="130" MinWidth="100"/>
                                <!-- Zrodlo zgloszenia -->
                                <DataGridTemplateColumn Header="Zrodlo" Width="SizeToCells" MinWidth="100" SortMemberPath="ZrodloZgloszenia">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="10,3" HorizontalAlignment="Center"
                                                    Background="{Binding ZrodloBgBrush}" Margin="4,0">
                                                <TextBlock Text="{Binding ZrodloIkona}" FontWeight="SemiBold" FontSize="10.5"
                                                           Foreground="{Binding ZrodloFgBrush}"
                                                           HorizontalAlignment="Center"
                                                           ToolTip="{Binding ZrodloZgloszenia}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Handlowiec z avatarem -->
                                <!-- Handlowiec: avatar + skrót Imię.X -->
                                <DataGridTemplateColumn Header="Handlowiec" Width="115">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                        Visibility="{Binding HandlowiecVis}" ToolTip="{Binding Handlowiec}">
                                                <Grid Width="22" Height="22" Margin="0,0,5,0">
                                                    <Border Width="22" Height="22" CornerRadius="11" Background="{Binding HandlowiecAvatarBrush}">
                                                        <TextBlock Text="{Binding HandlowiecInitials}" Foreground="White"
                                                                   FontWeight="Bold" FontSize="9"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Ellipse Width="22" Height="22" Visibility="{Binding HandlowiecAvatarPhotoVis}">
                                                        <Ellipse.Fill>
                                                            <ImageBrush ImageSource="{Binding HandlowiecAvatar}" Stretch="UniformToFill"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding Handlowiec}" VerticalAlignment="Center" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Typ" Binding="{Binding TypReklamacjiEtykieta}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="ToolTip" Value="{Binding TypReklamacjiEtykieta}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <!-- Korekta (ikonka 🔗 gdy reklamacja ma powiazana korekte z ksiegowosci) -->
                                <DataGridTemplateColumn Header="Korekta" Width="60" SortMemberPath="MaPowiazanie">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock x:Name="powIcon"
                                                       Text="🔗" FontSize="14"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="#27AE60"
                                                       Visibility="{Binding PowiazanieIkonaVis}"
                                                       ToolTip="{Binding PowiazanieTooltip}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Kg" Binding="{Binding SumaKg, StringFormat=N2}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Status" Width="130" SortMemberPath="StatusV2" Visibility="Collapsed">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="statusBorder" CornerRadius="10" Padding="10,4" HorizontalAlignment="Center" Background="#ECEFF1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock x:Name="statusText" Text="{Binding StatusV2Etykieta}" FontWeight="Bold" FontSize="10" Foreground="#546E7A" VerticalAlignment="Center"/>
                                                    <Ellipse Width="8" Height="8" Margin="6,0,0,0" Fill="{Binding PriorytetKropkaKolor}" VerticalAlignment="Center" ToolTip="{Binding PriorytetTooltip}"/>
                                                </StackPanel>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding StatusV2}" Value="ZGLOSZONA">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#FDEDEC"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#C0392B"/>
                                                </DataTrigger>
                                                <!-- Oczekuje = ZGLOSZONA + WymagaUzupelnienia (fioletowo-pomaranczowy) -->
                                                <DataTrigger Binding="{Binding StatusV2Etykieta}" Value="Oczekuje">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#FFE0B2"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#E65100"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusV2}" Value="W_ANALIZIE">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#FFF8E1"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#E67E22"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusV2}" Value="ZASADNA">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#E8F5E9"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusV2}" Value="ODRZUCONA">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#FFEBEE"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#C62828"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusV2}" Value="POWIAZANA">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#F3E5F5"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#7B1FA2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusV2}" Value="ZAMKNIETA">
                                                    <Setter TargetName="statusBorder" Property="Background" Value="#ECEFF1"/>
                                                    <Setter TargetName="statusText" Property="Foreground" Value="#546E7A"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- ZGŁOSIŁ: avatar + skrót Imię.X -->
                                <DataGridTemplateColumn Header="Zgłosił" Width="115">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ToolTip="{Binding Zglaszajacy}">
                                                <Grid Width="22" Height="22" Margin="0,0,5,0">
                                                    <Border Width="22" Height="22" CornerRadius="11" Background="{Binding ZglaszajacyAvatarBrush}">
                                                        <TextBlock Text="{Binding ZglaszajacyInitials}" Foreground="White" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Ellipse Width="22" Height="22" Visibility="{Binding ZglaszajacyAvatarPhotoVis}">
                                                        <Ellipse.Fill><ImageBrush ImageSource="{Binding ZglaszajacyAvatar}" Stretch="UniformToFill"/></Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding ZglaszajacySkrot}" VerticalAlignment="Center" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- ROZPATRUJE: avatar + skrót -->
                                <DataGridTemplateColumn Header="Rozpatruje" Width="115">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Visibility="{Binding RozpatrujacyVis}" ToolTip="{Binding OsobaRozpatrujaca}">
                                                <Grid Width="22" Height="22" Margin="0,0,5,0">
                                                    <Border Width="22" Height="22" CornerRadius="11" Background="{Binding RozpatrujacyAvatarBrush}">
                                                        <TextBlock Text="{Binding RozpatrujacyInitials}" Foreground="White" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Ellipse Width="22" Height="22" Visibility="{Binding RozpatrujacyAvatarPhotoVis}">
                                                        <Ellipse.Fill><ImageBrush ImageSource="{Binding RozpatrujacyAvatar}" Stretch="UniformToFill"/></Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding RozpatrujacySkrot}" VerticalAlignment="Center" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- ZATWIERDZONA: avatar + skrót + tooltip "kto + decyzja" -->
                                <DataGridTemplateColumn Header="Zatwierdzona" Width="115" SortMemberPath="UserZakonczenia">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Visibility="{Binding ZakonczylVis}" ToolTip="{Binding ZakonczylTooltip}">
                                                <Grid Width="22" Height="22" Margin="0,0,5,0">
                                                    <Border Width="22" Height="22" CornerRadius="11" Background="{Binding ZakonczylAvatarBrush}">
                                                        <TextBlock Text="{Binding ZakonczylInitials}" Foreground="White" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Ellipse Width="22" Height="22" Visibility="{Binding ZakonczylAvatarPhotoVis}">
                                                        <Ellipse.Fill><ImageBrush ImageSource="{Binding ZakonczylAvatar}" Stretch="UniformToFill"/></Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding UserZakonczeniaSkrot}" VerticalAlignment="Center" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Szczegoly reklamacji" Click="BtnSzczegoly_Click" FontWeight="SemiBold"/>
                                    <MenuItem Header="Zmien status" Click="BtnZmienStatus_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Eksportuj do Excel" Click="BtnExportExcel_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
                    <Border Grid.Column="1" Grid.RowSpan="4" Width="600" Margin="10,0,0,0" Background="White"
                            BorderBrush="#D5DBDB" BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="1" Color="#000000" Opacity="0.08" BlurRadius="8"/>
                        </Border.Effect>
                        <Grid>
                            <!-- PUSTY STAN — gdy nic nie zaznaczone -->
                            <StackPanel x:Name="panelEmpty" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                                <TextBlock Text="👈" FontSize="48" HorizontalAlignment="Center" Opacity="0.4"/>
                                <TextBlock Text="Wybierz reklamacje z listy" FontSize="14" FontWeight="SemiBold" Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,10,0,4"/>
                                <TextBlock Text="aby zobaczyc wszystkie szczegoly" FontSize="11" Foreground="#95A5A6" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- ZAWARTOSC — gdy zaznaczone -->
                            <ScrollViewer x:Name="panelSzczegoly" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="0,0,4,16">

                                    <!-- ══ HEADER v3 — Stripe/Linear style: białe tło + lewy pasek priorytetu + klient dominanta + KG jako amount ══ -->
                                    <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>     <!-- lewy pasek priorytetu -->
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- LEWY PASEK PRIORYTETU (zmieniany w code-behind: ps_PriorytetBadge tło) -->
                                            <Border Grid.Column="0" x:Name="ps_PriorytetBar" Background="#9CA3AF" CornerRadius="10,0,0,0"/>

                                            <!-- ZAWARTOŚĆ -->
                                            <StackPanel Grid.Column="1" Margin="14,12,12,12">

                                                <!-- ROW 1: Klient (DOMINANTA) ──  KG amount -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                        <TextBlock x:Name="ps_Kontrahent" Text="" FontSize="17" FontWeight="Bold" Foreground="#111827" TextWrapping="Wrap" LineHeight="20" TextTrimming="WordEllipsis"/>
                                                        <TextBlock x:Name="ps_DocKind" Text="Reklamacja" FontSize="9" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,2,0,0" Visibility="Collapsed"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <TextBlock x:Name="ps_SumaKg" Text="0" FontSize="22" FontWeight="Bold" Foreground="#EA580C" VerticalAlignment="Center"/>
                                                            <TextBlock Text="kg" FontSize="11" FontWeight="SemiBold" Foreground="#FB923C" VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- QUICK ACTION: PRZYJMIJ DO ROZPATRZENIA (widoczne TYLKO gdy ZGLOSZONA) -->
                                                <Button x:Name="ps_BtnQuickPrzyjmij" Click="BtnPrzekazAnaliza_Click"
                                                        HorizontalAlignment="Stretch" Margin="0,8,0,0" Cursor="Hand"
                                                        BorderThickness="0" Padding="0" Background="Transparent" Visibility="Collapsed"
                                                        ToolTip="Przyjmij reklamację do rozpatrzenia (status: ZGŁOSZONA → W ANALIZIE)">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bd" CornerRadius="6" Padding="10,7">
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                        <GradientStop Color="#2563EB" Offset="0"/>
                                                                        <GradientStop Color="#1D4ED8" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                    <TextBlock Text="▶" FontSize="13" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                    <TextBlock Text="PRZYJMIJ DO ROZPATRZENIA" FontSize="11" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="(W TOKU)" FontSize="9" FontWeight="SemiBold" Foreground="#BFDBFE" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="#1E40AF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- ROW 2: META inline — #numer · data · typ · dni temu -->
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock x:Name="ps_NumerDokumentu" Text="" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="10" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                                                    <TextBlock Text=" · " FontSize="11" Foreground="#D1D5DB" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ps_DataZgl" Text="" FontSize="10" Foreground="#6B7280" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ps_DniOd" Text="" FontSize="10" Foreground="#9CA3AF" Margin="3,0,0,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text=" · " FontSize="11" Foreground="#D1D5DB" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ps_Typ" Text="" FontSize="10" Foreground="#6B7280" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                                </StackPanel>

                                                <!-- ROW 3: Pill row — Status + Priorytet + Zrodlo + Handlowiec po prawej -->
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- LEWA: chipy meta -->
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <Border x:Name="ps_StatusBadge" CornerRadius="9" Padding="8,2" Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,4,0">
                                                            <TextBlock x:Name="ps_Status" Text="" FontSize="9" FontWeight="SemiBold" Foreground="#374151"/>
                                                        </Border>
                                                        <Border x:Name="ps_PriorytetBadge" CornerRadius="9" Padding="8,2" Background="#F3F4F6" Margin="0,0,4,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse x:Name="ps_PriorytetDot" Width="6" Height="6" Fill="#9CA3AF" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                                <TextBlock x:Name="ps_Priorytet" Text="" FontSize="9" FontWeight="SemiBold" Foreground="#374151"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border x:Name="ps_ZrodloBadge" CornerRadius="9" Padding="8,2" Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1">
                                                            <TextBlock x:Name="ps_Zrodlo" Text="" FontSize="9" FontWeight="SemiBold" Foreground="#374151"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <!-- PRAWA: Handlowiec -->
                                                    <StackPanel Grid.Column="1" x:Name="ps_HandlowiecPanel" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed" ToolTip="Handlowiec">
                                                        <Grid Width="20" Height="20" Margin="0,0,5,0">
                                                            <Border x:Name="ps_HandlowiecBg" Width="20" Height="20" CornerRadius="10" Background="#3498DB">
                                                                <TextBlock x:Name="ps_HandlowiecInit" Text="" Foreground="White" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <Ellipse x:Name="ps_HandlowiecPhoto" Width="20" Height="20" Visibility="Collapsed"/>
                                                        </Grid>
                                                        <TextBlock x:Name="ps_Handlowiec" Text="" FontSize="10" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Wymaga uzupelnienia (mały alert pasek poniżej) -->
                                                <!-- ALERT BRAK WAGOWY (faktura ma korektę FKSB) — czerwony banner mocny akcent -->
                                                <Border x:Name="ps_BrakWagowyAlert" CornerRadius="6" Padding="10,7" Margin="0,8,0,0" Visibility="Collapsed">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#FEE2E2" Offset="0"/>
                                                            <GradientStop Color="#FECACA" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.BorderBrush>
                                                        <SolidColorBrush Color="#DC2626"/>
                                                    </Border.BorderBrush>
                                                    <Border.BorderThickness>
                                                        <Thickness>1</Thickness>
                                                    </Border.BorderThickness>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="🚨" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="BRAK WAGOWY" FontSize="11" FontWeight="Bold" Foreground="#991B1B"/>
                                                            <TextBlock x:Name="ps_BrakWagowyDetal" Text="" FontSize="10" Foreground="#7F1D1D" Margin="0,1,0,0" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <Border x:Name="ps_WymagaUzup" CornerRadius="4" Padding="7,3" Background="#FEF3C7" BorderBrush="#FCD34D" BorderThickness="1" Margin="0,6,0,0" HorizontalAlignment="Left" Visibility="Collapsed">
                                                    <TextBlock Text="⚠ WYMAGA UZUPEŁNIENIA" FontSize="9" FontWeight="Bold" Foreground="#92400E"/>
                                                </Border>

                                                <!-- Mini-stats klient (3 mies) — sformatowana 1 linia, pokazuje gdy >0 -->
                                                <StackPanel x:Name="ps_StatsKlientPanel" Orientation="Horizontal" Margin="0,6,0,0" Visibility="Collapsed">
                                                    <TextBlock Text="📊 " FontSize="9" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ps_StatsCount" Text="0" FontSize="9" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                                                    <TextBlock Text=" rekl. · " FontSize="9" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ps_StatsKg" Text="0" FontSize="9" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                                                    <TextBlock Text=" kg · " FontSize="9" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ps_StatsWartosc" Text="0" FontSize="9" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                                                    <TextBlock Text=" zł — ostatnie 3 mies." FontSize="9" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <!-- hidden compat -->
                                                <TextBlock x:Name="ps_Id" Visibility="Collapsed"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- ══ FAKTURA BAZOWA + OPIS — w 1 linii z ikonkami (inline chipy) ══ -->
                                    <Border Background="#FAFBFC" Padding="12,9" Margin="8,6,8,6" CornerRadius="8" BorderBrush="#EDF1F4" BorderThickness="1">
                                        <StackPanel>
                                            <!-- Faktura bazowa chip — inline (pokazuje gdy korekta ma faktura bazowa) -->
                                            <StackPanel Orientation="Horizontal" x:Name="ps_FakturaPanel" Margin="0,0,0,4" Visibility="Collapsed">
                                                <Border Background="#E8F5E9" CornerRadius="4" Padding="7,3" Margin="0,0,4,0" BorderBrush="#C8E6C9" BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📄" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Faktura bazowa: " FontSize="10" Foreground="#558B2F" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="ps_FakturaNr" Text="" FontSize="10" FontWeight="Bold" Foreground="#1B5E20" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- (Hidden compat — ps_FakturaId nadal w kodzie ale ukryte) -->
                                                <TextBlock x:Name="ps_FakturaId" Text="" Visibility="Collapsed"/>
                                            </StackPanel>
                                            <!-- Opis w 1 linii z ikoną -->
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="💬" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Top" Foreground="#9E9E9E"/>
                                                <TextBlock x:Name="ps_Opis" Text="" FontSize="11" Foreground="#2C3E50" TextWrapping="Wrap" LineHeight="14"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- ══ PARTIE Z FAKTURY (z parametry.ini Symfonii) ══ -->
                                    <Border x:Name="ps_PartiePanel" Background="#E3F2FD" Padding="12,9" Margin="8,0,8,6" CornerRadius="8" Visibility="Collapsed">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="🐔 PARTIE Z FAKTURY" FontSize="8" FontWeight="Bold" Foreground="#1565C0"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <TextBlock x:Name="ps_PartieCount" Text="" FontSize="9" Foreground="#1565C0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <Button x:Name="ps_BtnSprawdzHistorie" Click="PsBtnSprawdzHistorie_Click" Cursor="Hand" BorderThickness="0" Padding="0" Background="Transparent"
                                                            ToolTip="Sprawdź czy partie z tej faktury były wcześniej reklamowane (w INNYCH reklamacjach)">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="bd" Background="#1976D2" CornerRadius="4" Padding="6,2">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="🔍" FontSize="9" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                                        <TextBlock Text="Sprawdź historię" FontSize="9" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="bd" Property="Background" Value="#0D47A1"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                            <!-- Lista partii — wiersze pionowo (kompaktowo, ale z hodowcą i datą inline) -->
                                            <!-- WrapPanel — grupy hodowców układają się w 2 kolumnach (Width grupy ustawiana w code-behind) -->
                                            <WrapPanel x:Name="ps_PartieList" Orientation="Horizontal"/>
                                            <!-- Sekcja auto + daty + opakowania — WrapPanel z chipami z ikonkami -->
                                            <WrapPanel x:Name="ps_PartieMetaChips" Margin="0,8,0,0" Orientation="Horizontal">
                                                <!-- Code-behind wypełnia kolorowymi chipami; te TextBlock pozostają tylko jako kompatybilność -->
                                                <TextBlock x:Name="ps_PartieAuto" Text="" Visibility="Collapsed"/>
                                                <TextBlock x:Name="ps_PartieDaty" Text="" Visibility="Collapsed"/>
                                                <TextBlock x:Name="ps_PartieOpak" Text="" Visibility="Collapsed"/>
                                            </WrapPanel>
                                            <TextBlock x:Name="ps_PartieZrodlo" Text="" FontSize="8" FontStyle="Italic" Foreground="#90CAF9" Margin="0,6,0,0"/>
                                            <!-- DEBUG: banner pokazujacy wynik LoadPartieInfoBatch, klik = otworz log w notepad -->
                                            <Border x:Name="ps_PartieDebugBanner" Background="#FFF3E0" CornerRadius="4" Padding="6,3" Margin="0,4,0,0" Cursor="Hand"
                                                    ToolTip="Klik = otworz log %TEMP%\reklamacje-partie.log w notepad" MouseLeftButtonUp="PartieDebugBanner_Click" Visibility="Collapsed">
                                                <TextBlock x:Name="ps_PartieDebugText" FontSize="9" FontWeight="SemiBold" Foreground="#E65100" TextWrapping="Wrap"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- ══ POWIAZANA SPRAWA (korekta partner) ══ -->
                                    <Border x:Name="ps_PowiazaniePanel" Background="#F3E5F5" Padding="12,9" Margin="8,0,8,6" CornerRadius="8" Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="🔗 POWIAZANA SPRAWA" FontSize="8" FontWeight="Bold" Foreground="#7B1FA2" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="ps_PowiazanieNr" Text="" FontSize="12" FontWeight="SemiBold" Foreground="#4A148C"/>
                                            <TextBlock x:Name="ps_PowiazanieData" Text="" FontSize="10" Foreground="#7B1FA2" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- ══ WORKFLOW STEPPER: Przyczyna → Akcje → Decyzja+SLA (3 kroki) ══ -->
                                    <Border x:Name="ps_StepperPanel" Background="White" Padding="12,10" Margin="8,0,8,6" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="🔄 PROCES ROZPATRZENIA" FontSize="8" FontWeight="Bold" Foreground="#6B7280" Margin="0,0,0,6"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="1.4*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- KROK 1: PRZYCZYNA -->
                                                <Border Grid.Column="0" x:Name="ps_PrzyczynaPanel" Background="White" CornerRadius="6" Padding="6,5" BorderBrush="#E5E7EB" BorderThickness="1" Visibility="Collapsed">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border x:Name="ps_PrzyczynaStep" Background="#9CA3AF" CornerRadius="8" Width="16" Height="16" Margin="0,0,4,0">
                                                                <TextBlock Text="1" FontSize="9" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Text="🔍 Przyczyna" FontSize="8" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock x:Name="ps_Przyczyna" Text="" FontSize="10" FontWeight="SemiBold" Foreground="#374151" TextWrapping="Wrap" Margin="0,3,0,0" LineHeight="12"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- strzałka 1→2 -->
                                                <TextBlock Grid.Column="1" Text="→" FontSize="14" FontWeight="Bold" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="3,0,3,0"/>

                                                <!-- KROK 2: AKCJE -->
                                                <Border Grid.Column="2" x:Name="ps_AkcjePanel" Background="White" CornerRadius="6" Padding="6,5" BorderBrush="#E5E7EB" BorderThickness="1" Visibility="Collapsed">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border x:Name="ps_AkcjeStep" Background="#9CA3AF" CornerRadius="8" Width="16" Height="16" Margin="0,0,4,0">
                                                                <TextBlock Text="2" FontSize="9" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Text="🛠 Akcje" FontSize="8" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock x:Name="ps_Akcje" Text="" FontSize="10" FontWeight="SemiBold" Foreground="#374151" TextWrapping="Wrap" Margin="0,3,0,0" LineHeight="12"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- strzałka 2→3 -->
                                                <TextBlock Grid.Column="3" Text="→" FontSize="14" FontWeight="Bold" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="3,0,3,0"/>

                                                <!-- KROK 3: DECYZJA + SLA RAZEM (szerszy, łączy obie sprawy) -->
                                                <Border Grid.Column="4" x:Name="ps_DecyzjaPanel" Background="White" CornerRadius="6" Padding="6,5" BorderBrush="#E5E7EB" BorderThickness="1">
                                                    <StackPanel>
                                                        <!-- Header kroku: number + ikony + SLA badge po prawej -->
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" x:Name="ps_DecyzjaStep" Background="#9CA3AF" CornerRadius="8" Width="16" Height="16" Margin="0,0,4,0">
                                                                <TextBlock Text="3" FontSize="9" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="1" Text="⚖ Decyzja  ⏱ SLA" FontSize="8" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2" x:Name="ps_SLABadge" Text="" FontSize="13" FontWeight="Bold" Foreground="#374151" VerticalAlignment="Center"/>
                                                        </Grid>
                                                        <!-- Decyzja BOLD -->
                                                        <TextBlock x:Name="ps_Decyzja" Text="—" FontSize="11" FontWeight="Bold" Foreground="#B91C1C" TextWrapping="Wrap" Margin="0,3,0,0" LineHeight="13"/>
                                                        <!-- Cienki separator -->
                                                        <Border Height="1" Background="#F3F4F6" Margin="0,4,0,4"/>
                                                        <!-- SLA status -->
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border x:Name="ps_SlaStep" Background="#9CA3AF" CornerRadius="3" Padding="4,1" Margin="0,0,5,0">
                                                                <TextBlock Text="SLA" FontSize="8" FontWeight="Bold" Foreground="White"/>
                                                            </Border>
                                                            <TextBlock x:Name="ps_SLAStatus" Text="" FontSize="9" Foreground="#374151" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <!-- Hidden compat: ps_SLAPanel widoczne dla code-behind -->
                                                        <Border x:Name="ps_SLAPanel" Visibility="Collapsed"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- ══ WORKFLOW: zglaszajacy / rozpatrujacy / zakonczyl OBOK SIEBIE ══ -->
                                    <Border Background="#F8F9FA" Padding="12,9" Margin="8,0,8,6" CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="WORKFLOW" FontSize="8" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,3"/>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- ZGLASZAJACY -->
                                                <StackPanel Grid.Column="0" x:Name="ps_ZglaszajacyPanel" HorizontalAlignment="Center" ToolTipService.InitialShowDelay="200">
                                                    <StackPanel.ToolTip>
                                                        <ToolTip>
                                                            <StackPanel MaxWidth="280">
                                                                <TextBlock Text="ZGLOSZONA PRZEZ" FontSize="9" FontWeight="Bold" Foreground="#3498DB"/>
                                                                <TextBlock x:Name="ps_ZgTipName" Text="" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                                <TextBlock x:Name="ps_ZgTipData" Text="" FontSize="10" Foreground="#7F8C8D"/>
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </StackPanel.ToolTip>
                                                    <Grid Width="28" Height="28" HorizontalAlignment="Center" Margin="0,0,0,4">
                                                        <Border x:Name="ps_ZgBg" Width="28" Height="28" CornerRadius="14" Background="#3498DB">
                                                            <TextBlock x:Name="ps_ZgInit" Text="" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Ellipse x:Name="ps_ZgPhoto" Width="28" Height="28" Visibility="Collapsed"/>
                                                    </Grid>
                                                    <TextBlock Text="ZGLOSIL" FontSize="8" FontWeight="Bold" Foreground="#3498DB" HorizontalAlignment="Center"/>
                                                    <TextBlock x:Name="ps_ZgName" Text="" FontSize="10" FontWeight="SemiBold" Foreground="#2C3E50" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                                                    <TextBlock x:Name="ps_ZgData" Text="" FontSize="9" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- ROZPATRUJE -->
                                                <StackPanel Grid.Column="1" x:Name="ps_RozpatrujePanel" HorizontalAlignment="Center" Visibility="Collapsed" ToolTipService.InitialShowDelay="200">
                                                    <StackPanel.ToolTip>
                                                        <ToolTip>
                                                            <StackPanel MaxWidth="280">
                                                                <TextBlock Text="ROZPATRUJE" FontSize="9" FontWeight="Bold" Foreground="#F39C12"/>
                                                                <TextBlock x:Name="ps_RpTipName" Text="" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                                <TextBlock x:Name="ps_RpTipData" Text="" FontSize="10" Foreground="#7F8C8D"/>
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </StackPanel.ToolTip>
                                                    <Grid Width="28" Height="28" HorizontalAlignment="Center" Margin="0,0,0,4">
                                                        <Border x:Name="ps_RpBg" Width="28" Height="28" CornerRadius="14" Background="#F39C12">
                                                            <TextBlock x:Name="ps_RpInit" Text="" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Ellipse x:Name="ps_RpPhoto" Width="28" Height="28" Visibility="Collapsed"/>
                                                    </Grid>
                                                    <TextBlock Text="ROZPATRUJE" FontSize="8" FontWeight="Bold" Foreground="#F39C12" HorizontalAlignment="Center"/>
                                                    <TextBlock x:Name="ps_RpName" Text="" FontSize="10" FontWeight="SemiBold" Foreground="#2C3E50" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                                                    <TextBlock x:Name="ps_RpData" Text="" FontSize="9" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- ZAKONCZYL -->
                                                <StackPanel Grid.Column="2" x:Name="ps_ZakonczylPanel" HorizontalAlignment="Center" Visibility="Collapsed" ToolTipService.InitialShowDelay="200">
                                                    <StackPanel.ToolTip>
                                                        <ToolTip>
                                                            <StackPanel MaxWidth="280">
                                                                <TextBlock x:Name="ps_ZkTipLabel" Text="ZAKONCZYL" FontSize="9" FontWeight="Bold" Foreground="#27AE60"/>
                                                                <TextBlock x:Name="ps_ZkTipName" Text="" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                                <TextBlock x:Name="ps_ZkTipData" Text="" FontSize="10" Foreground="#7F8C8D"/>
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </StackPanel.ToolTip>
                                                    <Grid Width="28" Height="28" HorizontalAlignment="Center" Margin="0,0,0,4">
                                                        <Border x:Name="ps_ZkBg" Width="28" Height="28" CornerRadius="14" Background="#27AE60">
                                                            <TextBlock x:Name="ps_ZkInit" Text="" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Ellipse x:Name="ps_ZkPhoto" Width="28" Height="28" Visibility="Collapsed"/>
                                                    </Grid>
                                                    <TextBlock x:Name="ps_ZkLabel" Text="ZAKONCZYL" FontSize="8" FontWeight="Bold" Foreground="#27AE60" HorizontalAlignment="Center"/>
                                                    <TextBlock x:Name="ps_ZkName" Text="" FontSize="10" FontWeight="SemiBold" Foreground="#2C3E50" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                                                    <TextBlock x:Name="ps_ZkData" Text="" FontSize="9" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- DecyzjaSla GRID przeniesiony PRZED workflow (powyzej) -->
                                    <Grid x:Name="ps_DecyzjaSlaGrid" Visibility="Collapsed"/>

                                    <!-- ══ ZAŁĄCZNIKI (PDF/DOCX/scan) — drag&drop dla nowych ══ -->
                                    <Border x:Name="ps_ZalacznikiBorder" Background="#FAFAFA" Padding="12,9" Margin="8,0,8,6" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1"
                                            AllowDrop="True" DragOver="ZalacznikiBorder_DragOver" DragLeave="ZalacznikiBorder_DragLeave" Drop="ZalacznikiBorder_Drop">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="📎 ZAŁĄCZNIKI" FontSize="8" FontWeight="Bold" Foreground="#95A5A6"/>
                                                <TextBlock Grid.Column="1" x:Name="ps_ZalacznikiCount" Text="" FontSize="9" Foreground="#7F8C8D"/>
                                            </Grid>
                                            <StackPanel x:Name="ps_ZalacznikiList"/>
                                            <TextBlock x:Name="ps_ZalacznikiPusty" Text="Brak — przeciągnij plik tutaj (PDF / DOCX / scan)" FontSize="10" FontStyle="Italic" Foreground="#BDC3C7"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- ══ HISTORIA ZMIAN — top 5 ══ -->
                                    <!-- ══ HISTORIA — zwijana (Expander) — zmniejsza zajęte miejsce ══ -->
                                    <Border Background="#FAFAFA" Padding="0" Margin="8,0,8,6" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1">
                                        <Expander IsExpanded="False" Padding="10,4">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📜 HISTORIA" FontSize="8" FontWeight="Bold" Foreground="#95A5A6" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ps_HistoriaCount" Text="" FontSize="9" Foreground="#7F8C8D" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Expander.Header>
                                            <StackPanel Margin="0,6,0,2">
                                                <StackPanel x:Name="ps_HistoriaList"/>
                                                <TextBlock x:Name="ps_HistoriaPusty" Text="Brak wpisów historii" FontSize="10" FontStyle="Italic" Foreground="#BDC3C7"/>
                                            </StackPanel>
                                        </Expander>
                                    </Border>

                                    <!-- ══ ZDJECIA — drag&drop dla nowych ══ -->
                                    <Border x:Name="ps_ZdjeciaBorder" Background="#FAFAFA" Padding="12,9" Margin="8,0,8,6" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1"
                                            AllowDrop="True" DragOver="ZdjeciaBorder_DragOver" DragLeave="ZdjeciaBorder_DragLeave" Drop="ZdjeciaBorder_Drop">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="🖼 ZDJĘCIA" FontSize="8" FontWeight="Bold" Foreground="#95A5A6"/>
                                                <TextBlock Grid.Column="1" x:Name="ps_ZdjeciaCount" Text="0 zdjec" FontSize="9" Foreground="#7F8C8D"/>
                                            </Grid>
                                            <StackPanel x:Name="ps_ZdjeciaPanel" Orientation="Horizontal">
                                                <Border x:Name="ps_Zdj1Border" Width="64" Height="64" Margin="0,0,6,0" Background="#E0E0E0" CornerRadius="6" ClipToBounds="True" Visibility="Collapsed">
                                                    <Image x:Name="ps_Zdj1" Stretch="UniformToFill"/>
                                                </Border>
                                                <Border x:Name="ps_Zdj2Border" Width="64" Height="64" Margin="0,0,6,0" Background="#E0E0E0" CornerRadius="6" ClipToBounds="True" Visibility="Collapsed">
                                                    <Image x:Name="ps_Zdj2" Stretch="UniformToFill"/>
                                                </Border>
                                                <Border x:Name="ps_Zdj3Border" Width="64" Height="64" Background="#E0E0E0" CornerRadius="6" ClipToBounds="True" Visibility="Collapsed">
                                                    <Image x:Name="ps_Zdj3" Stretch="UniformToFill"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock x:Name="ps_ZdjeciaPusty" Text="Brak zdjec" FontSize="10" FontStyle="Italic" Foreground="#BDC3C7" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- ══ SZYBKA AKCJA: pelny widok ══ -->
                                    <Border Background="White" Padding="10,6">
                                        <Button Click="BtnSzczegoly_Click" Background="#3498DB" Foreground="White" BorderThickness="0"
                                                Padding="0,6" FontSize="10" FontWeight="SemiBold" Cursor="Hand"
                                                ToolTip="Otworz pelny widok szczegolow w nowym oknie (dwuklik na wierszu tez dziala)">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <TextBlock Text="📋 Otworz pelny widok" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#2E86C1"/></Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

            <!-- BULK ACTION BAR - widoczny gdy zaznaczono >=2 wiersze (Ctrl+klik / Shift+klik) -->
            <Border x:Name="bulkActionBar" Grid.Row="2" Visibility="Collapsed"
                    Background="#34495E" CornerRadius="10" Padding="14,8" Margin="6,0,6,4">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.3" BlurRadius="10"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#3498DB" CornerRadius="12" Padding="8,2" Margin="0,0,8,0">
                            <TextBlock x:Name="txtBulkCount" Text="0" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <TextBlock Text="zaznaczonych  •  Ctrl+klik / Shift+klik = wiele wierszy" FontSize="11.5" Foreground="#ECF0F1" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Click="BulkPrzyjmij_Click" Padding="10,5" Margin="0,0,6,0" FontSize="11" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Przyjmij do rozpatrzenia (W_ANALIZIE) — przypisuje aktualnego usera jako rozpatrujacego">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="① Przyjmij" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Click="BulkZatwierdz_Click" Padding="10,5" Margin="0,0,6,0" FontSize="11" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Zatwierdz jako zasadne (ZASADNA)">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="✓ Zatwierdz" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Click="BulkOdrzuc_Click" Padding="10,5" Margin="0,0,6,0" FontSize="11" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Odrzuc (ODRZUCONA) — wymaga podania powodu">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="✕ Odrzuc" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Click="BulkZamknij_Click" Padding="10,5" Margin="0,0,12,0" FontSize="11" Background="#546E7A" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Zamknij (ZAMKNIETA)">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="🏁 Zamknij" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Click="BulkPriorytet_Click" Padding="10,5" Margin="0,0,6,0" FontSize="11" Background="#F39C12" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Zmien priorytet">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="⚡ Priorytet" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Click="BulkExport_Click" Padding="10,5" Margin="0,0,6,0" FontSize="11" Background="#16A085" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Eksportuj zaznaczone do CSV">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="📊 Eksport" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Click="BulkOdznacz_Click" Padding="10,5" FontSize="11" Background="Transparent" BorderBrush="White" BorderThickness="1" Foreground="White" Cursor="Hand" ToolTip="Odznacz wszystkie (Esc)">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="✕ Odznacz" FontSize="11" Foreground="White"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- STOPKA Z PRZYCISKAMI - PANEL HANDLOWCA + PANEL JAKOSCI -->
            <Border Grid.Row="3" Style="{StaticResource CardPanel}" Padding="16,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Informacje o zaznaczeniu -->
                    <TextBlock Grid.Row="0" x:Name="txtZaznaczenie" Text="Wybierz reklamacje z listy"
                               FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,8"/>

                    <!-- Dwa panele obok siebie: Handlowiec wezszy (*), Jakosc szerszy (2*) -->
                    <Grid Grid.Row="1" x:Name="paneleAkcji">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>       <!-- Handlowiec — krotszy (mniej guzikow) -->
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="2*"/>      <!-- Jakosc — szerszy (wiecej guzikow) -->
                        </Grid.ColumnDefinitions>

                        <!-- ============ PANEL HANDLOWCA ============ -->
                        <Border Grid.Column="0" Background="#EBF5FB" CornerRadius="10" Padding="12,10" BorderBrush="#3498DB" BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2,0,0,8">
                                    <Border Background="#3498DB" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                        <TextBlock Text="PANEL HANDLOWCA" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="podglad zgloszenia + edycja danych" FontSize="10.5" FontStyle="Italic" Foreground="#5D6D7E" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="(dostepne dla wszystkich uzytkownikow)" FontSize="9" FontStyle="Italic" Foreground="#85929E" Margin="2,-4,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <!-- PODGLAD = otwórz okno szczegółów (do oglądania, zdjęć, historii) -->
                                    <Button x:Name="btnSzczegoly" Click="BtnSzczegoly_Click" IsEnabled="False" Margin="0,0,8,0"
                                            Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"
                                            Width="135" Height="50">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="PODGLAD - tylko zobacz" FontWeight="Bold" FontSize="13" Foreground="#2980B9" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Text="Otwiera szczegolowy widok zgloszenia: opis, towary, partie, ZDJECIA, HISTORIA zmian, komentarze. Niczego tu nie zmieniasz - tylko ogladasz."/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="👁" FontSize="14" Foreground="White" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="PODGLAD" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="zobacz wszystko" FontSize="9" Foreground="#D6EAF8" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#2980B9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- EDYTUJ = otwórz okno do dopisania/poprawy danych -->
                                    <Button x:Name="btnUzupelnij" Click="BtnUzupelnij_Click" IsEnabled="False" Margin="0,0,8,0"
                                            Background="#F39C12" Foreground="White" BorderThickness="0" Cursor="Hand"
                                            Width="135" Height="50">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="EDYTUJ DANE - dopisz / popraw" FontWeight="Bold" FontSize="13" Foreground="#D68910" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Text="Otwiera FORMULARZ EDYCJI - mozesz dopisac brakujace pola, dodac towary, dodac zdjecia. Uzywaj gdy zgloszenie nie ma jeszcze pelnych informacji (np. korekta z Symfonii bez opisu)."/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="✏" FontSize="14" Foreground="White" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="EDYTUJ DANE" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="popraw / dopisz" FontSize="9" Foreground="#FCEBC8" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#D68910"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Handlowiec: zglos pelna reklamacje do korekty z Symfonii -->
                                    <Button x:Name="btnZglosDoKorekty" Click="BtnZglosDoKorekty_Click"
                                            Visibility="Collapsed" Width="155" Height="50" Margin="0,0,8,0"
                                            Background="#1ABC9C" Foreground="White" BorderThickness="0" Cursor="Hand"
                                            ToolTip="Wypelnij szczegoly reklamacji dla tej korekty z Symfonii">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <TextBlock Text="Zglos do tej korekty" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="opisz powod korekty" FontSize="9" Foreground="#D1F2EB" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#16A085"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Separator pionowy -->
                        <Border Grid.Column="1" Width="1" Background="#D6DBDF" Margin="12,4,12,4"/>

                        <!-- ============ PANEL JAKOSCI ============ -->
                        <Border x:Name="panelJakosci" Grid.Column="2" Background="#F4ECF7" CornerRadius="10" Padding="12,10" BorderBrush="#9B59B6" BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2,0,0,8">
                                    <Border Background="#9B59B6" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                        <TextBlock Text="PANEL JAKOSCI" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="rozpatrywanie reklamacji — krok po kroku" FontSize="10.5" FontStyle="Italic" Foreground="#5B2C6F" VerticalAlignment="Center"/>
                                    <!-- Pole zachowane dla kompatybilnosci kodu, niewidoczne -->
                                    <Border x:Name="txtJakoscBrakUprawnien" Visibility="Collapsed" Width="0" Height="0"/>
                                </StackPanel>
                                <TextBlock Text="(dostepne dla wszystkich uzytkownikow)" FontSize="9" FontStyle="Italic" Foreground="#9580A8" Margin="2,-4,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <!-- KROK 1: PRZYJMIJ - jakosc zaczyna rozpatrywac, bez komentarza -->
                                    <Button x:Name="btnPrzekazAnaliza" Click="BtnPrzekazAnaliza_Click" IsEnabled="False"
                                            Width="115" Height="50" Margin="0,0,6,0"
                                            Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="KROK 1: PRZYJMIJ" FontWeight="Bold" FontSize="13" Foreground="#2980B9" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Text="Przyjmujesz nowe zgloszenie do rozpatrzenia. Status zmienia sie ze ZGLOSZONA na W ANALIZIE. Dopiero potem mozesz wybrac ZATWIERDZ lub ODRZUC."/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="①" FontSize="13" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="PRZYJMIJ" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="do rozpatrzenia" FontSize="9" Foreground="#DCEBF7" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#2980B9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- KROK 2a: ZATWIERDZ - z polami przyczyna + akcje naprawcze -->
                                    <Button x:Name="btnZasadna" Click="BtnZasadna_Click" IsEnabled="False"
                                            Width="115" Height="50" Margin="0,0,6,0"
                                            Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="KROK 2a: ZATWIERDZ" FontWeight="Bold" FontSize="13" Foreground="#229954" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Text="Reklamacja jest ZASADNA - klient ma racje. Otworzy sie okno gdzie wpisujesz: PRZYCZYNE GLOWNA (dlaczego doszlo do bledu) + AKCJE NAPRAWCZE (co robimy zeby sie nie powtorzylo)."/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="✓" FontSize="13" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="ZATWIERDZ" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="zasadna + naprawa" FontSize="9" Foreground="#D5F5E3" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#229954"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- KROK 2b: ODRZUC - z powodem -->
                                    <Button x:Name="btnNiezasadna" Click="BtnNiezasadna_Click" IsEnabled="False"
                                            Width="115" Height="50" Margin="0,0,6,0"
                                            Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="KROK 2b: ODRZUC" FontWeight="Bold" FontSize="13" Foreground="#C0392B" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Text="Reklamacja jest NIEZASADNA - klient nie ma racji. Wpisujesz POWOD odrzucenia, ktory jest pokazywany handlowcowi i klientowi."/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="✗" FontSize="13" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="ODRZUC" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="z podaniem powodu" FontSize="9" Foreground="#FADBD8" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#C0392B"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- KROK 3: POWIAZ Z KOREKTA -->
                                    <Button x:Name="btnPowiaz" Click="BtnPowiaz_Click" IsEnabled="False"
                                            Width="115" Height="50" Margin="0,0,6,0"
                                            Background="#8E44AD" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="KROK 3: POWIAZ z korekta" FontWeight="Bold" FontSize="13" Foreground="#7D3C98" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Text="Po wystawieniu w Symfonii faktury korygujacej (FKS/FKSB/FWK) powiazujesz ja z reklamacja. Aktywne tylko gdy zgloszenie jest typu KOREKTA i jeszcze nie polaczone."/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="🔗" FontSize="12" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="POWIAZ" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="z korekta Symfonii" FontSize="9" Foreground="#E8DAEF" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#7D3C98"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- KROK 4: ZAMKNIJ -->
                                    <Button x:Name="btnZamknij" Click="BtnZamknij_Click" IsEnabled="False"
                                            Width="115" Height="50" Margin="0,0,6,0"
                                            Background="#546E7A" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.ToolTip>
                                            <ToolTip MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="KROK 4: ZAMKNIJ" FontWeight="Bold" FontSize="13" Foreground="#455A64" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Text="Sprawa zalatwiona - reklamacja przechodzi do ZAMKNIETE. Aktywne dopiero po POWIAZANIU z korekta lub po ZATWIERDZENIU/ODRZUCENIU."/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="10,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="🏁" FontSize="12" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="ZAMKNIJ" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="sprawa zalatwiona" FontSize="9" Foreground="#CFD8DC" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#455A64"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- USUN - tylko admin -->
                                    <Button x:Name="btnUsun" Click="BtnUsun_Click" IsEnabled="False"
                                            Visibility="Collapsed" Width="80" Height="50" Margin="0,0,0,0"
                                            Background="#922B21" Foreground="White" BorderThickness="0" Cursor="Hand"
                                            ToolTip="USUN reklamacje na stale (tylko admin UserID 11111)">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7" Padding="8,6">
                                                    <StackPanel>
                                                        <TextBlock Text="🗑" FontSize="14" Foreground="White" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="USUN" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#7B241C"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <!-- Komunikat pomocniczy pod przyciskami -->
                                <TextBlock x:Name="txtJakoscBrakAkcji" Margin="2,6,0,0" Text="Wybierz reklamacje z listy aby zobaczyc co mozna z nia zrobic"
                                           FontSize="10.5" FontStyle="Italic" Foreground="#7D6608"/>
                            </StackPanel>
                        </Border>

                        <!-- Separator wizualny - kompatybilnosc kodu (nie uzywany w nowym layoucie) -->
                        <Border x:Name="sepWorkflow" Visibility="Collapsed" Width="0" Height="0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
