<Window x:Class="Kalendarz1.Reklamacje.FormRozpatrzenieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rozpatrzenie reklamacji"
        Width="640" Height="680"
        MinWidth="540" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F6FA"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Padding="22,16,22,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.3">
                    <GradientStop Color="#8E44AD" Offset="0"/>
                    <GradientStop Color="#9B59B6" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txtHeader" Text="ROZPATRZENIE #0"
                               FontSize="17" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="txtSubheader" Text=""
                               FontSize="11" Foreground="#D7BDE2" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Grid Width="40" Height="40" HorizontalAlignment="Center">
                        <Border x:Name="avatarRozpatrujacy" Width="40" Height="40" CornerRadius="20"
                                Background="#D7BDE2">
                            <TextBlock x:Name="txtAvatarRozpatrujacy" Text="?"
                                       Foreground="White" FontWeight="Bold" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Ellipse x:Name="ellipseAvatarRozpatrujacy" Width="40" Height="40" Visibility="Collapsed">
                            <Ellipse.Fill>
                                <ImageBrush x:Name="imgBrushAvatarRozpatrujacy" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                    <TextBlock x:Name="txtRozpatrujacyNazwa" Text="" FontSize="9"
                               Foreground="#E8DAEF" HorizontalAlignment="Center" Margin="0,3,0,0"
                               MaxWidth="100" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- STATUS PIPELINE -->
        <Border Grid.Row="1" Padding="16,10" Background="White" BorderThickness="0,0,0,1" BorderBrush="#E8E8E8">
            <WrapPanel x:Name="pipelinePanel" Orientation="Horizontal"/>
        </Border>

        <!-- CONTENT — dynamiczna tresc -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="panelContent" Margin="22,18,22,10"/>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="3" Padding="22,12" Background="#F0F0F5" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
            <Grid>
                <TextBlock x:Name="txtError" Foreground="#E74C3C" FontSize="11" VerticalAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="360" Visibility="Collapsed"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnZapisz" Click="BtnZapisz_Click" Visibility="Collapsed"
                            Width="140" Height="40" FontSize="13" FontWeight="Bold"
                            Foreground="White" Background="#8E44AD" BorderThickness="0" Cursor="Hand"
                            Margin="0,0,10,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                        CornerRadius="8" Padding="14,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Zamknij" Click="BtnAnuluj_Click"
                            Width="90" Height="40" FontSize="13" FontWeight="SemiBold"
                            Foreground="White" Background="#95A5A6" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                        CornerRadius="8" Padding="14,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
