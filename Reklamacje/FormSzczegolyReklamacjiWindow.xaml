<Window x:Class="Kalendarz1.Reklamacje.FormSzczegolyReklamacjiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Szczegoly reklamacji"
        Width="1400" Height="960"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#ECF0F1"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryGreen" Color="#1E8449"/>
        <SolidColorBrush x:Key="TextDark" Color="#2C3E50"/>
        <SolidColorBrush x:Key="TextMuted" Color="#7F8C8D"/>
        <SolidColorBrush x:Key="TextLight" Color="#95A5A6"/>
        <SolidColorBrush x:Key="Border" Color="#E8E8E8"/>

        <Style x:Key="MiniCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" Color="#000" Opacity="0.04" BlurRadius="6" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#95A5A6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E8449"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#27AE60"/>
            <Setter Property="Height" Value="34"/>
        </Style>

        <Style x:Key="GreenCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="10,6">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F5E9"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RightAligned" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
        <Style x:Key="RightAlignedBold" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>  <!-- Jedna linia akcji -->
        </Grid.RowDefinitions>

        <!-- RED ACCENT -->
        <Border Grid.Row="0" Background="#C0392B"/>

        <!-- COMPACT HEADER -->
        <Border Grid.Row="1" Padding="20,10,20,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.3">
                    <GradientStop Color="#1E8449" Offset="0"/>
                    <GradientStop Color="#27AE60" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title + Badge -->
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="txtHeaderTitle" Text="REKLAMACJA #0"
                                   FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <Border x:Name="badgeStatus" CornerRadius="10" Padding="12,3" Margin="12,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="txtStatusBadge" FontWeight="Bold" FontSize="10.5"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="txtHeaderSubtitle" Text=""
                               FontSize="10.5" Foreground="#D5F5E3" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Avatars: Zglosil -> Przyjal -> Zakonczyl + skutek -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- 1. ZGLOSIL -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="ZGLOSIL" Foreground="#A9DFBF" FontSize="8" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,3" Opacity="0.85"/>
                        <Grid Width="40" Height="40" HorizontalAlignment="Center">
                            <Border x:Name="avatarZglaszajacyHeader" Width="40" Height="40" CornerRadius="20"
                                    Background="#3498DB" BorderBrush="White" BorderThickness="2">
                                <TextBlock x:Name="txtAvatarZglaszajacyHeader" Text="?"
                                           Foreground="White" FontWeight="Bold" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Ellipse x:Name="ellipseAvatarZglaszajacyHeader" Width="40" Height="40" Visibility="Collapsed">
                                <Ellipse.Fill>
                                    <ImageBrush x:Name="imgBrushZglaszajacyHeader" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                        <TextBlock x:Name="txtAvatarZglaszajacyNazwa" Text="Zglaszajacy"
                                   Foreground="White" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   Margin="0,3,0,0" MaxWidth="90" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- separator strzalka -->
                    <TextBlock x:Name="sepZglosil_Przyjal" Text="&#x25B6;" Foreground="#A9DFBF" FontSize="14"
                               VerticalAlignment="Center" Margin="12,12,12,0"/>

                    <!-- 2. PRZYJAL -->
                    <StackPanel x:Name="avatarPrzyjalGroup" HorizontalAlignment="Center">
                        <TextBlock Text="PRZYJAL" Foreground="#A9DFBF" FontSize="8" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,3" Opacity="0.85"/>
                        <Grid Width="40" Height="40" HorizontalAlignment="Center">
                            <Border x:Name="avatarRozpatrujacyHeader" Width="40" Height="40" CornerRadius="20"
                                    Background="#F39C12" BorderBrush="White" BorderThickness="2">
                                <TextBlock x:Name="txtAvatarRozpatrujacyHeader" Text="?"
                                           Foreground="White" FontWeight="Bold" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Ellipse x:Name="ellipseAvatarRozpatrujacyHeader" Width="40" Height="40" Visibility="Collapsed">
                                <Ellipse.Fill>
                                    <ImageBrush x:Name="imgBrushRozpatrujacyHeader" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                        <TextBlock x:Name="txtAvatarRozpatrujacyNazwa" Text="—"
                                   Foreground="White" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   Margin="0,3,0,0" MaxWidth="90" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- separator strzalka -->
                    <TextBlock x:Name="sepPrzyjal_Zakonczyl" Text="&#x25B6;" Foreground="#A9DFBF" FontSize="14"
                               VerticalAlignment="Center" Margin="12,12,12,0"/>

                    <!-- 3. ZAKONCZYL + skutek -->
                    <StackPanel x:Name="avatarZakonczylGroup" HorizontalAlignment="Center">
                        <TextBlock Text="ZAKONCZYL" Foreground="#A9DFBF" FontSize="8" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,3" Opacity="0.85"/>
                        <Grid Width="40" Height="40" HorizontalAlignment="Center">
                            <Border x:Name="avatarZakonczylHeader" Width="40" Height="40" CornerRadius="20"
                                    Background="#27AE60" BorderBrush="White" BorderThickness="2">
                                <TextBlock x:Name="txtAvatarZakonczylHeader" Text="?"
                                           Foreground="White" FontWeight="Bold" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Ellipse x:Name="ellipseAvatarZakonczylHeader" Width="40" Height="40" Visibility="Collapsed">
                                <Ellipse.Fill>
                                    <ImageBrush x:Name="imgBrushZakonczylHeader" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                        <TextBlock x:Name="txtAvatarZakonczylNazwa" Text="—"
                                   Foreground="White" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   Margin="0,3,0,0" MaxWidth="90" TextTrimming="CharacterEllipsis"/>
                        <Border x:Name="badgeSkutek" CornerRadius="6" Padding="6,1" Margin="0,3,0,0" HorizontalAlignment="Center">
                            <TextBlock x:Name="txtSkutek" Text="" FontSize="9" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Right info -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Zgloszono: " Foreground="#A9DFBF" FontSize="10.5"/>
                        <TextBlock x:Name="txtHeaderData" Foreground="White" FontSize="10.5" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0" x:Name="panelHeaderZamkniecia" Visibility="Collapsed">
                        <TextBlock Text="Zamknieto: " Foreground="#A9DFBF" FontSize="10.5"/>
                        <TextBlock x:Name="txtHeaderZamkniecia" Foreground="White" FontSize="10.5" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="Priorytet: " Foreground="#A9DFBF" FontSize="10.5"/>
                        <Border x:Name="badgePriorytet" CornerRadius="6" Padding="6,1" Margin="2,0,0,0">
                            <TextBlock x:Name="txtPriorytet" FontSize="9.5" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT: TWO COLUMNS -->
        <Grid Grid.Row="2" Margin="12,10,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="14,12">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Color="#000" Opacity="0.05" BlurRadius="8" Direction="270"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- INFO CARDS 2x2 -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Dokument -->
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource MiniCard}">
                                <StackPanel>
                                    <TextBlock Text="DOKUMENT" Style="{StaticResource SectionLabel}"/>
                                    <TextBlock x:Name="txtNumerDokumentu" Style="{StaticResource FieldValue}" Text="-"/>
                                    <TextBlock x:Name="txtIdDokumentu" FontSize="9.5" Foreground="#95A5A6" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Kontrahent -->
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource MiniCard}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="KONTRAHENT" Style="{StaticResource SectionLabel}"/>
                                    <TextBlock x:Name="txtNazwaKontrahenta" Style="{StaticResource FieldValue}" Text="-" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="txtIdKontrahenta" FontSize="9.5" Foreground="#95A5A6" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Wartosci -->
                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource MiniCard}">
                                <StackPanel>
                                    <TextBlock Text="WARTOSCI" Style="{StaticResource SectionLabel}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="txtSumaKg" FontSize="16" FontWeight="Bold" Foreground="#1E8449"/>
                                        <TextBlock Text=" kg" FontSize="10" Foreground="#7F8C8D" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                        <TextBlock x:Name="txtSumaWartosc" FontSize="13" FontWeight="SemiBold" Foreground="#E74C3C"/>
                                        <TextBlock Text=" zl" FontSize="10" Foreground="#95A5A6" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Osoby -->
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource MiniCard}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="OSOBY" Style="{StaticResource SectionLabel}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,1,0,4">
                                        <Grid Width="22" Height="22" Margin="0,0,6,0">
                                            <Border x:Name="avatarZglaszajacyCard" Width="22" Height="22" CornerRadius="11"
                                                    Background="#3498DB">
                                                <TextBlock x:Name="txtAvatarZglaszajacyCard" Text="?"
                                                           Foreground="White" FontWeight="Bold" FontSize="8"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Ellipse x:Name="ellipseAvatarZglaszajacyCard" Width="22" Height="22" Visibility="Collapsed">
                                                <Ellipse.Fill>
                                                    <ImageBrush x:Name="imgBrushZglaszajacyCard" Stretch="UniformToFill"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </Grid>
                                        <TextBlock x:Name="txtZglaszajacy" FontSize="10.5" FontWeight="SemiBold"
                                                   Foreground="#2C3E50" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="110"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <Grid Width="22" Height="22" Margin="0,0,6,0">
                                            <Border x:Name="avatarRozpatrujacyCard" Width="22" Height="22" CornerRadius="11"
                                                    Background="#95A5A6">
                                                <TextBlock x:Name="txtAvatarRozpatrujacyCard" Text="?"
                                                           Foreground="White" FontWeight="Bold" FontSize="8"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Ellipse x:Name="ellipseAvatarRozpatrujacyCard" Width="22" Height="22" Visibility="Collapsed">
                                                <Ellipse.Fill>
                                                    <ImageBrush x:Name="imgBrushRozpatrujacyCard" Stretch="UniformToFill"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </Grid>
                                        <TextBlock x:Name="txtRozpatrujacy" FontSize="10.5" FontWeight="SemiBold"
                                                   Foreground="#2C3E50" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="110"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="28,0,0,0">
                                        <TextBlock Text="Typ: " FontSize="9" Foreground="#95A5A6"/>
                                        <TextBlock x:Name="txtTypReklamacji" FontSize="9" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- KATEGORIA (Etap 2.5) -->
                        <Border x:Name="sectionKategoria" Visibility="Collapsed" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="KATEGORYZACJA" Style="{StaticResource SectionLabel}"/>
                                <Border Background="#EAF2FB" CornerRadius="6" Padding="12,10"
                                        BorderBrush="#B3D7F2" BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="Kategoria: " FontSize="10" Foreground="#5D6D7E" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="txtKategoria" FontSize="11" FontWeight="Bold" Foreground="#1565C0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Podkategoria: " FontSize="10" Foreground="#5D6D7E" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="txtPodkategoria" FontSize="11" Foreground="#2C3E50"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- OPIS -->
                        <TextBlock Text="OPIS PROBLEMU" Style="{StaticResource SectionLabel}" Margin="0,4,0,4"/>
                        <Border Background="#F8FFF8" CornerRadius="6" Padding="12,10"
                                BorderBrush="#D5F5E3" BorderThickness="1" Margin="0,0,0,10">
                            <TextBlock x:Name="txtOpis" TextWrapping="Wrap" FontSize="11.5"
                                       Foreground="#2C3E50" LineHeight="19" Text="-" MaxHeight="120"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>

                        <!-- NOTATKA JAKOSCI (Workflow V2) -->
                        <Border x:Name="sectionNotatkaJakosci" Visibility="Collapsed" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="NOTATKI DZIALU JAKOSCI" Style="{StaticResource SectionLabel}"/>
                                <Border Background="#FFEBEE" CornerRadius="6" Padding="12,10"
                                        BorderBrush="#FFCDD2" BorderThickness="1">
                                    <TextBlock x:Name="txtNotatkaJakosci" TextWrapping="Wrap" FontSize="11"
                                               Foreground="#B71C1C" LineHeight="18" MaxHeight="140"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- KOMENTARZ -->
                        <Border x:Name="sectionKomentarz" Visibility="Collapsed" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="KOMENTARZE" Style="{StaticResource SectionLabel}"/>
                                <Border Background="#FFF8E1" CornerRadius="6" Padding="12,10"
                                        BorderBrush="#FFE082" BorderThickness="1">
                                    <TextBlock x:Name="txtKomentarz" TextWrapping="Wrap" FontSize="11"
                                               Foreground="#5D4037" LineHeight="18" MaxHeight="100"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ROZWIAZANIE -->
                        <Border x:Name="sectionRozwiazanie" Visibility="Collapsed" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="ROZWIAZANIE" Style="{StaticResource SectionLabel}"/>
                                <Border Background="#E8F5E9" CornerRadius="6" Padding="12,10"
                                        BorderBrush="#A5D6A7" BorderThickness="1">
                                    <TextBlock x:Name="txtRozwiazanie" TextWrapping="Wrap" FontSize="11"
                                               Foreground="#1B5E20" LineHeight="18" MaxHeight="100"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ROZPATRZENIE -->
                        <Border x:Name="sectionRozpatrzenie" Visibility="Collapsed" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="ROZPATRZENIE" Style="{StaticResource SectionLabel}"/>
                                <Border Background="#FFF3E0" CornerRadius="6" Padding="12,10"
                                        BorderBrush="#FFE0B2" BorderThickness="1" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="PRZYCZYNA GLOWNA" FontSize="9" FontWeight="SemiBold" Foreground="#E65100" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtPrzyczynaGlowna" TextWrapping="Wrap" FontSize="11"
                                                   Foreground="#4E342E" LineHeight="18"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#E8F5E9" CornerRadius="6" Padding="12,10"
                                        BorderBrush="#A5D6A7" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="AKCJE NAPRAWCZE" FontSize="9" FontWeight="SemiBold" Foreground="#1B5E20" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtAkcjeNaprawcze" TextWrapping="Wrap" FontSize="11"
                                                   Foreground="#1B5E20" LineHeight="18"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- RIGHT PANEL -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="5*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>

                <!-- TOWARY -->
                <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="14,10" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" Color="#000" Opacity="0.05" BlurRadius="8" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="REKLAMOWANE TOWARY" FontSize="12" FontWeight="SemiBold" Foreground="#1E8449"/>
                                <TextBlock x:Name="txtTowaryCount" Text=" (0)" FontSize="12" Foreground="#95A5A6" Margin="2,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock x:Name="txtTowarySumaKg" FontSize="11" Foreground="#1E8449" FontWeight="SemiBold"/>
                                <TextBlock Text="  |  " Foreground="#BDC3C7"/>
                                <TextBlock x:Name="txtTowarySumaWartosc" FontSize="11" Foreground="#E74C3C" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                        <Border Grid.Row="1" CornerRadius="6" BorderBrush="#E8E8E8" BorderThickness="1" ClipToBounds="True">
                            <DataGrid x:Name="dgTowary"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#F0F0F0" BorderThickness="0"
                                      CanUserReorderColumns="False" CanUserResizeRows="False"
                                      SelectionMode="Single" Background="White"
                                      RowBackground="White" AlternatingRowBackground="#FAFFFE"
                                      RowHeight="32" FontSize="11.5"
                                      ColumnHeaderStyle="{StaticResource GreenColumnHeader}"
                                      CellStyle="{StaticResource GreenCell}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Lp." Binding="{Binding Lp}" Width="40"/>
                                    <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="120"/>
                                    <DataGridTextColumn Header="Nazwa" Binding="{Binding Nazwa}" Width="*"/>
                                    <DataGridTextColumn Header="Waga [kg]" Binding="{Binding Waga, StringFormat={}{0:#\,##0.00}}" Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource RightAligned}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Cena" Binding="{Binding Cena, StringFormat={}{0:#\,##0.00}}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource RightAligned}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Wartosc" Binding="{Binding Wartosc, StringFormat={}{0:#\,##0.00}}" Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource RightAlignedBold}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                        <Border Grid.Row="2" x:Name="borderTowarySummary" Background="#E8F5E9" CornerRadius="0,0,6,6"
                                BorderBrush="#A5D6A7" BorderThickness="1,0,1,1" Padding="10,6" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtTowarySummaryInfo" FontSize="10.5" Foreground="#1B5E20" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- BOTTOM TABS: Zdjecia / Partie / Historia -->
                <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="0" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" Color="#000" Opacity="0.05" BlurRadius="8" Direction="270"/>
                    </Border.Effect>
                    <TabControl x:Name="tabBottom" BorderThickness="0" Background="Transparent" Padding="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Padding" Value="14,6"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </TabControl.Resources>

                        <!-- TAB: ZDJECIA / ZALACZNIKI -->
                        <TabItem x:Name="sectionZdjecia">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Zalaczniki "/>
                                    <TextBlock x:Name="txtZdjeciaCount" Text="(0)" Foreground="#95A5A6" FontWeight="Normal"/>
                                </StackPanel>
                            </TabItem.Header>
                            <Grid Margin="10,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Background="#F4F6F7" CornerRadius="6" Cursor="Hand"
                                        MouseLeftButtonDown="Preview_MouseDown" ClipToBounds="True"
                                        AllowDrop="True" DragEnter="Zalaczniki_DragEnter" Drop="Zalaczniki_Drop" DragLeave="Zalaczniki_DragLeave">
                                    <Grid>
                                        <Image x:Name="imgPreview" Stretch="Uniform" Margin="6"/>
                                        <TextBlock x:Name="txtNoPhoto" Text="Wybierz zdjecie z listy ponizej"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="#BDC3C7" FontSize="13" FontStyle="Italic"/>
                                        <TextBlock Text="Kliknij aby powiekszyc" HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom" Margin="0,0,10,6"
                                                   FontSize="9" Foreground="#95A5A6" FontStyle="Italic"
                                                   x:Name="txtKliknijPowieksz" Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                                <ListBox Grid.Row="1" x:Name="lbThumbnails"
                                         SelectionChanged="Thumbnail_SelectionChanged"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                         BorderThickness="0" Background="Transparent"
                                         Height="64" Margin="0,6,0,0">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,6,0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="bd" CornerRadius="4" BorderThickness="2"
                                                                BorderBrush="Transparent" Background="#F0F0F0"
                                                                ClipToBounds="True" Cursor="Hand"
                                                                Width="80" Height="56">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="bd" Property="BorderBrush" Value="#1E8449"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="BorderBrush" Value="#A9DFBF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding Miniatura}" Stretch="UniformToFill"
                                                   Width="76" Height="52"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button x:Name="btnDodajZalacznik" Content="+ Dodaj zalacznik" Click="BtnDodajZalacznik_Click"
                                            Padding="12,7" FontSize="11" FontWeight="SemiBold"
                                            Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,8,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="btnUsunZalacznik" Content="Usun" Click="BtnUsunZalacznik_Click"
                                            Padding="12,7" FontSize="11" FontWeight="SemiBold"
                                            Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"
                                            IsEnabled="False">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock x:Name="txtZalacznikiHint" Text="  JPG, PNG, PDF do 10MB  |  Przeciagnij pliki tutaj"
                                               FontSize="10" FontStyle="Italic" Foreground="#95A5A6"
                                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <!-- TAB: PARTIE -->
                        <TabItem x:Name="sectionPartie" Visibility="Collapsed">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Partie "/>
                                    <TextBlock x:Name="txtPartieCount" Text="(0)" Foreground="#95A5A6" FontWeight="Normal"/>
                                </StackPanel>
                            </TabItem.Header>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10,8">
                                <ItemsControl x:Name="icPartie">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,8" Margin="0,0,0,4" Background="#F8FFF8"
                                                    CornerRadius="5" BorderBrush="#D5F5E3" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding NumerPartii}" FontWeight="SemiBold" FontSize="11.5" Foreground="#2C3E50"/>
                                                        <TextBlock Text="{Binding Dostawca}" FontSize="10" Foreground="#7F8C8D" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding DataDodaniaStr}" FontSize="9.5"
                                                               Foreground="#95A5A6" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>

                        <!-- TAB: HISTORIA -->
                        <TabItem x:Name="sectionHistoria" Visibility="Collapsed">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Historia "/>
                                    <TextBlock x:Name="txtHistoriaCount" Text="(0)" Foreground="#95A5A6" FontWeight="Normal"/>
                                </StackPanel>
                            </TabItem.Header>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10,8">
                                <ItemsControl x:Name="icHistoria">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,8" Margin="0,0,0,4" Background="#FAFAFA"
                                                    CornerRadius="6" BorderBrush="#EEEEEE" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Avatar -->
                                                    <Grid Width="28" Height="28" Margin="0,0,8,0" VerticalAlignment="Top">
                                                        <Border Width="28" Height="28" CornerRadius="14"
                                                                Background="{Binding AvatarColor}">
                                                            <TextBlock Text="{Binding Inicjaly}" Foreground="White"
                                                                       FontWeight="Bold" FontSize="10"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Ellipse Width="28" Height="28" Visibility="{Binding AvatarPhotoVisibility}">
                                                            <Ellipse.Fill>
                                                                <ImageBrush ImageSource="{Binding AvatarPhoto}" Stretch="UniformToFill"/>
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                    </Grid>

                                                    <!-- Content -->
                                                    <StackPanel Grid.Column="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Ellipse Width="7" Height="7" Fill="{Binding KolorStatusu}"
                                                                     VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                            <TextBlock Text="{Binding PoprzedniStatus}" FontWeight="SemiBold"
                                                                       Foreground="#7F8C8D" FontSize="10.5"/>
                                                            <TextBlock Text=" ► " Foreground="#BDC3C7" FontSize="9" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding StatusNowy}" FontWeight="Bold"
                                                                       FontSize="10.5" Foreground="{Binding KolorStatusu}"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Uzytkownik}" Foreground="#7F8C8D"
                                                                   FontSize="9.5" Margin="0,1,0,0"/>
                                                        <TextBlock Text="{Binding Komentarz}" Foreground="#5D6D7E"
                                                                   FontSize="10" TextWrapping="Wrap" Margin="0,3,0,0"
                                                                   MaxHeight="40" TextTrimming="CharacterEllipsis"
                                                                   Visibility="{Binding KomentarzVisibility}"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2" Text="{Binding DataZmianyStr}" Foreground="#95A5A6"
                                                               FontSize="9.5" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>

                        <!-- TAB: KOMENTARZE WEWNETRZNE -->
                        <TabItem x:Name="sectionKomentarze">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Dyskusja "/>
                                    <TextBlock x:Name="txtKomentarzeCount" Text="(0)" Foreground="#95A5A6" FontWeight="Normal"/>
                                </StackPanel>
                            </TabItem.Header>
                            <Grid Margin="10,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="icKomentarze">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="10,8" Margin="0,0,0,6" Background="#FAFBFC"
                                                        CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid Width="30" Height="30" Margin="0,0,10,0" VerticalAlignment="Top">
                                                            <Border Width="30" Height="30" CornerRadius="15"
                                                                    Background="{Binding AvatarColor}">
                                                                <TextBlock Text="{Binding Inicjaly}" Foreground="White"
                                                                           FontWeight="Bold" FontSize="10"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <Ellipse Width="30" Height="30" Visibility="{Binding AvatarPhotoVisibility}">
                                                                <Ellipse.Fill>
                                                                    <ImageBrush ImageSource="{Binding AvatarPhoto}" Stretch="UniformToFill"/>
                                                                </Ellipse.Fill>
                                                            </Ellipse>
                                                        </Grid>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding UserName}" FontWeight="SemiBold" FontSize="11" Foreground="#2C3E50"/>
                                                            <TextBlock Text="{Binding Tresc}" TextWrapping="Wrap" FontSize="11.5"
                                                                       Foreground="#546E7A" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding DataStr}" FontSize="9.5"
                                                                   Foreground="#95A5A6" VerticalAlignment="Top"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <Border Grid.Row="1" Margin="0,8,0,0" Background="White" CornerRadius="8"
                                        BorderBrush="#DDE2E6" BorderThickness="1.5" Padding="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtNowyKomentarz" FontSize="12" Padding="12,10"
                                                 AcceptsReturn="False" BorderThickness="0" Background="Transparent"
                                                 VerticalContentAlignment="Center"/>
                                        <Button Grid.Column="1" x:Name="btnDodajKomentarz" Content="Wyslij" Click="BtnDodajKomentarz_Click"
                                                Padding="16,9" FontSize="11" FontWeight="SemiBold"
                                                Background="#1E8449" Foreground="White" BorderThickness="0" Cursor="Hand"
                                                Margin="4">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.85"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>

        <!-- JEDNA LINIA: status + kontekstowe przyciski + menu Wiecej + Zamknij -->
        <Border Grid.Row="3" Background="#F8F9FA" Padding="16,12" BorderThickness="0,1,0,0" BorderBrush="#D0D7DE">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LEWA: status + podpowiedz -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Status:" FontSize="11.5" Foreground="#7F8C8D" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <Border x:Name="badgeStatusFooter" CornerRadius="10" Padding="10,3" Background="#3498DB" Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtStatusFooter" Text="Nowa" FontSize="11" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <TextBlock x:Name="txtFooterHint" Text="Co dalej? Kliknij decyzje po prawej." FontSize="11.5" FontStyle="Italic" Foreground="#5D6D7E" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- PRAWA: kontekstowe akcje -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">

                    <!-- WORKFLOW: pojawiaja sie tylko gdy maja sens -->
                    <Button x:Name="btnQ_Przyjmij" Click="BtnQ_Przyjmij_Click"
                            Padding="16,8" Margin="0,0,6,0" FontSize="12" FontWeight="Bold"
                            Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Visibility="Collapsed"
                            ToolTip="Przyjmij do rozpatrzenia (przypisuje Cie jako rozpatrujacego)">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="① PRZYJMIJ" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="btnQ_Zatwierdz" Click="BtnQ_Zatwierdz_Click"
                            Padding="16,8" Margin="0,0,6,0" FontSize="12" FontWeight="Bold"
                            Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Visibility="Collapsed"
                            ToolTip="Uznaj jako zasadna - wymaga przyczyny i akcji naprawczych">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="✓ ZATWIERDZ" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="btnQ_Odrzuc" Click="BtnQ_Odrzuc_Click"
                            Padding="16,8" Margin="0,0,12,0" FontSize="12" FontWeight="Bold"
                            Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Visibility="Collapsed"
                            ToolTip="Odrzuc - wymaga podania powodu">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="✕ ODRZUC" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- WIECEJ: dropdown menu z narzedziami -->
                    <Button x:Name="btnWiecej" Click="BtnWiecej_Click"
                            Padding="14,8" Margin="0,0,6,0" FontSize="12" FontWeight="SemiBold"
                            Background="#ECF0F1" Foreground="#2C3E50" BorderThickness="0" Cursor="Hand"
                            ToolTip="Wiecej akcji: edytuj, PDF, e-mail, folder">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="⋯ Wiecej" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Popup x:Name="popupWiecej" PlacementTarget="{Binding ElementName=btnWiecej}" Placement="Top" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Background="White" CornerRadius="8" BorderBrush="#BDC3C7" BorderThickness="1" Padding="6">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="3" Color="#000000" Opacity="0.25" BlurRadius="14"/>
                            </Border.Effect>
                            <StackPanel Width="240">
                                <Button Click="BtnH_Edytuj_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="12,9" HorizontalContentAlignment="Left">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📝" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Edytuj dane" FontSize="12" Foreground="#2C3E50" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#F8F9FA"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Click="BtnExportPDF_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="12,9" HorizontalContentAlignment="Left">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🖨" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Generuj PDF" FontSize="12" Foreground="#2C3E50" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#F8F9FA"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Click="BtnEmail_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="12,9" HorizontalContentAlignment="Left">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="✉" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Wyslij e-mail klientowi" FontSize="12" Foreground="#2C3E50" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#F8F9FA"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Click="BtnOtworzFolder_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="12,9" HorizontalContentAlignment="Left">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📁" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Otworz folder zalacznikow" FontSize="12" Foreground="#2C3E50" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#F8F9FA"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Pojawia sie kontekstowo gdy reklamacja to korekta z Symfonii -->
                                <Button x:Name="btnZglosDoKorekty" Click="BtnZglosDoKorekty_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="12,9" HorizontalContentAlignment="Left" Visibility="Collapsed">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="#E8F5E9" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🔗" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Zglos reklamacje do tej korekty" FontSize="12" FontWeight="SemiBold" Foreground="#1E8449" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#D5F5E3"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- ZAMKNIJ -->
                    <Button Click="BtnZamknij_Click"
                            Padding="20,8" FontSize="12" FontWeight="SemiBold"
                            Background="#7F8C8D" Foreground="White" BorderThickness="0" Cursor="Hand" IsCancel="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
