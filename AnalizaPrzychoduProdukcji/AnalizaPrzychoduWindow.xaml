<Window x:Class="Kalendarz1.AnalizaPrzychoduProdukcji.AnalizaPrzychoduWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Analiza przychodu produkcji"
        MinHeight="650" MinWidth="1100"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F9FAFB"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- KOLORY -->
        <SolidColorBrush x:Key="Accent" Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentHover" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="TextDark" Color="#111827"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
        <SolidColorBrush x:Key="Border" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="BgCard" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgSubtle" Color="#F3F4F6"/>
        <SolidColorBrush x:Key="HeaderBg" Color="#1F2937"/>
        <SolidColorBrush x:Key="Success" Color="#059669"/>
        <SolidColorBrush x:Key="Danger" Color="#DC2626"/>

        <!-- PRIMARY BUTTON -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GHOST BUTTON (transparent) -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgSubtle}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- HEADER ICON BUTTON -->
        <Style x:Key="BtnHeader" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4B5563"/>
        </Style>

        <!-- PILL TOGGLE (RadioButton styled jako pigułka) -->
        <Style x:Key="Pill" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="14" Padding="{TemplateBinding Padding}"
                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BgSubtle}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Accent}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBOBOX -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- KARTA STAT -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- KARTA STAT KLIKALNA (drill-down) -->
        <Style x:Key="StatCardClickable" TargetType="Border" BasedOn="{StaticResource StatCardStyle}">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- LIVE TOGGLE BUTTON -->
        <Style x:Key="BtnLiveOff" TargetType="Button" BasedOn="{StaticResource BtnHeader}">
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#4B5563"/>
        </Style>
        <Style x:Key="BtnLiveOn" TargetType="Button" BasedOn="{StaticResource BtnHeader}">
            <Setter Property="Background" Value="#065F46"/>
            <Setter Property="BorderBrush" Value="#10B981"/>
        </Style>

        <!-- TAB ITEM -->
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="RowHeight" Value="26"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource BgSubtle}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0 header -->
            <RowDefinition Height="Auto"/>   <!-- 1 filter primary -->
            <RowDefinition Height="Auto"/>   <!-- 2 filter secondary (collapsible) -->
            <RowDefinition Height="Auto"/>   <!-- 3 active-filter badge bar -->
            <RowDefinition Height="Auto"/>   <!-- 4 stat cards -->
            <RowDefinition Height="Auto"/>   <!-- 5 health strip -->
            <RowDefinition Height="*"/>      <!-- 6 tabs -->
            <RowDefinition Height="Auto"/>   <!-- 7 footer -->
        </Grid.RowDefinitions>

        <!-- ============ HEADER (kompaktowy, 1 wiersz) ============ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBg}" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Analiza przychodu produkcji"
                               FontSize="16" FontWeight="SemiBold" Foreground="White"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtLastRefresh" Text=""
                               FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Center"
                               Margin="14,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnLive" Style="{StaticResource BtnLiveOff}"
                            Click="BtnLive_Click" Margin="0,0,6,0" Padding="10,6"
                            ToolTip="Tryb LIVE: automatyczne odświeżanie co 60 s (Ctrl+L)">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="dotLive" Width="8" Height="8" Fill="#9CA3AF"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="txtLiveLabel" Text="LIVE" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Content="Eksport CSV" Style="{StaticResource BtnHeader}"
                            Click="BtnExportExcel_Click" Margin="0,0,6,0"
                            ToolTip="Eksportuje przefiltrowane dane do pliku CSV (Ctrl+E)"/>
                    <Button Content="✕" Style="{StaticResource BtnHeader}"
                            Click="BtnClose_Click" Padding="10,6"
                            ToolTip="Zamyka okno (Esc po dwukrotnym wciśnięciu)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ FILTR PRIMARY (1 wiersz) ============ -->
        <Border Grid.Row="1" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="16,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Od:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12" FontWeight="SemiBold"/>
                <DatePicker x:Name="dpDataOd" Style="{StaticResource ModernDatePicker}" Width="120"
                            ToolTip="Data początkowa zakresu (włącznie)"
                            SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                <TextBlock Text="Do:" VerticalAlignment="Center" Margin="10,0,4,0" FontSize="12" FontWeight="SemiBold"/>
                <DatePicker x:Name="dpDataDo" Style="{StaticResource ModernDatePicker}" Width="120"
                            ToolTip="Data końcowa zakresu (włącznie)"
                            SelectedDateChanged="DatePicker_SelectedDateChanged"/>

                <Border Width="1" Background="{StaticResource Border}" Margin="10,4" VerticalAlignment="Stretch"/>

                <Button Content="Dziś" Style="{StaticResource BtnGhost}" Click="BtnPresetDzis_Click" Margin="2,0"
                        ToolTip="Tylko dzisiejszy dzień"/>
                <Button Content="Wczoraj" Style="{StaticResource BtnGhost}" Click="BtnPresetWczoraj_Click" Margin="2,0"
                        ToolTip="Tylko wczorajszy dzień"/>
                <Button Content="7 dni" Style="{StaticResource BtnGhost}" Click="BtnPreset7Dni_Click" Margin="2,0"
                        ToolTip="Ostatnie 7 dni włącznie z dzisiejszym"/>
                <Button Content="30 dni" Style="{StaticResource BtnGhost}" Click="BtnPreset30Dni_Click" Margin="2,0"
                        ToolTip="Ostatnie 30 dni włącznie z dzisiejszym"/>
                <Button Content="Tydz." Style="{StaticResource BtnGhost}" Click="BtnPresetTydzien_Click" Margin="2,0"
                        ToolTip="Bieżący tydzień (poniedziałek – dziś)"/>
                <Button Content="Mc" Style="{StaticResource BtnGhost}" Click="BtnPresetMiesiac_Click" Margin="2,0"
                        ToolTip="Bieżący miesiąc — od pierwszego do dziś"/>

                <Border Width="1" Background="{StaticResource Border}" Margin="10,4" VerticalAlignment="Stretch"/>

                <TextBlock Text="Towar:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbTowar" Style="{StaticResource ModernComboBox}" Width="220"
                          DisplayMemberPath="Nazwa" SelectedValuePath="Wartosc"
                          ToolTip="Filtruje wszystkie zakładki po wybranym artykule"
                          SelectionChanged="CbTowar_SelectionChanged"/>

                <Button x:Name="btnFiltry" Style="{StaticResource BtnGhost}" Click="BtnFiltry_Click"
                        Margin="10,0,0,0" Padding="10,6"
                        ToolTip="Pokaż / ukryj dodatkowe filtry (operator, partia, terminal, godzina, klasa)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Filtry"/>
                        <Ellipse x:Name="dotFiltryActive" Width="6" Height="6" Fill="{StaticResource Danger}"
                                 Margin="6,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"
                                 ToolTip="Aktywne dodatkowe filtry"/>
                        <TextBlock Text=" ▾" Margin="2,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Content="Odśwież" Style="{StaticResource BtnPrimary}" Click="BtnRefresh_Click"
                        Margin="10,0,0,0"
                        ToolTip="Wymusza ponowne pobranie filtrów i danych z bazy"/>
            </StackPanel>
        </Border>

        <!-- ============ FILTR SECONDARY (rozwijany) ============ -->
        <Border x:Name="pnlFiltrySecondary" Grid.Row="2" Background="{StaticResource BgSubtle}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                Padding="16,10" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Operator:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbOperator" Style="{StaticResource ModernComboBox}" Width="170"
                          DisplayMemberPath="Nazwa" SelectedValuePath="Wartosc"
                          ToolTip="Filtruje po operatorze wagi"
                          SelectionChanged="Filter_SelectionChanged"/>

                <TextBlock Text="Partia:" VerticalAlignment="Center" Margin="14,0,4,0" FontSize="12" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbPartia" Style="{StaticResource ModernComboBox}" Width="130"
                          DisplayMemberPath="Nazwa" SelectedValuePath="Wartosc"
                          ToolTip="Filtruje po numerze partii produkcyjnej (P1)"
                          SelectionChanged="Filter_SelectionChanged"/>

                <TextBlock Text="Terminal:" VerticalAlignment="Center" Margin="14,0,4,0" FontSize="12" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbTerminal" Style="{StaticResource ModernComboBox}" Width="100"
                          DisplayMemberPath="Nazwa" SelectedValuePath="Id"
                          ToolTip="Filtruje po stanowisku ważenia"
                          SelectionChanged="Filter_SelectionChanged"/>

                <TextBlock Text="Godz.:" VerticalAlignment="Center" Margin="14,0,4,0" FontSize="12" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbGodzinaOd" Style="{StaticResource ModernComboBox}" Width="65"
                          ToolTip="Godzina początkowa zakresu (włącznie)"
                          SelectionChanged="Filter_SelectionChanged"/>
                <TextBlock Text="–" VerticalAlignment="Center" Margin="3,0"/>
                <ComboBox x:Name="cbGodzinaDo" Style="{StaticResource ModernComboBox}" Width="65"
                          ToolTip="Godzina końcowa zakresu (włącznie)"
                          SelectionChanged="Filter_SelectionChanged"/>

                <StackPanel x:Name="pnlKlasaKurczaka" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="Klasa:" VerticalAlignment="Center" Margin="14,0,4,0" FontSize="12" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cbKlasaKurczaka" Style="{StaticResource ModernComboBox}" Width="80"
                              DisplayMemberPath="Nazwa" SelectedValuePath="Wartosc"
                              ToolTip="Klasa kurczaka 1–12 (tylko dla ArticleID=40)"
                              SelectionChanged="Filter_SelectionChanged"/>
                </StackPanel>

                <TextBlock Text="Dostawca:" VerticalAlignment="Center" Margin="14,0,4,0" FontSize="12" FontWeight="SemiBold"/>
                <ComboBox x:Name="cbDostawca" Style="{StaticResource ModernComboBox}" Width="200"
                          DisplayMemberPath="Nazwa" SelectedValuePath="Wartosc"
                          ToolTip="Filtruje po dostawcy partii surowca (z PartiaDostawca)"
                          SelectionChanged="Filter_SelectionChanged"/>

                <CheckBox x:Name="chkPorownanie" Content="Porównaj z poprzednim okresem"
                          VerticalAlignment="Center" Margin="20,0,0,0" FontSize="12" FontWeight="SemiBold"
                          ToolTip="Włącza obliczanie zmiany % vs. równie długi poprzedzający okres (widoczne w karcie TREND)"
                          Checked="ChkPorownanie_Changed" Unchecked="ChkPorownanie_Changed"/>

                <Button x:Name="btnResetFiltry" Content="Wyczyść filtry" Style="{StaticResource BtnGhost}"
                        Click="BtnResetFiltry_Click" Margin="20,0,0,0"
                        ToolTip="Resetuje wszystkie dodatkowe filtry do wartości domyślnych"/>
            </StackPanel>
        </Border>

        <!-- ============ ACTIVE-FILTER BADGES (drill-down indicator) ============ -->
        <Border x:Name="pnlActiveBadges" Grid.Row="3" Background="#EFF6FF"
                BorderBrush="#BFDBFE" BorderThickness="0,0,0,1"
                Padding="16,6" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Aktywne filtry:" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextDark}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ItemsControl x:Name="icBadges">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ============ STAT CARDS (5) ============ -->
        <Border Grid.Row="4" Padding="16,10,16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCardClickable}"
                        MouseLeftButtonUp="StatCardSuma_Click"
                        ToolTip="Klik = przejdź do zakładki Wykres">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#DBEAFE" CornerRadius="8" Width="36" Height="36"
                                VerticalAlignment="Top" Margin="0,2,10,0">
                            <TextBlock Text="📦" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="SUMA PRZYCHODU" FontSize="10" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtSumaKg" Text="0 kg" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextDark}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="txtSumaKgInfo" Text="" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatCardClickable}"
                        MouseLeftButtonUp="StatCardLiczba_Click"
                        ToolTip="Klik = przejdź do zakładki Tabela (surowe rekordy)">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#CCFBF1" CornerRadius="8" Width="36" Height="36"
                                VerticalAlignment="Top" Margin="0,2,10,0">
                            <TextBlock Text="🔢" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="LICZBA WAŻEŃ" FontSize="10" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtLiczbaWazen" Text="0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextDark}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="txtLiczbaWazenInfo" Text="" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatCardClickable}"
                        MouseLeftButtonUp="StatCardSrednia_Click"
                        ToolTip="Klik = wykres pogrupowany wg Dnia">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#EDE9FE" CornerRadius="8" Width="36" Height="36"
                                VerticalAlignment="Top" Margin="0,2,10,0">
                            <TextBlock Text="📅" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="ŚREDNIA / DZIEŃ" FontSize="10" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtSredniaDzien" Text="0 kg" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextDark}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="txtSredniaDzienInfo" Text="" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource StatCardClickable}"
                        MouseLeftButtonUp="StatCardOdchylenie_Click"
                        ToolTip="Klik = tabela posortowana po Różnicy malejąco">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#FEE2E2" CornerRadius="8" Width="36" Height="36"
                                VerticalAlignment="Top" Margin="0,2,10,0">
                            <TextBlock Text="⚖" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="ODCHYLENIE OD STANDARDU" FontSize="10" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtOdchylenie" Text="0 kg" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextDark}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="txtOdchylenieInfo" Text="" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource StatCardClickable}" Margin="0"
                        MouseLeftButtonUp="StatCardTrend_Click"
                        ToolTip="Klik = włącz porównanie z poprzednim okresem i przejdź do widoku Dzień">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#FEF3C7" CornerRadius="8" Width="36" Height="36"
                                VerticalAlignment="Top" Margin="0,2,10,0">
                            <TextBlock Text="📊" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TREND vs POPRZ. OKRES" FontSize="10" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtTrend" Text="—" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="txtTrendInfo" Text="włącz porównanie okresów" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ============ HEALTH STRIP (insighty / alerty) ============ -->
        <Border x:Name="pnlHealthStrip" Grid.Row="5" Padding="16,0,16,8" Visibility="Collapsed">
            <Border x:Name="brdHealthInner" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="6" Padding="12,7">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="dotHealth" Width="9" Height="9" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="txtHealthTitle" Text="Stan: OK" FontSize="12" FontWeight="SemiBold"
                               Foreground="#065F46" VerticalAlignment="Center"/>
                    <Border Width="1" Background="#A7F3D0" Margin="10,2" VerticalAlignment="Stretch"/>
                    <ItemsControl x:Name="icHealthItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Border>

        <!-- ============ TABS (6) ============ -->
        <TabControl Grid.Row="6" Margin="16,0,16,8" x:Name="tabControl"
                    Background="Transparent" BorderThickness="0"
                    SelectionChanged="TabControl_SelectionChanged">

            <!-- ===== TAB: WYKRES ===== -->
            <TabItem Header="Wykres">
                <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Pill grouping -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Pokazuj wg:" VerticalAlignment="Center"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,8,0"/>
                            <RadioButton x:Name="pillGodzina" Content="Godzina" GroupName="Grup" Style="{StaticResource Pill}" IsChecked="True" Checked="Pill_Checked" ToolTip="Grupuj wg godziny doby (00:00–23:00)"/>
                            <RadioButton x:Name="pillDzien"   Content="Dzień"   GroupName="Grup" Style="{StaticResource Pill}" Checked="Pill_Checked" ToolTip="Grupuj wg daty (każdy dzień jako słupek)"/>
                            <RadioButton x:Name="pillOperator" Content="Operator" GroupName="Grup" Style="{StaticResource Pill}" Checked="Pill_Checked" ToolTip="Grupuj wg operatora wagi"/>
                            <RadioButton x:Name="pillTowar"    Content="Towar"    GroupName="Grup" Style="{StaticResource Pill}" Checked="Pill_Checked" ToolTip="Grupuj wg artykułu"/>
                            <RadioButton x:Name="pillPartia"   Content="Partia"   GroupName="Grup" Style="{StaticResource Pill}" Checked="Pill_Checked" ToolTip="Grupuj wg numeru partii (P1)"/>
                            <RadioButton x:Name="pillTerminal" Content="Terminal" GroupName="Grup" Style="{StaticResource Pill}" Checked="Pill_Checked" ToolTip="Grupuj wg stanowiska ważenia"/>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <lvc:CartesianChart x:Name="chartPrzychod">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Labels="{Binding PrzychodLabels}" LabelsRotation="45" FontSize="11"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis LabelFormatter="{Binding YFormatter}" FontSize="11"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                            <StackPanel x:Name="emptyWykres" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <TextBlock Text="📭" FontSize="36" HorizontalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="Brak danych w wybranym okresie" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextDark}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                <TextBlock Text="Spróbuj rozszerzyć zakres dat lub wyczyścić filtry" FontSize="11"
                                           Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,4,0,12"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Ostatnie 30 dni" Style="{StaticResource BtnGhost}"
                                            Click="BtnPreset30Dni_Click" Margin="2,0"/>
                                    <Button Content="Wyczyść filtry" Style="{StaticResource BtnGhost}"
                                            Click="BtnResetFiltry_Click" Margin="2,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ===== TAB: OPERATORZY ===== -->
            <TabItem Header="Operatorzy">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="380"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Filtr typu operatora -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Pokaż:" VerticalAlignment="Center"
                                           FontSize="12" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <RadioButton x:Name="opAll"      Content="Wszyscy"     GroupName="OpType" Style="{StaticResource Pill}" IsChecked="True" Checked="OpType_Checked"
                                             ToolTip="Wszyscy operatorzy razem"/>
                                <RadioButton x:Name="opPorcjuje" Content="Porcjujący" GroupName="OpType" Style="{StaticResource Pill}" Checked="OpType_Checked"
                                             ToolTip="Operatorzy ważący produkty końcowe (filet, korpus, ćwiartki itd.) – bez paletyzacji kurczaka A"/>
                                <RadioButton x:Name="opPaletuje" Content="Paletujący" GroupName="OpType" Style="{StaticResource Pill}" Checked="OpType_Checked"
                                             ToolTip="Operatorzy ważący kurczak Klasy A (palety surowca, ArticleID=40)"/>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <lvc:CartesianChart x:Name="chartOperatorzy">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Labels="{Binding OperatorLabels}" LabelsRotation="45" FontSize="11"/>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis LabelFormatter="{Binding YFormatter}" FontSize="11"/>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                                <StackPanel x:Name="emptyOperatorzy" HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                    <TextBlock Text="👥" FontSize="32" HorizontalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock Text="Brak danych operatorów" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextDark}" HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                    <TextBlock Text="Może filtr typu odcina wszystkich – sprawdź pillsy 'Pokaż'" FontSize="11"
                                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Margin="14,12,14,8">
                                <TextBlock Text="Ranking operatorów" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextDark}"/>
                                <TextBlock Text="Dwuklik = filtr po operatorze" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <DataGrid x:Name="dgRankingOperatorow" Grid.Row="1" Margin="0,0,0,8"
                                      MouseDoubleClick="DgRankingOperatorow_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="35"/>
                                    <DataGridTextColumn Header="Operator" Binding="{Binding Nazwa}" Width="*"/>
                                    <DataGridTemplateColumn Header="Suma kg" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid Margin="2,0">
                                                    <ProgressBar Maximum="100" Value="{Binding PctMax, Mode=OneWay}"
                                                                 Height="14" Background="{StaticResource BgSubtle}"
                                                                 Foreground="#93C5FD"
                                                                 BorderThickness="0"/>
                                                    <TextBlock Text="{Binding SumaKg, StringFormat=N0}"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                                               Margin="0,0,6,0" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextDark}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Ważeń" Binding="{Binding LiczbaWazen}" Width="60"/>
                                    <DataGridTextColumn Header="Anul." Binding="{Binding LiczbaAnulacji}" Width="50">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LiczbaAnulacji}" Value="0">
                                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== TAB: TOWARY (artykuły + warunkowe klasy) ===== -->
            <TabItem Header="Towary">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Margin="14,12,14,8">
                                <TextBlock Text="Przychody wg artykułów" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextDark}"/>
                                <TextBlock Text="Dwuklik = filtr po artykule" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <DataGrid x:Name="dgPrzychodyArtykuly" Grid.Row="1" Margin="0,0,0,8"
                                      MouseDoubleClick="DgPrzychodyArtykuly_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding ArticleID}" Width="50"/>
                                    <DataGridTextColumn Header="Skrót" Binding="{Binding ShortName}" Width="100"/>
                                    <DataGridTextColumn Header="Nazwa" Binding="{Binding ArticleName}" Width="*" MinWidth="200"/>
                                    <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N2}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="% udział" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid VerticalAlignment="Center" Margin="0,0,4,0">
                                                    <ProgressBar Maximum="100" Value="{Binding Procent, Mode=OneWay}"
                                                                 Height="14" Background="{StaticResource BgSubtle}"
                                                                 Foreground="{StaticResource Accent}"
                                                                 BorderThickness="0"/>
                                                    <TextBlock Text="{Binding Procent, StringFormat={}{0:N1}%}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextDark}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Ważeń" Binding="{Binding LiczbaWazen}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Śred. kg" Binding="{Binding SredniaKg, StringFormat=N2}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Sekcja klasy kurczaka — tylko gdy ArticleID=40 -->
                    <Border x:Name="pnlKlasySection" Grid.Row="1" Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6"
                            Margin="0,8,0,0" Padding="14" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="380"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="200"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.ColumnSpan="2" Text="Rozkład klas kurczaka (ArticleID = 40)"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <lvc:PieChart Grid.Row="1" x:Name="chartKlasy" LegendLocation="Bottom"/>

                            <DataGrid Grid.Row="1" Grid.Column="1" x:Name="dgKlasy" Margin="14,0,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Klasa" Binding="{Binding Klasa}" Width="55"/>
                                    <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N2}" Width="85"/>
                                    <DataGridTextColumn Header="%" Binding="{Binding Procent, StringFormat=N1}" Width="50"/>
                                    <DataGridTextColumn Header="Liczba" Binding="{Binding Liczba}" Width="60"/>
                                    <DataGridTextColumn Header="Śred." Binding="{Binding SredniaKg, StringFormat=N2}" Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== TAB: PARTIE ===== -->
            <TabItem Header="Partie">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="450"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Margin="14,12,14,8">
                                <TextBlock Text="Partie (P1)" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Klik = szczegóły · Dwuklik = filtruj" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <DataGrid x:Name="dgPartie" Grid.Row="1" Margin="0,0,0,8"
                                      SelectionChanged="DgPartie_SelectionChanged"
                                      MouseDoubleClick="DgPartie_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Partia" Binding="{Binding Partia}" Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Dostawca" Binding="{Binding Dostawca}" Width="*" MinWidth="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding Dostawca}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Dostawca}" Value="">
                                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                                        <Setter Property="FontStyle" Value="Italic"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N2}" Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="% udział" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid VerticalAlignment="Center" Margin="0,0,4,0">
                                                    <ProgressBar Maximum="100" Value="{Binding Procent, Mode=OneWay}"
                                                                 Height="14" Background="{StaticResource BgSubtle}"
                                                                 Foreground="{StaticResource Accent}"
                                                                 BorderThickness="0"/>
                                                    <TextBlock Text="{Binding Procent, StringFormat={}{0:N1}%}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextDark}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Ważeń" Binding="{Binding Liczba}" Width="60">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Margin="14,12,14,8">
                                <TextBlock x:Name="txtPartiaHeader" Text="Szczegóły partii" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtPartiaInfo" Text="Wybierz partię z listy" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <DataGrid x:Name="dgPartieArtykuly" Grid.Row="1" Margin="0,0,0,8"
                                      MouseDoubleClick="DgPartieArtykuly_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Artykuł" Binding="{Binding ArticleName}" Width="*"/>
                                    <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N2}" Width="80"/>
                                    <DataGridTextColumn Header="%" Binding="{Binding Procent, StringFormat=N1}" Width="50"/>
                                    <DataGridTextColumn Header="Szt" Binding="{Binding LiczbaWazen}" Width="50"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button x:Name="btnPokazWszystkieWazenia" Grid.Row="2"
                                    Content="Pokaż wszystkie ważenia z tej partii"
                                    Style="{StaticResource BtnPrimary}" Margin="14,0,14,12"
                                    Click="BtnPokazWszystkieWazenia_Click" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== TAB: WZORCE (heatmap | zmiany | dni - internal toggle) ===== -->
            <TabItem Header="Wzorce">
                <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <RadioButton x:Name="wzMapa"   Content="Mapa cieplna"  GroupName="Wz" Style="{StaticResource Pill}" IsChecked="True" Checked="Wzorzec_Checked"/>
                            <RadioButton x:Name="wzZmiany" Content="Zmiany"        GroupName="Wz" Style="{StaticResource Pill}" Checked="Wzorzec_Checked"/>
                            <RadioButton x:Name="wzDni"    Content="Dni tygodnia"  GroupName="Wz" Style="{StaticResource Pill}" Checked="Wzorzec_Checked"/>
                        </StackPanel>

                        <!-- Mapa cieplna -->
                        <ScrollViewer Grid.Row="1" x:Name="boxMapa" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icHeatmap">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Zmiany -->
                        <Grid Grid.Row="1" x:Name="boxZmiany" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="320"/>
                            </Grid.ColumnDefinitions>

                            <lvc:CartesianChart x:Name="chartZmiany">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Labels="{Binding ZmianyLabels}" FontSize="11"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis LabelFormatter="{Binding YFormatter}" FontSize="11"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>

                            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="ZMIANA DZIENNA (5:00–21:00)" FontSize="10" FontWeight="SemiBold" Foreground="#047857"/>
                                        <TextBlock x:Name="txtZmianaDzienna" Text="0 kg" FontSize="18" FontWeight="Bold" Foreground="#065F46"/>
                                        <TextBlock x:Name="txtZmianaDziennaSzt" Text="0 ważeń" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#EEF2FF" BorderBrush="#A5B4FC" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="ZMIANA NOCNA (21:00–5:00)" FontSize="10" FontWeight="SemiBold" Foreground="#3730A3"/>
                                        <TextBlock x:Name="txtZmianaNocna" Text="0 kg" FontSize="18" FontWeight="Bold" Foreground="#312E81"/>
                                        <TextBlock x:Name="txtZmianaNocnaSzt" Text="0 ważeń" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{StaticResource BgSubtle}" CornerRadius="6" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="NAJLEPSZA ZMIANA" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock x:Name="txtNajlepszaZmiana" Text="–" FontSize="14" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Dni tygodnia -->
                        <Grid Grid.Row="1" x:Name="boxDni" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="320"/>
                            </Grid.ColumnDefinitions>

                            <lvc:CartesianChart x:Name="chartDniTygodnia">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Labels="{Binding DniTygodniaLabels}" FontSize="11"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis LabelFormatter="{Binding YFormatter}" FontSize="11"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>

                            <DataGrid x:Name="dgDniTygodnia" Grid.Column="1" Margin="14,0,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Dzień" Binding="{Binding DzienTygodnia}" Width="*"/>
                                    <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat=N2}" Width="85"/>
                                    <DataGridTextColumn Header="Śred." Binding="{Binding SredniaKg, StringFormat=N2}" Width="75"/>
                                    <DataGridTextColumn Header="Dni" Binding="{Binding LiczbaDni}" Width="45"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ===== TAB: TABELA (surowe dane) ===== -->
            <TabItem Header="Tabela">
                <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="dgSzczegoly" Margin="0,8,0,0"
                                  CanUserSortColumns="True" CanUserReorderColumns="True"
                                  CanUserResizeColumns="True"
                                  EnableRowVirtualization="True"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="🔍 Filtruj po operatorze" Click="CtxFilterOperator_Click"/>
                                    <MenuItem Header="🔍 Filtruj po partii" Click="CtxFilterPartia_Click"/>
                                    <MenuItem Header="🔍 Filtruj po towarze" Click="CtxFilterTowar_Click"/>
                                    <MenuItem Header="🔍 Filtruj po terminalu" Click="CtxFilterTerminal_Click"/>
                                    <Separator/>
                                    <MenuItem Header="📋 Kopiuj wiersz" Click="CtxCopyRow_Click"/>
                                    <MenuItem Header="📦 Pokaż wszystkie ważenia tej partii" Click="CtxShowPartiaWazenia_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data" Binding="{Binding Data, StringFormat=yyyy-MM-dd}" Width="95"/>
                                <DataGridTextColumn Header="Godz." Binding="{Binding Godzina, StringFormat=HH:mm:ss}" Width="80"/>
                                <DataGridTextColumn Header="Towar" Binding="{Binding NazwaTowaru}" Width="*" MinWidth="180"/>
                                <DataGridTextColumn Header="kg standard" Binding="{Binding Weight, StringFormat=N2}" Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                            <Setter Property="ToolTip" Value="Waga standardowa (Weight)"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="kg rzeczywiste" Binding="{Binding ActWeight, StringFormat=N2}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="ToolTip" Value="Faktyczna waga netto (ActWeight)"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Różnica" Binding="{Binding Roznica, StringFormat={}{0:+0.00;-0.00;0.00}}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="ToolTip" Value="Różnica = kg rzeczywiste − kg standard. Plus = dokładamy, minus = za mało."/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Dokladamy}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Niedowaga}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="% odch." Binding="{Binding RoznicaProc, StringFormat={}{0:+0.0;-0.0;0.0}}" Width="65">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Operator" Binding="{Binding Operator}" Width="130"/>
                                <DataGridTextColumn Header="Partia" Binding="{Binding Partia}" Width="100"/>
                                <DataGridTextColumn Header="Term." Binding="{Binding Terminal}" Width="65"/>
                                <DataGridTextColumn Header="Wielkość" Binding="{Binding Klasa}" Width="65">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="ToolTip" Value="Wielkość/klasa (QntInCont) – tylko dla kurczaka"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Tara" Binding="{Binding Tara, StringFormat=N2}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="1" Padding="14,8" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="txtLiczbaWierszy" Text="0 rekordów" FontSize="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Eksport CSV" Style="{StaticResource BtnPrimary}" Click="BtnExportExcel_Click"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- ============ FOOTER (slim) ============ -->
        <Border Grid.Row="7" Background="{StaticResource BgSubtle}" Padding="16,5" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="txtStatus" Text="Gotowy" FontSize="11" Foreground="{StaticResource TextMuted}"/>
        </Border>

        <!-- ============ LOADING OVERLAY ============ -->
        <Border x:Name="loadingOverlay" Grid.Row="0" Grid.RowSpan="8"
                Background="#80F9FAFB" Visibility="Collapsed" Panel.ZIndex="999">
            <Border Background="{StaticResource BgCard}" CornerRadius="10" Padding="32,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="240" BorderBrush="{StaticResource Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="⏳" FontSize="26" HorizontalAlignment="Center"/>
                    <TextBlock Text="Ładowanie danych…" FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,8,0,4"
                               Foreground="{StaticResource TextDark}"/>
                    <TextBlock x:Name="txtLoadingDetails" Text="Pobieram z bazy LibraNet"
                               FontSize="11" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <ProgressBar IsIndeterminate="True" Height="3" Width="180"
                                 Background="{StaticResource BgSubtle}"
                                 Foreground="{StaticResource Accent}"
                                 BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
