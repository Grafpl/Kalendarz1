<Window x:Class="Kalendarz1.Zywiec.WidokSpecyfikacji.DopasujFaktureZakupuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dopasuj fakturę zakupu do dostawy"
        Height="660" Width="980"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F7FA"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="LabelText">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="ValueText">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,10"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="DOSTAWCA" Style="{StaticResource LabelText}"/>
                    <TextBlock x:Name="txtDostawca" Text="—" Style="{StaticResource ValueText}" FontSize="14" Margin="0,2,0,0"/>
                    <TextBlock x:Name="txtDostawcaMeta" Text="" Style="{StaticResource LabelText}" Margin="0,2,0,0" FontWeight="Normal"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="DOSTAWA (FarmerCalc)" Style="{StaticResource LabelText}"/>
                    <TextBlock x:Name="txtDostawa" Text="—" Style="{StaticResource ValueText}" FontSize="14" Margin="0,2,0,0"/>
                    <TextBlock x:Name="txtDostawaKg" Text="" Style="{StaticResource LabelText}" Margin="0,2,0,0" FontWeight="Normal"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="OBECNA FAKTURA" Style="{StaticResource LabelText}"/>
                    <TextBlock x:Name="txtObecnyNr" Text="(brak)" Style="{StaticResource ValueText}" FontSize="14" Margin="0,2,0,0" Foreground="#2563EB"/>
                    <TextBlock x:Name="txtObecnyMeta" Text="" Style="{StaticResource LabelText}" Margin="0,2,0,0" FontWeight="Normal"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Range filter -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Pokaż faktury z:" VerticalAlignment="Center" Margin="0,0,8,0"
                       Style="{StaticResource LabelText}"/>
            <ComboBox Grid.Column="1" x:Name="cmbRange" Width="180" Padding="6,4"
                      SelectionChanged="CmbRange_SelectionChanged">
                <ComboBoxItem Content="Ostatni miesiąc" IsSelected="True"/>
                <ComboBoxItem Content="Ostatnie 3 miesiące"/>
                <ComboBoxItem Content="Ostatnie 6 miesięcy"/>
                <ComboBoxItem Content="Ostatni rok"/>
            </ComboBox>
            <CheckBox Grid.Column="3" x:Name="chkKorekty" Content="Pokaż również korekty (FKZ)"
                      IsChecked="True" VerticalAlignment="Center"
                      Checked="ChkKorekty_Changed" Unchecked="ChkKorekty_Changed"/>
        </Grid>

        <!-- DataGrid -->
        <Border Grid.Row="2" Background="White" CornerRadius="6"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="dgInvoices"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="34"
                      MouseDoubleClick="DgInvoices_MouseDoubleClick"
                      Background="Transparent" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Numer" Binding="{Binding Numer}" Width="170">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Typ" Binding="{Binding Typ}" Width="60"/>
                    <DataGridTextColumn Header="Data" Binding="{Binding DataStr}" Width="100"/>
                    <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaStr}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="0,0,8,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Wartość netto" Binding="{Binding WartoscStr}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="0,0,8,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Zgodność" Width="*" MinWidth="240">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusIcon}" Foreground="{Binding StatusBrush}"
                                               FontWeight="Bold" FontSize="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="txtInfo"
                       Text="Ładowanie..."
                       Foreground="#64748B" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="  Odepnij fakturę  "
                    Padding="14,7" MinHeight="34" Margin="0,0,8,0"
                    Background="White" Foreground="#B91C1C"
                    BorderBrush="#FCA5A5" BorderThickness="1" Cursor="Hand"
                    Click="BtnOdepnij_Click"
                    ToolTip="Usun przypisanie FV z tej dostawy"/>
            <Button Grid.Column="2" Content="  ✓ Przypisz wybraną  "
                    Padding="14,7" MinHeight="34" Margin="0,0,8,0"
                    Background="#2563EB" Foreground="White" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnWybierz_Click"/>
            <Button Grid.Column="3" Content="  Anuluj  "
                    Padding="14,7" MinHeight="34"
                    Background="White" Foreground="#475569"
                    BorderBrush="#CBD5E1" BorderThickness="1" Cursor="Hand"
                    Click="BtnAnuluj_Click"/>
        </Grid>
    </Grid>
</Window>
