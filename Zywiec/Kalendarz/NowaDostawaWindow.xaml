<Window x:Class="Kalendarz1.Zywiec.Kalendarz.NowaDostawaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nowa dostawa"
        Height="980" Width="900"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Style przycisku akcji - primary -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#059669"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#9CA3AF"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#9CA3AF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D1D5DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Status toggle button -->
        <Style x:Key="StatusToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.06" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E40AF"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="FieldValueStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="FieldBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="58"/>
        </Style>
    </Window.Resources>

    <!-- Okno z borderem i cieniem -->
    <Border Background="#F1F5F9" CornerRadius="12" BorderBrush="#94A3B8" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" Opacity="0.4" ShadowDepth="6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- HEADER -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Background="#10B981" CornerRadius="12,12,0,0" Padding="22,15" MouseLeftButtonDown="Header_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="➕" FontSize="26" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="Nowa dostawa" FontSize="19" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="txtHeaderDate" FontSize="12" Foreground="#D1FAE5" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1" Content="✕" Click="BtnClose_Click" Cursor="Hand"
                            Background="Transparent" Foreground="White" BorderThickness="0"
                            FontSize="16" Width="34" Height="34" ToolTip="Zamknij (Esc)"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- ZAWARTOŚĆ -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,14">
                <StackPanel>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- 1. KIM I KIEDY -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="📋 KIM I KIEDY" Style="{StaticResource SectionHeaderStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="190"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Hodowca" Foreground="#475569" Style="{StaticResource FieldLabelStyle}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" x:Name="cmbDostawca" FontSize="13" Padding="8,6" Height="36"
                                                  IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                                  SelectionChanged="CmbDostawca_SelectionChanged"
                                                  KeyDown="CmbDostawca_KeyDown"
                                                  ToolTip="Wybierz hodowcę z listy lub zacznij wpisywać nazwę"/>
                                        <Button Grid.Column="1" Click="BtnRefreshHodowcy_Click" Margin="6,0,0,0"
                                                Background="#F3F4F6" BorderThickness="0" Cursor="Hand"
                                                Width="36" Height="36" ToolTip="Odśwież listę hodowców z bazy">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock Text="🔄" FontSize="14"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <Border Grid.Column="1" Width="1" Background="#E5E7EB" Margin="6,18,6,0"/>

                                <StackPanel Grid.Column="2" Margin="6,0,0,0">
                                    <TextBlock Text="Data odbioru" Foreground="#475569" Style="{StaticResource FieldLabelStyle}"/>
                                    <DatePicker x:Name="dpData" FontSize="13" Height="36" Padding="6,4"
                                                SelectedDateChanged="DpData_SelectedDateChanged"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- 2. KONFLIKT - hodowca ma już dostawę tego dnia -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <Border x:Name="borderConflict" Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="2" CornerRadius="10" Padding="14,10" Margin="0,0,0,10" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock x:Name="txtConflictMessage" FontSize="12" FontWeight="SemiBold" Foreground="#92400E" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- 4. KALKULATOR TRANSPORTU (bidirectional) -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <Border Style="{StaticResource SectionCardStyle}" Background="#EFF6FF" BorderBrush="#93C5FD">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="🧮" FontSize="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="KALKULATOR TRANSPORTU" FontSize="13" FontWeight="Bold" Foreground="#1E40AF" VerticalAlignment="Center"/>
                                    <Border Background="#DBEAFE" CornerRadius="3" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="wpisz dowolne 2 z 3 pól" FontSize="10" Foreground="#1E40AF"/>
                                    </Border>
                                </StackPanel>
                                <Button Grid.Column="1" Click="BtnUseCalc_Click" FontSize="11" Padding="12,5" Cursor="Hand"
                                        Background="#3B82F6" Foreground="White" BorderThickness="0"
                                        ToolTip="Wstaw obliczone wartości do pól dostawy">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✅" FontSize="11" Margin="0,0,5,0"/>
                                        <TextBlock Text="Wstaw do pól" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- 3 pola = bidirectional -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="1.4*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Szt/szuf -->
                                <Border Grid.Column="0" Background="White" Style="{StaticResource FieldBorderStyle}" BorderBrush="#BFDBFE" MinHeight="64">
                                    <StackPanel>
                                        <TextBlock Text="📦 Szt/szuf" Foreground="#1D4ED8" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="txtCalcSztSzuflada" Style="{StaticResource FieldValueStyle}" Foreground="#1E40AF"
                                                 TextChanged="CalcField_TextChanged" TextAlignment="Center" FontSize="20"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Grid.Column="1" Text="×" FontSize="24" FontWeight="Bold" Foreground="#1D4ED8" VerticalAlignment="Center" Margin="10,18,10,0"/>

                                <!-- Auta -->
                                <Border Grid.Column="2" Background="White" Style="{StaticResource FieldBorderStyle}" BorderBrush="#BFDBFE" MinHeight="64">
                                    <StackPanel>
                                        <TextBlock Text="🚚 Auta" Foreground="#1D4ED8" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="txtCalcAuta" Style="{StaticResource FieldValueStyle}" Foreground="#1E40AF"
                                                 TextChanged="CalcField_TextChanged" TextAlignment="Center" FontSize="20"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Grid.Column="3" Text="=" FontSize="24" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center" Margin="10,18,10,0"/>

                                <!-- Suma sztuk -->
                                <Border Grid.Column="4" Background="#10B981" Style="{StaticResource FieldBorderStyle}" BorderBrush="#059669" MinHeight="64">
                                    <StackPanel>
                                        <TextBlock Text="🐔 Suma sztuk" Foreground="#D1FAE5" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="txtCalcSumaSztuki" Style="{StaticResource FieldValueStyle}" Foreground="White"
                                                 TextChanged="CalcField_TextChanged" TextAlignment="Center" FontSize="20"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Hint pomocniczy -->
                            <TextBlock x:Name="txtCalcHint" FontSize="10" Foreground="#1E40AF" Margin="0,8,0,0" FontStyle="Italic" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- 5. GŁÓWNE DANE DOSTAWY -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="🚚 DANE DOSTAWY" Style="{StaticResource SectionHeaderStyle}"/>

                            <!-- Wiersz 1: Waga, Szt/szuf, Sztuki, Auta, obl.A -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Waga -->
                                <Border x:Name="borderWaga" Grid.Column="0" Background="#F0FDF4" Style="{StaticResource FieldBorderStyle}" BorderBrush="#BBF7D0" Margin="0,0,4,0">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="⚖️ Waga (kg)" Foreground="#15803D" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Grid.Column="1" x:Name="badgeWaga" FontSize="9" FontWeight="Bold" Foreground="#DC2626" Visibility="Collapsed"/>
                                        </Grid>
                                        <TextBox x:Name="txtWagaDek" Style="{StaticResource FieldValueStyle}" Foreground="#166534"
                                                 TextChanged="ValidationField_TextChanged" KeyDown="EnterAdvances_KeyDown"/>
                                    </StackPanel>
                                </Border>

                                <!-- Szt/szuf -->
                                <Border Grid.Column="1" Background="#EFF6FF" Style="{StaticResource FieldBorderStyle}" BorderBrush="#BFDBFE" Margin="4,0">
                                    <StackPanel>
                                        <TextBlock Text="📦 Szt/szuf" Foreground="#1D4ED8" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="txtSztNaSzuflade" Style="{StaticResource FieldValueStyle}" Foreground="#1E40AF"
                                                 TextChanged="ValidationField_TextChanged" KeyDown="EnterAdvances_KeyDown"/>
                                    </StackPanel>
                                </Border>

                                <!-- Sztuki -->
                                <Border Grid.Column="2" Background="#FEF9C3" Style="{StaticResource FieldBorderStyle}" BorderBrush="#FDE047" Margin="4,0">
                                    <StackPanel>
                                        <TextBlock Text="🐔 Sztuki" Foreground="#A16207" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="txtSztuki" Style="{StaticResource FieldValueStyle}" Foreground="#854D0E"
                                                 TextChanged="ValidationField_TextChanged" KeyDown="EnterAdvances_KeyDown"/>
                                    </StackPanel>
                                </Border>

                                <!-- Auta -->
                                <Border Grid.Column="3" Background="#E0E7FF" Style="{StaticResource FieldBorderStyle}" BorderBrush="#C7D2FE" Margin="4,0">
                                    <StackPanel>
                                        <TextBlock Text="🚚 Auta" Foreground="#4338CA" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="txtAuta" Style="{StaticResource FieldValueStyle}" Foreground="#3730A3"
                                                 TextChanged="ValidationField_TextChanged" KeyDown="EnterAdvances_KeyDown"/>
                                    </StackPanel>
                                </Border>

                                <!-- obl.A klikalne -->
                                <Border Grid.Column="4" Background="#F1F5F9" Style="{StaticResource FieldBorderStyle}" BorderBrush="#CBD5E1" Margin="4,0,0,0"
                                        Cursor="Hand" MouseLeftButtonUp="TxtOblA_Click"
                                        ToolTip="Auta = Sztuki / (Szt/szuf × 264). Klik = wstaw do pola Auta">
                                    <StackPanel>
                                        <TextBlock Text="🚚 obl. Auta ↰" Foreground="#64748B" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBlock x:Name="txtOblA" FontSize="17" FontWeight="Bold" Foreground="#64748B"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Wiersz 2: Cena + Dodatek + Typ ceny + Typ umowy -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Cena -->
                                <Border x:Name="borderCena" Grid.Column="0" Background="#FCE7F3" Style="{StaticResource FieldBorderStyle}" BorderBrush="#FBCFE8" Margin="0,0,4,0">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="💰 Cena (zł/kg)" Foreground="#BE185D" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Grid.Column="1" x:Name="badgeCena" FontSize="9" FontWeight="Bold" Foreground="#DC2626" Visibility="Collapsed"/>
                                        </Grid>
                                        <TextBox x:Name="txtCena" Style="{StaticResource FieldValueStyle}" Foreground="#9D174D"
                                                 TextChanged="ValidationField_TextChanged" KeyDown="EnterAdvances_KeyDown"/>
                                    </StackPanel>
                                </Border>

                                <!-- Dodatek -->
                                <Border Grid.Column="1" Background="#F8FAFC" Style="{StaticResource FieldBorderStyle}" BorderBrush="#E2E8F0" Margin="4,0">
                                    <StackPanel>
                                        <TextBlock Text="➕ Dodatek" Foreground="#475569" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox x:Name="txtDodatek" Style="{StaticResource FieldValueStyle}" Foreground="#334155"
                                                 KeyDown="EnterAdvances_KeyDown"/>
                                    </StackPanel>
                                </Border>

                                <!-- Typ ceny -->
                                <Border Grid.Column="2" Background="#F8FAFC" Style="{StaticResource FieldBorderStyle}" BorderBrush="#E2E8F0" Margin="4,0">
                                    <StackPanel>
                                        <TextBlock Text="💵 Typ ceny" Foreground="#475569" Style="{StaticResource FieldLabelStyle}"/>
                                        <ComboBox x:Name="cmbTypCeny" FontSize="12" Height="28" Padding="6,3" BorderThickness="1" BorderBrush="#E2E8F0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Typ umowy -->
                                <Border Grid.Column="3" Background="#F8FAFC" Style="{StaticResource FieldBorderStyle}" BorderBrush="#E2E8F0" Margin="4,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="📑 Typ umowy" Foreground="#475569" Style="{StaticResource FieldLabelStyle}"/>
                                        <ComboBox x:Name="cmbTypUmowy" FontSize="12" Height="28" Padding="6,3" BorderThickness="1" BorderBrush="#E2E8F0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Wiersz 3: Status jako toggle buttons -->
                            <StackPanel>
                                <TextBlock Text="🏷️ Status dostawy" Foreground="#475569" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,6"/>
                                <UniformGrid x:Name="statusButtonsPanel" Rows="1" Columns="6" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- 6. NOTATKA -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="📝 NOTATKA (opcjonalnie)" Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBox x:Name="txtNotatka" FontSize="12" Height="60"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" Padding="8,6"
                                     BorderBrush="#E2E8F0" BorderThickness="1"
                                     ToolTip="Notatka zostanie dodana do nowej dostawy"/>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════════════════════════════════ -->
                    <!-- KOMUNIKAT WALIDACJI -->
                    <!-- ═══════════════════════════════════════════════ -->
                    <Border x:Name="borderValidation" Background="#FEE2E2" CornerRadius="8" Padding="14,10" BorderBrush="#FCA5A5" BorderThickness="1" Visibility="Collapsed" Margin="0,0,0,4">
                        <TextBlock x:Name="txtValidationMessage" FontSize="12" Foreground="#991B1B" TextWrapping="Wrap" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- FOOTER: Akcje -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="20,12" CornerRadius="0,0,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Skróty -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#F3F4F6" CornerRadius="4" Padding="6,3" Margin="0,0,5,0">
                            <TextBlock Text="Ctrl+S" FontFamily="Consolas" FontSize="10" Foreground="#6B7280" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="zapisz" FontSize="11" Foreground="#9CA3AF" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <Border Background="#F3F4F6" CornerRadius="4" Padding="6,3" Margin="0,0,5,0">
                            <TextBlock Text="Ctrl+Enter" FontFamily="Consolas" FontSize="10" Foreground="#6B7280" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="zapisz i kolejna" FontSize="11" Foreground="#9CA3AF" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <Border Background="#F3F4F6" CornerRadius="4" Padding="6,3" Margin="0,0,5,0">
                            <TextBlock Text="Esc" FontFamily="Consolas" FontSize="10" Foreground="#6B7280" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="anuluj" FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Akcje -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Click="BtnAnuluj_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✕" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Anuluj" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnZapiszKolejna" Click="BtnZapiszIKolejna_Click" Style="{StaticResource AccentButtonStyle}" Margin="0,0,8,0"
                                ToolTip="Zapisz tę dostawę i otwórz nowe okno dla kolejnej (Ctrl+Enter)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Zapisz i kolejna" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnZapisz" Click="BtnZapisz_Click" Style="{StaticResource PrimaryButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✅" FontSize="14" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Utwórz dostawę" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
