<Window x:Class="Kalendarz1.Zywiec.Kalendarz.ChangeNotificationPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        ResizeMode="NoResize"
        Width="560" SizeToContent="Height"
        Loaded="Window_Loaded">

    <Border x:Name="mainBorder" CornerRadius="10" Background="White"
            BorderBrush="#E2E8F0" BorderThickness="1"
            Margin="8" Opacity="0"
            MouseEnter="MainBorder_MouseEnter"
            MouseLeave="MainBorder_MouseLeave">
        <Border.RenderTransform>
            <TranslateTransform x:Name="slideTransform" X="400"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.22" ShadowDepth="4" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>                  <!-- Nagłówek (avatar + dostawca + data + close) -->
                <RowDefinition Height="Auto" MaxHeight="440"/>  <!-- Lista zmian -->
                <RowDefinition Height="Auto"/>                  <!-- Stopka (timestamp + tytuł akcji) -->
            </Grid.RowDefinitions>

            <!-- NAGŁÓWEK: avatar + dostawca/LP + data odbioru + close -->
            <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                    CornerRadius="10,10,0,0" Padding="12,10,6,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- avatar -->
                        <ColumnDefinition Width="*"/>     <!-- dostawca + LP -->
                        <ColumnDefinition Width="Auto"/>  <!-- data odbioru -->
                        <ColumnDefinition Width="Auto"/>  <!-- close -->
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Grid Grid.Column="0" Width="36" Height="36" Margin="0,0,12,0" VerticalAlignment="Center">
                        <Border x:Name="avatarBorder" Width="36" Height="36" CornerRadius="18" Background="#4CAF50">
                            <TextBlock x:Name="avatarInitials" Text="" FontSize="13" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Ellipse x:Name="avatarImage" Width="36" Height="36" Visibility="Collapsed"/>
                    </Grid>

                    <!-- Dostawca prominentnie + LP -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="txtSubtitle" Text="" FontSize="14" FontWeight="Bold"
                                   Foreground="#0F172A" TextWrapping="Wrap"/>
                        <TextBlock x:Name="txtLpInfo" Text="" FontSize="11" Foreground="#64748B"
                                   Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Data odbioru -->
                    <Border x:Name="borderDataOdbioru" Grid.Column="2" VerticalAlignment="Center"
                            CornerRadius="5" Padding="8,4" Margin="8,0,8,0" Background="#FEF3C7"
                            BorderBrush="#F59E0B" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtDataOdbioru" Text="" FontSize="13" FontWeight="Bold"
                                       Foreground="#92400E" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Close -->
                    <Button Grid.Column="3" Click="BtnClose_Click" VerticalAlignment="Center"
                            Width="24" Height="24" Cursor="Hand" Margin="2,0,4,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="closeBorder" Background="#F1F5F9" CornerRadius="12"
                                        Width="24" Height="24">
                                    <TextBlock Text="✕" Foreground="#64748B" FontSize="12" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="closeBorder" Property="Background" Value="#E2E8F0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- LISTA ZMIAN -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="changesPanel" Margin="6,6,6,6"/>
            </ScrollViewer>

            <!-- STOPKA: tytuł akcji + timestamp -->
            <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10" Padding="12,6,12,7">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="txtTitle" Grid.Column="0" Text="" FontSize="11" FontWeight="SemiBold"
                               Foreground="#475569" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtTimestamp" Grid.Column="1" Text="" FontSize="10"
                               Foreground="#94A3B8" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
