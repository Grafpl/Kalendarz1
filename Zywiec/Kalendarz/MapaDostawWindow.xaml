<Window x:Class="Kalendarz1.Zywiec.Kalendarz.MapaDostawWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Mapa Dostaw Zywca"
        Width="1500" Height="950"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#0F172A"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="BgSecondary" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderColor" Color="#334155"/>

        <Style x:Key="KpiBorder" TargetType="Border">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#86EFAC"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="PeriodToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22C55E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#475569"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bd" Property="Background" Value="#16A34A"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top" Padding="12,8">
                    <StackPanel>
                        <TextBlock Text="MAPA DOSTAW ZYWCA" FontSize="13" FontWeight="Bold" Foreground="#86EFAC"/>
                        <TextBlock Text="Wizualizacja lokalizacji hodowcow" FontSize="9" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Debug panel -->
                <Border DockPanel.Dock="Top" Padding="8,4" Background="#1A1A2E" BorderBrush="#334155" BorderThickness="0,1,0,1">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="DIAGNOSTYKA" Click="BtnDiagnostyka_Click" Margin="6,0,0,0"
                                Background="#B45309" Foreground="White" FontSize="9" FontWeight="Bold" Padding="8,2"
                                BorderThickness="0" Cursor="Hand"/>
                        <TextBlock x:Name="txtDebug" Text="Ladowanie..." FontSize="9" Foreground="#F59E0B" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Period -->
                <Border DockPanel.Dock="Top" Padding="10,6" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="OKRES" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                        <WrapPanel>
                            <ToggleButton x:Name="btnDzien" Content="Dzis" Style="{StaticResource PeriodToggleStyle}" Click="BtnPeriod_Click" Tag="day"/>
                            <ToggleButton x:Name="btnTydzien" Content="Tydzien" Style="{StaticResource PeriodToggleStyle}" IsChecked="True" Click="BtnPeriod_Click" Tag="week"/>
                            <ToggleButton x:Name="btn2Tygodnie" Content="2 Tygodnie" Style="{StaticResource PeriodToggleStyle}" Click="BtnPeriod_Click" Tag="2weeks"/>
                        </WrapPanel>
                        <TextBlock x:Name="txtOkres" FontSize="9" Foreground="#64748B" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Day checkboxes -->
                <Border DockPanel.Dock="Top" Padding="10,5" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="DNI" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,3"/>
                        <WrapPanel x:Name="panelDniFiltr"/>
                    </StackPanel>
                </Border>

                <!-- Status checkboxes - ALL statuses -->
                <Border DockPanel.Dock="Top" Padding="10,5" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="STATUS" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,3"/>
                        <WrapPanel>
                            <CheckBox x:Name="chkPotwierdzony" Content="Potwierdzony" Foreground="#86EFAC" IsChecked="True" Margin="0,0,8,2" Click="Filter_Changed" FontSize="10"/>
                            <CheckBox x:Name="chkDoWykupienia" Content="Do wykupienia" Foreground="#A78BFA" IsChecked="True" Margin="0,0,8,2" Click="Filter_Changed" FontSize="10"/>
                            <CheckBox x:Name="chkInne" Content="B.Wolny/B.Kontr/Inne" Foreground="#FBBF24" IsChecked="True" Margin="0,0,8,2" Click="Filter_Changed" FontSize="10"/>
                            <CheckBox x:Name="chkAnulowany" Content="Anulowany" Foreground="#F87171" IsChecked="False" Margin="0,0,8,2" Click="Filter_Changed" FontSize="10"/>
                            <CheckBox x:Name="chkSprzedany" Content="Sprzedany" Foreground="#60A5FA" IsChecked="False" Margin="0,0,8,2" Click="Filter_Changed" FontSize="10"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Search -->
                <Border DockPanel.Dock="Top" Padding="10,5" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                    <TextBox x:Name="txtSzukaj" TextChanged="TxtSzukaj_TextChanged"
                             Background="#334155" Foreground="White" BorderBrush="#475569" BorderThickness="1"
                             Padding="8,5" FontSize="11" VerticalContentAlignment="Center"/>
                </Border>

                <!-- KPIs -->
                <Border DockPanel.Dock="Top" Padding="6,5" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                    <UniformGrid Columns="3">
                        <Border Style="{StaticResource KpiBorder}">
                            <StackPanel>
                                <TextBlock Text="DOSTAWY" Style="{StaticResource KpiLabel}"/>
                                <TextBlock x:Name="txtKpiDostawy" Text="0" Style="{StaticResource KpiValue}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource KpiBorder}">
                            <StackPanel>
                                <TextBlock Text="HODOWCY" Style="{StaticResource KpiLabel}"/>
                                <TextBlock x:Name="txtKpiHodowcy" Text="0" Style="{StaticResource KpiValue}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource KpiBorder}">
                            <StackPanel>
                                <TextBlock Text="AUTA" Style="{StaticResource KpiLabel}"/>
                                <TextBlock x:Name="txtKpiAuta" Text="0" Style="{StaticResource KpiValue}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Border>

                <!-- Delivery list -->
                <Border Padding="4,3">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" x:Name="txtLiczbaLista" FontSize="9" Foreground="{StaticResource TextMuted}" Margin="8,2,0,3"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="panelDostawy"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- MAP -->
        <Grid Grid.Column="1">
            <wv2:WebView2 x:Name="webView"/>
            <Border x:Name="loadingOverlay" Background="#CC0F172A" Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="txtLoadingStatus" Text="Ladowanie mapy..." FontSize="14" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
