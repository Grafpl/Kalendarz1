<Window x:Class="Kalendarz1.Zywiec.Kalendarz.MapaDostawWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Mapa Dostaw Zywca"
        Width="1500" Height="950"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F1F5F9"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top" Background="#1E293B" Padding="12,10">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="UZUPELNIJ GEO" Click="BtnUzupelnijGeo_Click" Margin="0,0,4,0"
                                    Background="#16A34A" Foreground="White" FontSize="9" FontWeight="Bold"
                                    Padding="6,3" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"/>
                            <Button Content="DIAGNOSTYKA" Click="BtnDiagnostyka_Click"
                                    Background="#B45309" Foreground="White" FontSize="9" FontWeight="Bold"
                                    Padding="6,3" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="MAPA DOSTAW" FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="txtDebug" Text="" FontSize="9" Foreground="#F59E0B" Margin="0,2,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Period buttons -->
                <Border DockPanel.Dock="Top" Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <UniformGrid Columns="3" Margin="0,0,0,4">
                            <Button x:Name="btnDzien" Content="DZIS" Click="BtnPeriod_Click" Tag="day" Margin="0,0,3,0" Padding="0,6" FontSize="10" FontWeight="Bold" Background="#F1F5F9" Foreground="#64748B" BorderBrush="#E2E8F0" BorderThickness="1" Cursor="Hand"/>
                            <Button x:Name="btnTydzien" Content="TYDZIEN" Click="BtnPeriod_Click" Tag="week" Margin="0,0,3,0" Padding="0,6" FontSize="10" FontWeight="Bold" Background="#1E40AF" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            <Button x:Name="btn2Tygodnie" Content="2 TYGODN." Click="BtnPeriod_Click" Tag="2weeks" Padding="0,6" FontSize="10" FontWeight="Bold" Background="#F1F5F9" Foreground="#64748B" BorderBrush="#E2E8F0" BorderThickness="1" Cursor="Hand"/>
                        </UniformGrid>
                        <TextBlock x:Name="txtOkres" FontSize="10" Foreground="#64748B" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Day checkboxes -->
                <Border DockPanel.Dock="Top" Padding="10,6" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <WrapPanel x:Name="panelDniFiltr"/>
                </Border>

                <!-- Status checkboxes -->
                <Border DockPanel.Dock="Top" Padding="10,6" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <WrapPanel>
                        <CheckBox x:Name="chkPotwierdzony" Content="Potwierdzony" Foreground="#16A34A" IsChecked="True" Margin="0,0,10,3" Click="Filter_Changed" FontSize="10" FontWeight="SemiBold"/>
                        <CheckBox x:Name="chkDoWykupienia" Content="Do wykupienia" Foreground="#7C3AED" IsChecked="True" Margin="0,0,10,3" Click="Filter_Changed" FontSize="10" FontWeight="SemiBold"/>
                        <CheckBox x:Name="chkInne" Content="Inne" Foreground="#D97706" IsChecked="True" Margin="0,0,10,3" Click="Filter_Changed" FontSize="10" FontWeight="SemiBold"/>
                        <CheckBox x:Name="chkAnulowany" Content="Anulowany" Foreground="#DC2626" IsChecked="False" Margin="0,0,10,3" Click="Filter_Changed" FontSize="10"/>
                        <CheckBox x:Name="chkSprzedany" Content="Sprzedany" Foreground="#2563EB" IsChecked="False" Margin="0,0,10,3" Click="Filter_Changed" FontSize="10"/>
                    </WrapPanel>
                </Border>

                <!-- Search -->
                <Border DockPanel.Dock="Top" Padding="10,6" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <TextBox x:Name="txtSzukaj" TextChanged="TxtSzukaj_TextChanged"
                             Background="#F8FAFC" Foreground="#1E293B" BorderBrush="#CBD5E1" BorderThickness="1"
                             Padding="8,5" FontSize="11" VerticalContentAlignment="Center"/>
                </Border>

                <!-- KPIs -->
                <Border DockPanel.Dock="Top" Padding="8,6" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <UniformGrid Columns="3">
                        <Border Background="#F0FDF4" CornerRadius="6" Padding="8,4" Margin="0,0,4,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="txtKpiDostawy" Text="0" FontSize="18" FontWeight="Bold" Foreground="#16A34A" HorizontalAlignment="Center"/>
                                <TextBlock Text="dostaw" FontSize="8" Foreground="#64748B" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#EFF6FF" CornerRadius="6" Padding="8,4" Margin="0,0,4,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="txtKpiHodowcy" Text="0" FontSize="18" FontWeight="Bold" Foreground="#2563EB" HorizontalAlignment="Center"/>
                                <TextBlock Text="hodowcow" FontSize="8" Foreground="#64748B" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FFF7ED" CornerRadius="6" Padding="8,4">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="txtKpiAuta" Text="0" FontSize="18" FontWeight="Bold" Foreground="#EA580C" HorizontalAlignment="Center"/>
                                <TextBlock Text="aut" FontSize="8" Foreground="#64748B" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Border>

                <!-- Delivery list -->
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" x:Name="txtLiczbaLista" FontSize="9" Foreground="#94A3B8" Margin="10,4,0,2"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,0">
                        <StackPanel x:Name="panelDostawy"/>
                    </ScrollViewer>
                </DockPanel>
            </DockPanel>
        </Border>

        <!-- MAP -->
        <Grid Grid.Column="1">
            <wv2:WebView2 x:Name="webView"/>
            <Border x:Name="loadingOverlay" Background="#E0F1F5F9" Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="txtLoadingStatus" Text="Ladowanie..." FontSize="13" Foreground="#64748B" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
