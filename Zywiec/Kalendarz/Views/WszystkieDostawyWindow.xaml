<Window x:Class="Kalendarz1.Zywiec.Kalendarz.Views.WszystkieDostawyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📦 Wszystkie dostawy żywca"
        Width="1500" Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9">
    <Window.Resources>
        <Style x:Key="FilterTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#64748B"/>
        </Style>
        <Style x:Key="WarningBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#F59E0B"/>
        </Style>
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HERO -->
        <Border Grid.Row="0" CornerRadius="10" Padding="14" Margin="0,0,0,8">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#166534" Offset="0"/>
                    <GradientStop Color="#0F4F26" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="📦 Wszystkie dostawy żywca" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="txtHeroPodtytul" Text="Pełna lista z filtrami, KPI, eksportem do Excel/PDF oraz historią zmian" FontSize="11" Foreground="#D1FAE5" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔄 Odśwież" Style="{StaticResource SecondaryBtn}" Click="BtnOdswiez_Click" Margin="0,0,6,0"/>
                    <Button Content="📊 Excel" Style="{StaticResource PrimaryBtn}" Click="BtnEksportExcel_Click" Margin="0,0,6,0"/>
                    <Button Content="📄 PDF" Style="{StaticResource WarningBtn}" Click="BtnEksportPdf_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- PASEK FILTRÓW -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,8" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="🔍 Szukaj" FontSize="9" FontWeight="SemiBold" Foreground="#475569"/>
                    <TextBox x:Name="txtSzukaj" Width="200" Style="{StaticResource FilterTextBox}"
                             KeyUp="TxtSzukaj_KeyUp"
                             ToolTip="Po nazwie hodowcy, numerze LP lub treści uwagi"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Od" FontSize="9" FontWeight="SemiBold" Foreground="#475569"/>
                    <DatePicker x:Name="dpDataOd" Width="120" Height="28" FontSize="11"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Text="Do" FontSize="9" FontWeight="SemiBold" Foreground="#475569"/>
                    <DatePicker x:Name="dpDataDo" Width="120" Height="28" FontSize="11"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                    <TextBlock Text="Dostawca" FontSize="9" FontWeight="SemiBold" Foreground="#475569"/>
                    <ComboBox x:Name="cmbDostawca" Width="200" Style="{StaticResource FilterCombo}" IsEditable="True"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="0,0,12,0">
                    <TextBlock Text="Status" FontSize="9" FontWeight="SemiBold" Foreground="#475569"/>
                    <ComboBox x:Name="cmbBufor" Width="140" Style="{StaticResource FilterCombo}"/>
                </StackPanel>

                <StackPanel Grid.Column="5" Margin="0,0,12,0" VerticalAlignment="Bottom">
                    <CheckBox x:Name="chkTylkoStali" Content="★ Stali" FontSize="10" Margin="0,0,0,3"/>
                    <CheckBox x:Name="chkTylkoZeSmsem" Content="📱 ze SMS" FontSize="10" Margin="0,0,0,3"/>
                    <CheckBox x:Name="chkWymagajaSms" Content="⚠️ wymaga aktualizacji" FontSize="10"/>
                </StackPanel>

                <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="✓ Zastosuj" Style="{StaticResource PrimaryBtn}" Click="BtnZastosujFiltry_Click" Margin="0,0,6,0"/>
                    <Button Content="✖ Wyczyść" Style="{StaticResource SecondaryBtn}" Click="BtnWyczyscFiltry_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DATAGRID + SIDE PANEL -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                <DataGrid x:Name="dgDostawy"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F1F5F9"
                          AlternatingRowBackground="#F8FAFC"
                          RowHeight="28"
                          HeadersVisibility="Column"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          SelectionChanged="DgDostawy_SelectionChanged"
                          MouseDoubleClick="DgDostawy_MouseDoubleClick"
                          FontSize="11">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{Binding StatusKolor}"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="🔍 Otwórz w głównym kalendarzu" Click="MenuPokazWKalendarzu_Click"/>
                            <Separator/>
                            <MenuItem Header="📋 Kopiuj wiersz do schowka" Click="MenuKopiujWiersz_Click"/>
                            <MenuItem Header="📜 Pokaż historię zmian (audit)" Click="MenuPokazAudyt_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="LP" Binding="{Binding LP}" Width="60" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="Data" Binding="{Binding DataOdbioru, StringFormat=yyyy-MM-dd}" Width="90"/>
                        <DataGridTextColumn Header="★" Binding="{Binding StalyKlientIkona}" Width="24">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="📱" Binding="{Binding SmsStatus}" Width="26">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="ToolTip" Value="{Binding SmsCreatedAt, StringFormat='SMS wysłany: {0:dd.MM.yyyy HH:mm}'}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Dostawca" Binding="{Binding Dostawca}" Width="200" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="A" Binding="{Binding Auta}" Width="32"/>
                        <DataGridTextColumn Header="Szt" Binding="{Binding SztukiDek, StringFormat='#,0'}" Width="65"/>
                        <DataGridTextColumn Header="Waga" Binding="{Binding WagaDek, StringFormat='0.00'}" Width="55"/>
                        <DataGridTextColumn Header="Doba" Binding="{Binding RoznicaDni}" Width="42"/>
                        <DataGridTextColumn Header="Typ" Binding="{Binding TypCeny}" Width="50"/>
                        <DataGridTextColumn Header="Cena" Binding="{Binding Cena, StringFormat='0.00'}" Width="50"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Bufor}" Width="100"/>
                        <DataGridTextColumn Header="Ub" Binding="{Binding Ubytek}" Width="36"/>
                        <DataGridTextColumn Header="Uwagi" Binding="{Binding Uwagi}" Width="200"/>
                        <DataGridTextColumn Header="Utworzone" Binding="{Binding DataUtw, StringFormat=yyyy-MM-dd HH:mm}" Width="120"/>
                        <DataGridTextColumn Header="Kto" Binding="{Binding KtoStwo}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- SIDE PANEL — drill-down wybranego wiersza -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Text="📋 Szczegóły dostawy" FontWeight="Bold" FontSize="13" Foreground="#0F172A" Margin="0,0,0,8"/>
                        <Grid x:Name="panelSzczegoly" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="txtDetDostawca" FontSize="14" FontWeight="Bold" Foreground="#166534"/>
                                <TextBlock x:Name="txtDetDataLp" FontSize="10" Foreground="#64748B" Margin="0,2,0,12"/>

                                <Border Background="#F8FAFC" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock x:Name="txtDetAuta" FontSize="11"/>
                                        <TextBlock x:Name="txtDetSztuki" FontSize="11" Margin="0,3,0,0"/>
                                        <TextBlock x:Name="txtDetWaga" FontSize="11" Margin="0,3,0,0"/>
                                        <TextBlock x:Name="txtDetDoba" FontSize="11" Margin="0,3,0,0"/>
                                        <TextBlock x:Name="txtDetCena" FontSize="11" Margin="0,3,0,0"/>
                                        <TextBlock x:Name="txtDetStatus" FontSize="11" Margin="0,3,0,0" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="📱 Status SMS" FontWeight="SemiBold" FontSize="10" Foreground="#475569" Margin="0,8,0,4"/>
                                <Border x:Name="brdDetSms" Background="#F1F5F9" CornerRadius="6" Padding="10">
                                    <TextBlock x:Name="txtDetSms" FontSize="11" TextWrapping="Wrap"/>
                                </Border>

                                <TextBlock Text="📝 Uwagi" FontWeight="SemiBold" FontSize="10" Foreground="#475569" Margin="0,12,0,4"/>
                                <Border Background="#FEFCE8" CornerRadius="6" Padding="10">
                                    <TextBlock x:Name="txtDetUwagi" FontSize="11" TextWrapping="Wrap" Foreground="#713F12"/>
                                </Border>

                                <TextBlock Text="📜 Historia zmian (audit)" FontWeight="SemiBold" FontSize="10" Foreground="#475569" Margin="0,12,0,4"/>
                                <Border Background="#F8FAFC" CornerRadius="6" Padding="6" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <DataGrid x:Name="dgAudit"
                                              AutoGenerateColumns="False" HeadersVisibility="Column"
                                              CanUserAddRows="False" IsReadOnly="True"
                                              GridLinesVisibility="None" RowHeight="22"
                                              MaxHeight="220" FontSize="10">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Kiedy" Binding="{Binding Kiedy, StringFormat=dd.MM HH:mm}" Width="80"/>
                                            <DataGridTextColumn Header="Pole" Binding="{Binding Pole}" Width="80"/>
                                            <DataGridTextColumn Header="Z → na" Binding="{Binding Zmiana}" Width="*"/>
                                            <DataGridTextColumn Header="Kto" Binding="{Binding Kto}" Width="80"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="txtBrakSelekcji"
                                   Text="Wybierz dostawę z listy aby zobaczyć szczegóły, SMS i historię zmian."
                                   FontStyle="Italic" Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Background="#0F172A" CornerRadius="6" Padding="10,6" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtStatus" Grid.Column="0" Text="Gotowy" Foreground="#94A3B8" FontSize="10"/>
                <TextBlock x:Name="txtLicznik" Grid.Column="1" Foreground="#10B981" FontSize="10" FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</Window>
