<Window x:Class="Kalendarz1.Zywiec.Kalendarz.HistoriaZmianWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kalendarz1.Zywiec.Kalendarz"
        Title="Historia Zmian - Audyt Systemu"
        Height="700" Width="1200"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#ECEFF1"
        FontFamily="Segoe UI">

    <Window.Resources>
        <local:InitialsConverter x:Key="InitialsConverter"/>
        <local:UserAvatarBrushConverter x:Key="UserAvatarBrushConverter"/>
        <!-- Style dla DataGrid -->
        <Style x:Key="AuditDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="AlternatingRowBackground" Value="#F5F5F5"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ColumnHeaderHeight" Value="36"/>
        </Style>

        <!-- Style dla wiersza DataGrid - lepsze zaznaczenie + auto-size z minimum -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="MinHeight" Value="50"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DCEDC8"/>
                    <Setter Property="BorderBrush" Value="#5C8A3A"/>
                    <Setter Property="BorderThickness" Value="0,1,0,1"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F8E9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style dla komórki DataGrid -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style dla nagłówków kolumn -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#5C8A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#4B732F"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>

        <!-- Style dla przycisków -->
        <Style x:Key="FilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#5C8A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4B732F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- NAGŁÓWEK -->
        <Border Grid.Row="0" Background="#2E7D32" CornerRadius="4" Padding="15,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📜 Historia Zmian" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="txtFilteredLP" FontSize="20" FontWeight="Bold" Foreground="#C5E1A5" Margin="10,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Przeglądaj wszystkie zmiany dokonane w systemie dostaw" FontSize="12" Foreground="#DCEDC8"/>
                        <TextBlock x:Name="txtFilteredHodowca" FontSize="12" Foreground="#FFFDE7" Margin="10,0,0,0" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <!-- STATYSTYKI -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Border Background="#1B5E20" CornerRadius="4" Padding="8,4" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="DZIŚ" FontSize="9" Foreground="#A5D6A7" FontWeight="Bold"/>
                            <TextBlock x:Name="txtStatDzis" Text="0" FontSize="16" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1B5E20" CornerRadius="4" Padding="8,4" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="MOJE" FontSize="9" Foreground="#A5D6A7" FontWeight="Bold"/>
                            <TextBlock x:Name="txtStatMoje" Text="0" FontSize="16" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1B5E20" CornerRadius="4" Padding="8,4" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="TOP USER" FontSize="9" Foreground="#A5D6A7" FontWeight="Bold"/>
                            <TextBlock x:Name="txtStatTop" Text="-" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1B5E20" CornerRadius="4" Padding="8,4" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="AKTYWNOŚĆ 24h" FontSize="9" Foreground="#A5D6A7" FontWeight="Bold"/>
                            <Canvas x:Name="sparklineCanvas" Width="220" Height="22"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="Ostatnie odświeżenie:" Foreground="#A5D6A7" FontSize="10"/>
                    <TextBlock x:Name="txtLastRefresh" Text="-" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FILTRY -->
        <Border Grid.Row="1" Background="White" CornerRadius="4" Padding="15,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Filtr LP -->
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="LP Dostawy:" FontSize="11" Foreground="#757575" Margin="0,0,0,3"/>
                    <TextBox x:Name="txtFilterLP" Width="100" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>

                <!-- Filtr Użytkownik -->
                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="Użytkownik:" FontSize="11" Foreground="#757575" Margin="0,0,0,3"/>
                    <ComboBox x:Name="cmbFilterUser" Width="120" Height="28" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Wszyscy" IsSelected="True"/>
                    </ComboBox>
                </StackPanel>

                <!-- Filtr Hodowca -->
                <StackPanel Grid.Column="2" Margin="0,0,15,0">
                    <TextBlock Text="Hodowca:" FontSize="11" Foreground="#757575" Margin="0,0,0,3"/>
                    <ComboBox x:Name="cmbFilterHodowca" Width="180" Height="28" VerticalContentAlignment="Center"
                              IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True">
                        <ComboBoxItem Content="Wszyscy" IsSelected="True"/>
                    </ComboBox>
                </StackPanel>

                <!-- Filtr Typ Operacji -->
                <StackPanel Grid.Column="3" Margin="0,0,15,0">
                    <TextBlock Text="Typ operacji:" FontSize="11" Foreground="#757575" Margin="0,0,0,3"/>
                    <ComboBox x:Name="cmbFilterOperation" Width="100" Height="28" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                        <ComboBoxItem Content="INSERT"/>
                        <ComboBoxItem Content="UPDATE"/>
                        <ComboBoxItem Content="DELETE"/>
                    </ComboBox>
                </StackPanel>

                <!-- Filtr Okres -->
                <StackPanel Grid.Column="4" Margin="0,0,15,0">
                    <TextBlock Text="Okres:" FontSize="11" Foreground="#757575" Margin="0,0,0,3"/>
                    <ComboBox x:Name="cmbFilterPeriod" Width="130" Height="28" VerticalContentAlignment="Center" SelectionChanged="CmbFilterPeriod_SelectionChanged">
                        <ComboBoxItem Content="Ostatnie 24h" IsSelected="True" Tag="24"/>
                        <ComboBoxItem Content="Ostatnie 7 dni" Tag="168"/>
                        <ComboBoxItem Content="Ostatnie 30 dni" Tag="720"/>
                        <ComboBoxItem Content="Własny zakres" Tag="0"/>
                    </ComboBox>
                </StackPanel>

                <!-- Daty Od-Do -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" x:Name="pnlCustomDates" Visibility="Collapsed">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Od:" FontSize="11" Foreground="#757575" Margin="0,0,0,3"/>
                        <DatePicker x:Name="dpDateFrom" Width="110" Height="28"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Do:" FontSize="11" Foreground="#757575" Margin="0,0,0,3"/>
                        <DatePicker x:Name="dpDateTo" Width="110" Height="28"/>
                    </StackPanel>
                </StackPanel>

                <!-- Przyciski -->
                <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button x:Name="btnSearch" Content="Szukaj" Style="{StaticResource FilterButtonStyle}" Click="BtnSearch_Click"/>
                    <Button x:Name="btnClear" Content="Wyczyść" Style="{StaticResource FilterButtonStyle}" Background="#78909C" Click="BtnClear_Click"/>
                    <Button x:Name="btnRefresh" Content="Odśwież" Style="{StaticResource FilterButtonStyle}" Background="#0288D1" Click="BtnRefresh_Click"/>
                    <Button x:Name="btnExport" Content="Eksport CSV" Style="{StaticResource FilterButtonStyle}" Background="#7B1FA2" Click="BtnExport_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- GŁÓWNY OBSZAR -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="300"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="240" MinHeight="180"/>
            </Grid.RowDefinitions>

            <!-- GÓRNA CZĘŚĆ - HISTORIA ZMIAN -->
            <Border Grid.Row="0" Background="White" CornerRadius="4" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📜 HISTORIA ZMIAN DOSTAWY  •  dwuklik = otwórz dostawę w kalendarzu" FontWeight="Bold" FontSize="12" Foreground="#2E7D32" Margin="5,0,0,5"/>
                    <DataGrid Grid.Row="1" x:Name="dgAuditLog" Style="{StaticResource AuditDataGridStyle}"
                              EnableRowVirtualization="True" EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              MouseDoubleClick="DgAuditLog_MouseDoubleClick">
                        <DataGrid.Columns>
                            <!-- Czas: data z dniem tygodnia + HH:mm:ss + relatywny -->
                            <DataGridTemplateColumn Header="Czas" Width="150" SortMemberPath="DataZmiany">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="6,3" VerticalAlignment="Center"
                                                    ToolTip="{Binding DataZmianyFormatted}">
                                            <TextBlock Text="{Binding DataZmianyDateLong}" FontSize="11" Foreground="#546E7A"/>
                                            <TextBlock Text="{Binding DataZmianyShort}" FontWeight="Bold" FontSize="13" Foreground="#212121"/>
                                            <TextBlock Text="{Binding DataZmianyRelative}" FontSize="10" Foreground="#9E9E9E" FontStyle="Italic"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Operacja: kolorowy badge -->
                            <DataGridTemplateColumn Header="Operacja" Width="100" SortMemberPath="TypOperacji">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Margin="3" Padding="8,3"
                                                Background="{Binding TypOperacjiBackground}"
                                                BorderBrush="{Binding TypOperacjiColor}" BorderThickness="1"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding TypOperacjiIcon}" FontSize="11" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding TypOperacjiDisplay}" FontWeight="SemiBold" FontSize="11"
                                                           Foreground="{Binding TypOperacjiColor}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- LP -->
                            <DataGridTextColumn Header="LP" Binding="{Binding RekordID}" Width="65" SortMemberPath="RekordID">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#1976D2"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Hodowca: dwuklik nawiguje -->
                            <DataGridTextColumn Header="Hodowca" Binding="{Binding HodowcaDisplay}" Width="180" SortMemberPath="Hodowca">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="5,0"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#1B5E20"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="ToolTip" Value="{Binding HodowcaDisplay}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Data dostawy: dzień tygodnia + data odbioru -->
                            <DataGridTextColumn Header="Data dostawy" Binding="{Binding DataOdbioruDisplay}" Width="130" SortMemberPath="DataOdbioru">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="6,0"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#0D47A1"/>
                                        <Setter Property="ToolTip" Value="{Binding DataOdbioruDisplay}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Użytkownik z avatarem (styl jak Cykle Wstawień: zdjęcie z UserAvatarManager + fallback inicjały) -->
                            <DataGridTemplateColumn Header="Użytkownik" Width="180" SortMemberPath="UserName">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0"
                                                    ToolTip="{Binding UserDisplay}">
                                            <Grid Width="32" Height="32">
                                                <!-- Pod spodem: kółko z inicjałami (widoczne gdy brak zdjęcia) -->
                                                <Border Width="32" Height="32" CornerRadius="16" Background="#6366F1">
                                                    <TextBlock Text="{Binding UserDisplay, Converter={StaticResource InitialsConverter}}"
                                                               FontSize="11" FontWeight="Bold" Foreground="White"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- Na wierzch: zdjęcie userId (jeśli istnieje, inaczej null = przezroczyste) -->
                                                <Ellipse Width="32" Height="32"
                                                         Fill="{Binding UserID, Converter={StaticResource UserAvatarBrushConverter}}"/>
                                            </Grid>
                                            <TextBlock Text="{Binding UserDisplay}" FontSize="12" Foreground="#212121"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Pole -->
                            <DataGridTextColumn Header="Pole" Binding="{Binding NazwaPolaDisplay}" Width="100" SortMemberPath="NazwaPola">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="5,0"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Stara wartość -->
                            <DataGridTemplateColumn Header="Stara wartość" Width="2*" MinWidth="180" SortMemberPath="StaraWartosc">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFEBEE" CornerRadius="6" Margin="3,4"
                                                Padding="10,5" BorderBrush="#EF9A9A" BorderThickness="1"
                                                ToolTip="{Binding StaraWartoscDisplay}" VerticalAlignment="Stretch">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Prefix: minus dla zwykłej wartości / ikonka notatnika dla notatki -->
                                                <Border Grid.Column="0" CornerRadius="3" Padding="3,1" Margin="0,0,8,0"
                                                        VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsNote}" Value="True">
                                                                    <Setter Property="Background" Value="#C62828"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock VerticalAlignment="Center" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="−"/>
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                                <Setter Property="FontSize" Value="16"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsNote}" Value="True">
                                                                        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                                                                        <Setter Property="Text" Value="&#xE70B;"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Setter Property="FontSize" Value="11"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <!-- Treść -->
                                                <TextBlock Grid.Column="1" Text="{Binding StaraWartoscDisplay}" Foreground="#7F1D1D"
                                                           FontWeight="SemiBold" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontSize" Value="13"/>
                                                            <Setter Property="TextWrapping" Value="NoWrap"/>
                                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsNote}" Value="True">
                                                                    <Setter Property="FontSize" Value="10"/>
                                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                                    <Setter Property="TextTrimming" Value="None"/>
                                                                    <Setter Property="VerticalAlignment" Value="Top"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Nowa wartość -->
                            <DataGridTemplateColumn Header="Nowa wartość" Width="2*" MinWidth="180" SortMemberPath="NowaWartosc">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#E8F5E9" CornerRadius="6" Margin="3,4"
                                                Padding="10,5" BorderBrush="#A5D6A7" BorderThickness="1"
                                                ToolTip="{Binding NowaWartoscDisplay}" VerticalAlignment="Stretch">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Prefix: ✓ dla zwykłej wartości / ikonka notatnika (białe na ciemnozielonym) dla notatki -->
                                                <Border Grid.Column="0" CornerRadius="3" Padding="3,1" Margin="0,0,8,0"
                                                        VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsNote}" Value="True">
                                                                    <Setter Property="Background" Value="#2E7D32"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock VerticalAlignment="Center" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="✓"/>
                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                                <Setter Property="FontSize" Value="14"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsNote}" Value="True">
                                                                        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                                                                        <Setter Property="Text" Value="&#xE70B;"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Setter Property="FontSize" Value="11"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <!-- Treść -->
                                                <TextBlock Grid.Column="1" Text="{Binding NowaWartoscDisplay}" Foreground="#14532D"
                                                           FontWeight="Bold" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontSize" Value="13"/>
                                                            <Setter Property="TextWrapping" Value="NoWrap"/>
                                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsNote}" Value="True">
                                                                    <Setter Property="FontSize" Value="10"/>
                                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                                    <Setter Property="TextTrimming" Value="None"/>
                                                                    <Setter Property="VerticalAlignment" Value="Top"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Źródło -->
                            <DataGridTextColumn Header="Źródło" Binding="{Binding ZrodloZmianyDisplay}" Width="130" SortMemberPath="ZrodloZmiany">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="5,0"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="Foreground" Value="#546E7A"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Batch (transakcja) -->
                            <DataGridTextColumn Header="" Binding="{Binding BatchBadge}" Width="40">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#7B1FA2"/>
                                        <Setter Property="ToolTip" Value="Wpis powiązany z innymi w tej samej transakcji (≤3s)"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Opis -->
                            <DataGridTextColumn Header="Opis" Binding="{Binding OpisZmiany}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="5,0"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="ToolTip" Value="{Binding OpisZmiany}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- SEPARATOR z chwytakiem -->
            <Border Grid.Row="1" Background="#E0E0E0" Margin="0,2,0,2">
                <GridSplitter Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              Background="Transparent" Cursor="SizeNS" ShowsPreview="True"/>
            </Border>

            <!-- DOLNA CZĘŚĆ - Dashboard kołowy: kto co zmieniał -->
            <Border Grid.Row="2" Background="White" CornerRadius="4" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="👥 KTO CO ZMIENIAŁ" FontWeight="Bold" FontSize="12" Foreground="#2E7D32"/>
                        <TextBlock x:Name="txtPieChartTotal" FontSize="11" Foreground="#78909C" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Wykres kołowy (donut) -->
                        <Grid Grid.Column="0" Width="180" Height="180" Margin="0,0,15,0">
                            <Canvas x:Name="pieChartCanvas" Width="180" Height="180"/>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock x:Name="txtPieChartCenter" Text="0" FontSize="28" FontWeight="Bold" Foreground="#1B5E20" HorizontalAlignment="Center"/>
                                <TextBlock Text="zmian" FontSize="10" Foreground="#757575" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Lista użytkowników z avatarem, count, % i rozbiciem operacji/pól -->
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="icPieLegend">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FAFAFA" CornerRadius="4" Margin="0,2,8,4" Padding="6,4"
                                                ToolTip="{Binding FullTooltip}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- WIERSZ 1: kolor + avatar + nazwa + count + % -->
                                                <Ellipse Grid.Row="0" Grid.Column="0" Width="10" Height="10"
                                                         Fill="{Binding ColorBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <Grid Grid.Row="0" Grid.Column="1" Width="26" Height="26" Margin="0,0,8,0">
                                                    <Border Width="26" Height="26" CornerRadius="13" Background="#6366F1">
                                                        <TextBlock Text="{Binding UserDisplay, Converter={StaticResource InitialsConverter}}"
                                                                   FontSize="10" FontWeight="Bold" Foreground="White"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Ellipse Width="26" Height="26"
                                                             Fill="{Binding UserID, Converter={StaticResource UserAvatarBrushConverter}}"/>
                                                </Grid>
                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding UserDisplay}" FontSize="12"
                                                           FontWeight="SemiBold" Foreground="#212121" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding Count}" FontSize="13" FontWeight="Bold"
                                                           Foreground="#1B5E20" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding PercentDisplay}" FontSize="10"
                                                           Foreground="#9E9E9E" VerticalAlignment="Center" Margin="6,0,0,0" Width="42"/>

                                                <!-- WIERSZ 2: rozbicie operacji + top pola -->
                                                <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="3"
                                                            Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding OperationsBreakdown}" FontSize="10"
                                                               Foreground="#546E7A" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="{Binding TopFieldsBreakdown}" FontSize="10"
                                                               Foreground="#1976D2" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- STOPKA -->
        <Border Grid.Row="3" Background="#2E7D32" CornerRadius="4" Padding="15,8" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Wyników: " Foreground="#A5D6A7" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtResultCount" Text="0" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock x:Name="txtStatusInfo" Text="" Foreground="#DCEDC8" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnLoadMore" Content="⬇ Załaduj kolejne" Style="{StaticResource FilterButtonStyle}" Background="#0288D1" Click="BtnLoadMore_Click" Visibility="Collapsed"/>
                    <Button x:Name="btnClose" Content="Zamknij" Style="{StaticResource FilterButtonStyle}" Background="#546E7A" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
