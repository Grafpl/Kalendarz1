                                    <TextBlock x:Name="txtTopCzas" Text="-" FontSize="16" FontWeight="Bold" Foreground="#27AE60"/>
                                    <TextBlock x:Name="txtTopCzasVal" Text="" FontSize="12" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Najwyzszy % potwierdzonych -->
                            <Border Grid.Column="2" Background="#F5EEF8" CornerRadius="12" Padding="18,14" Margin="5,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Najwyzszy % potw." FontSize="11" Foreground="#5D6D7E" Margin="0,0,0,6"/>
