<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Kalendarz1.StatystykiPracownikow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kalendarz1"
        mc:Ignorable="d"
        Title="KPI Zakupowcow - Wstawienia"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F7">

    <Window.Resources>
        <Style x:Key="FilterButton" TargetType="Button">
            <Setter Property="Background" Value="#EAECEE"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabHeaderStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBorder" Background="Transparent" BorderBrush="Transparent"
                                BorderThickness="0,0,0,3" Padding="{TemplateBinding Padding}" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="BorderBrush" Value="#5C8A3A"/>
                                <Setter Property="Foreground" Value="#2C3E50"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Naglowek -->
        <TextBlock Grid.Row="0"
                   Text="KPI Zakupowcow - Wstawienia Kurczakow"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,20"/>

        <!-- Panel wyboru daty -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,10">
            <Border.Effect>
                <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Wybor Okresu" FontSize="14" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,10"/>

                <!-- Szybki wybor -->
                <WrapPanel Margin="0,0,0,8">
                    <Button x:Name="btnDzis" Content="Dzis" Style="{StaticResource FilterButton}"
                            Padding="12,6" FontSize="12" Margin="0,0,8,4" Click="FilterButton_Click" Tag="Today"/>
                    <Button x:Name="btnWczoraj" Content="Wczoraj" Style="{StaticResource FilterButton}"
                            Padding="12,6" FontSize="12" Margin="0,0,8,4" Click="FilterButton_Click" Tag="Yesterday"/>
                    <Button x:Name="btnTydzien" Content="Ten Tydzien" Style="{StaticResource FilterButton}"
                            Padding="12,6" FontSize="12" Margin="0,0,8,4" Click="FilterButton_Click" Tag="Week"/>
                    <Button x:Name="btnPoprzedniTydzien" Content="Poprzedni Tydzien" Style="{StaticResource FilterButton}"
                            Padding="12,6" FontSize="12" Margin="0,0,8,4" Click="FilterButton_Click" Tag="LastWeek"/>
                    <Button x:Name="btnMiesiac" Content="Ten Miesiac" Style="{StaticResource FilterButton}"
                            Padding="12,6" FontSize="12" Margin="0,0,8,4" Click="FilterButton_Click" Tag="Month"/>
                    <Button x:Name="btnPoprzedniMiesiac" Content="Poprzedni Miesiac" Style="{StaticResource FilterButton}"
                            Padding="12,6" FontSize="12" Margin="0,0,8,4" Click="FilterButton_Click" Tag="LastMonth"/>
                    <Button x:Name="btnRok" Content="2026" Style="{StaticResource FilterButton}"
                            Padding="12,6" FontSize="12" Margin="0,0,8,4" Click="FilterButton_Click" Tag="Year"/>
                    <Button x:Name="btnPoprzedniRok" Content="2025" Style="{StaticResource FilterButton}"
                            Padding="12,6" FontSize="12" Margin="0,0,8,4" Click="FilterButton_Click" Tag="LastYear"/>
                </WrapPanel>

                <!-- Miesiace 2026 -->
                <StackPanel Margin="0,4,0,8">
                    <TextBlock Text="2026:" FontSize="11" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,4"/>
                    <WrapPanel>
                        <Button Content="Sty" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2026-01"/>
                        <Button Content="Lut" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2026-02"/>
                        <Button Content="Mar" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2026-03"/>
                        <Button Content="Kwi" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2026-04"/>
                        <Button Content="Maj" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2026-05"/>
                        <Button Content="Cze" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2026-06"/>
                        <Button Content="Lip" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2026-07"/>
                        <Button Content="Sie" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2026-08"/>
                        <Button Content="Wrz" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2026-09"/>
                        <Button Content="Paz" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2026-10"/>
                        <Button Content="Lis" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2026-11"/>
                        <Button Content="Gru" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2026-12"/>
                    </WrapPanel>
                </StackPanel>

                <!-- Miesiace 2025 -->
                <StackPanel Margin="0,4,0,0">
                    <TextBlock Text="2025:" FontSize="11" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,4"/>
                    <WrapPanel>
                        <Button Content="Sty" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2025-01"/>
                        <Button Content="Lut" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2025-02"/>
                        <Button Content="Mar" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2025-03"/>
                        <Button Content="Kwi" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2025-04"/>
                        <Button Content="Maj" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2025-05"/>
                        <Button Content="Cze" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2025-06"/>
                        <Button Content="Lip" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2025-07"/>
                        <Button Content="Sie" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2025-08"/>
                        <Button Content="Wrz" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2025-09"/>
                        <Button Content="Paz" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2025-10"/>
                        <Button Content="Lis" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2025-11"/>
                        <Button Content="Gru" Style="{StaticResource FilterButton}" Padding="10,5" FontSize="11" Margin="0,0,6,3" Click="FilterButton_Click" Tag="2025-12"/>
                    </WrapPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Podsumowanie -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource KpiCard}" Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock Text="Utworzone" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtTotalStworzone" Text="0" FontSize="30" FontWeight="Bold" Foreground="#5C8A3A"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="Potwierdzone" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtTotalPotwierdzone" Text="0" FontSize="30" FontWeight="Bold" Foreground="#3498DB"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="Oczekujace" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtTotalOczekujace" Text="0" FontSize="30" FontWeight="Bold" Foreground="#F39C12"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource KpiCard}" Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock Text="% Potwierdzonych" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtProcentPotwierdzone" Text="0%" FontSize="30" FontWeight="Bold" Foreground="#9B59B6"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- TabControl -->
        <TabControl x:Name="mainTabControl" Grid.Row="3" BorderThickness="0" Background="Transparent" Padding="0">

            <!-- ==================== TAB 1: PRZEGLAD ==================== -->
            <TabItem Header="Przeglad Wstawien" Style="{StaticResource TabHeaderStyle}">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Lewa kolumna -->
                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Kto utworzyl -->
                        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,10">
                            <Border.Effect>
                                <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Kto Utworzyl Wstawienia" FontSize="18" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,15"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Canvas x:Name="canvasStworzone" Grid.Column="0" Width="180" Height="180" Margin="10"/>
                                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="10,0,0,0">
                                        <ItemsControl x:Name="itemsStworzone">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,8">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Button Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Stretch" Padding="0" Click="BtnPracownikDetails_Click" Tag="{Binding NazwaPracownika}">
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Grid Width="28" Height="28" Margin="0,0,8,0">
                                                                    <Border Width="28" Height="28" CornerRadius="14" Background="{Binding Kolor}">
                                                                        <TextBlock Text="{Binding Initials}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                                                    </Border>
                                                                    <Ellipse Width="28" Height="28" x:Name="avatarEllipse">
                                                                        <Ellipse.Fill>
                                                                            <ImageBrush ImageSource="{Binding AvatarSource}" Stretch="UniformToFill"/>
                                                                        </Ellipse.Fill>
                                                                    </Ellipse>
                                                                </Grid>
                                                                <TextBlock Text="{Binding NazwaPracownika}" FontWeight="SemiBold" Foreground="#5D6D7E" TextDecorations="Underline" VerticalAlignment="Center"/>
                                                                <TextBlock FontWeight="Bold" Foreground="#5C8A3A" Margin="5,0,0,0" VerticalAlignment="Center">
                                                                    <Run Text=" ("/><Run Text="{Binding LiczbaAkcji}"/><Run Text=")"/>
                                                                </TextBlock>
                                                                <TextBlock FontStyle="Italic" Foreground="#7F8C8D" Margin="5,0,0,0" VerticalAlignment="Center">
                                                                    <Run Text=" - "/><Run Text="{Binding ProcentTekst, Mode=OneWay}"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Button>
                                                        <Border Grid.Row="1" Height="8" Background="#EAECEE" CornerRadius="4" Margin="0,5,0,0">
                                                            <Border HorizontalAlignment="Left" Background="{Binding Kolor}" CornerRadius="4" Width="{Binding ProcentWidth, Mode=OneWay}"/>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Kto potwierdzil -->
                        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Kto Potwierdzil Wstawienia" FontSize="18" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,15"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Canvas x:Name="canvasPotwierdzone" Grid.Column="0" Width="180" Height="180" Margin="10"/>
                                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="10,0,0,0">
                                        <ItemsControl x:Name="itemsPotwierdzone">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,8">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Button Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Stretch" Padding="0" Click="BtnPracownikDetails_Click" Tag="{Binding NazwaPracownika}">
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Grid Width="28" Height="28" Margin="0,0,8,0">
                                                                    <Border Width="28" Height="28" CornerRadius="14" Background="{Binding Kolor}">
                                                                        <TextBlock Text="{Binding Initials}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                                                    </Border>
                                                                    <Ellipse Width="28" Height="28">
                                                                        <Ellipse.Fill>
                                                                            <ImageBrush ImageSource="{Binding AvatarSource}" Stretch="UniformToFill"/>
                                                                        </Ellipse.Fill>
                                                                    </Ellipse>
                                                                </Grid>
                                                                <TextBlock Text="{Binding NazwaPracownika}" FontWeight="SemiBold" Foreground="#5D6D7E" TextDecorations="Underline" VerticalAlignment="Center"/>
                                                                <TextBlock FontWeight="Bold" Foreground="#3498DB" Margin="5,0,0,0" VerticalAlignment="Center">
                                                                    <Run Text=" ("/><Run Text="{Binding LiczbaAkcji}"/><Run Text=")"/>
                                                                </TextBlock>
                                                                <TextBlock FontStyle="Italic" Foreground="#7F8C8D" Margin="5,0,0,0" VerticalAlignment="Center">
                                                                    <Run Text=" - "/><Run Text="{Binding ProcentTekst, Mode=OneWay}"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Button>
                                                        <Border Grid.Row="1" Height="8" Background="#EAECEE" CornerRadius="4" Margin="0,5,0,0">
                                                            <Border HorizontalAlignment="Left" Background="{Binding Kolor}" CornerRadius="4" Width="{Binding ProcentWidth, Mode=OneWay}"/>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Prawa kolumna - Tabela -->
                    <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20" Margin="10,0,0,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                        </Border.Effect>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Szczegolowa Lista Wstawien" FontSize="18" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,15"/>
                            <DataGrid x:Name="dgSzczegoly" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="0" Background="White" RowBackground="White" AlternatingRowBackground="#F8F9FA" FontSize="12" RowHeight="36">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Lp" Binding="{Binding Lp}" Width="50"/>
                                    <DataGridTextColumn Header="Dostawca" Binding="{Binding Dostawca}" Width="150"/>
                                    <DataGridTextColumn Header="Data Wstawienia" Binding="{Binding DataWstawienia, StringFormat=dd.MM.yyyy}" Width="120"/>
                                    <DataGridTextColumn Header="Ilosc" Binding="{Binding IloscWstawienia}" Width="80"/>
                                    <DataGridTemplateColumn Header="Utworzyl" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2">
                                                    <Grid Width="26" Height="26" Margin="0,0,6,0">
                                                        <Border Width="26" Height="26" CornerRadius="13" Background="#5C8A3A">
                                                            <TextBlock Text="{Binding InitialsStworzyl}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="9" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <Ellipse Width="26" Height="26">
                                                            <Ellipse.Fill>
                                                                <ImageBrush ImageSource="{Binding AvatarStworzyl}" Stretch="UniformToFill"/>
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                    </Grid>
                                                    <TextBlock Text="{Binding KtoStworzyl}" VerticalAlignment="Center" FontSize="11"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Data Utw." Binding="{Binding DataUtw, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                    <DataGridTemplateColumn Header="Potwierdzil" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2">
                                                    <Grid Width="26" Height="26" Margin="0,0,6,0">
                                                        <Border Width="26" Height="26" CornerRadius="13" Background="#3498DB">
                                                            <TextBlock Text="{Binding InitialsPotwierdził}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="9" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <Ellipse Width="26" Height="26">
                                                            <Ellipse.Fill>
                                                                <ImageBrush ImageSource="{Binding AvatarPotwierdził}" Stretch="UniformToFill"/>
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                    </Grid>
                                                    <TextBlock Text="{Binding KtoPotwierdził}" VerticalAlignment="Center" FontSize="11"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Data Potw." Binding="{Binding DataConf, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ==================== TAB 2: KPI ZAKUPOWCOW ==================== -->
            <TabItem Header="KPI Zakupowcow" Style="{StaticResource TabHeaderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <StackPanel>

                        <!-- Top performers -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Najwyzszy wolumen -->
                            <Border Grid.Column="0" Background="#EBF5FB" CornerRadius="12" Padding="18,14" Margin="0,0,5,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Najwyzszy wolumen" FontSize="11" Foreground="#5D6D7E" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="txtTopWolumen" Text="-" FontSize="16" FontWeight="Bold" Foreground="#2980B9"/>
                                    <TextBlock x:Name="txtTopWolumenVal" Text="" FontSize="12" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Najszybsze potwierdzenie -->
                            <Border Grid.Column="1" Background="#EAFAF1" CornerRadius="12" Padding="18,14" Margin="5,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Najszybsze potw. (sr.)" FontSize="11" Foreground="#5D6D7E" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="txtTopCzas" Text="-" FontSize="16" FontWeight="Bold" Foreground="#27AE60"/>
                                    <TextBlock x:Name="txtTopCzasVal" Text="" FontSize="12" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Najwyzszy % potwierdzonych -->
                            <Border Grid.Column="2" Background="#F5EEF8" CornerRadius="12" Padding="18,14" Margin="5,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Najwyzszy % potw." FontSize="11" Foreground="#5D6D7E" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="txtTopProcent" Text="-" FontSize="16" FontWeight="Bold" Foreground="#8E44AD"/>
                                    <TextBlock x:Name="txtTopProcentVal" Text="" FontSize="12" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Najwiecej dostawcow -->
                            <Border Grid.Column="3" Background="#FEF9E7" CornerRadius="12" Padding="18,14" Margin="5,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Najwiecej dostawcow" FontSize="11" Foreground="#5D6D7E" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="txtTopDostawcy" Text="-" FontSize="16" FontWeight="Bold" Foreground="#F39C12"/>
                                    <TextBlock x:Name="txtTopDostawcyVal" Text="" FontSize="12" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Ranking zakupowcow -->
                        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                            <Border.Effect>
                                <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                            </Border.Effect>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Ranking Zakupowcow" FontSize="18" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,15"/>
                                <DataGrid x:Name="dgKpiRanking" AutoGenerateColumns="False" IsReadOnly="True"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                          BorderThickness="0" Background="White"
                                          RowBackground="White" AlternatingRowBackground="#F8F9FA"
                                          FontSize="12" RowHeight="42" CanUserSortColumns="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="40">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#5C8A3A"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTemplateColumn Header="Zakupowiec" Width="200" SortMemberPath="Nazwa">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                        <Grid Width="30" Height="30" Margin="0,0,8,0">
                                                            <Border Width="30" Height="30" CornerRadius="15" Background="{Binding KolorBrush}">
                                                                <TextBlock Text="{Binding Inicjaly}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                            </Border>
                                                            <Ellipse Width="30" Height="30">
                                                                <Ellipse.Fill>
                                                                    <ImageBrush ImageSource="{Binding AvatarSource}" Stretch="UniformToFill"/>
                                                                </Ellipse.Fill>
                                                            </Ellipse>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Nazwa}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Utworzone" Binding="{Binding Utworzone}" Width="90" SortMemberPath="Utworzone">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Potwierdzone" Binding="{Binding Potwierdzone}" Width="100" SortMemberPath="Potwierdzone">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="#3498DB"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTemplateColumn Header="% Potw." Width="120" SortMemberPath="ProcentPotwierdzonych">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid VerticalAlignment="Center" Margin="4,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding ProcentPotwTekst}" FontWeight="SemiBold" Foreground="#8E44AD" VerticalAlignment="Center"/>
                                                        <Border Grid.Column="1" Height="6" Background="#EAECEE" CornerRadius="3" Margin="4,0,0,0" VerticalAlignment="Center">
                                                            <Border HorizontalAlignment="Left" Background="#8E44AD" CornerRadius="3" Width="{Binding ProcentPotwWidth}"/>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Sr. czas potw." Binding="{Binding SredniCzasPotwTekst}" Width="120" SortMemberPath="SredniCzasPotwGodziny">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="#27AE60"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Dostawcy" Binding="{Binding LiczbaDostawcow}" Width="80" SortMemberPath="LiczbaDostawcow">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="#F39C12"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Wolumen (szt.)" Binding="{Binding WolumenTekst}" Width="120" SortMemberPath="Wolumen">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#2980B9"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Wst./dzien" Binding="{Binding ProduktywTekst}" Width="90" SortMemberPath="Produktywnosc">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <!-- Przestrzen na przyszle KPI -->
                        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                            <Border.Effect>
                                <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                            </Border.Effect>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Dodatkowe KPI (miejsce na rozbudowe)" FontSize="18" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,15"/>
                                <Border Background="#F8F9FA" CornerRadius="8" Padding="30" MinHeight="120">
                                    <TextBlock Text="Tu mozesz dodac kolejne wskazniki KPI - np. trendy miesiac do miesiaca, porownania okresow, cele i ich realizacja, alerty o niepotwierdzonych wstawieniach, itd."
                                               FontSize="13" Foreground="#95A5A6" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                                </Border>
                            </DockPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
