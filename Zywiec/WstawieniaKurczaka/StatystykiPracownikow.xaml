<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Kalendarz1.StatystykiPracownikow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kalendarz1"
        mc:Ignorable="d"
        Title="KPI Zakupowcow - Wstawienia"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F7">

    <Window.Resources>
        <Style x:Key="FilterButton" TargetType="Button">
            <Setter Property="Background" Value="#EAECEE"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Global DataGrid row hover -->
        <Style x:Key="RankingRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#F0F2F5"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBF5FB"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D4EFDF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RankingHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F3F5"/>
            <Setter Property="Foreground" Value="#495057"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#DEE2E6"/>
            <Setter Property="BorderThickness" Value="0,0,1,2"/>
        </Style>

        <Style x:Key="RankingCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#F4F6F7"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabHeaderStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBorder" Background="Transparent" BorderBrush="Transparent"
                                BorderThickness="0,0,0,3" Padding="{TemplateBinding Padding}" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="BorderBrush" Value="#5C8A3A"/>
                                <Setter Property="Foreground" Value="#2C3E50"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ======== DARK HEADER ======== -->
        <Border Grid.Row="0" Padding="28,16,28,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.4">
                    <GradientStop Color="#1A1D21" Offset="0"/>
                    <GradientStop Color="#2C3533" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="KPI Zakupowcow" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Sledzenie wydajnosci wstawien, kalendarza, specyfikacji, SMS, hodowcow, dokumentow i wnioskow"
                               FontSize="11" Foreground="#8C9196" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#5C8A3A" CornerRadius="6" Padding="14,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtHeaderUtw" Text="0" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,5,0"/>
                            <TextBlock Text="utw." FontSize="11" Foreground="#FFFFFFBB" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#3498DB" CornerRadius="6" Padding="14,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtHeaderPotw" Text="0" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,5,0"/>
                            <TextBlock Text="potw." FontSize="11" Foreground="#FFFFFFBB" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#F39C12" CornerRadius="6" Padding="14,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtHeaderOcz" Text="0" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,5,0"/>
                            <TextBlock Text="ocz." FontSize="11" Foreground="#FFFFFFBB" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ======== DATE PICKER (compact) ======== -->
        <Border Grid.Row="1" Background="White" Padding="16,6,16,6" Margin="0">
            <Border.Effect><DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="1" BlurRadius="4" Opacity="0.15"/></Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Szybki wybor - 1 linia -->
                <WrapPanel Grid.Row="0">
                    <Button x:Name="btnDzis" Content="Dzis" Style="{StaticResource FilterButton}"
                            Padding="10,4" FontSize="11" Margin="0,0,5,0" Click="FilterButton_Click" Tag="Today"/>
                    <Button x:Name="btnWczoraj" Content="Wczoraj" Style="{StaticResource FilterButton}"
                            Padding="10,4" FontSize="11" Margin="0,0,5,0" Click="FilterButton_Click" Tag="Yesterday"/>
                    <Button x:Name="btnTydzien" Content="Tydzien" Style="{StaticResource FilterButton}"
                            Padding="10,4" FontSize="11" Margin="0,0,5,0" Click="FilterButton_Click" Tag="Week"/>
                    <Button x:Name="btnPoprzedniTydzien" Content="Pop.Tydz" Style="{StaticResource FilterButton}"
                            Padding="10,4" FontSize="11" Margin="0,0,5,0" Click="FilterButton_Click" Tag="LastWeek"/>
                    <Button x:Name="btnMiesiac" Content="Miesiac" Style="{StaticResource FilterButton}"
                            Padding="10,4" FontSize="11" Margin="0,0,5,0" Click="FilterButton_Click" Tag="Month"/>
                    <Button x:Name="btnPoprzedniMiesiac" Content="Pop.Mies" Style="{StaticResource FilterButton}"
                            Padding="10,4" FontSize="11" Margin="0,0,5,0" Click="FilterButton_Click" Tag="LastMonth"/>
                    <Button x:Name="btnRok" Content="2026" Style="{StaticResource FilterButton}"
                            Padding="10,4" FontSize="11" Margin="0,0,5,0" Click="FilterButton_Click" Tag="Year"/>
                    <Button x:Name="btnPoprzedniRok" Content="2025" Style="{StaticResource FilterButton}"
                            Padding="10,4" FontSize="11" Margin="0,0,5,0" Click="FilterButton_Click" Tag="LastYear"/>

                    <Border Width="1" Background="#DEE2E6" Margin="6,2,8,2"/>

                    <!-- 2026 miesiace inline -->
                    <TextBlock Text="2026:" FontSize="10" Foreground="#7F8C8D" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button Content="I" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2026-01"/>
                    <Button Content="II" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2026-02"/>
                    <Button Content="III" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2026-03"/>
                    <Button Content="IV" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2026-04"/>
                    <Button Content="V" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2026-05"/>
                    <Button Content="VI" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2026-06"/>
                    <Button Content="VII" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2026-07"/>
                    <Button Content="VIII" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2026-08"/>
                    <Button Content="IX" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2026-09"/>
                    <Button Content="X" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2026-10"/>
                    <Button Content="XI" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2026-11"/>
                    <Button Content="XII" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,6,0" Click="FilterButton_Click" Tag="2026-12"/>

                    <Border Width="1" Background="#DEE2E6" Margin="0,2,8,2"/>

                    <!-- 2025 miesiace inline -->
                    <TextBlock Text="2025:" FontSize="10" Foreground="#7F8C8D" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button Content="I" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2025-01"/>
                    <Button Content="II" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2025-02"/>
                    <Button Content="III" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2025-03"/>
                    <Button Content="IV" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2025-04"/>
                    <Button Content="V" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2025-05"/>
                    <Button Content="VI" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2025-06"/>
                    <Button Content="VII" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2025-07"/>
                    <Button Content="VIII" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2025-08"/>
                    <Button Content="IX" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2025-09"/>
                    <Button Content="X" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2025-10"/>
                    <Button Content="XI" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,2,0" Click="FilterButton_Click" Tag="2025-11"/>
                    <Button Content="XII" Style="{StaticResource FilterButton}" Padding="7,4" FontSize="10" Margin="0,0,0,0" Click="FilterButton_Click" Tag="2025-12"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- ======== SUMMARY CARDS ======== -->
        <Grid Grid.Row="2" Margin="16,6,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Utworzone -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="0,0,5,0" ClipToBounds="True">
                <Border.Effect><DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="1" BlurRadius="6" Opacity="0.2"/></Border.Effect>
                <Grid>
                    <Border Width="4" HorizontalAlignment="Left" Background="#5C8A3A" CornerRadius="10,0,0,10"/>
                    <StackPanel Margin="16,12,14,12">
                        <TextBlock Text="UTWORZONE" FontSize="10" Foreground="#95A5A6" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtTotalStworzone" Text="0" FontSize="28" FontWeight="Bold" Foreground="#5C8A3A"/>
                            <TextBlock Text=" wstawien" FontSize="11" Foreground="#95A5A6" VerticalAlignment="Bottom" Margin="4,0,0,5"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Potwierdzone -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Margin="5,0" ClipToBounds="True">
                <Border.Effect><DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="1" BlurRadius="6" Opacity="0.2"/></Border.Effect>
                <Grid>
                    <Border Width="4" HorizontalAlignment="Left" Background="#3498DB" CornerRadius="10,0,0,10"/>
                    <StackPanel Margin="16,12,14,12">
                        <TextBlock Text="POTWIERDZONE" FontSize="10" Foreground="#95A5A6" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtTotalPotwierdzone" Text="0" FontSize="28" FontWeight="Bold" Foreground="#3498DB"/>
                            <TextBlock Text=" wstawien" FontSize="11" Foreground="#95A5A6" VerticalAlignment="Bottom" Margin="4,0,0,5"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Oczekujace -->
            <Border Grid.Column="2" Background="White" CornerRadius="10" Margin="5,0" ClipToBounds="True">
                <Border.Effect><DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="1" BlurRadius="6" Opacity="0.2"/></Border.Effect>
                <Grid>
                    <Border Width="4" HorizontalAlignment="Left" Background="#F39C12" CornerRadius="10,0,0,10"/>
                    <StackPanel Margin="16,12,14,12">
                        <TextBlock Text="OCZEKUJACE" FontSize="10" Foreground="#95A5A6" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtTotalOczekujace" Text="0" FontSize="28" FontWeight="Bold" Foreground="#F39C12"/>
                            <TextBlock Text=" wstawien" FontSize="11" Foreground="#95A5A6" VerticalAlignment="Bottom" Margin="4,0,0,5"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- % Potwierdzonych -->
            <Border Grid.Column="3" Background="White" CornerRadius="10" Margin="5,0,0,0" ClipToBounds="True">
                <Border.Effect><DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="1" BlurRadius="6" Opacity="0.2"/></Border.Effect>
                <Grid>
                    <Border Width="4" HorizontalAlignment="Left" Background="#9B59B6" CornerRadius="10,0,0,10"/>
                    <StackPanel Margin="16,12,14,12">
                        <TextBlock Text="% POTWIERDZONYCH" FontSize="10" Foreground="#95A5A6" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <TextBlock x:Name="txtProcentPotwierdzone" Text="0%" FontSize="28" FontWeight="Bold" Foreground="#9B59B6"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- TabControl -->
        <TabControl x:Name="mainTabControl" Grid.Row="3" BorderThickness="0" Background="Transparent" Padding="0" Margin="16,0,16,10">

            <!-- ==================== TAB 1: PRZEGLAD ==================== -->
            <TabItem Header="Przeglad Wstawien" Style="{StaticResource TabHeaderStyle}">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Tabela na gorze - pelna szerokosc -->
                    <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="14" Margin="0,0,0,8">
                        <Border.Effect>
                            <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                        </Border.Effect>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Szczegolowa Lista Wstawien" FontSize="15" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,8"/>
                            <DataGrid x:Name="dgSzczegoly" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="0" Background="White" RowBackground="White" AlternatingRowBackground="#F8F9FA" FontSize="12" RowHeight="36">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Lp" Binding="{Binding Lp}" Width="50"/>
                                    <DataGridTextColumn Header="Dostawca" Binding="{Binding Dostawca}" Width="150"/>
                                    <DataGridTextColumn Header="Data Wstawienia" Binding="{Binding DataWstawienia, StringFormat=dd.MM.yyyy}" Width="120"/>
                                    <DataGridTextColumn Header="Ilosc" Binding="{Binding IloscWstawienia}" Width="80"/>
                                    <DataGridTemplateColumn Header="Utworzyl" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2">
                                                    <Grid Width="26" Height="26" Margin="0,0,6,0">
                                                        <Border Width="26" Height="26" CornerRadius="13" Background="#5C8A3A">
                                                            <TextBlock Text="{Binding InitialsStworzyl}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="9" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <Ellipse Width="26" Height="26">
                                                            <Ellipse.Fill>
                                                                <ImageBrush ImageSource="{Binding AvatarStworzyl}" Stretch="UniformToFill"/>
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                    </Grid>
                                                    <TextBlock Text="{Binding KtoStworzyl}" VerticalAlignment="Center" FontSize="11"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Data Utw." Binding="{Binding DataUtw, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                    <DataGridTemplateColumn Header="Potwierdzil" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2">
                                                    <Grid Width="26" Height="26" Margin="0,0,6,0">
                                                        <Border Width="26" Height="26" CornerRadius="13" Background="#3498DB">
                                                            <TextBlock Text="{Binding InitialsPotwierdził}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="9" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <Ellipse Width="26" Height="26">
                                                            <Ellipse.Fill>
                                                                <ImageBrush ImageSource="{Binding AvatarPotwierdził}" Stretch="UniformToFill"/>
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                    </Grid>
                                                    <TextBlock Text="{Binding KtoPotwierdził}" VerticalAlignment="Center" FontSize="11"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Data Potw." Binding="{Binding DataConf, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- Diagramy pod tabela - 2 kolumny, mniejsze -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Kto utworzyl -->
                        <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="12,10" Margin="0,0,4,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="1" BlurRadius="6" Opacity="0.25"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Kto Utworzyl" FontSize="12" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,6"/>
                                    <Canvas x:Name="canvasStworzone" Width="110" Height="110"/>
                                </StackPanel>
                                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" MaxHeight="140" Margin="8,0,0,0">
                                    <ItemsControl x:Name="itemsStworzone">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Button Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Stretch" Padding="0" Click="BtnPracownikDetails_Click" Tag="{Binding NazwaPracownika}">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Grid Width="22" Height="22" Margin="0,0,5,0">
                                                                <Border Width="22" Height="22" CornerRadius="11" Background="{Binding Kolor}">
                                                                    <TextBlock Text="{Binding Initials}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="8" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <Ellipse Width="22" Height="22" x:Name="avatarEllipse">
                                                                    <Ellipse.Fill>
                                                                        <ImageBrush ImageSource="{Binding AvatarSource}" Stretch="UniformToFill"/>
                                                                    </Ellipse.Fill>
                                                                </Ellipse>
                                                            </Grid>
                                                            <TextBlock Text="{Binding NazwaPracownika}" FontWeight="SemiBold" Foreground="#5D6D7E" FontSize="11" TextDecorations="Underline" VerticalAlignment="Center"/>
                                                            <TextBlock FontWeight="Bold" Foreground="#5C8A3A" Margin="4,0,0,0" FontSize="11" VerticalAlignment="Center">
                                                                <Run Text="("/><Run Text="{Binding LiczbaAkcji}"/><Run Text=")"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Button>
                                                    <Border Grid.Row="1" Height="5" Background="#EAECEE" CornerRadius="3" Margin="0,2,0,0">
                                                        <Border HorizontalAlignment="Left" Background="{Binding Kolor}" CornerRadius="3" Width="{Binding ProcentWidth, Mode=OneWay}"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Kto potwierdzil -->
                        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="12,10" Margin="4,0,0,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="1" BlurRadius="6" Opacity="0.25"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Kto Potwierdzil" FontSize="12" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,6"/>
                                    <Canvas x:Name="canvasPotwierdzone" Width="110" Height="110"/>
                                </StackPanel>
                                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" MaxHeight="140" Margin="8,0,0,0">
                                    <ItemsControl x:Name="itemsPotwierdzone">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Button Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Stretch" Padding="0" Click="BtnPracownikDetails_Click" Tag="{Binding NazwaPracownika}">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Grid Width="22" Height="22" Margin="0,0,5,0">
                                                                <Border Width="22" Height="22" CornerRadius="11" Background="{Binding Kolor}">
                                                                    <TextBlock Text="{Binding Initials}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="8" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <Ellipse Width="22" Height="22">
                                                                    <Ellipse.Fill>
                                                                        <ImageBrush ImageSource="{Binding AvatarSource}" Stretch="UniformToFill"/>
                                                                    </Ellipse.Fill>
                                                                </Ellipse>
                                                            </Grid>
                                                            <TextBlock Text="{Binding NazwaPracownika}" FontWeight="SemiBold" Foreground="#5D6D7E" FontSize="11" TextDecorations="Underline" VerticalAlignment="Center"/>
                                                            <TextBlock FontWeight="Bold" Foreground="#3498DB" Margin="4,0,0,0" FontSize="11" VerticalAlignment="Center">
                                                                <Run Text="("/><Run Text="{Binding LiczbaAkcji}"/><Run Text=")"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Button>
                                                    <Border Grid.Row="1" Height="5" Background="#EAECEE" CornerRadius="3" Margin="0,2,0,0">
                                                        <Border HorizontalAlignment="Left" Background="{Binding Kolor}" CornerRadius="3" Width="{Binding ProcentWidth, Mode=OneWay}"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ==================== TAB 2: KPI WIELOMODULOWE ==================== -->
            <TabItem Header="KPI Wielomodulowe" Style="{StaticResource TabHeaderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <StackPanel>

                        <!-- Hidden TextBlocks for leader data (used by C# code, not displayed) -->
                        <TextBlock x:Name="txtCmLiderWstawien" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderWstawienVal" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderKalendarz" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderKalendarzVal" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderSpec" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderSpecVal" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderHodowcy" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderHodowcyVal" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderOgolny" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderOgolnyVal" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderNajszybszy" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderNajszybszyVal" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderNajaktywniejszy" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderNajaktywniejszyVal" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderWolumen" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderWolumenVal" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderJakosc" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderJakoscVal" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderSeria" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtCmLiderSeriaVal" Visibility="Collapsed"/>

                        <!-- Ranking wielomodulowy -->
                        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                            <Border.Effect>
                                <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                            </Border.Effect>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Ranking Wielomodulowy Zakupowcow" FontSize="18" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,15"/>
                                <TextBlock DockPanel.Dock="Top" Text="Dwuklik w komorke = szczegoly akcji danego modulu" FontSize="10" Foreground="#95A5A6" Margin="0,0,0,10" FontStyle="Italic"/>
                                <DataGrid x:Name="dgCrossModule" AutoGenerateColumns="False" IsReadOnly="True"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          GridLinesVisibility="None" HeadersVisibility="Column"
                                          BorderThickness="0" Background="White"
                                          RowStyle="{StaticResource RankingRowStyle}"
                                          ColumnHeaderStyle="{StaticResource RankingHeaderStyle}"
                                          CellStyle="{StaticResource RankingCellStyle}"
                                          FontSize="12" RowHeight="44" CanUserSortColumns="True"
                                          HorizontalScrollBarVisibility="Auto"
                                          SelectionMode="Single" SelectionUnit="FullRow"
                                          MouseDoubleClick="DgCrossModule_MouseDoubleClick"
                                          Cursor="Hand">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="35">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#5C8A3A"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTemplateColumn Header="Zakupowiec" Width="180" SortMemberPath="Nazwa">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                        <Grid Width="28" Height="28" Margin="0,0,6,0">
                                                            <Border Width="28" Height="28" CornerRadius="14" Background="{Binding KolorBrush}">
                                                                <TextBlock Text="{Binding Inicjaly}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                                            </Border>
                                                            <Ellipse Width="28" Height="28">
                                                                <Ellipse.Fill>
                                                                    <ImageBrush ImageSource="{Binding AvatarSource}" Stretch="UniformToFill"/>
                                                                </Ellipse.Fill>
                                                            </Ellipse>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Nazwa}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2C3E50" FontSize="12"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Wstawienia (utworzone) -->
                                        <DataGridTemplateColumn Header="Wstawienia" Width="90" SortMemberPath="WstawieniaUtworzone">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="#27AE60"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,8"/><Setter Property="Background" Value="#F1F3F5"/><Setter Property="BorderBrush" Value="#DEE2E6"/><Setter Property="BorderThickness" Value="0,0,1,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding WstawieniaUtworzone}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="14" Foreground="#27AE60"
                                                               ToolTip="Utworzone wstawienia (WstawieniaKurczakow)"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Potwierdzenia -->
                                        <DataGridTemplateColumn Header="Potwierdz." Width="90" SortMemberPath="WstawieniaPotwierdzone">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="#1E8449"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,8"/><Setter Property="Background" Value="#F1F3F5"/><Setter Property="BorderBrush" Value="#DEE2E6"/><Setter Property="BorderThickness" Value="0,0,1,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding WstawieniaPotwierdzone}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="14" Foreground="#1E8449"
                                                               ToolTip="Potwierdzone wstawienia (WstawieniaKurczakow)"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Kalendarz -->
                                        <DataGridTemplateColumn Header="Kalendarz" Width="90" SortMemberPath="KalendarzTotal">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="#2980B9"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,8"/><Setter Property="Background" Value="#F1F3F5"/><Setter Property="BorderBrush" Value="#DEE2E6"/><Setter Property="BorderThickness" Value="0,0,1,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding KalendarzTotal}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="14" Foreground="#2980B9"
                                                               ToolTip="{Binding KalendarzTooltip}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Specyfikacja (wprowadzenia + weryfikacje) -->
                                        <DataGridTemplateColumn Header="Specyfikacja" Width="100" SortMemberPath="SpecyfikacjaTotal">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="#8E44AD"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,8"/><Setter Property="Background" Value="#F1F3F5"/><Setter Property="BorderBrush" Value="#DEE2E6"/><Setter Property="BorderThickness" Value="0,0,1,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding SpecyfikacjaTotal}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="14" Foreground="#8E44AD"
                                                               ToolTip="{Binding SpecyfikacjaTooltip}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Pozyskiwanie Hodowcow -->
                                        <DataGridTemplateColumn Header="Pozyskiwanie" Width="100" SortMemberPath="HodowcyTotal">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="#E74C3C"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,8"/><Setter Property="Background" Value="#F1F3F5"/><Setter Property="BorderBrush" Value="#DEE2E6"/><Setter Property="BorderThickness" Value="0,0,1,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding HodowcyTotal}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="14" Foreground="#E74C3C"
                                                               ToolTip="{Binding HodowcyTooltip}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Dokumenty -->
                                        <DataGridTemplateColumn Header="Dokumenty" Width="90" SortMemberPath="DokumentyTotal">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="#16A085"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,8"/><Setter Property="Background" Value="#F1F3F5"/><Setter Property="BorderBrush" Value="#DEE2E6"/><Setter Property="BorderThickness" Value="0,0,1,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DokumentyTotal}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="14" Foreground="#16A085"
                                                               ToolTip="{Binding DokumentyTooltip}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Wnioski -->
                                        <DataGridTemplateColumn Header="Wnioski" Width="80" SortMemberPath="WnioskiTotal">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="#E67E22"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,8"/><Setter Property="Background" Value="#F1F3F5"/><Setter Property="BorderBrush" Value="#DEE2E6"/><Setter Property="BorderThickness" Value="0,0,1,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding WnioskiTotal}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="14" Foreground="#E67E22"
                                                               ToolTip="{Binding WnioskiTooltip}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- SUMA -->
                                        <DataGridTemplateColumn Header="SUMA" Width="80" SortMemberPath="SumaAkcji">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="White"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="12"/><Setter Property="Background" Value="#1ABC9C"/><Setter Property="Padding" Value="10,8"/><Setter Property="BorderThickness" Value="0,0,0,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Background="#E8F8F5" CornerRadius="6" Padding="6,2" Margin="2">
                                                        <TextBlock Text="{Binding SumaAkcji}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontWeight="Bold" FontSize="15" Foreground="#1ABC9C"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- EFEKTYWNOSC -->
                                        <DataGridTemplateColumn Header="Efektywn." Width="85" SortMemberPath="Efektywnosc">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="White"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="11"/><Setter Property="Background" Value="#2ECC71"/><Setter Property="Padding" Value="10,8"/><Setter Property="BorderThickness" Value="0,0,0,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding EfektywnoscTekst}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="13" Foreground="#27AE60"
                                                               ToolTip="Stosunek akcji merytorycznych (bez edycji) do calkowitych"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- AUDYT -->
                                        <DataGridTemplateColumn Header="Audyt" Width="80" SortMemberPath="AudytTotal">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="White"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="11"/><Setter Property="Background" Value="#E74C3C"/><Setter Property="Padding" Value="10,8"/><Setter Property="BorderThickness" Value="0,0,0,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="6" Padding="6,2" Margin="2"
                                                            ToolTip="{Binding AudytTooltip}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AudytTotal}" Value="0">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="14">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="{Binding AudytTotal}"/>
                                                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AudytTotal}" Value="0">
                                                                            <Setter Property="Text" Value="-"/>
                                                                            <Setter Property="Foreground" Value="#BDC3C7"/>
                                                                            <Setter Property="FontWeight" Value="Normal"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <!-- Hidden elements referenced by C# code -->
                        <TextBlock x:Name="txtAlertPuste" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtAlertSerie" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtAlertSamo" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtAlertOdwrocone" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtAlertPozaGodz" Visibility="Collapsed"/>
                        <TextBlock x:Name="txtAlertPowtNotatki" Visibility="Collapsed"/>
                        <DataGrid x:Name="dgCrossModuleDetail" Visibility="Collapsed"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
