                                    <TextBlock x:Name="txtTopProcentVal" Text="" FontSize="12" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Najwiecej dostawcow -->
                            <Border Grid.Column="3" Background="#FEF9E7" CornerRadius="12" Padding="18,14" Margin="5,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Najwiecej dostawcow" FontSize="11" Foreground="#5D6D7E" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="txtTopDostawcy" Text="-" FontSize="16" FontWeight="Bold" Foreground="#F39C12"/>
                                    <TextBlock x:Name="txtTopDostawcyVal" Text="" FontSize="12" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Ranking zakupowcow -->
                        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                            <Border.Effect>
                                <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                            </Border.Effect>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Ranking Zakupowcow" FontSize="18" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,15"/>
                                <DataGrid x:Name="dgKpiRanking" AutoGenerateColumns="False" IsReadOnly="True"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                          BorderThickness="0" Background="White"
                                          RowBackground="White" AlternatingRowBackground="#F8F9FA"
                                          FontSize="12" RowHeight="42" CanUserSortColumns="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="40">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#5C8A3A"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTemplateColumn Header="Zakupowiec" Width="200" SortMemberPath="Nazwa">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                        <Grid Width="30" Height="30" Margin="0,0,8,0">
                                                            <Border Width="30" Height="30" CornerRadius="15" Background="{Binding KolorBrush}">
                                                                <TextBlock Text="{Binding Inicjaly}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                            </Border>
                                                            <Ellipse Width="30" Height="30">
                                                                <Ellipse.Fill>
                                                                    <ImageBrush ImageSource="{Binding AvatarSource}" Stretch="UniformToFill"/>
                                                                </Ellipse.Fill>
                                                            </Ellipse>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Nazwa}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Utworzone" Binding="{Binding Utworzone}" Width="90" SortMemberPath="Utworzone">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Potwierdzone" Binding="{Binding Potwierdzone}" Width="100" SortMemberPath="Potwierdzone">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="#3498DB"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTemplateColumn Header="% Potw." Width="120" SortMemberPath="ProcentPotwierdzonych">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid VerticalAlignment="Center" Margin="4,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding ProcentPotwTekst}" FontWeight="SemiBold" Foreground="#8E44AD" VerticalAlignment="Center"/>
                                                        <Border Grid.Column="1" Height="6" Background="#EAECEE" CornerRadius="3" Margin="4,0,0,0" VerticalAlignment="Center">
                                                            <Border HorizontalAlignment="Left" Background="#8E44AD" CornerRadius="3" Width="{Binding ProcentPotwWidth}"/>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Sr. czas potw." Binding="{Binding SredniCzasPotwTekst}" Width="120" SortMemberPath="SredniCzasPotwGodziny">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="#27AE60"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Dostawcy" Binding="{Binding LiczbaDostawcow}" Width="80" SortMemberPath="LiczbaDostawcow">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="#F39C12"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Wolumen (szt.)" Binding="{Binding WolumenTekst}" Width="120" SortMemberPath="Wolumen">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#2980B9"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Wst./dzien" Binding="{Binding ProduktywTekst}" Width="90" SortMemberPath="Produktywnosc">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <!-- Przestrzen na przyszle KPI -->
                        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                            <Border.Effect>
                                <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                            </Border.Effect>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Dodatkowe KPI (miejsce na rozbudowe)" FontSize="18" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,15"/>
                                <Border Background="#F8F9FA" CornerRadius="8" Padding="30" MinHeight="120">
                                    <TextBlock Text="Tu mozesz dodac kolejne wskazniki KPI - np. trendy miesiac do miesiaca, porownania okresow, cele i ich realizacja, alerty o niepotwierdzonych wstawieniach, itd."
                                               FontSize="13" Foreground="#95A5A6" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                                </Border>
                            </DockPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== TAB 3: KPI WIELOMODULOWE ==================== -->
            <TabItem Header="KPI Wielomodulowe" Style="{StaticResource TabHeaderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <StackPanel>

                        <!-- Top performers per module -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#EAFAF1" CornerRadius="12" Padding="14,12" Margin="0,0,4,0">
                                <Border.Effect><DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="6" Opacity="0.25"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="LIDER WSTAWIEN" FontSize="9" Foreground="#5D6D7E" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="txtCmLiderWstawien" Text="-" FontSize="14" FontWeight="Bold" Foreground="#27AE60"/>
                                    <TextBlock x:Name="txtCmLiderWstawienVal" Text="" FontSize="11" Foreground="#7F8C8D"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#EBF5FB" CornerRadius="12" Padding="14,12" Margin="4,0">
                                <Border.Effect><DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="6" Opacity="0.25"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="LIDER KALENDARZA" FontSize="9" Foreground="#5D6D7E" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="txtCmLiderKalendarz" Text="-" FontSize="14" FontWeight="Bold" Foreground="#2980B9"/>
                                    <TextBlock x:Name="txtCmLiderKalendarzVal" Text="" FontSize="11" Foreground="#7F8C8D"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#F5EEF8" CornerRadius="12" Padding="14,12" Margin="4,0">
                                <Border.Effect><DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="6" Opacity="0.25"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="LIDER SPECYFIKACJI" FontSize="9" Foreground="#5D6D7E" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="txtCmLiderSpec" Text="-" FontSize="14" FontWeight="Bold" Foreground="#8E44AD"/>
                                    <TextBlock x:Name="txtCmLiderSpecVal" Text="" FontSize="11" Foreground="#7F8C8D"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Background="#FDEDEC" CornerRadius="12" Padding="14,12" Margin="4,0">
                                <Border.Effect><DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="6" Opacity="0.25"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="LIDER POZYSKIWANIA" FontSize="9" Foreground="#5D6D7E" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="txtCmLiderHodowcy" Text="-" FontSize="14" FontWeight="Bold" Foreground="#E74C3C"/>
                                    <TextBlock x:Name="txtCmLiderHodowcyVal" Text="" FontSize="11" Foreground="#7F8C8D"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Background="#E8F6F3" CornerRadius="12" Padding="14,12" Margin="4,0,0,0">
                                <Border.Effect><DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="6" Opacity="0.25"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="LIDER OGOLNY" FontSize="9" Foreground="#5D6D7E" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="txtCmLiderOgolny" Text="-" FontSize="14" FontWeight="Bold" Foreground="#1ABC9C"/>
                                    <TextBlock x:Name="txtCmLiderOgolnyVal" Text="" FontSize="11" Foreground="#7F8C8D"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Ranking wielomodulowy -->
                        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                            <Border.Effect>
                                <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                            </Border.Effect>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Ranking Wielomodulowy Zakupowcow" FontSize="18" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,15"/>
                                <TextBlock DockPanel.Dock="Top" Text="Dwuklik w komorke = szczegoly akcji danego modulu" FontSize="10" Foreground="#95A5A6" Margin="0,0,0,10" FontStyle="Italic"/>
                                <DataGrid x:Name="dgCrossModule" AutoGenerateColumns="False" IsReadOnly="True"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          GridLinesVisibility="None" HeadersVisibility="Column"
                                          BorderThickness="0" Background="White"
                                          RowStyle="{StaticResource RankingRowStyle}"
                                          ColumnHeaderStyle="{StaticResource RankingHeaderStyle}"
                                          CellStyle="{StaticResource RankingCellStyle}"
                                          FontSize="12" RowHeight="44" CanUserSortColumns="True"
                                          HorizontalScrollBarVisibility="Auto"
                                          SelectionMode="Single" SelectionUnit="FullRow"
                                          MouseDoubleClick="DgCrossModule_MouseDoubleClick"
                                          Cursor="Hand">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="35">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#5C8A3A"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTemplateColumn Header="Zakupowiec" Width="180" SortMemberPath="Nazwa">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                        <Grid Width="28" Height="28" Margin="0,0,6,0">
                                                            <Border Width="28" Height="28" CornerRadius="14" Background="{Binding KolorBrush}">
                                                                <TextBlock Text="{Binding Inicjaly}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                                            </Border>
                                                            <Ellipse Width="28" Height="28">
                                                                <Ellipse.Fill>
                                                                    <ImageBrush ImageSource="{Binding AvatarSource}" Stretch="UniformToFill"/>
                                                                </Ellipse.Fill>
                                                            </Ellipse>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Nazwa}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2C3E50" FontSize="12"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Wstawienia -->
                                        <DataGridTemplateColumn Header="Wstawienia" Width="90" SortMemberPath="WstawieniaTotal">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="#27AE60"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,8"/><Setter Property="Background" Value="#F1F3F5"/><Setter Property="BorderBrush" Value="#DEE2E6"/><Setter Property="BorderThickness" Value="0,0,1,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding WstawieniaTotal}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="14" Foreground="#27AE60"
                                                               ToolTip="{Binding WstawieniaTooltip}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Kalendarz -->
                                        <DataGridTemplateColumn Header="Kalendarz" Width="90" SortMemberPath="KalendarzTotal">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="#2980B9"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,8"/><Setter Property="Background" Value="#F1F3F5"/><Setter Property="BorderBrush" Value="#DEE2E6"/><Setter Property="BorderThickness" Value="0,0,1,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding KalendarzTotal}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="14" Foreground="#2980B9"
                                                               ToolTip="{Binding KalendarzTooltip}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Specyfikacja (wprowadzenia + weryfikacje) -->
                                        <DataGridTemplateColumn Header="Specyfikacja" Width="100" SortMemberPath="SpecyfikacjaTotal">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="#8E44AD"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,8"/><Setter Property="Background" Value="#F1F3F5"/><Setter Property="BorderBrush" Value="#DEE2E6"/><Setter Property="BorderThickness" Value="0,0,1,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding SpecyfikacjaTotal}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="14" Foreground="#8E44AD"
                                                               ToolTip="{Binding SpecyfikacjaTooltip}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Pozyskiwanie Hodowcow -->
                                        <DataGridTemplateColumn Header="Pozyskiwanie" Width="100" SortMemberPath="HodowcyTotal">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="#E74C3C"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,8"/><Setter Property="Background" Value="#F1F3F5"/><Setter Property="BorderBrush" Value="#DEE2E6"/><Setter Property="BorderThickness" Value="0,0,1,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding HodowcyTotal}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="14" Foreground="#E74C3C"
                                                               ToolTip="{Binding HodowcyTooltip}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Dokumenty -->
                                        <DataGridTemplateColumn Header="Dokumenty" Width="90" SortMemberPath="DokumentyTotal">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="#16A085"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,8"/><Setter Property="Background" Value="#F1F3F5"/><Setter Property="BorderBrush" Value="#DEE2E6"/><Setter Property="BorderThickness" Value="0,0,1,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DokumentyTotal}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="14" Foreground="#16A085"
                                                               ToolTip="{Binding DokumentyTooltip}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Wnioski -->
                                        <DataGridTemplateColumn Header="Wnioski" Width="80" SortMemberPath="WnioskiTotal">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="#E67E22"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,8"/><Setter Property="Background" Value="#F1F3F5"/><Setter Property="BorderBrush" Value="#DEE2E6"/><Setter Property="BorderThickness" Value="0,0,1,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding WnioskiTotal}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="14" Foreground="#E67E22"
                                                               ToolTip="{Binding WnioskiTooltip}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- SUMA -->
                                        <DataGridTemplateColumn Header="SUMA" Width="80" SortMemberPath="SumaAkcji">
                                            <DataGridTemplateColumn.HeaderStyle><Style TargetType="DataGridColumnHeader"><Setter Property="Foreground" Value="White"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="12"/><Setter Property="Background" Value="#1ABC9C"/><Setter Property="Padding" Value="10,8"/><Setter Property="BorderThickness" Value="0,0,0,2"/></Style></DataGridTemplateColumn.HeaderStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Background="#E8F8F5" CornerRadius="6" Padding="6,2" Margin="2">
                                                        <TextBlock Text="{Binding SumaAkcji}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontWeight="Bold" FontSize="15" Foreground="#1ABC9C"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <!-- Legenda modulow -->
                        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                            <Border.Effect>
                                <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Legenda - co mierzy kazdy modul" FontSize="16" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,12"/>
                                <WrapPanel>
                                    <Border Background="#EAFAF1" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                        <TextBlock FontSize="11"><Run FontWeight="Bold" Foreground="#27AE60" Text="Wstawienia"/><Run Text=" = Utworzone + Potwierdzone cykle wstawien (WstawieniaKurczakow)"/></TextBlock>
                                    </Border>
                                    <Border Background="#EBF5FB" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                        <TextBlock FontSize="11"><Run FontWeight="Bold" Foreground="#2980B9" Text="Kalendarz"/><Run Text=" = Dostawy utworzone + Potw. wagi + Potw. sztuk (HarmonogramDostaw)"/></TextBlock>
                                    </Border>
                                    <Border Background="#F5EEF8" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                        <TextBlock FontSize="11"><Run FontWeight="Bold" Foreground="#8E44AD" Text="Specyfikacja"/><Run Text=" = Wprowadzenia + Weryfikacje specyfikacji surowca (RozliczeniaZatwierdzenia)"/></TextBlock>
                                    </Border>
                                    <Border Background="#FDEDEC" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                        <TextBlock FontSize="11"><Run FontWeight="Bold" Foreground="#E74C3C" Text="Pozyskiwanie"/><Run Text=" = Telefony + Notatki CRM + Oceny dostawcow z modulu Pozyskiwanie Hodowcow"/></TextBlock>
                                    </Border>
                                    <Border Background="#E8F6F3" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                        <TextBlock FontSize="11"><Run FontWeight="Bold" Foreground="#16A085" Text="Dokumenty"/><Run Text=" = Utworzone + Wyslane + Otrzymane dokumenty/umowy (HarmonogramDostaw flagi)"/></TextBlock>
                                    </Border>
                                    <Border Background="#FDF2E9" CornerRadius="6" Padding="10,6" Margin="0,0,8,8">
                                        <TextBlock FontSize="11"><Run FontWeight="Bold" Foreground="#E67E22" Text="Wnioski"/><Run Text=" = Wnioski o zmiany danych hodowcow zlozone + rozpatrzone (DostawcyCR)"/></TextBlock>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Szczegoly per modul -->
                        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                            <Border.Effect>
                                <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                            </Border.Effect>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Rozbicie Szczegolowe per Modul" FontSize="18" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,15"/>
                                <DataGrid x:Name="dgCrossModuleDetail" AutoGenerateColumns="False" IsReadOnly="True"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          GridLinesVisibility="None" HeadersVisibility="Column"
                                          BorderThickness="0" Background="White"
                                          RowStyle="{StaticResource RankingRowStyle}"
                                          ColumnHeaderStyle="{StaticResource RankingHeaderStyle}"
                                          CellStyle="{StaticResource RankingCellStyle}"
                                          FontSize="11" RowHeight="36" CanUserSortColumns="True"
                                          HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="30">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="#95A5A6"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Zakupowiec" Binding="{Binding Nazwa}" Width="160" SortMemberPath="Nazwa">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="FontWeight" Value="SemiBold"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <!-- Wstawienia detail -->
                                        <DataGridTextColumn Header="W:Utw" Binding="{Binding WstawieniaUtworzone}" Width="55">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="W:Potw" Binding="{Binding WstawieniaPotwierdzone}" Width="60">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <!-- Kalendarz detail -->
                                        <DataGridTextColumn Header="K:Dost" Binding="{Binding KalendarzDostawy}" Width="55">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="K:Waga" Binding="{Binding KalendarzPotwWagi}" Width="60">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="K:Szt" Binding="{Binding KalendarzPotwSztuk}" Width="55">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <!-- Specyfikacja detail -->
                                        <DataGridTextColumn Header="Wprow." Binding="{Binding SpecWprowadzenia}" Width="60">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="Foreground" Value="#8E44AD"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Weryf." Binding="{Binding SpecWeryfikacje}" Width="60">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="Foreground" Value="#8E44AD"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <!-- Pozyskiwanie Hodowcow detail -->
                                        <DataGridTextColumn Header="H:Tel" Binding="{Binding HodowcyTelefony}" Width="50">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="H:Not" Binding="{Binding HodowcyNotatki}" Width="50">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="H:Oc" Binding="{Binding HodowcyOceny}" Width="50">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <!-- Dokumenty detail -->
                                        <DataGridTextColumn Header="D:Utw" Binding="{Binding DokumentyUtworzone}" Width="55">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="D:Wys" Binding="{Binding DokumentyWyslane}" Width="55">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="D:Otrz" Binding="{Binding DokumentyOtrzymane}" Width="55">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <!-- Wnioski detail -->
                                        <DataGridTextColumn Header="Wn:Zloz" Binding="{Binding WnioskiZlozone}" Width="60">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Wn:Dec" Binding="{Binding WnioskiRozpatrzone}" Width="60">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <!-- Propozycje dodatkowych KPI -->
                        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                            <Border.Effect>
                                <DropShadowEffect Color="#D5D8DC" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Propozycje dodatkowych KPI do wdrozenia" FontSize="16" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,12"/>
                                <Border Background="#F8F9FA" CornerRadius="8" Padding="20" MinHeight="80">
                                    <TextBlock FontSize="12" Foreground="#5D6D7E" TextWrapping="Wrap" LineHeight="22">
                                        <Run FontWeight="Bold">1.</Run><Run Text=" Czas reakcji na wstawienie (sr. czas od utworzenia do potwierdzenia per osoba)"/><LineBreak/>
                                        <Run FontWeight="Bold">2.</Run><Run Text=" Trend miesiac do miesiaca (porownanie aktywnosci z poprzednim okresem, strzalki gora/dol)"/><LineBreak/>
                                        <Run FontWeight="Bold">3.</Run><Run Text=" Procent potwierdzen wagi/sztuk w ciagu 24h od dostawy"/><LineBreak/>
                                        <Run FontWeight="Bold">4.</Run><Run Text=" Pokrycie dostawcow (ile unikalnych dostawcow obsluzyl kazdy zakupowiec)"/><LineBreak/>
                                        <Run FontWeight="Bold">5.</Run><Run Text=" Wolumen zakupow per osoba (suma IloscWstawienia + SztukiDek z kalendarza)"/><LineBreak/>
                                        <Run FontWeight="Bold">6.</Run><Run Text=" Wskaznik samodzielnosci (ile operacji bez pomocy innych)"/><LineBreak/>
                                        <Run FontWeight="Bold">7.</Run><Run Text=" Wskaznik poprawek SMS (ile razy musial wyslac korekte po zmianie planu)"/><LineBreak/>
                                        <Run FontWeight="Bold">8.</Run><Run Text=" Skutecznosc telefonow do hodowcow (% odebranych / proba kontaktu)"/><LineBreak/>
                                        <Run FontWeight="Bold">9.</Run><Run Text=" Czas od zatwierdzenia specyfikacji do weryfikacji (dwuetapowy workflow)"/><LineBreak/>
                                        <Run FontWeight="Bold">10.</Run><Run Text=" Aktywnosc godzinowa (heat-mapa: kiedy w ciagu dnia pracownik jest najaktywniejszy)"/><LineBreak/>
                                        <Run FontWeight="Bold">11.</Run><Run Text=" Wskaznik terminowosci dokumentow (ile dokumentow wyslanych w terminie)"/><LineBreak/>
                                        <Run FontWeight="Bold">12.</Run><Run Text=" Ranking jakosci hodowcow per zakupowiec (sr. ocena dostawcow ktore obsluguje)"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
