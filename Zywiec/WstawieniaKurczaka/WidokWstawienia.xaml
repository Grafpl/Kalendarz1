<Window x:Class="Kalendarz1.WidokWstawienia"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="🐔 System Zarządzania Wstawieniami Kurczaków" 
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#ECF0F1"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#5C8A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4B732F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A5C24"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E5E8EC"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5C8A3A"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFB"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#5C8A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#4B732F"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="10,5">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F5E9"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HasDropShadow" Value="True"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#E8F5E9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#ECF0F1" Offset="0"/>
                <GradientStop Color="#E0E6E8" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="4" Margin="0,0,8,0" BorderBrush="#5C8A3A" BorderThickness="1.5" VerticalAlignment="Center">
                        <Image x:Name="imgLogo" Width="28" Height="28" Stretch="Uniform"/>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,14,0">
                            <TextBlock Text="📋 Panel Główny Wstawień" FontSize="12" FontWeight="Bold" Foreground="#2C3E50"/>
                            <TextBlock Text="Zarządzanie hodowcami, dostawami i kontaktami" FontSize="8.5" Foreground="#5C8A3A" FontWeight="SemiBold" Margin="0,1,0,0"/>
                        </StackPanel>

                        <!-- 🔍 Szukajka (po lewej, zaraz przy tytule) -->
                        <Border Background="#F8F9FA" CornerRadius="14" Padding="8,3" BorderBrush="#CFD8DC" BorderThickness="1"
                                Width="200" Height="28" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔍" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#5C8A3A"/>
                                <TextBox Grid.Column="1" x:Name="textBoxFilter"
                                         BorderThickness="0" Background="Transparent"
                                         Padding="0" FontSize="10.5" Foreground="#2C3E50"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- ➕ Dodaj (po szukajce) -->
                        <Button Style="{StaticResource PrimaryButton}"
                                Height="28" FontSize="10" Click="BtnDodaj_Click"
                                ToolTip="Dodaj nowe wstawienie (Ctrl+N)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Text="Dodaj" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- ⌨️ Legenda skrótów klawiszowych — 3 grupy: 📱 SMS / ✅ Akcje / 📋 Lista -->
                    <Border Grid.Column="2" Background="#FFFFFF" CornerRadius="8" Padding="10,5" BorderBrush="#CFD8DC" BorderThickness="1"
                            VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8,0,8,0">
                        <Border.ToolTip>
                            <TextBlock>
                                <Run Text="Skróty klawiszowe działają gdy fokus jest w tabeli." FontWeight="Bold"/>
                                <LineBreak/>
                                <Run Text="Najpierw kliknij wiersz, potem naciśnij klawisz."/>
                                <LineBreak/>
                                <LineBreak/>
                                <Run Text="📱 SMS" FontWeight="Bold" Foreground="#C0392B"/>
                                <LineBreak/>
                                <Run Text="   S = wyślij SMS krótki (skopiuje treść do schowka)"/>
                                <LineBreak/>
                                <Run Text="   Shift+S = wyślij SMS pełny (oficjalny standardowy)"/>
                                <LineBreak/>
                                <LineBreak/>
                                <Run Text="✅ Akcje" FontWeight="Bold" Foreground="#27AE60"/>
                                <LineBreak/>
                                <Run Text="   F = potwierdź wstawienie (bez pytania)"/>
                                <LineBreak/>
                                <Run Text="   R = oznacz 'nie odebrał' + snooze 3 dni"/>
                                <LineBreak/>
                                <LineBreak/>
                                <Run Text="📋 Lista" FontWeight="Bold" Foreground="#2980B9"/>
                                <LineBreak/>
                                <Run Text="   Ctrl+N = dodaj nowe wstawienie"/>
                                <LineBreak/>
                                <Run Text="   Enter = otwórz edycję wstawienia"/>
                                <LineBreak/>
                                <Run Text="   Del = usuń wstawienie (z potwierdzeniem)"/>
                                <LineBreak/>
                                <Run Text="   F5 = odśwież wszystkie listy"/>
                            </TextBlock>
                        </Border.ToolTip>
                        <StackPanel Orientation="Horizontal">

                            <!-- GRUPA 1: 📱 SMS (priorytetowe, czerwone) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                                <TextBlock Text="📱" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"
                                           ToolTip="📱 SMS — najczęściej używane skróty"/>
                                <Border Background="#C0392B" CornerRadius="4" Padding="6,2" Margin="0,0,3,0"
                                        ToolTip="Wyślij SMS krótki (wariant 2) — kopiuje treść do schowka">
                                    <TextBlock Text="S" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="krótki" FontSize="10" Foreground="#37474F" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Border Background="#C0392B" CornerRadius="4" Padding="6,2" Margin="0,0,3,0"
                                        ToolTip="Wyślij SMS pełny (wariant 1) — oficjalny standardowy">
                                    <TextBlock Text="⇧S" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="pełny" FontSize="10" Foreground="#37474F" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Rectangle Width="1" Height="20" Fill="#CFD8DC" Margin="6,0,6,0" VerticalAlignment="Center"/>

                            <!-- GRUPA 2: ✅ Akcje (potwierdź / nie odebrał) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                                <TextBlock Text="✅" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"
                                           ToolTip="✅ Akcje — zmień status wstawienia"/>
                                <Border Background="#27AE60" CornerRadius="4" Padding="6,2" Margin="0,0,3,0"
                                        ToolTip="Potwierdź wstawienie natychmiast — bez pytania">
                                    <TextBlock Text="F" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="potwierdź" FontSize="10" Foreground="#37474F" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Border Background="#E67E22" CornerRadius="4" Padding="6,2" Margin="0,0,3,0"
                                        ToolTip="Oznacz 'nie odebrał' i odłóż o 3 dni (tylko Przypomnienia)">
                                    <TextBlock Text="R" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="nie odebrał" FontSize="10" Foreground="#37474F" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Rectangle Width="1" Height="20" Fill="#CFD8DC" Margin="6,0,6,0" VerticalAlignment="Center"/>

                            <!-- GRUPA 3: 📋 Lista (CRUD + odświeżanie) -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"
                                           ToolTip="📋 Lista — zarządzanie wstawieniami"/>
                                <Border Background="#2980B9" CornerRadius="4" Padding="6,2" Margin="0,0,3,0"
                                        ToolTip="Dodaj nowe wstawienie">
                                    <TextBlock Text="Ctrl+N" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="dodaj" FontSize="10" Foreground="#37474F" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Border Background="#7F8C8D" CornerRadius="4" Padding="6,2" Margin="0,0,3,0"
                                        ToolTip="Otwórz edycję wybranego wstawienia">
                                    <TextBlock Text="Enter" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="edytuj" FontSize="10" Foreground="#37474F" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Border Background="#E74C3C" CornerRadius="4" Padding="6,2" Margin="0,0,3,0"
                                        ToolTip="Usuń wstawienie (z potwierdzeniem)">
                                    <TextBlock Text="Del" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="usuń" FontSize="10" Foreground="#37474F" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Border Background="#16A085" CornerRadius="4" Padding="6,2" Margin="0,0,3,0"
                                        ToolTip="Odśwież wszystkie tabele (ponownie pobierz dane z bazy)">
                                    <TextBlock Text="F5" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="odśwież" FontSize="10" Foreground="#37474F" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btnAudyt" Style="{StaticResource InfoButton}"
                                Height="28" FontSize="10" Click="BtnAudyt_Click"
                                ToolTip="Ponów pomiar czasu ładowania (audyt) i pokaż raport"
                                Background="#8E44AD" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Text="Audyt" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnOstatnieWstawienia" Style="{StaticResource InfoButton}"
                                Height="28" FontSize="10" Click="BtnOstatnieWstawienia_Click"
                                ToolTip="Ostatnie wstawienia hodowców — pogrupowane wg statusu (Aktywni / Do wykupienia / Anulowane)"
                                Background="#27AE60" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🐣" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Text="Ostatnie wstawienia" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnStatystyki" Style="{StaticResource InfoButton}"
                                Width="120" Height="28" FontSize="10" Click="BtnStatystyki_Click"
                                ToolTip="Statystyki pracowników" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Text="Statystyki" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnPomoc" Style="{StaticResource InfoButton}"
                                Width="95" Height="28" FontSize="10" Click="BtnPomoc_Click"
                                ToolTip="Instrukcja obsługi systemu">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="❓" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock Text="Instrukcja" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Nagłówek listy wstawień (szukajka + Dodaj są w lewym górnym pasku) -->
                        <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock Text="📋 Lista Wstawień" FontSize="15" FontWeight="Bold" Foreground="#2C3E50"/>
                            <TextBlock Text="🔍 Szukajka i ➕ Dodaj są w lewym górnym rogu okna."
                                       FontSize="8" Foreground="#95A5A6" FontStyle="Italic" Margin="0,1,0,0"/>
                        </StackPanel>

                        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                            <DataGrid x:Name="dataGridWstawienia"
                                      Style="{StaticResource ModernDataGrid}"
                                      ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                                      CellStyle="{StaticResource DataGridCellStyle}"
                                      RowHeight="30">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="✏️ Edytuj wstawienie" Click="MenuEdytuj_Click" FontWeight="SemiBold"/>
                                        <MenuItem Header="➕ Nowe wstawienie (kopiuj dane)" Click="MenuNoweWstawienieKopiuj_Click" FontWeight="SemiBold"/>
                                        <MenuItem Header="📅 Zmień datę wstawienia" Click="MenuZmienDateWstawienia_Click" FontWeight="SemiBold"/>
                                        <MenuItem Header="💰 Zmień typ ceny" Click="MenuZmienTypCeny_Click" FontWeight="SemiBold"/>
                                        <Separator/>
                                        <MenuItem Header="✅ Potwierdzenie wstawienia" Click="MenuPotwierdzWstawienieGrid_Click" FontWeight="SemiBold" Foreground="#27AE60"/>
                                        <MenuItem Header="↩️ Cofnij potwierdzenie" Click="MenuCofnijPotwierdzenie_Click" Foreground="#E67E22"/>
                                        <Separator/>
                                        <MenuItem Header="📞 Zadzwoń do hodowcy" Click="MenuZadzwonHodowcyWst_Click" FontWeight="SemiBold" Foreground="#15803D"/>
                                        <Separator/>
                                        <MenuItem Header="📱 1️⃣  SMS — Oficjalny standardowy" Tag="1" Click="MenuSmsWariantWst_Click" FontWeight="SemiBold"/>
                                        <MenuItem Header="📱 2️⃣  SMS — Krótki i konkretny" Tag="2" Click="MenuSmsWariantWst_Click"/>
                                        <MenuItem Header="📱 3️⃣  SMS — Przyjazny i ciepły" Tag="3" Click="MenuSmsWariantWst_Click"/>
                                        <MenuItem Header="📱 4️⃣  SMS — Z pytaniem o termin" Tag="4" Click="MenuSmsWariantWst_Click"/>
                                        <MenuItem Header="📱 5️⃣  SMS — Z delikatnym przypomnieniem" Tag="5" Click="MenuSmsWariantWst_Click"/>
                                        <Separator/>
                                        <MenuItem Header="🌾 6️⃣  Wolny rynek — prośba o orientacyjny termin" Tag="6" Click="MenuSmsWariantWst_Click" Foreground="#5C8A3A"/>
                                        <MenuItem Header="🌾 7️⃣  Wolny rynek — otwarcie drogi do kontaktu" Tag="7" Click="MenuSmsWariantWst_Click" Foreground="#5C8A3A"/>
                                        <MenuItem Header="🌾 8️⃣  Wolny rynek — sygnał zainteresowania (lekki)" Tag="8" Click="MenuSmsWariantWst_Click" Foreground="#5C8A3A"/>
                                        <Separator/>
                                        <MenuItem Header="🗑️ Usuń wstawienie" Click="MenuUsun_Click" Foreground="#E74C3C"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,6">
                            <Grid Margin="0,0,0,2">
                                <TextBlock Text="⏰ Przypomnienia" FontSize="13" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Left"/>
                                <Border Background="#FFEBEE" CornerRadius="6" Padding="5,2" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔔 " FontSize="8" Foreground="#E74C3C" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtLiczbaPrzypomnien" Text="0" FontSize="9" Foreground="#E74C3C" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <TextBlock Text="PPM → Opcje kontaktu  •  ⭐ = stały klient (miał Potwierdzony)" FontSize="7.5" Foreground="#7F8C8D" FontStyle="Italic"/>
                        </StackPanel>

                        <Border Grid.Row="1" BorderBrush="#F39C12" BorderThickness="2" CornerRadius="8" ClipToBounds="True">
                            <DataGrid x:Name="dataGridPrzypomnienia"
                                      Style="{StaticResource ModernDataGrid}"
                                      ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                                      CellStyle="{StaticResource DataGridCellStyle}"
                                      RowHeight="24" FontSize="9">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="📵 Nie odebrał (+3 dni)" Click="MenuNieOdebral_Click" FontWeight="SemiBold"/>
                                        <MenuItem Header="📞 3 próby telefonu (+1 miesiąc)" Click="MenuTryProby_Click" FontWeight="SemiBold"/>
                                        <Separator/>
                                        <MenuItem Header="🕐 Odłożenie na dłużej..." Click="MenuOdlozDluzej_Click"/>
                                        <MenuItem Header="➕ Dodanie numeru hodowcy" Click="MenuDodajNumer_Click"/>
                                        <Separator/>
                                        <MenuItem Header="📞 Zadzwoń do hodowcy (z mojego telefonu)" Click="MenuZadzwonHodowcyPrz_Click" FontWeight="SemiBold" Foreground="#15803D"/>
                                        <MenuItem Header="📞 Zadzwoń (Łącze z telefonem)" Click="MenuZadzwon_Click"/>
                                        <Separator/>
                                        <MenuItem Header="📱 1️⃣  SMS — Oficjalny standardowy" Tag="1" Click="MenuSmsWariant_Click" FontWeight="SemiBold"/>
                                        <MenuItem Header="📱 2️⃣  SMS — Krótki i konkretny" Tag="2" Click="MenuSmsWariant_Click"/>
                                        <MenuItem Header="📱 3️⃣  SMS — Przyjazny i ciepły" Tag="3" Click="MenuSmsWariant_Click"/>
                                        <MenuItem Header="📱 4️⃣  SMS — Z pytaniem o termin" Tag="4" Click="MenuSmsWariant_Click"/>
                                        <MenuItem Header="📱 5️⃣  SMS — Z delikatnym przypomnieniem" Tag="5" Click="MenuSmsWariant_Click"/>
                                        <Separator/>
                                        <MenuItem Header="🌾 6️⃣  Wolny rynek — prośba o orientacyjny termin" Tag="6" Click="MenuSmsWariant_Click" Foreground="#5C8A3A"/>
                                        <MenuItem Header="🌾 7️⃣  Wolny rynek — otwarcie drogi do kontaktu" Tag="7" Click="MenuSmsWariant_Click" Foreground="#5C8A3A"/>
                                        <MenuItem Header="🌾 8️⃣  Wolny rynek — sygnał zainteresowania (lekki)" Tag="8" Click="MenuSmsWariant_Click" Foreground="#5C8A3A"/>
                                        <Separator/>
                                        <MenuItem Header="📲 Wyślij SMS (Łącze z telefonem)" Click="MenuSmsPhoneLink_Click" FontWeight="SemiBold"/>
                                        <MenuItem Header="📋 Kopiuj numer telefonu" Click="MenuKopiujNumer_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                            </DataGrid>
                        </Border>

                        <!-- Sekcja: Nadchodzące wstawienia (zakupowiec dzwoni potwierdzić, bo czasami zmieniają) -->
                        <StackPanel Grid.Row="2" Margin="0,8,0,4">
                            <Grid>
                                <TextBlock Text="📞 Nadchodzące wstawienia (zadzwoń potwierdzić)" FontSize="12" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Left"/>
                                <Border Background="#E3F2FD" CornerRadius="6" Padding="5,2" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗓 " FontSize="8" Foreground="#1976D2" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtLiczbaDoPotwierdzenia" Text="0" FontSize="9" Foreground="#1976D2" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <TextBlock Text="Wstawienia w ciągu 14 dni — zadzwoń żeby potwierdzić termin" FontSize="7.5" Foreground="#7F8C8D" FontStyle="Italic"/>
                        </StackPanel>

                        <Border Grid.Row="3" BorderBrush="#1976D2" BorderThickness="2" CornerRadius="8" ClipToBounds="True">
                            <!-- ContextMenu jest dodawany programowo w SetupDoPotwierdzeniaColumns -->
                            <DataGrid x:Name="dataGridDoPotwierdzenia"
                                      Style="{StaticResource ModernDataGrid}"
                                      ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                                      CellStyle="{StaticResource DataGridCellStyle}"
                                      RowHeight="24" FontSize="9"/>
                        </Border>

                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardPanel}" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,5">
                            <TextBlock Text="📜 Historia Kontaktów" FontSize="12" FontWeight="Bold" Foreground="#2C3E50"/>
                            <TextBlock Text="Wszystkie odłożenia" FontSize="7.5" Foreground="#7F8C8D" FontStyle="Italic"/>
                        </StackPanel>

                        <Border Grid.Row="1" BorderBrush="#9B59B6" BorderThickness="1.5" CornerRadius="8" ClipToBounds="True">
                            <DataGrid x:Name="dataGridHistoria"
                                      Style="{StaticResource ModernDataGrid}"
                                      ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                                      CellStyle="{StaticResource DataGridCellStyle}"
                                      FontSize="11.5"
                                      VerticalScrollBarVisibility="Auto"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- 📊 Status bar dolny — liczniki w czasie rzeczywistym -->
            <Border Grid.Row="2" Background="#FFFFFF" CornerRadius="6" Padding="10,4" Margin="6,4,6,0"
                    BorderBrush="#E0E6E8" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="📋" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="statusWstawienia" Text="Wstawień: —" FontSize="10" FontWeight="SemiBold" Foreground="#37474F" VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <TextBlock Text="⏰" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="statusPrzypomnienia" Text="Przypomnień: —" FontSize="10" FontWeight="SemiBold" Foreground="#E74C3C" VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <TextBlock Text="📞" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="statusNadchodzace" Text="Nadchodzących: —" FontSize="10" FontWeight="SemiBold" Foreground="#1976D2" VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <TextBlock Text="📜" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="statusHistoria" Text="Historia: —" FontSize="10" FontWeight="SemiBold" Foreground="#9B59B6" VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <TextBlock Text="⭐" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="statusStali" Text="Stałych: —" FontSize="10" FontWeight="SemiBold" Foreground="#4CAF50" VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <!-- Counter dzisiejszych akcji (Sergiusz / Teresa / etc.) -->
                        <TextBlock Text="📅" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="statusDzisiaj" Text="Dzisiaj: —" FontSize="10" FontWeight="SemiBold" Foreground="#0EA5E9" VerticalAlignment="Center"
                                   ToolTip="Twoje dzisiejsze SMS-y i połączenia (z bazy)"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2" x:Name="statusUser" Text="" FontSize="9" Foreground="#95A5A6" FontStyle="Italic" VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>