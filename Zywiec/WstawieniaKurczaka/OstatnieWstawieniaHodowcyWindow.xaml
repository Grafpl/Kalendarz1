<Window x:Class="Kalendarz1.OstatnieWstawieniaHodowcyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="🐣 Ostatnie wstawienia hodowców — pogrupowane + detekcja kolizji"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        Background="#ECF0F1"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E5E8EC"/>
        </Style>

        <Style x:Key="KafelekKlasyfikacji" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F0F2F5"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFBFC"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#5C8A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#4B732F"/>
            <Setter Property="Height" Value="38"/>
        </Style>

        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="8,4">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F5E9"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FilterButton" TargetType="ToggleButton">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CFD8DC"/>
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5C8A3A"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4B732F"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5C8A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRowHeader">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🐣 Ostatnie wstawienia hodowców" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock x:Name="txtSubtitle"
                               Text="Klasyfikacja na podstawie 2 ostatnich wstawień każdego hodowcy + detekcja kolizji nazwisk"
                               FontSize="11" Foreground="#5C8A3A" FontWeight="SemiBold" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#5C8A3A"/>
                    <Border Background="#F8F9FA" CornerRadius="14" Padding="8,4"
                            BorderBrush="#CFD8DC" BorderThickness="1" Width="260">
                        <TextBox x:Name="txtFilter" BorderThickness="0" Background="Transparent"
                                 FontSize="12" Foreground="#2C3E50"
                                 TextChanged="TxtFilter_TextChanged"/>
                    </Border>
                    <Button x:Name="btnOdswiez" Content="🔄 Odśwież"
                            Background="#3498DB" Foreground="White" FontWeight="SemiBold" FontSize="11"
                            BorderThickness="0" Padding="12,6" Margin="10,0,0,0" Cursor="Hand"
                            Click="BtnOdswiez_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filtry -->
        <Border Grid.Row="1" Style="{StaticResource CardPanel}" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Pokaż grupy:" FontSize="12" FontWeight="SemiBold" Foreground="#37474F" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <ToggleButton x:Name="btnFilterAktywne" Style="{StaticResource FilterButton}" IsChecked="True" Click="FilterGroup_Click">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#27AE60" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblAktywneCount" Text="Aktywni (0)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="btnFilterDoWykupienia" Style="{StaticResource FilterButton}" IsChecked="True" Click="FilterGroup_Click">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#F39C12" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblDoWykupieniaCount" Text="Do wykupienia (0)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="btnFilterAnulowane" Style="{StaticResource FilterButton}" IsChecked="True" Click="FilterGroup_Click">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#E74C3C" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblAnulowaneCount" Text="Anulowane (0)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="btnFilterInne" Style="{StaticResource FilterButton}" IsChecked="False" Click="FilterGroup_Click">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#95A5A6" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblInneCount" Text="Inne (0)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <Border Background="#E0E6E8" Width="1" Margin="6,4" VerticalAlignment="Stretch"/>

                    <ToggleButton x:Name="btnFilterKolizje" Style="{StaticResource FilterButton}" IsChecked="False" Click="FilterGroup_Click"
                                  ToolTip="Pokaż tylko hodowców u których wykryto kolizję nazwiska z innym hodowcą">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblKolizjeFilter" Text="Tylko kolizje (0)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Od roku:" FontSize="12" Foreground="#37474F" Margin="0,0,7,0" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cbOdRoku" Width="110" FontSize="12" SelectionChanged="CbOdRoku_SelectionChanged">
                        <ComboBoxItem Content="2026"/>
                        <ComboBoxItem Content="2025" IsSelected="True"/>
                        <ComboBoxItem Content="2024"/>
                        <ComboBoxItem Content="2023"/>
                        <ComboBoxItem Content="Wszystkie"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}" Padding="0">
            <DataGrid x:Name="dgHodowcy"
                      Style="{StaticResource ModernDataGrid}"
                      ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                      CellStyle="{StaticResource DataGridCellStyle}"
                      MouseDoubleClick="DgHodowcy_MouseDoubleClick"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Items[0].GroupColor}" CornerRadius="6" Padding="14,10" Margin="0,8,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Items[0].GroupIcon}" FontSize="16" Margin="0,0,10,0" Foreground="White"/>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                                        <Border Background="#FFFFFF" CornerRadius="10" Padding="10,2" Margin="12,0,0,0" Opacity="0.85">
                                            <TextBlock Text="{Binding ItemCount, StringFormat=' {0} hodowców '}" FontWeight="SemiBold" FontSize="11" Foreground="#37474F" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </DataGrid.GroupStyle>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Status" Width="150" SortMemberPath="GroupSortKey">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource KafelekKlasyfikacji}" Background="{Binding GroupColor}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding GroupIcon}" FontSize="13" Foreground="White" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding GroupShortName}" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Wstawił" Width="80" SortMemberPath="KtoStwoName">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{Binding AvatarTooltip}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Width="52" Height="52">
                                    <Border x:Name="avatarFallback" Width="48" Height="48" CornerRadius="24"
                                            Background="{Binding KtoStwoFallbackColor}"
                                            BorderBrush="#FFFFFF" BorderThickness="2">
                                        <TextBlock Text="{Binding KtoStwoInicjal}" FontSize="17" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Ellipse x:Name="avatarEllipse" Width="48" Height="48"
                                             Stroke="#FFFFFF" StrokeThickness="2"
                                             Visibility="Collapsed"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Hodowca" Width="420" SortMemberPath="Dostawca">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Margin="0,4">
                                    <TextBlock Text="{Binding Dostawca}" FontWeight="SemiBold" FontSize="14"
                                               Foreground="#2C3E50" TextTrimming="CharacterEllipsis"/>
                                    <ItemsControl ItemsSource="{Binding KolizjePartnerzy}"
                                                  Visibility="{Binding KolizjaVisibility}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="5" Background="#FFF8E1" BorderBrush="#FFD54F"
                                                        BorderThickness="1" Padding="6,2" Margin="0,1,0,0"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock FontSize="10.5" TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding TooltipFull}">
                                                        <Run Text="⚠️" FontSize="10"/>
                                                        <Run Text="{Binding Dostawca, Mode=OneWay}"
                                                             FontWeight="SemiBold" Foreground="#5D4037"/>
                                                        <Run Text=" — ost. wstaw. " Foreground="#8D6E63"/>
                                                        <Run Text="{Binding OstatnieWstawienieData, StringFormat=yyyy-MM-dd, Mode=OneWay}"
                                                             FontWeight="SemiBold" Foreground="#5D4037"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding StatusIkonka, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Ost. wstaw."
                                        Binding="{Binding OstatnieWstawienieData, StringFormat=dd.MM.yyyy}"
                                        Width="120"
                                        SortMemberPath="OstatnieWstawienieData">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="12.5"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Sztuk"
                                        Binding="{Binding OstatnieWstawienieIlosc, StringFormat=#\,##0}"
                                        Width="100"
                                        SortMemberPath="OstatnieWstawienieIlosc">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="FontSize" Value="12.5"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Wst."
                                        Binding="{Binding LiczbaWstawien}"
                                        Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#546E7A"/>
                                <Setter Property="FontSize" Value="12"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Dostawy z 2 ostatnich wstawień (chronologicznie)" Width="*" MinWidth="400">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding DostawyChipy}" VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8" Padding="10,5" Margin="3,3"
                                                    Background="{Binding ChipBackground}"
                                                    BorderBrush="{Binding ChipBorder}"
                                                    BorderThickness="1"
                                                    ToolTip="{Binding Tooltip}">
                                                <StackPanel>
                                                    <TextBlock FontSize="12.5" FontWeight="Bold" Foreground="{Binding ChipForeground}">
                                                        <Run Text="{Binding DataKrotka, Mode=OneWay}"/>
                                                        <Run Text="  ·  "/>
                                                        <Run Text="{Binding StatusKrotki, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="10.5" FontWeight="SemiBold" Opacity="0.78"
                                                               Foreground="{Binding ChipForeground}"
                                                               Text="{Binding SzczegolyKrotkie, Mode=OneWay}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Stopka -->
        <Border Grid.Row="3" Style="{StaticResource CardPanel}" Padding="14,10" Margin="4,6,4,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="txtStatus"
                           Text="Sortowanie w grupie: od najwcześniejszego wstawienia. Dwuklik = edycja wstawienia. ⚠️ = nazwisko występuje u innego hodowcy."
                           FontSize="11" Foreground="#7F8C8D" FontStyle="Italic" VerticalAlignment="Center"/>

                <Button Grid.Column="1" Content="✖ Zamknij" Click="BtnZamknij_Click"
                        Background="#95A5A6" Foreground="White" FontWeight="SemiBold" FontSize="12"
                        BorderThickness="0" Padding="16,7" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>
