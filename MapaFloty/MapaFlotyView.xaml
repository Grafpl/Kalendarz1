<UserControl x:Class="Kalendarz1.MapaFloty.MapaFlotyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <UserControl.Resources>
        <!-- Styl przycisków toolbarowych (ikony) -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5c6bc0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                BorderThickness="0" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#e8eaf6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#c5cae9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Styl przycisków akcji -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,7"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Debug button -->
        <Style x:Key="DbgBtn" TargetType="Button">
            <Setter Property="Background" Value="#e8eaf6"/>
            <Setter Property="Foreground" Value="#5c6bc0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="FontSize" Value="9.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#c5cae9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ═══ PANEL BOCZNY ═══ -->
        <Border Grid.Column="0" Grid.RowSpan="3" Background="#f7f8fa" BorderBrush="#e4e6ea" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Nagłówek -->
                <Border DockPanel.Dock="Top" Padding="16,14,16,12" Background="White">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.06" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Tytuł + badge'y -->
                        <DockPanel Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="FLOTA" FontSize="19" FontWeight="ExtraBold" Foreground="#1a237e"/>
                                <TextBlock Text="LIVE" FontSize="19" FontWeight="ExtraLight" Foreground="#7986cb" Margin="5,0,0,0"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="#e8eaf6" CornerRadius="10" Padding="8,3" Margin="0,0,4,0" ToolTip="Liczba pojazdów na mapie">
                                    <TextBlock x:Name="VehicleCountText" Text="0" Foreground="#3949ab" FontWeight="Bold" FontSize="12"/>
                                </Border>
                                <Border Background="#fce4ec" CornerRadius="10" Padding="8,3" ToolTip="Odświeżenie za...">
                                    <TextBlock x:Name="CountdownText" Text="30s" Foreground="#c62828" FontSize="10" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </DockPanel>

                        <!-- Compact KPI strip (Polish++ pomysł 1) — 1 linia zamiast 4 boxów -->
                        <Border Background="#f8f9fc" CornerRadius="10" Padding="6,5" BorderBrush="#e4e6ea" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                <Border x:Name="ChipMoving" Padding="8,3" CornerRadius="6" Background="Transparent"
                                        Cursor="Hand" Tag="moving" MouseLeftButtonUp="ChipFilter_Click"
                                        ToolTip="W trasie (klawisz 1)" Margin="0,0,2,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🟢" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock x:Name="MovingCountText" Text="0" Foreground="#2e7d32" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="trasa" Foreground="#558b2f" FontSize="10" VerticalAlignment="Center" Margin="4,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="ChipStopped" Padding="8,3" CornerRadius="6" Background="Transparent"
                                        Cursor="Hand" Tag="stopped" MouseLeftButtonUp="ChipFilter_Click"
                                        ToolTip="Postój / wyłączone (klawisz 2)" Margin="0,0,2,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🟠" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock x:Name="StoppedCountText" Text="0" Foreground="#e65100" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="postój" Foreground="#ef6c00" FontSize="10" VerticalAlignment="Center" Margin="4,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="ChipBase" Padding="8,3" CornerRadius="6" Background="Transparent"
                                        Cursor="Hand" Tag="base" MouseLeftButtonUp="ChipFilter_Click"
                                        ToolTip="W bazie (klawisz 4)" Margin="0,0,2,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏠" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock x:Name="InGeofenceText" Text="0" Foreground="#1565c0" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="baza" Foreground="#1976d2" FontSize="10" VerticalAlignment="Center" Margin="4,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="ChipAll" Padding="8,3" CornerRadius="6" Background="#e8eaf6" BorderBrush="#3949ab" BorderThickness="1"
                                        Cursor="Hand" Tag="all" MouseLeftButtonUp="ChipFilter_Click"
                                        ToolTip="Wszystkie (klawisz 3)" Margin="2,0,0,0" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="∑" FontSize="13" FontWeight="Bold" Foreground="#3949ab" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock x:Name="AvgSpeedText" Text="0" Foreground="#283593" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="km/h" Foreground="#5c6bc0" FontSize="10" VerticalAlignment="Center" Margin="4,1,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Wyszukiwarka -->
                        <Border Background="#f5f6fa" CornerRadius="8" Padding="10,8" Margin="0,12,0,0" BorderBrush="#e0e3ea" BorderThickness="1">
                            <TextBox x:Name="SearchBox" Background="Transparent" Foreground="#37474f"
                                     FontSize="12.5" BorderThickness="0" CaretBrush="#37474f"
                                     TextChanged="SearchBox_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Resources>
                                            <VisualBrush x:Key="hint" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="  Szukaj pojazdu, kierowcy, trasy..." FontSize="12.5" Foreground="#b0bec5"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Style.Resources>
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background" Value="{StaticResource hint}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Border>

                        <!-- Toolbar: sortowanie + ikony -->
                        <DockPanel Margin="0,10,0,0">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="&#x21bb;" Click="BtnRefresh_Click" Style="{StaticResource ToolBtn}" ToolTip="Odśwież dane (F5)"/>
                                <Button Content="&#x2316;" Click="BtnCenterAll_Click" Style="{StaticResource ToolBtn}" ToolTip="Dopasuj widok do wszystkich pojazdów"/>
                                <Button Content="&#x2699;" Click="BtnMapping_Click" Style="{StaticResource ToolBtn}" ToolTip="Mapowanie pojazdów i kierowców"/>
                            </StackPanel>
                            <ComboBox x:Name="SortCombo" SelectedIndex="0" SelectionChanged="SortCombo_Changed"
                                      FontSize="11" Padding="8,5" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Status + nazwa"/>
                                <ComboBoxItem Content="Prędkość malejąco"/>
                                <ComboBoxItem Content="Nazwa A-Z"/>
                                <ComboBoxItem Content="Ostatnia aktualizacja"/>
                            </ComboBox>
                        </DockPanel>

                        <!-- Mini ikony akcji (Polish++ pomysł 2) — 4 ikony 36px zamiast 4 button'ów -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="👁" Click="BtnMonitor_Click" Style="{StaticResource ToolBtn}"
                                    ToolTip="Monitor kursów — porównuje plan vs faktyczny GPS"
                                    FontSize="16" Width="36" Height="36"/>
                            <Button Content="🔄" Click="BtnSyncKursy_Click" Style="{StaticResource ToolBtn}"
                                    ToolTip="Sync Webfleet — wysyłka kursów do nawigacji TomTom"
                                    FontSize="16" Width="36" Height="36"/>
                            <Button Content="📈" Click="BtnPdfReport_Click" Style="{StaticResource ToolBtn}"
                                    ToolTip="Raport PDF — wydruk stanu floty"
                                    FontSize="16" Width="36" Height="36"/>
                            <Button Content="👤" Click="BtnDriverPanel_Click" Style="{StaticResource ToolBtn}"
                                    ToolTip="Panel kierowców — przegląd aktywności"
                                    FontSize="16" Width="36" Height="36"/>
                        </StackPanel>

                        <!-- Wolne zamówienia (Faza 4-C) — toggle warstwa na mapie -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Wolne zam.:" Foreground="#546e7a"
                                       FontSize="10.5" VerticalAlignment="Center" Margin="2,0,6,0"/>
                            <DatePicker Grid.Column="1" x:Name="OrdersDate"
                                        SelectedDateChanged="OrdersDate_Changed"
                                        FontSize="11"/>
                            <ToggleButton Grid.Column="2" x:Name="BtnToggleOrders"
                                          Content="📦" FontSize="13"
                                          ToolTip="Pokaż / ukryj wolne zamówienia na mapie"
                                          Click="BtnToggleOrders_Click"
                                          Margin="4,0,0,0" Padding="8,3" Cursor="Hand"
                                          Background="#fff3e0" Foreground="#e65100" BorderBrush="#ffb74d"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Lista pojazdów (scrollowana) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                    <StackPanel x:Name="VehicleListPanel" Margin="10,6,10,10"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══ MAPA ═══ -->
        <wv2:WebView2 x:Name="MapWebView" Grid.Column="1"/>

        <!-- ═══ DEBUG ═══ -->
        <Border x:Name="DebugPanel" Grid.Row="1" Grid.Column="1" Background="White" MaxHeight="180" Visibility="Collapsed"
                BorderBrush="#e4e6ea" BorderThickness="0,1,0,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#f7f8fa" Padding="0,0,0,0">
                    <DockPanel Margin="10,5,6,5">
                        <TextBlock Text="Logi diagnostyczne" Foreground="#00897b" FontWeight="SemiBold" FontSize="10.5" VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Kopiuj" Click="BtnCopyDebug_Click" Style="{StaticResource DbgBtn}" Margin="0,0,4,0"/>
                            <Button Content="Wyczyść" Click="BtnClearDebug_Click" Style="{StaticResource DbgBtn}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="DebugScroll">
                    <TextBox x:Name="DebugLog" Background="White" Foreground="#2e7d32" FontFamily="Consolas" FontSize="9.5"
                             IsReadOnly="True" TextWrapping="Wrap" BorderThickness="0" Padding="10,6" VerticalScrollBarVisibility="Disabled"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══ PASEK STATUSU ═══ -->
        <Border Grid.Row="2" Grid.Column="1" Background="White" Padding="12,0" BorderBrush="#e4e6ea" BorderThickness="0,1,0,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" Text="Ładowanie..." Foreground="#78909c" FontSize="10.5" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Debug" Click="BtnToggleDebug_Click" Style="{StaticResource DbgBtn}" Foreground="#90a4ae" Background="Transparent" Margin="0,0,10,0"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Akt: " Foreground="#90a4ae" FontSize="10" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LastUpdateText" Text="--:--" Foreground="#546e7a" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text=" | co 30s" Foreground="#b0bec5" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
