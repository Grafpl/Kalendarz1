<Window x:Class="Kalendarz1.MapaFloty.AdresyKlientowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adresy klientów — geokodowanie GPS" Width="1000" Height="650"
        MinWidth="800" MinHeight="450" WindowStartupLocation="CenterOwner"
        Background="#f7f8fa">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Adresy klientów" FontSize="20" FontWeight="Bold" Foreground="#1a237e"/>
            <TextBlock Text="Wpisz adres klienta — system automatycznie pobierze współrzędne GPS (OpenStreetMap Nominatim)" Foreground="#78909c" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#e0e0e0" BorderThickness="1" ClipToBounds="True">
            <DataGrid x:Name="AdresyGrid" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      Background="White" Foreground="#263238"
                      RowBackground="White" AlternatingRowBackground="#fafafa"
                      BorderThickness="0" FontSize="12"
                      HorizontalGridLinesBrush="#eeeeee"
                      SelectionMode="Single" SelectionUnit="FullRow">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#f5f5f8"/>
                        <Setter Property="Foreground" Value="#546e7a"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#e0e0e0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Kod klienta" Binding="{Binding KodKlienta}" IsReadOnly="True" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#1a237e"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,6"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Nazwa" Binding="{Binding Nazwa, UpdateSourceTrigger=PropertyChanged}" Width="160">
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox"><Setter Property="Padding" Value="4"/></Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Ulica" Binding="{Binding Ulica, UpdateSourceTrigger=PropertyChanged}" Width="180">
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox"><Setter Property="Padding" Value="4"/></Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Miasto" Binding="{Binding Miasto, UpdateSourceTrigger=PropertyChanged}" Width="130">
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox"><Setter Property="Padding" Value="4"/></Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Kod poczt." Binding="{Binding KodPocztowy, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                    <DataGridTextColumn Header="Lat" Binding="{Binding Lat, StringFormat=F5}" IsReadOnly="True" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#2e7d32"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="6"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Lon" Binding="{Binding Lon, StringFormat=F5}" IsReadOnly="True" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#2e7d32"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="6"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" IsReadOnly="True" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="Padding" Value="6"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBlock x:Name="StatusText" Text="" Foreground="#78909c" FontSize="11" VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Content="Geokoduj wszystkie" Click="BtnGeocodeAll_Click"
                        Background="#e8f5e9" Foreground="#2e7d32" BorderThickness="0"
                        Padding="16,9" Margin="0,0,8,0" Cursor="Hand" FontSize="12" FontWeight="SemiBold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Zapisz i zamknij" Click="BtnSave_Click"
                        Background="#1565c0" Foreground="White" BorderThickness="0"
                        Padding="20,9" Margin="0,0,8,0" Cursor="Hand" FontSize="13" FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Anuluj" Click="BtnCancel_Click"
                        Background="#eceff1" Foreground="#546e7a" BorderBrush="#cfd8dc" BorderThickness="1"
                        Padding="16,9" Cursor="Hand" FontSize="12">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
