<Window x:Class="Kalendarz1.MapaFloty.SyncKursowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Synchronizacja kursów z Webfleet" Width="1100" Height="700"
        MinWidth="900" MinHeight="500" WindowStartupLocation="CenterOwner"
        Background="#f7f8fa">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Synchronizacja kursów z Webfleet" FontSize="20" FontWeight="Bold" Foreground="#1a237e"/>
                <TextBlock Text="Wysyłaj kursy transportowe jako zlecenia dostawy na nawigacje TomTom kierowców" Foreground="#78909c" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Data:" Foreground="#546e7a" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <DatePicker x:Name="DatePick" Width="130" FontSize="12" SelectedDateChanged="DatePick_Changed"/>
                <Button Content="Odśwież" Click="BtnRefresh_Click" Background="#e8eaf6" Foreground="#3949ab"
                        BorderThickness="0" Padding="14,7" Margin="8,0,0,0" Cursor="Hand" FontSize="12">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Statystyki -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Background="#e8eaf6" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Kursów: " Foreground="#3949ab" FontSize="12"/>
                    <TextBlock x:Name="TotalCount" Text="0" Foreground="#1a237e" FontWeight="Bold" FontSize="12"/>
                </StackPanel>
            </Border>
            <Border Background="#e8f5e9" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Wysłanych: " Foreground="#2e7d32" FontSize="12"/>
                    <TextBlock x:Name="SentCount" Text="0" Foreground="#1b5e20" FontWeight="Bold" FontSize="12"/>
                </StackPanel>
            </Border>
            <Border Background="#fff3e0" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Oczekujących: " Foreground="#e65100" FontSize="12"/>
                    <TextBlock x:Name="PendingCount" Text="0" Foreground="#bf360c" FontWeight="Bold" FontSize="12"/>
                </StackPanel>
            </Border>
            <Border Background="#ffebee" CornerRadius="6" Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Błędy: " Foreground="#c62828" FontSize="12"/>
                    <TextBlock x:Name="ErrorCount" Text="0" Foreground="#b71c1c" FontWeight="Bold" FontSize="12"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Lista kursów -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" BorderBrush="#e0e0e0" BorderThickness="1" ClipToBounds="True">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="KursyList"/>
            </ScrollViewer>
        </Border>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="3" Foreground="#78909c" FontSize="11" Margin="0,10,0,0"/>
    </Grid>
</Window>
