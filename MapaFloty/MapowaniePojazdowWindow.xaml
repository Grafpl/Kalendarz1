<Window x:Class="Kalendarz1.MapaFloty.MapowaniePojazdowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mapowanie pojazdów — Webfleet GPS do systemu transportowego"
        Width="950" Height="620" MinWidth="750" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="#f5f5f8">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Mapowanie pojazdów Webfleet" FontSize="20" FontWeight="Bold" Foreground="#1a237e"/>
            <TextBlock Text="Wskaż, który pojazd GPS z Webfleet odpowiada któremu pojazdowi spedytora w systemie."
                       Foreground="#78909c" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Statystyki -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Background="#e8f5e9" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Zmapowane: " Foreground="#388e3c" FontSize="12"/>
                    <TextBlock x:Name="MappedCountText" Text="0" Foreground="#2e7d32" FontWeight="Bold" FontSize="12"/>
                </StackPanel>
            </Border>
            <Border Background="#ffebee" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Niezmapowane: " Foreground="#c62828" FontSize="12"/>
                    <TextBlock x:Name="UnmappedCountText" Text="0" Foreground="#b71c1c" FontWeight="Bold" FontSize="12"/>
                </StackPanel>
            </Border>
            <Border Background="#e8eaf6" CornerRadius="6" Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Pojazdy w systemie: " Foreground="#3949ab" FontSize="12"/>
                    <TextBlock x:Name="InternalCountText" Text="0" Foreground="#283593" FontWeight="Bold" FontSize="12"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- DataGrid -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" BorderBrush="#e0e0e0" BorderThickness="1"
                Padding="0" ClipToBounds="True">
            <DataGrid x:Name="MappingGrid" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      Background="White" Foreground="#263238"
                      RowBackground="White" AlternatingRowBackground="#fafafa"
                      BorderThickness="0" FontSize="12.5"
                      HorizontalGridLinesBrush="#eeeeee"
                      SelectionMode="Single" SelectionUnit="FullRow">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#f5f5f8"/>
                        <Setter Property="Foreground" Value="#546e7a"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="11.5"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#e0e0e0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nr Webfleet" Binding="{Binding WebfleetObjectNo}" IsReadOnly="True" Width="95">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#1a237e"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="12,6"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Nazwa w Webfleet" Binding="{Binding WebfleetObjectName}" IsReadOnly="True" Width="200">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="Padding" Value="12,6"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Kierowca Webfleet" Binding="{Binding WebfleetDriver}" IsReadOnly="True" Width="170">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#607d8b"/><Setter Property="Padding" Value="12,6"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Pojazd w systemie transportowym" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.InternalVehicles, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedValue="{Binding PojazdID, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="ID" DisplayMemberPath="Display"
                                          FontSize="12" Padding="8,4" Margin="4,2" BorderBrush="#cfd8dc"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Przyciski -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Auto-mapuj po rejestracji" Click="BtnAutoMap_Click"
                    Background="#e3f2fd" Foreground="#1565c0" BorderBrush="#90caf9" BorderThickness="1"
                    Padding="18,9" Margin="0,0,8,0" Cursor="Hand" FontSize="12"/>
            <Button Content="Zapisz" Click="BtnSave_Click"
                    Background="#2e7d32" Foreground="White" BorderThickness="0"
                    Padding="24,9" Margin="0,0,8,0" Cursor="Hand" FontSize="13" FontWeight="Bold"/>
            <Button Content="Anuluj" Click="BtnCancel_Click"
                    Background="#eceff1" Foreground="#546e7a" BorderBrush="#cfd8dc" BorderThickness="1"
                    Padding="18,9" Cursor="Hand" FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
