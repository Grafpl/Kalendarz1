<Window x:Class="Kalendarz1.MapaFloty.RaportEfektywnosciWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Raport efektywności floty" Width="1300" Height="750"
        MinWidth="900" MinHeight="500" WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="#f7f8fa">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="16,10" BorderBrush="#e4e6ea" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Raport efektywności floty" FontSize="18" FontWeight="Bold" Foreground="#1a237e" Margin="0,0,16,0"/>
                    <TextBlock Text="Od:" Foreground="#546e7a" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <DatePicker x:Name="DateFrom" Width="120" FontSize="11"/>
                    <TextBlock Text="Do:" Foreground="#546e7a" FontSize="12" VerticalAlignment="Center" Margin="10,0,4,0"/>
                    <DatePicker x:Name="DateTo" Width="120" FontSize="11"/>
                    <Button Content="Tydzień" Click="BtnWeek_Click" Background="#e8eaf6" Foreground="#3949ab"
                            BorderThickness="0" Padding="10,5" Margin="6,0,0,0" Cursor="Hand" FontSize="11">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Załaduj" Click="BtnLoad_Click" Background="#1565c0" Foreground="White"
                            BorderThickness="0" Padding="14,5" Margin="8,0,0,0" Cursor="Hand" FontSize="11" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Eksport PDF" Click="BtnPdf_Click" Background="#e8f5e9" Foreground="#2e7d32"
                            BorderThickness="0" Padding="10,5" Margin="6,0,0,0" Cursor="Hand" FontSize="11">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                <TextBlock x:Name="StatusText" Text="" Foreground="#90a4ae" FontSize="11"
                           DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ReportPanel" Margin="16,8,16,16"/>
        </ScrollViewer>
    </Grid>
</Window>
