<Window x:Class="Kalendarz1.MapaFloty.HistoriaPojazdowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Historia tras pojazdu" Width="1400" Height="900"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="#f7f8fa">
    <Window.Resources>
        <Style x:Key="TBtn" TargetType="Button">
            <Setter Property="Background" Value="#e8eaf6"/>
            <Setter Property="Foreground" Value="#3949ab"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#c5cae9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0: Toolbar ═══ -->
        <Border Grid.Row="0" Background="White" Padding="16,10" BorderBrush="#e4e6ea" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Historia tras" FontSize="18" FontWeight="Bold" Foreground="#1a237e" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="Pojazd:" Foreground="#546e7a" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox x:Name="VehicleCombo" Width="260" FontSize="12" Padding="8,5" VerticalContentAlignment="Center"/>
                    <TextBlock Text="Data:" Foreground="#546e7a" FontSize="12" VerticalAlignment="Center" Margin="14,0,4,0"/>
                    <DatePicker x:Name="DatePick" Width="130" FontSize="12"/>
                    <Button Content="Załaduj trasę" Click="BtnLoad_Click"
                            Background="#1565c0" Foreground="White" BorderThickness="0"
                            Padding="20,7" Margin="10,0,0,0" Cursor="Hand" FontSize="12" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Eksport GPX" Click="BtnExportGpx_Click"
                            Background="#e8f5e9" Foreground="#2e7d32" BorderThickness="0"
                            Padding="14,7" Margin="6,0,0,0" Cursor="Hand" FontSize="11">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                <TextBlock x:Name="StatusLabel" Text="Wybierz pojazd i datę" Foreground="#90a4ae" FontSize="11"
                           DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ═══ ROW 1: Stats bar (pojawia się po załadowaniu) ═══ -->
        <Border x:Name="StatsBar" Grid.Row="1" Background="White" BorderBrush="#e4e6ea" BorderThickness="0,0,0,1"
                Visibility="Collapsed" Padding="0,4">
            <StackPanel x:Name="StatsPanel" Orientation="Horizontal" HorizontalAlignment="Center"/>
        </Border>

        <!-- ═══ ROW 2: Mapa (WebView2) ═══ -->
        <wv2:WebView2 x:Name="HistoryWebView" Grid.Row="2"/>

        <!-- ═══ ROW 3: SLIDER + kontrolki odtwarzania (WPF natywne) ═══ -->
        <Border x:Name="ScrubberBar" Grid.Row="3" Background="White" BorderBrush="#e4e6ea" BorderThickness="0,1,0,0"
                Padding="16,8" Visibility="Collapsed">
            <StackPanel>
                <!-- Rząd przycisków + info -->
                <DockPanel Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="&#9194;" Click="BtnStepBack10_Click" Style="{StaticResource TBtn}" ToolTip="-10 punktów" Width="32" Height="32" FontSize="12"/>
                        <Button Content="&#9664;" Click="BtnStepBack1_Click" Style="{StaticResource TBtn}" ToolTip="Poprzedni punkt" Margin="3,0,3,0" Width="32" Height="32" FontSize="12"/>
                        <Button x:Name="BtnPlay" Content="&#9654;" Click="BtnPlay_Click" Style="{StaticResource TBtn}" ToolTip="Odtwórz / Pauza"
                                Width="40" Height="40" FontSize="16" Background="#1565c0" Foreground="White"/>
                        <Button Content="&#9654;" Click="BtnStepFwd1_Click" Style="{StaticResource TBtn}" ToolTip="Następny punkt" Margin="3,0,3,0" Width="32" Height="32" FontSize="12"/>
                        <Button Content="&#9193;" Click="BtnStepFwd10_Click" Style="{StaticResource TBtn}" ToolTip="+10 punktów" Width="32" Height="32" FontSize="12"/>
                        <Button x:Name="BtnSpeedLabel" Content="x10" Click="BtnSpeed_Click" Margin="8,0,0,0"
                                Background="#e8eaf6" Foreground="#3949ab" BorderThickness="0" Padding="10,5"
                                Cursor="Hand" FontSize="11" FontWeight="Bold" Width="50" Height="32" ToolTip="Zmień prędkość odtwarzania">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <!-- Info środek -->
                    <TextBlock x:Name="ScrubInfo" Text="" Foreground="#263238" FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <!-- Ocena jazdy -->
                    <Border x:Name="ScoreBadge" DockPanel.Dock="Right" HorizontalAlignment="Right" CornerRadius="8"
                            Padding="10,4" Visibility="Collapsed">
                        <TextBlock x:Name="ScoreText" FontSize="12" FontWeight="Bold"/>
                    </Border>
                </DockPanel>
                <!-- Slider -->
                <Slider x:Name="TrackSlider" Minimum="0" Maximum="0" Value="0"
                        ValueChanged="TrackSlider_ValueChanged"
                        IsSnapToTickEnabled="False" TickFrequency="1"
                        Height="22"/>
                <!-- Timeline bar (kolorowy pasek) -->
                <Canvas x:Name="TimelineCanvas" Height="14" Margin="0,2,0,0" ClipToBounds="True"/>
                <!-- Czasy pod sliderem -->
                <DockPanel Margin="0,2,0,0">
                    <TextBlock x:Name="TimeStart" Text="" Foreground="#90a4ae" FontSize="10"/>
                    <TextBlock x:Name="TimeEnd" Text="" Foreground="#90a4ae" FontSize="10"
                               DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- ═══ ROW 4: Segmenty (lista) ═══ -->
        <Border x:Name="SegmentsBar" Grid.Row="4" Background="White" BorderBrush="#e4e6ea" BorderThickness="0,1,0,0"
                MaxHeight="200" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SegmentsList" Margin="0"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
