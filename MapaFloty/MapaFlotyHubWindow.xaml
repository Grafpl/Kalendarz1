<Window x:Class="Kalendarz1.MapaFloty.MapaFlotyHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kalendarz1.MapaFloty"
        Title="Mapa Floty - Hub - ZPSP"
        Width="1500" Height="900"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#f7f8fa">
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    <TabControl x:Name="HubTabs" TabStripPlacement="Top" Background="#f7f8fa" BorderThickness="0">
        <TabItem Header="🗺️ Mapa Live">
            <local:MapaFlotyView x:Name="FlotaView"/>
        </TabItem>
        <TabItem Header="📊 Oś czasu">
            <local:OsCzasuFlotyView x:Name="OsCzasuView"/>
        </TabItem>
        <TabItem Header="📈 Raport efektywności">
            <local:RaportEfektywnosciView x:Name="RaportView"/>
        </TabItem>
    </TabControl>
</Window>
