<Window x:Class="Kalendarz1.MapaFloty.MapowanieWebfletHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mapowanie Webfleet (GPS) - ZPSP"
        Width="600" Height="430"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A237E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="24,20" BorderBrush="#E0E3EA" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="🔗  Mapowanie Webfleet (GPS)" FontSize="20" FontWeight="Bold" Foreground="#1A237E"/>
                <TextBlock Text="Połącz pojazdy i kierowców z Webfleet GPS z bazą TransportPL"
                           FontSize="12" Foreground="#546E7A" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content: 2 action cards -->
        <Grid Grid.Row="1" Margin="24,24,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20,24"
                    BorderBrush="#E0E3EA" BorderThickness="1" Margin="0,0,8,0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.06" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="🚛" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Pojazdy" FontSize="18" FontWeight="Bold" Foreground="#1A237E"
                               HorizontalAlignment="Center" Margin="0,12,0,4"/>
                    <TextBlock Text="Webfleet GPS  ↔  TransportPL.Pojazd"
                               FontSize="11" Foreground="#90A4AE"
                               HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <Button x:Name="BtnPojazdy" Content="Otwórz mapowanie pojazdów"
                            Style="{StaticResource ActionBtn}" Click="BtnPojazdy_Click" IsEnabled="False"/>
                    <TextBlock x:Name="TxtPojazdyStats" Text="" FontSize="11" Foreground="#546E7A"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20,24"
                    BorderBrush="#E0E3EA" BorderThickness="1" Margin="8,0,0,0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.06" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="👤" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Kierowcy" FontSize="18" FontWeight="Bold" Foreground="#1A237E"
                               HorizontalAlignment="Center" Margin="0,12,0,4"/>
                    <TextBlock Text="Webfleet GPS  ↔  TransportPL.Kierowca"
                               FontSize="11" Foreground="#90A4AE"
                               HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <Button x:Name="BtnKierowcy" Content="Otwórz mapowanie kierowców"
                            Style="{StaticResource ActionBtn}" Click="BtnKierowcy_Click" IsEnabled="False"
                            Background="#00838F"/>
                    <TextBlock x:Name="TxtKierowcyStats" Text="" FontSize="11" Foreground="#546E7A"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="White" Padding="24,12" BorderBrush="#E0E3EA" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="TxtStatus" Text="Pobieranie danych z Webfleet..." VerticalAlignment="Center"
                           FontSize="12" Foreground="#546E7A"/>
                <Button DockPanel.Dock="Right" Content="Zamknij" Click="BtnClose_Click"
                        Background="White" Foreground="#37474F" FontSize="12" Padding="14,7"
                        BorderBrush="#CFD8DC" BorderThickness="1" Cursor="Hand"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
