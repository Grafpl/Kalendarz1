<Window x:Class="Kalendarz1.MapaFloty.MapowanieWebfletHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mapowanie Webfleet (GPS) - ZPSP"
        Width="680" Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI"
        ResizeMode="CanResize"
        MinWidth="600" MinHeight="500">

    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A237E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="#CFD8DC" BorderThickness="1"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#ECEFF1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="24,16,24,12" BorderBrush="#E0E3EA" BorderThickness="0,0,0,1">
            <StackPanel>
                <DockPanel>
                    <Button DockPanel.Dock="Right" x:Name="BtnRefresh" Content="⟳ Odśwież"
                            Style="{StaticResource GhostBtn}" Click="BtnRefresh_Click"
                            ToolTip="Pobierz ponownie z Webfleet"/>
                    <StackPanel>
                        <TextBlock Text="🔗  Mapowanie Webfleet (GPS)" FontSize="20" FontWeight="Bold" Foreground="#1A237E"/>
                        <TextBlock Text="Połącz pojazdy i kierowców z Webfleet GPS z bazą TransportPL"
                                   FontSize="12" Foreground="#546E7A" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>

                <!-- Banner: status migracji Webfleet -->
                <Border x:Name="MigrationBanner" Background="#FFF3E0" CornerRadius="6" Padding="14,10" Margin="0,12,0,0"
                        BorderBrush="#FFB74D" BorderThickness="1" Visibility="Collapsed">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="⚠" FontSize="16" Foreground="#E65100" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Webfleet zmigrował API na OAuth 2.0" FontSize="13" FontWeight="Bold"
                                       Foreground="#BF360C" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#5D4037">
                            Stary endpoint <Run FontFamily="Consolas">csv.webfleet.com</Run> został wycofany.
                            Nowy <Run FontFamily="Consolas">api.webfleet.com</Run> wymaga <Run FontWeight="Bold">OAuth 2.0 Bearer token</Run> + client_id / client_secret.
                            Twój obecny klucz API jest legacy i nie zadziała. Skontaktuj się z Webfleet po nowe credentials.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- URL edytor + szybkie szablony -->
                <Border Background="#F5F7FA" CornerRadius="5" Padding="10,7" Margin="0,8,0,0"
                        BorderBrush="#CFD8DC" BorderThickness="1">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="URL:" VerticalAlignment="Center" Foreground="#37474F"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" x:Name="TxtBaseUrl" Height="26" FontSize="11"
                                     VerticalContentAlignment="Center" Padding="6,0"
                                     BorderBrush="#CFD8DC" BorderThickness="1"
                                     ToolTip="Aktualny endpoint Webfleet API"/>
                            <Button Grid.Column="2" Content="Zapisz i przeładuj" Margin="6,0,0,0"
                                    Style="{StaticResource GhostBtn}" Click="BtnSaveUrl_Click"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="32,5,0,0">
                            <TextBlock Text="Szablony:" FontSize="10" Foreground="#90A4AE" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Button Content="csv (legacy)" Click="BtnUrlCsv_Click" Padding="6,2" FontSize="10"
                                    Background="White" BorderBrush="#CFD8DC" BorderThickness="1" Margin="0,0,4,0"
                                    Cursor="Hand"/>
                            <Button Content="api (OAuth)" Click="BtnUrlApi_Click" Padding="6,2" FontSize="10"
                                    Background="White" BorderBrush="#CFD8DC" BorderThickness="1"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Auto-map CTA (zielony banner) -->
        <Border Grid.Row="1" Background="#E8F5E9" BorderBrush="#A5D6A7" BorderThickness="1"
                CornerRadius="8" Margin="24,16,24,0" Padding="14,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" x:Name="BtnAutoMapAll" Content="⚡ Auto-mapuj wszystkie po rejestracji"
                        Click="BtnAutoMapAll_Click"
                        Background="#2E7D32" Foreground="White" FontWeight="Bold" FontSize="13"
                        Padding="16,10" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="🎯 Szybkie mapowanie" FontSize="13" FontWeight="Bold" Foreground="#1B5E20"/>
                    <TextBlock Text="Automatycznie zmapuj wszystkie pojazdy po numerze rejestracyjnym (Webfleet ↔ TransportPL.Pojazd)"
                               FontSize="11" Foreground="#2E7D32" Margin="0,2,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2" Margin="24,12,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- POJAZDY card -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20,20"
                    BorderBrush="#E0E3EA" BorderThickness="1" Margin="0,0,8,0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.06" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="🚛" FontSize="46" HorizontalAlignment="Center"/>
                    <TextBlock Text="Pojazdy" FontSize="18" FontWeight="Bold" Foreground="#1A237E"
                               HorizontalAlignment="Center" Margin="0,8,0,2"/>
                    <TextBlock Text="Webfleet GPS ↔ TransportPL.Pojazd"
                               FontSize="10.5" Foreground="#90A4AE"
                               HorizontalAlignment="Center" Margin="0,0,0,14"/>

                    <!-- Progress: zmapowane vs wszystkie -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Zmapowane" FontSize="10.5" Foreground="#90A4AE" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="TxtPojazdyProgress" Text="—" FontSize="13" FontWeight="Bold" Foreground="#1A237E"/>
                    </Grid>
                    <Border Background="#ECEFF1" Height="6" CornerRadius="3" ClipToBounds="True" Margin="0,4,0,14">
                        <Grid HorizontalAlignment="Left">
                            <Border x:Name="ProgressPojazdy" Width="0" Height="6" Background="#43A047" CornerRadius="3"/>
                        </Grid>
                    </Border>

                    <Button x:Name="BtnPojazdy" Content="Otwórz mapowanie pojazdów"
                            Style="{StaticResource ActionBtn}" Click="BtnPojazdy_Click" IsEnabled="False"/>
                </StackPanel>
            </Border>

            <!-- KIEROWCY card -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20,20"
                    BorderBrush="#E0E3EA" BorderThickness="1" Margin="8,0,0,0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.06" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="👤" FontSize="46" HorizontalAlignment="Center"/>
                    <TextBlock Text="Kierowcy" FontSize="18" FontWeight="Bold" Foreground="#1A237E"
                               HorizontalAlignment="Center" Margin="0,8,0,2"/>
                    <TextBlock Text="Webfleet GPS ↔ TransportPL.Kierowca"
                               FontSize="10.5" Foreground="#90A4AE"
                               HorizontalAlignment="Center" Margin="0,0,0,14"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Zmapowane" FontSize="10.5" Foreground="#90A4AE" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="TxtKierowcyProgress" Text="—" FontSize="13" FontWeight="Bold" Foreground="#00838F"/>
                    </Grid>
                    <Border Background="#ECEFF1" Height="6" CornerRadius="3" ClipToBounds="True" Margin="0,4,0,14">
                        <Grid HorizontalAlignment="Left">
                            <Border x:Name="ProgressKierowcy" Width="0" Height="6" Background="#43A047" CornerRadius="3"/>
                        </Grid>
                    </Border>

                    <Button x:Name="BtnKierowcy" Content="Otwórz mapowanie kierowców"
                            Style="{StaticResource ActionBtn}" Click="BtnKierowcy_Click" IsEnabled="False"
                            Background="#00838F"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading overlay (visible while fetching) -->
        <Border x:Name="LoadingOverlay" Grid.Row="2" Background="#CCFFFFFF" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⟳" FontSize="48" Foreground="#1A237E" HorizontalAlignment="Center">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="LoaderRotate" CenterX="20" CenterY="32"/>
                    </TextBlock.RenderTransform>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="TextBlock.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="LoaderRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:1.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                <TextBlock x:Name="TxtLoading" Text="Pobieranie pojazdów z Webfleet..." FontSize="13" FontWeight="SemiBold"
                           Foreground="#1A237E" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="White" Padding="24,12" BorderBrush="#E0E3EA" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="TxtStatus" Text="" VerticalAlignment="Center"
                           FontSize="11.5" Foreground="#546E7A"/>
                <Button DockPanel.Dock="Right" Content="Zamknij" Click="BtnClose_Click"
                        Style="{StaticResource GhostBtn}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
