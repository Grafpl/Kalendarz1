<Window x:Class="Kalendarz1.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kalendarz1.WPF"
        mc:Ignorable="d"
        Title="Podsumowanie Tygodniowe Zamówień" 
        Height="768" Width="1280"
        WindowState="Maximized"
        Background="#F5F7FA"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="PrimaryGreen" Color="#5C8A3A"/>
            <SolidColorBrush x:Key="PrimaryGreenHover" Color="#4B732F"/>
            <SolidColorBrush x:Key="PrimaryGreenPressed" Color="#3A5C24"/>
            <SolidColorBrush x:Key="TextDark" Color="#2C3E50"/>
            <SolidColorBrush x:Key="TextLight" Color="#7F8C8D"/>
            <SolidColorBrush x:Key="BackgroundLight" Color="#F5F7FA"/>
            <SolidColorBrush x:Key="LightGreen" Color="#E0F0D6"/>
            <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0"/>

            <DropShadowEffect x:Key="DropShadowEffect" ShadowDepth="2" Color="#000000" Opacity="0.15" BlurRadius="8"/>
            <DropShadowEffect x:Key="CardShadow" ShadowDepth="0" Color="#000000" Opacity="0.1" BlurRadius="10"/>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <Style x:Key="ActionButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="MinWidth" Value="95"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Margin" Value="3,0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <Style x:Key="NavigationButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="#2C3E50"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <Style x:Key="DayButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#F5F7FA"/>
                <Setter Property="Foreground" Value="#2C3E50"/>
                <Setter Property="FontSize" Value="8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Width" Value="48"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Margin" Value="1,0"/>
                <Setter Property="ClickMode" Value="Press"/>
                <Setter Property="Focusable" Value="False"/>
            </Style>

            <Style x:Key="FilterTextBoxStyle" TargetType="TextBox">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Background" Value="White"/>
            </Style>

            <Style x:Key="ModernDataGridHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#2C3E50"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>

            <!-- Styl M - średni rozmiar tabeli z szerszymi kolumnami -->
            <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="GridLinesVisibility" Value="None"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="RowHeight" Value="38"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserDeleteRows" Value="False"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="AlternatingRowBackground" Value="#F8F9FA"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="MinColumnWidth" Value="60"/>
                <Setter Property="ColumnHeaderStyle" Value="{StaticResource ModernDataGridHeaderStyle}"/>
                <!-- PERFORMANCE: Wirtualizacja i recycling -->
                <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
                <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
                <Setter Property="VirtualizingPanel.ScrollUnit" Value="Item"/>
                <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="True"/>
                <Setter Property="EnableRowVirtualization" Value="True"/>
                <Setter Property="EnableColumnVirtualization" Value="True"/>
            </Style>

            <Style x:Key="PanelBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="15"/>
                <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            </Style>

            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#2C3E50"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
            </Style>

            <Style x:Key="NotesTextBoxStyle" TargetType="TextBox">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="10"/>
                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Background" Value="#FEFEFE"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="AcceptsReturn" Value="True"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="IsReadOnly" Value="False"/>
                <Style.Triggers>
                    <Trigger Property="IsFocused" Value="True">
                        <Setter Property="BorderBrush" Value="#4CAF50"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="RightAlignedCellStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="Padding" Value="0,0,8,0"/>
            </Style>

            <Style x:Key="CenterAlignedCellStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="BoldCellStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0"/>   <!-- toolbar przeniesiony do prawego panelu (nad Podsumowanie dnia) -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- ✅ LOADING OVERLAY - drobiowy styl z czerwoną ramką -->
        <Border x:Name="loadingOverlay" Grid.Row="0" Grid.RowSpan="3"
                Background="#80000000" Visibility="Collapsed"
                Panel.ZIndex="1000" IsHitTestVisible="True">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border CornerRadius="16" Padding="40,25" Background="White"
                        BorderBrush="#E74C3C" BorderThickness="4">
                    <StackPanel>
                        <TextBlock x:Name="loadingSpinner" FontSize="50"
                                   HorizontalAlignment="Center" Margin="0,0,0,10">
                            <Run Foreground="#E74C3C">🐔</Run>
                        </TextBlock>
                        <TextBlock x:Name="loadingText" Text="Ładowanie danych..."
                                   FontSize="16" HorizontalAlignment="Center" FontWeight="Bold"
                                   Foreground="#27AE60"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Toolbar przeniesiony do prawego panelu (nad "Podsumowanie dnia") — tabela zamówień sięga samej góry -->

        <Grid x:Name="mainContentGrid" Grid.Row="1">
            <!-- Ukryte elementy kompatybilności -->
            <ComboBox x:Name="cbFilterProduct" Visibility="Collapsed"
                      DisplayMemberPath="Value" SelectedValuePath="Key"/>
            <CheckBox x:Name="chkShowReleasesWithoutOrders" Visibility="Collapsed"
                      Checked="ChkShowReleases_Changed" Unchecked="ChkShowReleases_Changed"/>
            <CheckBox x:Name="chkShowAnulowane" Visibility="Collapsed" IsChecked="False"
                      Checked="ChkShowAnulowane_Changed" Unchecked="ChkShowAnulowane_Changed"/>
            <RadioButton x:Name="rbPickupDate" Visibility="Collapsed" GroupName="DateFilter"
                         Checked="RbDateFilter_Checked"/>
            <RadioButton x:Name="rbSlaughterDate" Visibility="Collapsed" GroupName="DateFilter"
                         Checked="RbDateFilter_Checked" IsChecked="True"/>
            <WrapPanel x:Name="pnlProductButtons" Visibility="Collapsed"/>
            <TextBox x:Name="txtFilterRecipient" Visibility="Collapsed"/>
            <RadioButton x:Name="rbSwieze" Visibility="Collapsed" IsChecked="True"/>
            <RadioButton x:Name="rbMrozone" Visibility="Collapsed"/>

            <!-- ZAWARTOŚĆ - dwie kolumny z przesuwnym splitterem -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Tabela zamówień ma stałą szerokość (priorytet przy zmniejszaniu okna);
                         prawy panel (kafelki) jest elastyczny i kurczy się pierwszy -->
                    <ColumnDefinition x:Name="leftColumnDef" Width="620" MinWidth="540"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition x:Name="rightColumnDef" Width="*" MinWidth="340"/>
                </Grid.ColumnDefinitions>

                <!-- Lewa kolumna - zakładki -->
                <TabControl x:Name="tabOrders" Grid.Column="0" Background="Transparent" BorderThickness="0"
                            Margin="10,0,5,10" SelectionChanged="TabOrders_SelectionChanged">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </TabControl.ItemContainerStyle>
                    <TabItem Header="Zamówienia" FontSize="12" FontWeight="SemiBold">
                        <DataGrid x:Name="dgOrders"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  SelectionChanged="DgOrders_SelectionChanged"
                                  MouseDoubleClick="DgOrders_MouseDoubleClick"
                                  MouseRightButtonUp="DgOrders_MouseRightButtonUp">
                            <DataGrid.ContextMenu>
                                <ContextMenu x:Name="contextMenuOrders">
                                    <MenuItem x:Name="menuDuplikuj" Header="🔄 Duplikuj zamówienie" Click="MenuDuplikuj_Click"/>
                                    <MenuItem x:Name="menuCykliczne" Header="📅 Zamówienia cykliczne" Click="MenuCykliczne_Click"/>
                                    <MenuItem x:Name="menuPokazCykl" Header="🔗 Pokaż cały cykl" Click="MenuPokazCykl_Click" Visibility="Collapsed"/>
                                    <MenuItem x:Name="menuAnulujCykl" Header="🔗❌ Anuluj cały cykl" Click="MenuAnulujCykl_Click" Visibility="Collapsed"/>
                                    <MenuItem x:Name="menuModyfikuj" Header="✏️ Modyfikuj zamówienie" Click="MenuModyfikuj_Click"/>
                                    <MenuItem x:Name="menuNotatka" Header="📝 Dodaj/Edytuj notatkę" Click="MenuNotatka_Click"/>
                                    <MenuItem x:Name="menuPrzypiszHandlowca" Header="👤 Przypisz handlowca…" Click="MenuPrzypiszHandlowca_Click"/>
                                    <Separator/>
                                    <MenuItem x:Name="menuSzczegolyZamowienia" Header="📊 Szczegóły zamówienia" Click="MenuSzczegolyZamowienia_Click"/>
                                    <MenuItem x:Name="menuSzczegolyPlatnosci" Header="💳 Płatności kontrahenta" Click="MenuSzczegolyPlatnosci_Click"/>
                                    <MenuItem x:Name="menuHistoriaZamowien" Header="📋 Historia zamówień" Click="MenuHistoriaZamowien_Click"/>
                                    <MenuItem x:Name="menuHistoriaZmian" Header="📜 Historia zmian zamówienia" Click="MenuHistoriaZmian_Click"/>
                                    <MenuItem x:Name="menuTransportInfo" Header="🚚 Informacje o transporcie" Click="MenuTransportInfo_Click"/>
                                    <Separator/>
                                    <MenuItem x:Name="menuShowAnulowane" Header="Pokaż anulowane" IsCheckable="True"
                                              Click="MenuShowAnulowane_Click"/>
                                    <MenuItem x:Name="menuShowWydaniaBezZam" Header="Pokaż wydania bez zam." IsCheckable="True"
                                              Click="MenuShowWydaniaBezZam_Click"/>
                                    <Separator/>
                                    <MenuItem x:Name="menuOdswiez" Header="🔄 Odśwież dane" Click="MenuOdswiez_Click"/>
                                    <Separator/>
                                    <MenuItem x:Name="menuDaneOdbiorcy" Header="👤 Dokładne dane odbiorcy" Click="MenuDaneOdbiorcy_Click" FontWeight="SemiBold"/>
                                    <Separator/>
                                    <MenuItem x:Name="menuAnuluj" Header="❌ Anuluj zamówienie" Click="MenuAnuluj_Click"/>
                                    <MenuItem x:Name="menuPrzywroc" Header="✅ Przywróć zamówienie" Click="MenuPrzywroc_Click" Visibility="Collapsed"/>
                                    <MenuItem x:Name="menuUsun" Header="🗑️ USUŃ TRWALE zamówienie" Click="MenuUsun_Click" Visibility="Collapsed"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Transport" FontSize="12" FontWeight="SemiBold" Visibility="Collapsed">
                        <DataGrid x:Name="dgTransport"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  AutoGenerateColumns="False"
                                  SelectionChanged="DgTransport_SelectionChanged"/>
                    </TabItem>
                    <TabItem Header="Historia zmian" FontSize="12" FontWeight="SemiBold" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Panel filtrów -->
                            <Border Grid.Row="0" Background="#ECF0F1" Padding="10" Margin="0,0,0,5">
                                <WrapPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                        <TextBlock Text="Kto edytował:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11"/>
                                        <ComboBox x:Name="cmbHistoriaKtoEdytowal" Width="120" FontSize="11"
                                                  SelectionChanged="CmbHistoriaFiltr_SelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                        <TextBlock Text="Odbiorca:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11"/>
                                        <ComboBox x:Name="cmbHistoriaOdbiorca" Width="150" FontSize="11"
                                                  SelectionChanged="CmbHistoriaFiltr_SelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                        <TextBlock Text="Typ zmiany:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11"/>
                                        <ComboBox x:Name="cmbHistoriaTyp" Width="120" FontSize="11"
                                                  SelectionChanged="CmbHistoriaFiltr_SelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                        <TextBlock Text="Handlowiec:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11"/>
                                        <ComboBox x:Name="cmbHistoriaHandlowiec" Width="120" FontSize="11"
                                                  SelectionChanged="CmbHistoriaFiltr_SelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                        <TextBlock Text="Towar:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11"/>
                                        <ComboBox x:Name="cmbHistoriaTowar" Width="150" FontSize="11"
                                                  SelectionChanged="CmbHistoriaFiltr_SelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                        <TextBlock Text="Data uboju:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11"/>
                                        <ComboBox x:Name="cmbHistoriaDataUboju" Width="120" FontSize="11"
                                                  SelectionChanged="CmbHistoriaFiltr_SelectionChanged"/>
                                    </StackPanel>
                                    <Button x:Name="btnHistoriaCzysc" Content="✕ Wyczyść filtry"
                                            Padding="8,4" FontSize="11" Margin="0,0,0,5"
                                            Click="BtnHistoriaCzyscFiltry_Click"/>
                                </WrapPanel>
                            </Border>

                            <DataGrid Grid.Row="1" x:Name="dgHistoriaZmian"
                                      Style="{StaticResource ModernDataGridStyle}"
                                      AutoGenerateColumns="False"
                                      CanUserSortColumns="True"/>
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="tabDashboard" Header="📊 Dashboard" FontSize="12" FontWeight="SemiBold" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid Margin="10" Background="#F0F2F5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- SEKCJA 1: BILANS I WYDAJNOŚĆ -->
                                <Grid Grid.Row="0" Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="300"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Lewa strona: Bilans produktów -->
                                    <Border Grid.Column="0" Margin="5,0,10,0" CornerRadius="12" Background="White">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.1" BlurRadius="10"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Nagłówek -->
                                            <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="20,12">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#2c3e50" Offset="0"/>
                                                        <GradientStop Color="#3498db" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📊 BILANS PRODUKTÓW" FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Border Background="#27AE60" CornerRadius="12" Padding="12,5" Margin="5,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="✓ " FontSize="12" Foreground="White" FontWeight="Bold"/>
                                                                <TextBlock x:Name="txtBilansOk" Text="0" FontSize="12" Foreground="White" FontWeight="Bold"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Background="#F39C12" CornerRadius="12" Padding="12,5" Margin="5,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="⚠ " FontSize="12" Foreground="White" FontWeight="Bold"/>
                                                                <TextBlock x:Name="txtBilansUwaga" Text="0" FontSize="12" Foreground="White" FontWeight="Bold"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Background="#E74C3C" CornerRadius="12" Padding="12,5" Margin="5,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="✗ " FontSize="12" Foreground="White" FontWeight="Bold"/>
                                                                <TextBlock x:Name="txtBilansBrak" Text="0" FontSize="12" Foreground="White" FontWeight="Bold"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- Tabela -->
                                            <DataGrid x:Name="dgDashboardProdukty" Grid.Row="1"
                                                      Style="{StaticResource ModernDataGridStyle}"
                                                      AutoGenerateColumns="False"
                                                      CanUserSortColumns="True"
                                                      MaxHeight="280"
                                                      Margin="5"/>
                                        </Grid>
                                    </Border>

                                    <!-- Prawa strona: Wydajność -->
                                    <Border Grid.Column="1" Margin="0,0,5,0" CornerRadius="12" Background="White">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.1" BlurRadius="10"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Nagłówek -->
                                            <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="15,12">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#8e44ad" Offset="0"/>
                                                        <GradientStop Color="#3498db" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="⚙️ WYDAJNOŚĆ" FontSize="14" Foreground="White" FontWeight="Bold"/>
                                            </Border>

                                            <!-- Zawartość -->
                                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="15">
                                                <TextBlock x:Name="txtWydajnoscGlowna" Text="78%" FontSize="56" Foreground="#2c3e50" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Wydajność tuszki" FontSize="12" Foreground="#7f8c8d" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                                                <!-- Pasek postępu -->
                                                <Grid Margin="0,0,0,20">
                                                    <Border Background="#E0E0E0" CornerRadius="5" Height="10"/>
                                                    <Border x:Name="progressWydajnosc" Background="#27AE60" CornerRadius="5" Height="10" HorizontalAlignment="Left" Width="200"/>
                                                </Grid>

                                                <!-- Tuszka A i B -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0" Background="#E8F8E8" CornerRadius="8" Padding="15,10" Margin="0,0,5,0">
                                                        <StackPanel HorizontalAlignment="Center">
                                                            <TextBlock Text="TUSZKA A" FontSize="10" Foreground="#27AE60" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                            <TextBlock x:Name="txtTuszkaA" Text="85%" FontSize="22" Foreground="#27AE60" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Column="1" Background="#E8F0F8" CornerRadius="8" Padding="15,10" Margin="5,0,0,0">
                                                        <StackPanel HorizontalAlignment="Center">
                                                            <TextBlock Text="TUSZKA B" FontSize="10" Foreground="#3498DB" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                            <TextBlock x:Name="txtTuszkaB" Text="15%" FontSize="22" Foreground="#3498DB" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- SEKCJA 2: DOSTĘPNOŚĆ DLA HANDLOWCÓW -->
                                <Border Grid.Row="1" Margin="5,0,5,15" CornerRadius="12" Background="White">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.1" BlurRadius="10"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Nagłówek -->
                                        <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="20,12">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#00b09b" Offset="0"/>
                                                    <GradientStop Color="#96c93d" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Grid>
                                                <TextBlock Text="🛒 DOSTĘPNOŚĆ PRODUKTÓW DLA HANDLOWCÓW" FontSize="14" Foreground="White" FontWeight="Bold"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <TextBlock Text="Legenda: " Foreground="#E0FFE0" FontSize="11" VerticalAlignment="Center"/>
                                                    <Border Background="#27AE60" CornerRadius="3" Padding="8,2" Margin="5,0">
                                                        <TextBlock Text="Dostępny" Foreground="White" FontSize="10"/>
                                                    </Border>
                                                    <Border Background="#E74C3C" CornerRadius="3" Padding="8,2" Margin="5,0">
                                                        <TextBlock Text="Brak" Foreground="White" FontSize="10"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Karty produktów -->
                                        <ItemsControl x:Name="icDostepnoscProduktow" Grid.Row="1" Margin="10">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="5" Padding="15" CornerRadius="10" Width="220"
                                                            BorderThickness="3" BorderBrush="{Binding KolorRamki}">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{Binding KolorTla}"/>
                                                        </Border.Background>
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Nazwa produktu -->
                                                            <TextBlock Grid.Row="0" Text="{Binding Nazwa}"
                                                                       FontWeight="Bold" FontSize="13"
                                                                       Foreground="#2c3e50" TextWrapping="Wrap"/>

                                                            <!-- Pasek postępu -->
                                                            <Grid Grid.Row="1" Margin="0,10,0,8">
                                                                <Border Background="#E0E0E0" CornerRadius="5" Height="16"/>
                                                                <Border Background="{Binding KolorPaska}" CornerRadius="5" Height="16"
                                                                        HorizontalAlignment="Left" Width="{Binding SzerokoscPaska}"/>
                                                                <TextBlock Text="{Binding ProcentText}" FontSize="10" FontWeight="Bold"
                                                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Grid>

                                                            <!-- BILANS - główna informacja -->
                                                            <Border Grid.Row="2" Background="{Binding KolorRamki}" CornerRadius="5" Padding="8,5" Margin="0,0,0,8">
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                    <TextBlock Text="DO SPRZEDANIA: " FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding BilansText}" FontSize="14" Foreground="White" FontWeight="Bold"/>
                                                                </StackPanel>
                                                            </Border>

                                                            <!-- Plan/Fakt i Stan -->
                                                            <Grid Grid.Row="3" Margin="0,0,0,5">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock Text="Plan/Fakt:" FontSize="9" Foreground="#7f8c8d"/>
                                                                    <TextBlock Text="{Binding PlanFaktText}" FontSize="11" FontWeight="SemiBold" Foreground="#2c3e50"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="Stan mag.:" FontSize="9" Foreground="#7f8c8d"/>
                                                                    <TextBlock Text="{Binding StanText}" FontSize="11" FontWeight="SemiBold" Foreground="#2c3e50"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <!-- Zamówienia -->
                                                            <StackPanel Grid.Row="4" Orientation="Horizontal">
                                                                <TextBlock Text="Zamówienia: " FontSize="10" Foreground="#7f8c8d"/>
                                                                <TextBlock Text="{Binding ZamowioneText}" FontSize="10" FontWeight="SemiBold" Foreground="#e74c3c"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem x:Name="tabStatystyki" Header="📈 Statystyki" FontSize="12" FontWeight="SemiBold" Visibility="Collapsed">
                        <Grid Margin="10" Background="#F0F2F5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Panel filtrów statystyk -->
                            <Border Grid.Row="0" Background="#ECF0F1" Padding="15" CornerRadius="8" Margin="0,0,0,10">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1" Color="#000000" Opacity="0.1" BlurRadius="5"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                                        <TextBlock Text="Okres:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                        <ComboBox x:Name="cmbStatystykiOkres" Width="120" Height="30"
                                                  SelectionChanged="CmbStatystykiOkres_SelectionChanged">
                                            <ComboBoxItem Content="Rok" Tag="Year"/>
                                            <ComboBoxItem Content="Miesiąc" Tag="Month" IsSelected="True"/>
                                            <ComboBoxItem Content="Tydzień" Tag="Week"/>
                                            <ComboBoxItem Content="Dzień" Tag="Day"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,20,0">
                                        <TextBlock Text="Od:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <DatePicker x:Name="dpStatystykiOd" Width="130" Height="30"
                                                    SelectedDateChanged="DpStatystyki_SelectedDateChanged"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,20,0">
                                        <TextBlock Text="Do:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <DatePicker x:Name="dpStatystykiDo" Width="130" Height="30"
                                                    SelectedDateChanged="DpStatystyki_SelectedDateChanged"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,20,0">
                                        <TextBlock Text="Handlowiec:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <ComboBox x:Name="cmbStatystykiHandlowiec" Width="120" Height="30"
                                                  SelectionChanged="CmbStatystykiHandlowiec_SelectionChanged"/>
                                    </StackPanel>

                                    <Button Grid.Column="5" x:Name="btnStatystykiOdswiez" Content="🔄 Odśwież"
                                            Background="#3498DB" Foreground="White" FontWeight="Bold"
                                            Padding="15,8" Click="BtnStatystykiOdswiez_Click"/>
                                </Grid>
                            </Border>

                            <!-- Dwie kolumny: odbiorcy i przyczyny -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="350"/>
                                </Grid.ColumnDefinitions>

                                <!-- Lewa kolumna - Tabela statystyk per odbiorca -->
                                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="10" Margin="0,0,10,0">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.1" BlurRadius="10"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Nagłówek -->
                                        <Border Grid.Row="0" CornerRadius="8,8,0,0" Padding="15,10" Margin="0,0,0,10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#e74c3c" Offset="0"/>
                                                    <GradientStop Color="#c0392b" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Grid>
                                                <TextBlock Text="📊 ANULOWANE WG ODBIORCY"
                                                           FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Border Background="#27AE60" CornerRadius="12" Padding="12,5" Margin="5,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Łącznie: " FontSize="12" Foreground="White"/>
                                                            <TextBlock x:Name="txtStatystykiLacznieAnulowanych" Text="0" FontSize="12" Foreground="White" FontWeight="Bold"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <DataGrid Grid.Row="1" x:Name="dgStatystykiAnulowane"
                                                  Style="{StaticResource ModernDataGridStyle}"
                                                  AutoGenerateColumns="False"
                                                  CanUserSortColumns="True"/>
                                    </Grid>
                                </Border>

                                <!-- Prawa kolumna - Podział według przyczyn -->
                                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="10">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.1" BlurRadius="10"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Nagłówek przyczyn -->
                                        <Border Grid.Row="0" CornerRadius="8,8,0,0" Padding="15,10" Margin="0,0,0,10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#9B59B6" Offset="0"/>
                                                    <GradientStop Color="#8E44AD" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="📋 PODZIAŁ WG PRZYCZYN"
                                                       FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </Border>

                                        <DataGrid Grid.Row="1" x:Name="dgStatystykiPrzyczyny"
                                                  Style="{StaticResource ModernDataGridStyle}"
                                                  AutoGenerateColumns="False"
                                                  CanUserSortColumns="True"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>

                <!-- SPLITTER - przeciągnij aby zmienić szerokość paneli -->
                <GridSplitter Grid.Column="1" Width="6"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              Background="#E0E0E0" Cursor="SizeWE"
                              ShowsPreview="True"/>

                <!-- Prawa kolumna - szczegóły i podsumowanie -->
                <Grid x:Name="rightPanel" Grid.Column="2" Margin="3,0,4,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- nagłówek Podsumowanie dnia -->
                    <RowDefinition Height="54*"/>     <!-- towary (karty) — na górze -->
                    <RowDefinition Height="46*"/>     <!-- szczegóły zamówienia + notatki (na dole, wyższe) -->
                </Grid.RowDefinitions>

                <!-- Ukryte elementy kompatybilności (wyszukiwarka produktu + dane klienta — kod ich używa, -->
                <!-- ale nazwa kontrahenta pokazuje się teraz w nagłówku kolumny "Produkt" w szczegółach) -->
                <TextBlock x:Name="txtSearchWatermark" Visibility="Collapsed"/>
                <TextBox x:Name="txtProductSearch" Visibility="Collapsed" TextChanged="TxtProductSearch_TextChanged"/>
                <TextBlock x:Name="txtOrderClient" Visibility="Collapsed"/>
                <TextBlock x:Name="txtOrderInfo" Visibility="Collapsed"/>
                <DataGrid x:Name="dgAggregation" Visibility="Collapsed"
                          Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False"/>

                <!-- Pasek akcji (z dawnego górnego toolbara) + nagłówek "Podsumowanie dnia" -->
                <StackPanel Grid.Row="0">
                <!-- Nawigacja tygodnia + dni + akcje — nad podsumowaniem -->
                <StackPanel Orientation="Horizontal" Margin="0,3,0,4">
                    <Button x:Name="btnPreviousWeek" Style="{StaticResource NavigationButtonStyle}"
                            Content="&#x25C0;" FontSize="12" Width="28" Height="28"
                            Click="BtnPreviousWeek_Click"/>
                    <Button x:Name="btnNextWeek" Style="{StaticResource NavigationButtonStyle}"
                            Content="&#x25B6;" FontSize="12" Width="28" Height="28"
                            Click="BtnNextWeek_Click" Margin="4,0,0,0"/>

                    <StackPanel x:Name="panelDays" Orientation="Horizontal"
                                Margin="10,0,0,0" VerticalAlignment="Center"/>

                    <!-- MinWidth=0 PRZYMUSOWO — ActionButtonStyle ma MinWidth=95, które wygrywa z Width -->
                    <Button x:Name="btnNew" Style="{StaticResource ActionButtonStyle}"
                            Background="#2ECC71" Content="➕" Width="28" ToolTip="Nowe zamówienie"
                            MinWidth="0" Padding="0"
                            Click="BtnNew_Click" FontSize="12" Height="28" Margin="10,0,0,0"/>

                    <Button x:Name="btnRefresh" Style="{StaticResource ActionButtonStyle}"
                            Background="#9B59B6" Content="🔄" Width="28" ToolTip="Odśwież dane"
                            MinWidth="0" Padding="0"
                            Click="BtnRefresh_Click" Margin="4,0,0,0" FontSize="12" Height="28"/>

                    <Button x:Name="btnOpenHistoria" Style="{StaticResource ActionButtonStyle}"
                            Background="#8E44AD" Content="📜" Width="28" ToolTip="Historia zmian"
                            MinWidth="0" Padding="0"
                            Click="BtnOpenHistoria_Click" Margin="4,0,0,0" FontSize="12" Height="28"/>

                    <!-- Pozostałe akcje pod jednym comboboxem (Dashboard / Statystyki / Transport / Usuń) -->
                    <ComboBox x:Name="cbAkcje" Width="56" Height="28" FontSize="12" Margin="4,0,0,0"
                              VerticalContentAlignment="Center" ToolTip="Więcej akcji (Dashboard / Statystyki / Transport / Usuń)"
                              SelectionChanged="CbAkcje_SelectionChanged">
                        <ComboBoxItem Content="⋯" IsSelected="True"/>
                        <ComboBoxItem Content="📊 Dashboard" Tag="dash"/>
                        <ComboBoxItem Content="📈 Statystyki" Tag="stat"/>
                        <ComboBoxItem Content="🚚 Transport" Tag="tran"/>
                        <ComboBoxItem x:Name="cbiUsun" Content="🗑️ Usuń zamówienie" Tag="usun" Visibility="Collapsed"/>
                    </ComboBox>
                </StackPanel>

                <!-- Nagłówek "Podsumowanie dnia" + filtr produktu -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                    <TextBlock Text="Podsumowanie dnia"
                               Style="{StaticResource SectionHeaderStyle}" Margin="0,0,12,0"/>
                    <ComboBox x:Name="cbProductFilter" Width="180" Height="26" FontSize="11"
                              VerticalContentAlignment="Center" MaxDropDownHeight="450"
                              VerticalAlignment="Center"
                              ToolTip="Filtruj zamówienia po towarze"
                              SelectionChanged="CbProductFilter_SelectionChanged"/>
                    <!-- Przełącznik Zam./Wyd. ukryty — bilans zawsze liczony z zamówień (Zam.) -->
                    <RadioButton x:Name="rbBilansZamowienia" Content="Zam." IsChecked="True" Visibility="Collapsed"
                                 VerticalAlignment="Center" FontSize="10"
                                 Checked="RbBilans_Checked"/>
                    <RadioButton x:Name="rbBilansWydania" Content="Wyd." Visibility="Collapsed"
                                 VerticalAlignment="Center" FontSize="10"
                                 Checked="RbBilans_Checked"/>
                    <Border x:Name="boxBilansSuma" Margin="16,0,0,0" CornerRadius="9" Padding="9,2"
                            Background="#F2F4F7" VerticalAlignment="Center">
                        <TextBlock x:Name="txtBilansSuma"
                                   FontSize="10" FontWeight="SemiBold" Foreground="#2C3E50"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <Button x:Name="btnPrzychodLibra" Style="{StaticResource ActionButtonStyle}"
                            Background="#16A085" Content="📦" Width="22" Height="22"
                            MinWidth="0" Padding="0"
                            Margin="8,0,0,0" FontSize="10" VerticalAlignment="Center"
                            ToolTip="Przychód produkcji z LibraNet (ważenia In0E) — per towar + rozkład godzinowy"
                            Click="BtnPrzychodLibra_Click"/>
                </StackPanel>
                </StackPanel>

                <!-- Karty towarów — na samej górze, zajmują najwięcej wysokości -->
                <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}">
                    <!-- Scrollbar ZAWSZE zarezerwowany (Visible, nie Auto) — Auto powodowało pętlę layoutu:
                         pojawiający się/znikający pasek zmieniał szerokość panelu i karty "tańczyły" -->
                    <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled" Padding="1,1,3,1">
                        <WrapPanel x:Name="wpProductCards" Orientation="Horizontal"/>
                    </ScrollViewer>
                </Border>

                <!-- Szczegóły zamówienia (na dole): tabela + [Waluta po lewej | szersze notatki po prawej] -->
                <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="dgDetails" Grid.Row="0"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="False"
                                  SelectionUnit="Cell"
                                  SelectionMode="Single"/>

                        <Grid Grid.Row="1" Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Po lewej: tylko Waluta -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                <TextBlock Text="Waluta:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="10"/>
                                <ComboBox x:Name="cbWalutaPanel" Width="55" Height="22" FontSize="10"
                                          SelectionChanged="CbWalutaPanel_SelectionChanged">
                                    <ComboBoxItem Content="PLN" IsSelected="True"/>
                                    <ComboBoxItem Content="EUR"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Po prawej: szerokie notatki -->
                            <TextBox x:Name="txtNotes" Grid.Column="1"
                                     Style="{StaticResource NotesTextBoxStyle}"
                                     FontSize="11" Padding="6" Height="64" Margin="8,0,0,0"
                                     ToolTip="Notatki do zamówienia"/>
                        </Grid>
                    </Grid>
                </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#34495E">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtStatus" Grid.Column="0" Text="Gotowy"
                           Foreground="#BDC3C7" FontSize="11" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1" Text="F5=Odśwież | Ctrl+F=Produkt | Ctrl+N=Nowe | Esc=Wyczyść"
                           Foreground="#7F8C8D" FontSize="10" VerticalAlignment="Center" Margin="0,0,15,0"/>

                <TextBlock x:Name="txtStatusTime" Grid.Column="2" Text=""
                           Foreground="#95A5A6" FontSize="10" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>