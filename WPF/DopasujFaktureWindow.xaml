<Window x:Class="Kalendarz1.WPF.DopasujFaktureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dopasuj fakturę do zamówienia"
        Height="640" Width="900"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F7FA"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="LabelText">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="ValueText">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header (klient + zamówienie) -->
            <RowDefinition Height="Auto"/>  <!-- Range filter -->
            <RowDefinition Height="*"/>     <!-- Grid -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,12"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="KLIENT" Style="{StaticResource LabelText}"/>
                    <TextBlock x:Name="txtKlient" Text="—" Style="{StaticResource ValueText}" FontSize="15" Margin="0,2,0,0"/>
                    <TextBlock x:Name="txtKlientId" Text="" Style="{StaticResource LabelText}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="ZAMÓWIENIE" Style="{StaticResource LabelText}"/>
                    <TextBlock x:Name="txtZamId" Text="—" Style="{StaticResource ValueText}" FontSize="15" Margin="0,2,0,0"/>
                    <TextBlock x:Name="txtZamSuma" Text="" Style="{StaticResource LabelText}" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Range filter + obecny numer -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Pokaż faktury z:" VerticalAlignment="Center" Margin="0,0,8,0"
                       Style="{StaticResource LabelText}"/>
            <ComboBox Grid.Column="1" x:Name="cmbRange" Width="180" Padding="6,4"
                      SelectionChanged="CmbRange_SelectionChanged">
                <ComboBoxItem Content="Ostatni miesiąc" IsSelected="True"/>
                <ComboBoxItem Content="Ostatnie 3 miesiące"/>
                <ComboBoxItem Content="Ostatnie 6 miesięcy"/>
                <ComboBoxItem Content="Ostatni rok"/>
            </ComboBox>
            <TextBlock Grid.Column="3" Text="Obecny nr faktury:" VerticalAlignment="Center" Margin="0,0,8,0"
                       Style="{StaticResource LabelText}"/>
            <TextBlock Grid.Column="4" x:Name="txtObecnyNr" Text="—"
                       FontWeight="SemiBold" VerticalAlignment="Center"/>
        </Grid>

        <!-- DataGrid with invoices -->
        <Border Grid.Row="2" Background="White" CornerRadius="6"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="dgInvoices"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="32"
                      MouseDoubleClick="DgInvoices_MouseDoubleClick"
                      Background="Transparent" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Numer" Binding="{Binding Numer}" Width="160"/>
                    <DataGridTextColumn Header="Data" Binding="{Binding DataStr}" Width="100"/>
                    <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaStr}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="0,0,8,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Wartość netto" Binding="{Binding WartoscStr}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="0,0,8,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Status" Width="*" MinWidth="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusIcon}" Foreground="{Binding StatusBrush}"
                                               FontWeight="Bold" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"
                                               FontWeight="Medium"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="txtInfo"
                       Text="Wybierz fakturę z listy lub wpisz numer ręcznie"
                       Foreground="#64748B" VerticalAlignment="Center"/>
            <Button Grid.Column="1" x:Name="btnWybierz" Content="  Wybierz fakturę  "
                    Padding="14,7" MinHeight="34" Margin="0,0,8,0"
                    Background="#2563EB" Foreground="White" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnWybierz_Click"/>
            <Button Grid.Column="2" x:Name="btnAnuluj" Content="  Anuluj  "
                    Padding="14,7" MinHeight="34"
                    Background="White" Foreground="#475569"
                    BorderBrush="#CBD5E1" BorderThickness="1" Cursor="Hand"
                    Click="BtnAnuluj_Click"/>
        </Grid>
    </Grid>
</Window>
