<Window x:Class="Kalendarz1.WPF.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hasło"
        Width="620" Height="560"
        MinWidth="540" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="ToolWindow"
        Background="#F8FAFC"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="28,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#64748B"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="BigPasswordBox" TargetType="PasswordBox">
            <Setter Property="Padding" Value="14,14"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="32,28,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tytuł -->
        <TextBlock x:Name="TitleText"
                   Grid.Row="0"
                   Text="Wpisz hasło"
                   FontSize="26" FontWeight="Bold"
                   Foreground="#1E293B"/>

        <!-- Opis (dynamiczny: ustaw nowe / wpisz istniejące) -->
        <TextBlock x:Name="DescriptionText"
                   Grid.Row="1"
                   Margin="0,12,0,24"
                   Foreground="#64748B"
                   FontSize="14"
                   LineHeight="22"
                   TextWrapping="Wrap"
                   Text="Podaj swoje hasło."/>

        <!-- Pole hasła -->
        <TextBlock Grid.Row="2" Text="Hasło" Style="{StaticResource FieldLabel}"/>
        <PasswordBox x:Name="PwdBox"
                     Grid.Row="3"
                     Style="{StaticResource BigPasswordBox}"
                     KeyDown="Field_KeyDown"/>

        <!-- Pole "powtórz hasło" — tylko w trybie SET -->
        <StackPanel x:Name="ConfirmPanel"
                    Grid.Row="4"
                    Margin="0,18,0,0"
                    Visibility="Collapsed">
            <TextBlock Text="Powtórz hasło" Style="{StaticResource FieldLabel}"/>
            <PasswordBox x:Name="PwdConfirmBox"
                         Style="{StaticResource BigPasswordBox}"
                         KeyDown="Field_KeyDown"/>
            <TextBlock x:Name="StrengthHint"
                       Margin="0,10,0,0"
                       FontSize="12"
                       Foreground="#94A3B8"
                       Text="💡 Wskazówka: silne hasło ma minimum 8 znaków + cyfrę + literę"/>
        </StackPanel>

        <!-- Status / błąd -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="5"
                   Margin="0,18,0,0"
                   Foreground="#DC2626"
                   FontSize="13"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"/>

        <!-- Przyciski -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Anuluj"
                    Style="{StaticResource BtnSecondary}"
                    Width="130"
                    Margin="0,0,12,0"
                    Click="Cancel_Click"/>
            <Button x:Name="OkButton"
                    Content="OK"
                    Style="{StaticResource BtnPrimary}"
                    Width="160"
                    Click="Ok_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
