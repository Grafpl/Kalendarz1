<Window x:Class="Kalendarz1.WPF.SprawozdaniaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kalendarz1.WPF"
        Title="Sprawozdania — Skup drobiu rzeźnego"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#F2F4F7"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        FontFamily="Segoe UI"
        AllowsTransparency="False">

    <Window.Resources>
        <!-- ============ PALETTE ============ -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2E7D32"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1B5E20"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#256528"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5B6772"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8B95A0"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D7DBE0"/>
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="#EAEDF0"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F7F9FB"/>

        <!-- Karty -->
        <SolidColorBrush x:Key="HandelBg" Color="#E8F5E9"/>
        <SolidColorBrush x:Key="HandelBorder" Color="#2E7D32"/>
        <SolidColorBrush x:Key="HandelText" Color="#1B5E20"/>
        <SolidColorBrush x:Key="LibraBg" Color="#E3F2FD"/>
        <SolidColorBrush x:Key="LibraBorder" Color="#1565C0"/>
        <SolidColorBrush x:Key="LibraText" Color="#0D47A1"/>
        <SolidColorBrush x:Key="SpecBg" Color="#F3E5F5"/>
        <SolidColorBrush x:Key="SpecBorder" Color="#7B1FA2"/>
        <SolidColorBrush x:Key="SpecText" Color="#4A148C"/>

        <!-- Status delty -->
        <SolidColorBrush x:Key="DeltaOk" Color="#2E7D32"/>
        <SolidColorBrush x:Key="DeltaOkBg" Color="#E8F5E9"/>
        <SolidColorBrush x:Key="DeltaWarn" Color="#B5680E"/>
        <SolidColorBrush x:Key="DeltaWarnBg" Color="#FFF4E0"/>
        <SolidColorBrush x:Key="DeltaBad" Color="#B72A2A"/>
        <SolidColorBrush x:Key="DeltaBadBg" Color="#FDEAEA"/>

        <!-- Chipy presetów -->
        <SolidColorBrush x:Key="ChipBg" Color="#EDF0F3"/>
        <SolidColorBrush x:Key="ChipFg" Color="#3B4654"/>
        <SolidColorBrush x:Key="ChipActiveBg" Color="#2E7D32"/>
        <SolidColorBrush x:Key="ChipActiveFg" Color="#FFFFFF"/>

        <!-- ============ CONVERTERS ============ -->
        <local:StatusToBrushConv x:Key="StatusBrush"/>

        <!-- ============ TITLE BAR BUTTONS ============ -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#27602A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============ PRIMARY/SECONDARY BUTTON ============ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F2F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ CHIP TOGGLE BUTTON ============ -->
        <Style x:Key="PresetChip" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource ChipBg}"/>
            <Setter Property="Foreground" Value="{StaticResource ChipFg}"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="16" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ChipActiveBg}"/>
                                <Setter Property="Foreground" Value="{StaticResource ChipActiveFg}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ DATAGRID STYLES ============ -->
        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7F9FB"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,11"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="SeparatorVisibility" Value="Collapsed"/>
        </Style>

        <Style x:Key="DgHeaderRight" TargetType="DataGridColumnHeader" BasedOn="{StaticResource DgHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="Padding" Value="10,11,14,11"/>
        </Style>

        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="rowBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="accent" Grid.Column="0"
                                        Background="{Binding StatusKey, Converter={StaticResource StatusBrush}}"/>
                                <DataGridCellsPresenter Grid.Column="1"
                                                        ItemsPanel="{TemplateBinding ItemsPanel}"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="rowBorder" Property="Background" Value="#F0F5FA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="rowBorder" Property="Background" Value="#E1ECF6"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsTotal}" Value="True">
                                <Setter TargetName="rowBorder" Property="Background" Value="#E8F2EC"/>
                                <Setter TargetName="rowBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="rowBorder" Property="BorderThickness" Value="0,2,0,0"/>
                                <Setter TargetName="accent" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTotal}" Value="True">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Height" Value="46"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NumCell" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="34"/>
        </Style>

        <!-- Card hover lift — subtle "raise" on hover -->
        <Style x:Key="CardLift" TargetType="Border">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                 To="-2" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                 To="0" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ZSRIR send button — prominent style z glow effect -->
        <Style x:Key="ZsrirSendButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#2E7D32" Opacity="0.35" BlurRadius="14" ShadowDepth="2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                                <Setter TargetName="bd" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{x:Static local:SprawozdaniaWindow.CloseCmd}"/>
        <KeyBinding Key="F5" Command="{x:Static local:SprawozdaniaWindow.RefreshCmd}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{x:Static local:SprawozdaniaWindow.ExportCsvCmd}"/>
        <KeyBinding Key="Left" Modifiers="Ctrl" Command="{x:Static local:SprawozdaniaWindow.PrevWeekCmd}"/>
        <KeyBinding Key="Right" Modifiers="Ctrl" Command="{x:Static local:SprawozdaniaWindow.NextWeekCmd}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <!-- Title bar -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- ZSRIR strip (NEW) -->
            <RowDefinition Height="Auto"/>
            <!-- Cards -->
            <RowDefinition Height="*"/>
            <!-- DataGrid + textboxes -->
        </Grid.RowDefinitions>

        <!-- ============ TITLE BAR ============ -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="📊" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Sprawozdania" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" · Skup drobiu rzeźnego" FontSize="13" Foreground="#B7D5BB" VerticalAlignment="Center"/>
                    <Border Background="#27602A" CornerRadius="3" Padding="8,3" Margin="20,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#B7D5BB"/>
                            <TextBlock x:Name="lblPeriodTop" Text="—" FontSize="11.5" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource TitleBarButton}" Click="BtnMinimize_Click" ToolTip="Minimalizuj">
                        <Path Width="10" Height="1" Stretch="Fill" Fill="White" Data="M 0,0 L 10,0"/>
                    </Button>
                    <Button Style="{StaticResource CloseButton}" Click="BtnClose_Click" ToolTip="Zamknij (Esc)">
                        <Path Width="10" Height="10" Stretch="Uniform" Stroke="White" StrokeThickness="1.4"
                              Data="M 0,0 L 10,10 M 10,0 L 0,10"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ TOOLBAR ============ -->
        <Border Grid.Row="1" Background="White" Padding="20,10" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Row 0: Date pickers + Mini-piguły kafelków + Pobierz -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="OD" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <DatePicker x:Name="dpFrom" Width="130" SelectedDateFormat="Short"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="DO" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <DatePicker x:Name="dpTo" Width="130" SelectedDateFormat="Short"/>
                    </StackPanel>
                </StackPanel>

                <!-- Mini-piguły z podsumowaniem (HANDEL · LIBRA · SPEC · Δ) — inline obok datapickerów -->
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="14,0,14,0">
                    <Border x:Name="pillHandel" CornerRadius="13" Padding="8,4" Margin="0,0,6,0"
                            Background="{StaticResource HandelBg}" BorderBrush="{StaticResource HandelBorder}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource HandelBorder}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="HANDEL" FontSize="9.5" FontWeight="Bold" Foreground="{StaticResource HandelText}" VerticalAlignment="Center"/>
                            <TextBlock Text=" · " FontSize="10" Opacity="0.5" Foreground="{StaticResource HandelText}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="cardHandelKg" Text="—" FontSize="12" FontWeight="Bold" Foreground="{StaticResource HandelText}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="cardHandelW" Text="—" FontSize="10.5" Foreground="{StaticResource HandelText}" Opacity="0.75" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="pillLibra" CornerRadius="13" Padding="8,4" Margin="0,0,6,0"
                            Background="{StaticResource LibraBg}" BorderBrush="{StaticResource LibraBorder}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource LibraBorder}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="LIBRA" FontSize="9.5" FontWeight="Bold" Foreground="{StaticResource LibraText}" VerticalAlignment="Center"/>
                            <TextBlock Text=" · " FontSize="10" Opacity="0.5" Foreground="{StaticResource LibraText}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="cardLibraKg" Text="—" FontSize="12" FontWeight="Bold" Foreground="{StaticResource LibraText}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="cardLibraInfo" Text="" FontSize="10.5" Foreground="{StaticResource LibraText}" Opacity="0.75" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="pillSpec" CornerRadius="13" Padding="8,4" Margin="0,0,6,0"
                            Background="{StaticResource SpecBg}" BorderBrush="{StaticResource SpecBorder}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource SpecBorder}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="SPEC" FontSize="9.5" FontWeight="Bold" Foreground="{StaticResource SpecText}" VerticalAlignment="Center"/>
                            <TextBlock Text=" · " FontSize="10" Opacity="0.5" Foreground="{StaticResource SpecText}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="cardSpecKg" Text="—" FontSize="12" FontWeight="Bold" Foreground="{StaticResource SpecText}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="cardSpecC" Text="—" FontSize="10.5" Foreground="{StaticResource SpecText}" Opacity="0.75" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="cardDeltaBorder" CornerRadius="13" Padding="8,4"
                            Background="{StaticResource DeltaOkBg}" BorderBrush="{StaticResource DeltaOk}" BorderThickness="1.5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Δ" FontSize="11.5" FontWeight="Bold" Foreground="{StaticResource DeltaOk}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="cardDeltaKg" Text="—" FontSize="12" FontWeight="Bold" Foreground="{StaticResource DeltaOk}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="cardDeltaProc" Text="—" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource DeltaOk}" Opacity="0.85" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button x:Name="btnRefresh" Style="{StaticResource SecondaryButton}" Click="BtnRefresh_Click"
                            ToolTip="Odśwież (F5)" Margin="0,0,6,0">
                        <TextBlock Text="🔄  Odśwież"/>
                    </Button>
                    <Button x:Name="btnExport" Style="{StaticResource SecondaryButton}" Click="BtnExport_Click"
                            ToolTip="Eksport CSV (Ctrl+E)" Margin="0,0,6,0">
                        <TextBlock Text="📤  Eksport CSV"/>
                    </Button>
                    <Button x:Name="btnLoad" Style="{StaticResource PrimaryButton}" Click="BtnLoad_Click"
                            ToolTip="Pobierz dane">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="Pobierz dane"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Row 1: Nawigacja ±1 tydz + Preset chips -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,14,0,0">
                    <Button x:Name="btnPrevWeek" Style="{StaticResource SecondaryButton}" Click="BtnShiftWeek_Click" Tag="Prev"
                            Padding="10,6" Margin="0,0,4,0"
                            ToolTip="Przesuń zakres o tydzień wstecz (Ctrl+←)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="«" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="tydzień" FontSize="11.5" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnNextWeek" Style="{StaticResource SecondaryButton}" Click="BtnShiftWeek_Click" Tag="Next"
                            Padding="10,6" Margin="0,0,16,0"
                            ToolTip="Przesuń zakres o tydzień w przód (Ctrl+→)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="tydzień" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="»" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Height="22" Background="{StaticResource BorderBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>

                    <TextBlock Text="📅 Szybkie zakresy:" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ToggleButton x:Name="chipPoprzTydzien" Style="{StaticResource PresetChip}" Content="Poprzedni tydzień" Click="Preset_Click" Tag="PrevWeek"/>
                    <ToggleButton x:Name="chipTenTydzien" Style="{StaticResource PresetChip}" Content="Ten tydzień" Click="Preset_Click" Tag="ThisWeek"/>
                    <ToggleButton x:Name="chipPoprzMiesiac" Style="{StaticResource PresetChip}" Content="Poprzedni miesiąc" Click="Preset_Click" Tag="PrevMonth"/>
                    <ToggleButton x:Name="chipTenMiesiac" Style="{StaticResource PresetChip}" Content="Ten miesiąc" Click="Preset_Click" Tag="ThisMonth"/>
                    <ToggleButton x:Name="chip30Dni" Style="{StaticResource PresetChip}" Content="Ostatnie 30 dni" Click="Preset_Click" Tag="Last30"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ ZSRIR STRIP — integracja z MRiRW ============ -->
        <Border Grid.Row="2" Background="White" Padding="12,6" Margin="20,6,20,0"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="6">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.04" BlurRadius="8" ShadowDepth="1" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Lewa: logo ZSRIR -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            ToolTip="ZSRIR · MRiRW — tygodniowy raport skupu, wysyłka przez API ministerstwa">
                    <Border Width="30" Height="30" CornerRadius="15" Background="#1B5E20" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="📡" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="ZSRIR · MRiRW" FontSize="12.5" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Środek: status -->
                <Border Grid.Column="1" x:Name="zsrirStatusBorder" CornerRadius="4" Padding="10,5" Margin="16,0,16,0"
                        Background="#FFF4E0" BorderBrush="#E89614" BorderThickness="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" x:Name="zsrirStatusDot" Fill="#E89614" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="zsrirStatusTitle" Text="Nieskonfigurowane"
                                   FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="zsrirStatusHint" Text="Skonfiguruj login API"
                                   FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Prawa: akcje -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnZsrirHistory" Style="{StaticResource SecondaryButton}" Click="BtnZsrirHistory_Click"
                            Padding="8,5" Margin="0,0,4,0" ToolTip="Historia wysyłek do ZSRIR">
                        <TextBlock Text="📜  Historia"/>
                    </Button>
                    <Button x:Name="btnZsrirSettings" Style="{StaticResource SecondaryButton}" Click="BtnZsrirSettings_Click"
                            Padding="8,5" Margin="0,0,4,0" ToolTip="Konfiguracja API (login, hasło)">
                        <TextBlock Text="⚙  Konfiguracja"/>
                    </Button>
                    <Button x:Name="btnZsrirTest" Style="{StaticResource SecondaryButton}" Click="BtnZsrirTest_Click"
                            Padding="8,5" Margin="0,0,4,0" ToolTip="Test logowania do API">
                        <TextBlock Text="🔌  Test"/>
                    </Button>
                    <Button x:Name="btnZsrirSend" Style="{StaticResource ZsrirSendButton}" Click="BtnZsrirSend_Click"
                            ToolTip="Wyślij raport za wybrany okres do ZSRIR (do MRiRW)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📤" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Wyślij do MRiRW"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sekcja CARDS usunięta — kafelki są teraz mini-pigułami w toolbarze obok datapickerów -->
        <Grid Grid.Row="3" Height="0"/>

        <!-- ============ BOTTOM AREA: DataGrid + TextBoxes + Footer ============ -->
        <Grid Grid.Row="4" Margin="20,8,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <!-- DataGrid -->
                <RowDefinition Height="Auto"/>
                <!-- TextBoxes (collapsed) -->
                <RowDefinition Height="Auto"/>
                <!-- Footer status bar -->
            </Grid.RowDefinitions>

            <!-- DataGrid per dzień -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="6">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.04" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- DataGrid header bar -->
                    <Border Grid.Row="0" Background="#FAFBFC" Padding="18,10" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1" CornerRadius="6,6,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="📊 Porównanie per dzień" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text=" · 3 źródła danych z kolorowaniem delty" FontSize="11.5"
                                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                            <Button x:Name="btnToggleText" Style="{StaticResource SecondaryButton}" Click="BtnToggleText_Click"
                                    HorizontalAlignment="Right" Padding="12,5"
                                    ToolTip="Pokaż/ukryj sekcję tekstów do kopiowania">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="lblToggleText" Text="📝  Ukryj teksty"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="dgPerDzien" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserReorderColumns="False" CanUserResizeRows="False"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column" RowHeaderWidth="0"
                              Background="White" BorderThickness="0"
                              CellStyle="{StaticResource DgCell}"
                              ColumnHeaderStyle="{StaticResource DgHeader}"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              IsReadOnly="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              MouseDoubleClick="DgPerDzien_MouseDoubleClick">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource DgRow}">
                                <Setter Property="ToolTip" Value="{Binding TooltipText}"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="🔍  Pokaż szczegóły dnia" Click="MenuShowDetails_Click"/>
                                <Separator/>
                                <MenuItem Header="📋  Kopiuj wiersz" Click="MenuCopyRow_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="DZIEŃ" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DataText}" FontSize="13" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                            <Border Background="#EEF2F6" CornerRadius="2" Padding="4,1"
                                                    Visibility="{Binding DowVis}">
                                                <TextBlock Text="{Binding Dow}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- HANDEL group -->
                            <DataGridTemplateColumn Header="HANDEL kg" Width="110" HeaderStyle="{StaticResource DgHeaderRight}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HKg, StringFormat={}{0:N0}}" Style="{StaticResource NumCell}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="HANDEL wartość" Width="130" HeaderStyle="{StaticResource DgHeaderRight}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HW, StringFormat={}{0:N2} zł}" Style="{StaticResource NumCell}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="HANDEL zł/kg" Width="90" HeaderStyle="{StaticResource DgHeaderRight}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HC, StringFormat={}{0:N2}}" Style="{StaticResource NumCell}" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Separator -->
                            <DataGridTemplateColumn Header="LIBRA kg" Width="110" HeaderStyle="{StaticResource DgHeaderRight}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LKg, StringFormat={}{0:N0}}" Style="{StaticResource NumCell}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- SPEC group -->
                            <DataGridTemplateColumn Header="SPEC kg" Width="110" HeaderStyle="{StaticResource DgHeaderRight}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SKg, StringFormat={}{0:N0}}" Style="{StaticResource NumCell}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="SPEC wartość" Width="130" HeaderStyle="{StaticResource DgHeaderRight}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SW, StringFormat={}{0:N2} zł}" Style="{StaticResource NumCell}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="SPEC zł/kg" Width="90" HeaderStyle="{StaticResource DgHeaderRight}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SC, StringFormat={}{0:N2}}" Style="{StaticResource NumCell}" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Delta — pill with color -->
                            <DataGridTemplateColumn Header="Δ kg" Width="100" HeaderStyle="{StaticResource DgHeaderRight}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="8,3" HorizontalAlignment="Right"
                                                Background="{Binding StatusKey, Converter={StaticResource StatusBrush}, ConverterParameter=Tint}">
                                            <TextBlock Text="{Binding DKgText}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{Binding StatusKey, Converter={StaticResource StatusBrush}, ConverterParameter=Dark}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Δ %" Width="90" HeaderStyle="{StaticResource DgHeaderRight}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DProcText}" Style="{StaticResource NumCell}" FontWeight="SemiBold"
                                                   Foreground="{Binding StatusKey, Converter={StaticResource StatusBrush}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state overlay -->
                    <Border x:Name="emptyState" Grid.Row="1" Background="White" Visibility="Collapsed" IsHitTestVisible="False">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="380">
                            <Border CornerRadius="40" Width="72" Height="72" Background="#F0F3F6" HorizontalAlignment="Center">
                                <TextBlock Text="📊" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Brak danych dla wybranego okresu"
                                       FontSize="16" FontWeight="SemiBold" Margin="0,16,0,6"
                                       HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Zmień zakres dat lub kliknij Pobierz dane"
                                       FontSize="12" HorizontalAlignment="Center" TextAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Text boxes — widoczne od razu (user może ukryć przyciskiem) -->
            <Border x:Name="textBoxesPanel" Grid.Row="1" Background="White" Margin="0,12,0,0"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="6"
                    Visibility="Visible" MaxHeight="300">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Wewnętrzny -->
                    <Border Grid.Column="0" Padding="14,12" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋 Kontrola wewnętrzna" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="lblCopyHintWew" Text="" FontSize="11"
                                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <Button x:Name="btnCopyWew" Style="{StaticResource PrimaryButton}" Click="BtnCopyWewnetrzny_Click"
                                        HorizontalAlignment="Right" Padding="11,5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋" Margin="0,0,5,0"/>
                                        <TextBlock Text="Kopiuj"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <TextBox x:Name="txtWewnetrzny" Grid.Row="1"
                                     FontFamily="Consolas" FontSize="11.5"
                                     AcceptsReturn="True" TextWrapping="NoWrap" IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                     Padding="10,8" Background="#FAFBFC"/>
                        </Grid>
                    </Border>

                    <!-- Oficjalny -->
                    <Border Grid.Column="1" Padding="14,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📨 Notka do ministerstwa" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="lblCopyHintOf" Text="" FontSize="11"
                                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <Button x:Name="btnCopyOf" Style="{StaticResource PrimaryButton}" Click="BtnCopyOficjalny_Click"
                                        HorizontalAlignment="Right" Padding="11,5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋" Margin="0,0,5,0"/>
                                        <TextBlock Text="Kopiuj"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <TextBox x:Name="txtOficjalny" Grid.Row="1"
                                     FontFamily="Segoe UI" FontSize="12.5"
                                     AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                     Padding="10,8" Background="#FAFBFC"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Footer status bar -->
            <Border Grid.Row="2" Padding="14,8" Margin="0,12,0,16" Background="White"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource DeltaOk}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="lblFooterStatus" Text="Gotowy" FontSize="11.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="  ·  " FontSize="11.5" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblFooterCount" Text="" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🟢 .112 HANDEL" FontSize="10.5" Foreground="{StaticResource HandelText}" Margin="0,0,12,0"/>
                        <TextBlock Text="🔵 .109 LIBRANET" FontSize="10.5" Foreground="{StaticResource LibraText}" Margin="0,0,12,0"/>
                        <TextBlock Text="🟣 PDF Specyfikacje" FontSize="10.5" Foreground="{StaticResource SpecText}" Margin="0,0,16,0"/>
                        <TextBlock Text="⏱" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock x:Name="lblFooterTime" Text="—" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading overlay -->
        <Border x:Name="loadingOverlay" Grid.Row="0" Grid.RowSpan="5" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="6"/>
                <TextBlock Text="Pobieranie danych..." Margin="0,10,0,0" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                <TextBlock Text="HANDEL (.112) + LibraNet (.109) + Specyfikacje (FarmerCalc)"
                           Margin="0,4,0,0" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
