<Window x:Class="Kalendarz1.WPF.PanelFakturWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:Kalendarz1.WPF"
        mc:Ignorable="d"
        Title="Panel Faktur — Zamówienia Klientów"
        MinHeight="500" MinWidth="700"
        WindowState="Maximized"
        Background="{DynamicResource Brush.Bg}"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        SizeChanged="Window_SizeChanged">

    <Window.Resources>
        <ResourceDictionary>

            <!-- ═══════════════════════════════════════════════════════
                 BRUSHES — clean professional palette (Slate / Blue 600)
                 ═══════════════════════════════════════════════════════ -->
            <SolidColorBrush x:Key="Brush.Bg"             Color="#F8FAFC"/>
            <SolidColorBrush x:Key="Brush.Surface"        Color="#FFFFFF"/>
            <SolidColorBrush x:Key="Brush.SurfaceAlt"     Color="#F8FAFC"/>
            <SolidColorBrush x:Key="Brush.Border"         Color="#E5E7EB"/>
            <SolidColorBrush x:Key="Brush.BorderStrong"   Color="#D1D5DB"/>
            <SolidColorBrush x:Key="Brush.Text"           Color="#0F172A"/>
            <SolidColorBrush x:Key="Brush.TextSecondary"  Color="#475569"/>
            <SolidColorBrush x:Key="Brush.TextMuted"      Color="#94A3B8"/>

            <SolidColorBrush x:Key="Brush.Primary"        Color="#2563EB"/>
            <SolidColorBrush x:Key="Brush.PrimaryHover"   Color="#1D4ED8"/>
            <SolidColorBrush x:Key="Brush.PrimaryDark"    Color="#1E40AF"/>
            <SolidColorBrush x:Key="Brush.PrimarySoft"    Color="#EFF6FF"/>

            <SolidColorBrush x:Key="Brush.Success"        Color="#059669"/>
            <SolidColorBrush x:Key="Brush.SuccessSoft"    Color="#ECFDF5"/>
            <SolidColorBrush x:Key="Brush.SuccessText"    Color="#065F46"/>

            <SolidColorBrush x:Key="Brush.Warning"        Color="#D97706"/>
            <SolidColorBrush x:Key="Brush.WarningSoft"    Color="#FFFBEB"/>
            <SolidColorBrush x:Key="Brush.WarningText"    Color="#92400E"/>

            <SolidColorBrush x:Key="Brush.Danger"         Color="#DC2626"/>
            <SolidColorBrush x:Key="Brush.DangerSoft"     Color="#FEF2F2"/>
            <SolidColorBrush x:Key="Brush.DangerText"     Color="#991B1B"/>

            <SolidColorBrush x:Key="Brush.Yellow"         Color="#FEF9C3"/>
            <SolidColorBrush x:Key="Brush.YellowText"     Color="#854D0E"/>

            <!-- Toolbar: białe tło — Light Pro style (Microsoft 365 / Notion) -->
            <SolidColorBrush x:Key="Brush.PrimaryGrad" Color="#FFFFFF"/>

            <!-- Header DataGrid: jasna szara, czytelne -->
            <SolidColorBrush x:Key="Brush.HeaderGrad" Color="#F8FAFC"/>

            <!-- ═══════════════════════════════════════════════════════
                 SIZES — STATIC (DPI-friendly, używane przez StaticResource)
                 ═══════════════════════════════════════════════════════ -->
            <sys:Double x:Key="Size.Btn.Sm">30</sys:Double>
            <sys:Double x:Key="Size.Btn.Md">36</sys:Double>
            <sys:Double x:Key="Size.Btn.Lg">42</sys:Double>
            <sys:Double x:Key="Size.Icon.Sm">14</sys:Double>
            <sys:Double x:Key="Size.Icon.Md">18</sys:Double>
            <sys:Double x:Key="Size.Icon.Lg">24</sys:Double>
            <sys:Double x:Key="Size.Avatar.Sm">22</sys:Double>
            <sys:Double x:Key="Size.Avatar.Md">28</sys:Double>
            <sys:Double x:Key="Size.Strip">4</sys:Double>
            <sys:Double x:Key="Size.Card.Radius">8</sys:Double>
            <sys:Double x:Key="Size.Pill.Radius">4</sys:Double>
            <CornerRadius x:Key="Radius.Card">8</CornerRadius>
            <CornerRadius x:Key="Radius.CardTop">8,8,0,0</CornerRadius>
            <CornerRadius x:Key="Radius.CardBottom">0,0,8,8</CornerRadius>
            <CornerRadius x:Key="Radius.Pill">4</CornerRadius>

            <!-- Min font 11 — przy DPI 100% jeszcze czytelne, przy 150%+ luksus -->
            <sys:Double x:Key="Font.Xs">11</sys:Double>
            <sys:Double x:Key="Font.Sm">12</sys:Double>
            <sys:Double x:Key="Font.Md">13</sys:Double>
            <sys:Double x:Key="Font.Lg">15</sys:Double>
            <sys:Double x:Key="Font.Xl">17</sys:Double>
            <sys:Double x:Key="Font.Xxl">22</sys:Double>

            <Thickness x:Key="Pad.Card">14</Thickness>
            <Thickness x:Key="Pad.Btn">14,8</Thickness>
            <Thickness x:Key="Pad.Pill">10,4</Thickness>

            <!-- ═══════════════════════════════════════════════════════
                 SIZES — DYNAMIC (zmieniane przez density toggle z code-behind)
                 ═══════════════════════════════════════════════════════ -->
            <sys:Double x:Key="Density.Row.Height">40</sys:Double>
            <sys:Double x:Key="Density.Row.HeightDetails">32</sys:Double>
            <sys:Double x:Key="Density.Row.Font">12</sys:Double>
            <Thickness  x:Key="Density.Cell.Pad">10,6</Thickness>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <local:StatusToIconConverter  x:Key="StatusToIcon"/>
            <local:StatusToColorConverter x:Key="StatusToColor"/>

            <!-- Bardzo subtelne cienie — czysty, płaski look -->
            <DropShadowEffect x:Key="Fx.Card"   BlurRadius="6" ShadowDepth="1" Opacity="0.05" Direction="270"/>
            <DropShadowEffect x:Key="Fx.Subtle" BlurRadius="3" ShadowDepth="0" Opacity="0.04" Direction="270"/>

            <!-- ═══════════════════════════════════════════════════════
                 STYLES — przyciski
                 ═══════════════════════════════════════════════════════ -->

            <!-- Bazowy przycisk z zaokrąglonym tłem -->
            <Style x:Key="BtnBase" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource Brush.Primary}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize"   Value="{StaticResource Font.Md}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding"    Value="{StaticResource Pad.Btn}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor"     Value="Hand"/>
                <Setter Property="MinHeight"  Value="{StaticResource Size.Btn.Md}"/>
                <Setter Property="Effect"     Value="{StaticResource Fx.Subtle}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextBlock.FontSize="{TemplateBinding FontSize}"
                                                  TextBlock.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.PrimaryHover}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.BorderStrong}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}"/>

            <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
                <Setter Property="Background" Value="{StaticResource Brush.Success}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#15803D"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="BtnWarning" TargetType="Button" BasedOn="{StaticResource BtnBase}">
                <Setter Property="Background" Value="{StaticResource Brush.Warning}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#C2410C"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Przycisk ikon w toolbarze (Light theme) -->
            <Style x:Key="BtnIcon" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                <Setter Property="MinWidth"   Value="{StaticResource Size.Btn.Md}"/>
                <Setter Property="MinHeight"  Value="{StaticResource Size.Btn.Md}"/>
                <Setter Property="Padding"    Value="10,4"/>
                <Setter Property="FontSize"   Value="{StaticResource Font.Md}"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor"     Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextBlock.FontSize="{TemplateBinding FontSize}"
                                                  TextBlock.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.SurfaceAlt}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Day button -->
            <Style x:Key="BtnDay" TargetType="Button">
                <Setter Property="MinWidth"  Value="48"/>
                <Setter Property="MinHeight" Value="{StaticResource Size.Btn.Md}"/>
                <Setter Property="Margin"    Value="2,0"/>
                <Setter Property="Padding"   Value="6,3"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="{StaticResource Font.Xs}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.PrimarySoft}"/>
                                    <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Brush.Primary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- DatePicker button (Light) — duży tekst daty + caret -->
            <Style x:Key="BtnDateHero" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="14,8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="MinHeight" Value="{StaticResource Size.Btn.Md}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}"
                                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.SurfaceAlt}"/>
                                    <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 3-segment toggle (RadioButton group) -->
            <Style x:Key="SegmentBtn" TargetType="RadioButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
                <Setter Property="MinWidth" Value="34"/>
                <Setter Property="MinHeight" Value="{StaticResource Size.Btn.Md}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="{StaticResource Font.Md}"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="b" Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="1,1,0,1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.SurfaceAlt}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.Primary}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- Pierwszy segment (lewa zaokr.), ostatni (prawa zaokr. + prawy border) -->
            <Style x:Key="SegmentBtnFirst" TargetType="RadioButton" BasedOn="{StaticResource SegmentBtn}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="b" Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="1,1,0,1"
                                    CornerRadius="6,0,0,6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.SurfaceAlt}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.Primary}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="SegmentBtnLast" TargetType="RadioButton" BasedOn="{StaticResource SegmentBtn}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="b" Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                    CornerRadius="0,6,6,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.SurfaceAlt}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.Primary}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════════
                 STYLES — toolbar (overflow-aware)
                 ═══════════════════════════════════════════════════════ -->
            <Style TargetType="ToolBarTray">
                <Setter Property="Background" Value="{StaticResource Brush.PrimaryGrad}"/>
                <Setter Property="IsLocked" Value="True"/>
            </Style>

            <Style TargetType="ToolBar">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="OverflowMode" Value="AsNeeded"/>
                <Setter Property="Padding" Value="6,4"/>
            </Style>

            <!-- ═══════════════════════════════════════════════════════
                 STYLES — TextBox (search)
                 ═══════════════════════════════════════════════════════ -->
            <Style x:Key="SearchBox" TargetType="TextBox">
                <Setter Property="MinHeight" Value="{StaticResource Size.Btn.Md}"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="FontSize" Value="{StaticResource Font.Md}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border CornerRadius="6" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════════
                 STYLES — DataGrid główny
                 ═══════════════════════════════════════════════════════ -->
            <Style x:Key="ProDataGrid" TargetType="DataGrid">
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="SelectionUnit" Value="FullRow"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#F1F5F9"/>
                <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="{DynamicResource Density.Row.Font}"/>
                <Setter Property="RowBackground" Value="White"/>
                <Setter Property="AlternatingRowBackground" Value="{StaticResource Brush.SurfaceAlt}"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="CanUserResizeRows" Value="False"/>
                <Setter Property="CanUserResizeColumns" Value="True"/>
                <Setter Property="CanUserReorderColumns" Value="False"/>
                <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="EnableRowVirtualization" Value="True"/>
                <Setter Property="EnableColumnVirtualization" Value="True"/>
                <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
                <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            </Style>

            <Style x:Key="ProColHeader" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource Brush.HeaderGrad}"/>
                <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="FontSize"   Value="{StaticResource Font.Xs}"/>
                <Setter Property="MinHeight"  Value="34"/>
                <Setter Property="Padding"    Value="10,6"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="ProCell" TargetType="DataGridCell">
                <Setter Property="Padding" Value="{DynamicResource Density.Cell.Pad}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.PrimarySoft}"/>
                        <Setter Property="Foreground" Value="{StaticResource Brush.PrimaryDark}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Wiersz z left-strip 4px (kolor priorytetu) -->
            <Style x:Key="ProRow" TargetType="DataGridRow">
                <Setter Property="MinHeight" Value="{DynamicResource Density.Row.Height}"/>
                <Setter Property="FontSize"  Value="{DynamicResource Density.Row.Font}"/>
                <Setter Property="Cursor"    Value="Hand"/>
                <Setter Property="Background" Value="{Binding RowBackground}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridRow">
                            <Border BorderThickness="0,0,0,1" BorderBrush="#F1F5F9" SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Lewy pasek priorytetu -->
                                    <Rectangle Grid.Column="0" Fill="{Binding PriorityStripColor}"/>
                                    <SelectiveScrollingGrid Grid.Column="1" Background="{TemplateBinding Background}">
                                        <SelectiveScrollingGrid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </SelectiveScrollingGrid.ColumnDefinitions>
                                        <SelectiveScrollingGrid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </SelectiveScrollingGrid.RowDefinitions>
                                        <DataGridCellsPresenter Grid.Column="1"
                                                                ItemsPanel="{TemplateBinding ItemsPanel}"
                                                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        <DataGridDetailsPresenter Grid.Column="1" Grid.Row="1"
                                                                  Visibility="{TemplateBinding DetailsVisibility}"
                                                                  SelectiveScrollingGrid.SelectiveScrollingOrientation="Vertical"/>
                                    </SelectiveScrollingGrid>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#EFF6FF"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.PrimarySoft}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Wiersze szczegółów (prawy panel) — kompaktowe, niezależne od density głównej tabeli -->
            <Style x:Key="CompactRow" TargetType="DataGridRow">
                <Setter Property="MinHeight" Value="32"/>
                <Setter Property="FontSize"  Value="{StaticResource Font.Sm}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#EFF6FF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Komórki w prawym panelu -->
            <Style x:Key="DetailCell" TargetType="DataGridCell">
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.PrimarySoft}"/>
                        <Setter Property="Foreground" Value="{StaticResource Brush.PrimaryDark}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Header kolumn w prawym panelu — większy padding -->
            <Style x:Key="DetailColHeader" TargetType="DataGridColumnHeader" BasedOn="{StaticResource ProColHeader}">
                <Setter Property="MinHeight" Value="38"/>
                <Setter Property="Padding"   Value="12,8"/>
                <Setter Property="FontSize"  Value="{StaticResource Font.Xs}"/>
            </Style>

            <!-- ═══════════════════════════════════════════════════════
                 STYLES — TabControl prawego panelu
                 ═══════════════════════════════════════════════════════ -->
            <Style x:Key="DetailTabs" TargetType="TabControl">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
            </Style>

            <Style x:Key="DetailTabItem" TargetType="TabItem">
                <Setter Property="FontSize" Value="{StaticResource Font.Sm}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
                <Setter Property="Padding" Value="14,11"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Grid>
                                <Border x:Name="b" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Rectangle x:Name="ind" Height="3" VerticalAlignment="Bottom" Fill="{StaticResource Brush.Primary}" Visibility="Collapsed"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Primary}"/>
                                    <Setter TargetName="ind" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <!-- Highlight gdy Tag="highlight" (zmiany do uwagi) — pomarańczowe tło + tekst -->
                                <Trigger Property="Tag" Value="highlight">
                                    <Setter Property="Foreground" Value="{StaticResource Brush.WarningText}"/>
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.WarningSoft}"/>
                                    <Setter TargetName="ind" Property="Fill" Value="{StaticResource Brush.Warning}"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="Tag" Value="highlight"/>
                                        <Condition Property="IsSelected" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Foreground" Value="{StaticResource Brush.WarningText}"/>
                                    <Setter TargetName="ind" Property="Visibility" Value="Visible"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Pill / status badge -->
            <Style x:Key="StatusPill" TargetType="Border">
                <Setter Property="CornerRadius" Value="{StaticResource Radius.Pill}"/>
                <Setter Property="Padding" Value="{StaticResource Pad.Pill}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
            </Style>

            <Style x:Key="HeaderCounterPill" TargetType="Border">
                <Setter Property="CornerRadius" Value="{StaticResource Radius.Pill}"/>
                <Setter Property="Padding" Value="8,3"/>
                <Setter Property="Margin" Value="6,0,0,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════════
         GŁÓWNY GRID — 3 kolumny (lewa | splitter | prawa)
         W trybach Medium/Narrow code-behind ukrywa splitter+prawą
         ═══════════════════════════════════════════════════════════════ -->
    <Grid x:Name="rootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="colLeft"     Width="*"  MinWidth="500"/>
            <ColumnDefinition x:Name="colSplitter" Width="6"/>
            <ColumnDefinition x:Name="colRight"    Width="520" MinWidth="420" MaxWidth="780"/>
        </Grid.ColumnDefinitions>

        <!-- ═════════════ LEWA STRONA ═════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- ToolBarTray -->
                <RowDefinition Height="*"/>      <!-- DataGrid pełnowymiarowy -->
            </Grid.RowDefinitions>

            <!-- ───── TOOLBAR — Light Pro: białe tło z subtle border ───── -->
            <Border Grid.Row="0" Background="{StaticResource Brush.PrimaryGrad}"
                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1"
                    Padding="16,12">
                <StackPanel>

                    <!-- ROW 1: pasek nawigacji + akcje + info wybranego zamowienia -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- 0 prev -->
                            <ColumnDefinition Width="Auto"/>  <!-- 1 date hero -->
                            <ColumnDefinition Width="Auto"/>  <!-- 2 next -->
                            <ColumnDefinition Width="Auto"/>  <!-- 3 today -->
                            <ColumnDefinition Width="Auto"/>  <!-- 4 +nowe -->
                            <ColumnDefinition Width="Auto"/>  <!-- 5 density toggle -->
                            <ColumnDefinition Width="Auto"/>  <!-- 6 refresh -->
                            <ColumnDefinition Width="*"/>     <!-- 7 spacer -->
                            <ColumnDefinition Width="Auto"/>  <!-- 8 paneOrderInfo -->
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnPrevDay" Grid.Column="0"
                                Content="‹" Style="{StaticResource BtnIcon}"
                                FontSize="{StaticResource Font.Lg}"
                                Click="BtnPrevDay_Click" ToolTip="Poprzedni dzień (←)"/>

                        <Button x:Name="btnDate" Grid.Column="1"
                                Style="{StaticResource BtnDateHero}"
                                Margin="6,0"
                                Click="BtnDate_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtSelectedDate" Text="—"
                                           FontSize="{StaticResource Font.Lg}"
                                           FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="▾" Margin="10,0,0,0"
                                           FontSize="{StaticResource Font.Xs}" Foreground="{StaticResource Brush.TextMuted}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Popup x:Name="popupCalendar" PlacementTarget="{Binding ElementName=btnDate}"
                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                            <Border Background="White" BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="1" CornerRadius="8" Padding="4"
                                    Effect="{StaticResource Fx.Card}">
                                <Calendar x:Name="calendarPicker"
                                          SelectedDatesChanged="Calendar_SelectedDatesChanged"/>
                            </Border>
                        </Popup>

                        <Button x:Name="btnNextDay" Grid.Column="2"
                                Content="›" Style="{StaticResource BtnIcon}"
                                FontSize="{StaticResource Font.Lg}"
                                Click="BtnNextDay_Click" ToolTip="Następny dzień (→)"/>

                        <Button x:Name="btnToday" Grid.Column="3" Content="Dziś"
                                Style="{StaticResource BtnIcon}"
                                FontWeight="Medium" FontSize="{StaticResource Font.Sm}"
                                Margin="14,0,0,0"
                                Click="BtnToday_Click" ToolTip="Skocz do dziś (Home)"/>

                        <!-- Nowy przycisk: Stwórz zamówienie (mniejszy) -->
                        <Button x:Name="btnNoweZamowienie" Grid.Column="4" Content="+ Nowe"
                                FontWeight="SemiBold" FontSize="{StaticResource Font.Xs}"
                                Foreground="White" Background="#16A34A"
                                BorderThickness="0" Padding="10,5" Cursor="Hand"
                                Margin="10,0,0,0" MinHeight="{StaticResource Size.Btn.Md}"
                                Click="BtnNoweZamowienie_Click"
                                ToolTip="Stwórz nowe zamówienie (Ctrl+N)">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="#15803D"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Density toggle przeniesiony z ROW 2 do ROW 1 obok "Stwórz zamówienie" -->
                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                            <RadioButton x:Name="rbDensityCompact" GroupName="Density"
                                         Style="{StaticResource SegmentBtnFirst}"
                                         Content="≡" ToolTip="Kompaktowa"
                                         IsChecked="True" Checked="DensityRadio_Checked" Tag="Compact"/>
                            <RadioButton x:Name="rbDensityDefault" GroupName="Density"
                                         Style="{StaticResource SegmentBtn}"
                                         Content="☰" ToolTip="Domyślna"
                                         Checked="DensityRadio_Checked" Tag="Default"/>
                            <RadioButton x:Name="rbDensityComfort" GroupName="Density"
                                         Style="{StaticResource SegmentBtnLast}"
                                         Content="▤" ToolTip="Komfortowa"
                                         Checked="DensityRadio_Checked" Tag="Comfort"/>
                        </StackPanel>

                        <Button Grid.Column="6" x:Name="btnRefresh" Content="Odśwież"
                                Style="{StaticResource BtnIcon}"
                                FontWeight="Medium" FontSize="{StaticResource Font.Sm}"
                                Margin="10,0,0,0"
                                Click="BtnRefresh_Click" ToolTip="Odśwież dane (F5)"/>

                        <!-- Hidden compat (code-behind nadal pisze do txtWeekInfo) -->
                        <TextBlock x:Name="txtWeekInfo" Visibility="Collapsed"/>

                        <!-- WYBRANE ZAMÓWIENIE (po prawej) — ZAWSZE widoczne (puste gdy nic nie wybrane) -->
                        <Border x:Name="paneOrderInfo" Grid.Column="8"
                                VerticalAlignment="Center" HorizontalAlignment="Right"
                                Width="460" Height="80"
                                Background="{StaticResource Brush.SurfaceAlt}"
                                BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                CornerRadius="6" Padding="14,9">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock x:Name="txtOdbiorca" Text="—"
                                               FontSize="{StaticResource Font.Lg}" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Text}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="txtOrderMeta" Text=""
                                               FontSize="{StaticResource Font.Sm}"
                                               Foreground="{StaticResource Brush.TextSecondary}"
                                               Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                    <!-- ukryte (zachowane dla compatibility z code-behind) -->
                                    <TextBlock x:Name="txtHandlowiec" Visibility="Collapsed"/>
                                    <TextBlock x:Name="txtDataZamowienia" Visibility="Collapsed"/>
                                </StackPanel>
                                <Border x:Name="borderTransport" Grid.Column="1"
                                        Background="White" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                        CornerRadius="4" Padding="8,4" Margin="10,0,0,0"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock x:Name="txtGodzWyjazdu" Text="" FontSize="{StaticResource Font.Sm}"
                                                   FontWeight="SemiBold" Foreground="{StaticResource Brush.PrimaryDark}"/>
                                        <TextBlock x:Name="txtKierowca" Text="" FontSize="10"
                                                   Foreground="{StaticResource Brush.TextSecondary}"/>
                                        <TextBlock x:Name="txtPojazd" Text="" FontSize="10"
                                                   Foreground="{StaticResource Brush.TextMuted}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ROW 2 i ROW 3 usuniete - wszystko przeniesione do ROW 1.
                         Hidden compat elements (code-behind nadal pisze do nich, ale nie sa wyswietlane). -->
                    <StackPanel Visibility="Collapsed">
                        <ComboBox x:Name="cmbProduct" SelectionChanged="CmbProduct_SelectionChanged"/>
                        <CheckBox x:Name="chkShowFakturowane" IsChecked="True"
                                  Checked="ChkShowFakturowane_Changed" Unchecked="ChkShowFakturowane_Changed"/>
                        <TextBlock x:Name="txtCntDoFaktury"/>
                        <TextBlock x:Name="txtCntZafakt"/>
                        <TextBlock x:Name="txtCntZmian"/>
                        <TextBlock x:Name="txtCntKwota"/>
                        <Border x:Name="badgeKwotaEur"><TextBlock x:Name="txtCntKwotaEur"/></Border>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ───── DataGrid pełnowymiarowy (bez nagłówka karty — przeniesione do toolbara) ───── -->
            <Border Grid.Row="1" Background="White" Margin="10,10,5,10"
                    CornerRadius="{StaticResource Radius.Card}" Effect="{StaticResource Fx.Card}">
                <Grid>
                    <DataGrid x:Name="dgOrders"
                              Style="{StaticResource ProDataGrid}"
                              ColumnHeaderStyle="{StaticResource ProColHeader}"
                              CellStyle="{StaticResource ProCell}"
                              RowStyle="{StaticResource ProRow}"
                              ItemsSource="{Binding ZamowieniaList}"
                              SelectionChanged="DgOrders_SelectionChanged"
                              MouseDoubleClick="DgOrders_MouseDoubleClick">

                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Dopasuj fakturę do klienta..."
                                          Click="MenuItem_DopasujFakture_Click"/>
                                <MenuItem Header="Wyczyść numer faktury (cofnij dopasowanie)"
                                          Click="MenuItem_WyczyscFakture_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>

                        <!-- Grupowanie po statusie — header z ikoną + nazwą + licznikiem -->
                        <DataGrid.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Brush.SurfaceAlt}"
                                                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,1"
                                                Padding="14,8">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- Kropka koloru statusu -->
                                                <Ellipse Width="9" Height="9" Margin="0,0,8,0"
                                                         Fill="{Binding Name, Converter={StaticResource StatusToColor}}"
                                                         VerticalAlignment="Center"/>
                                                <!-- Glyph statusu (ikona Unicode) -->
                                                <TextBlock Text="{Binding Name, Converter={StaticResource StatusToIcon}}"
                                                           FontSize="{StaticResource Font.Md}" FontWeight="Bold"
                                                           Foreground="{Binding Name, Converter={StaticResource StatusToColor}}"
                                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <!-- Nazwa statusu -->
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="{StaticResource Font.Sm}" FontWeight="SemiBold"
                                                           Foreground="{StaticResource Brush.Text}"
                                                           VerticalAlignment="Center"/>
                                                <!-- Licznik -->
                                                <Border Background="White"
                                                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                                        CornerRadius="10" Padding="7,1" Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding ItemCount}"
                                                               FontSize="11" FontWeight="Medium"
                                                               Foreground="{StaticResource Brush.TextSecondary}"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </DataGrid.GroupStyle>
                        <DataGrid.Columns>
                            <!-- Klient — z ikoną statusu dopasowania faktury -->
                            <DataGridTemplateColumn Header="Klient" Width="*" MinWidth="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding MatchIcon}"
                                                       Foreground="{Binding MatchBrush}"
                                                       FontWeight="Bold" FontSize="14"
                                                       Margin="0,0,6,0" VerticalAlignment="Center"
                                                       Visibility="{Binding MatchVis}"
                                                       ToolTip="{Binding MatchTooltip}"/>
                                            <TextBlock Text="{Binding KlientName}" FontWeight="Medium"
                                                       FontSize="{DynamicResource Density.Row.Font}"
                                                       Foreground="{StaticResource Brush.Text}"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Handlowiec — z avatarem (jak w Zamowieniach Klientow) -->
                            <DataGridTemplateColumn Header="Handl." Width="Auto" MinWidth="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="24" Height="24" CornerRadius="12"
                                                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                                    Background="White" Margin="0,0,6,0"
                                                    ClipToBounds="True"
                                                    Visibility="{Binding HasAvatarVis}">
                                                <Image Source="{Binding HandlowiecAvatar}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>
                                            <TextBlock Text="{Binding Handlowiec}"
                                                       FontSize="{DynamicResource Density.Row.Font}"
                                                       Foreground="{StaticResource Brush.TextSecondary}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Ilość — szersza, żeby liczby w stylu "12 500" się mieściły -->
                            <DataGridTemplateColumn Header="Ilość kg" Width="Auto" MinWidth="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TotalIlosc, StringFormat=N0}"
                                                   FontWeight="Bold" FontSize="{DynamicResource Density.Row.Font}"
                                                   Foreground="{StaticResource Brush.Text}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Padding="0,0,8,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Wartość — z walutą (PLN/EUR per zamówienie) -->
                            <DataGridTemplateColumn Header="Wartość" Width="Auto" MinWidth="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding WartoscDisplay}"
                                                   FontWeight="Bold" FontSize="{DynamicResource Density.Row.Font}"
                                                   Foreground="{Binding WartoscColor}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Cen ✓/✗ -->
                            <DataGridTemplateColumn Header="Cen" Width="Auto" MinWidth="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding CenaDisplay}" Foreground="{Binding CenaColor}"
                                                   FontWeight="Bold" FontSize="{StaticResource Font.Md}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Status zostal usuniety (grupowanie po statusie pokazuje to w naglowkach grup) -->

                            <!-- Wyjazd — czysty tekst bez tła -->
                            <DataGridTemplateColumn Header="Wyjazd" Width="Auto" MinWidth="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding GodzWyjazdu}" FontSize="{StaticResource Font.Xs}"
                                                   Foreground="{StaticResource Brush.PrimaryDark}" FontWeight="Medium"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="{Binding HasTransport, Converter={StaticResource BoolToVis}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Kierowca -->
                            <DataGridTextColumn Header="Kierowca" Binding="{Binding Kierowca}"
                                                Width="Auto" MinWidth="100"/>

                            <!-- Nr faktury (z Symfonii, po eksporcie) -->
                            <DataGridTextColumn Header="Nr faktury" Binding="{Binding NumerFaktury}"
                                                Width="Auto" MinWidth="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Undo banner — floating overlay nad DataGridem (niewidoczny domyślnie) -->
            <Border x:Name="undoBanner" Grid.Row="1"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,16,16"
                    Background="#1E293B" CornerRadius="6" Padding="14,8"
                    Effect="{StaticResource Fx.Card}"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="txtUndoMsg" Text="Wykonano akcję" Foreground="White"
                               VerticalAlignment="Center" FontSize="{StaticResource Font.Sm}"
                               Margin="0,0,14,0"/>
                    <Button Content="Cofnij" Click="BtnUndo_Click"
                            Background="Transparent" Foreground="#7DD3FC"
                            BorderThickness="0" Padding="10,3" Cursor="Hand"
                            FontSize="{StaticResource Font.Sm}" FontWeight="Bold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#0EA5E9"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

        </Grid>

        <!-- ═════════════ SPLITTER (tylko w trybie Wide) ═════════════ -->
        <GridSplitter x:Name="splitter" Grid.Column="1" Width="6"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="Transparent"
                      Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

        <!-- ═════════════ PRAWA STRONA — TabControl 3 zakładki + akcje ═════════════ -->
        <Border x:Name="paneRight" Grid.Column="2" Background="White" Margin="5,10,10,10"
                CornerRadius="{StaticResource Radius.Card}" Effect="{StaticResource Fx.Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>     <!-- TabControl -->
                    <RowDefinition Height="Auto"/>  <!-- Notatki zamowienia -->
                    <RowDefinition Height="Auto"/>  <!-- Akcje -->
                </Grid.RowDefinitions>

                <TabControl x:Name="tabsDetail" Grid.Row="0" Style="{StaticResource DetailTabs}">

                    <!-- TAB 1: Pozycje zamówienia -->
                    <TabItem Header="Pozycje zamówienia" Style="{StaticResource DetailTabItem}">
                        <DataGrid x:Name="dgDetails"
                                  Style="{StaticResource ProDataGrid}"
                                  ColumnHeaderStyle="{StaticResource DetailColHeader}"
                                  CellStyle="{StaticResource DetailCell}"
                                  RowStyle="{StaticResource CompactRow}"/>
                    </TabItem>

                    <!-- TAB 2: Zmiany (highlightowana gdy są zmiany — Tag="highlight" w code-behind) -->
                    <TabItem x:Name="tabZmiany" Style="{StaticResource DetailTabItem}">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Zmiany" VerticalAlignment="Center"/>
                                <Border x:Name="badgeChanges" Background="{StaticResource Brush.Warning}"
                                        CornerRadius="9" MinWidth="20" Padding="6,1" Margin="7,0,0,0"
                                        VerticalAlignment="Center" Visibility="Collapsed">
                                    <TextBlock x:Name="txtChangesCount" Text="0"
                                               FontSize="10" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </TabItem.Header>
                        <Grid>
                            <!-- Brak zmian -->
                            <StackPanel x:Name="panelNoChanges" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Border Width="48" Height="48" CornerRadius="24"
                                        Background="{StaticResource Brush.SuccessSoft}" HorizontalAlignment="Center">
                                    <TextBlock Text="✓" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource Brush.Success}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Brak zmian"
                                           FontSize="{StaticResource Font.Md}" FontWeight="Medium"
                                           Foreground="{StaticResource Brush.Text}"
                                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                <TextBlock Text="Zamówienie nie było modyfikowane"
                                           FontSize="{StaticResource Font.Sm}" Foreground="{StaticResource Brush.TextMuted}"
                                           HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>

                            <!-- Lista zmian -->
                            <Grid x:Name="panelChangesDiff" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="icChangesCards">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource Brush.Border}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="14,9">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Obrazek towaru lub unicode/emoji ikona -->
                                                        <Grid Grid.Column="0" Width="32" Height="32"
                                                              Margin="0,2,10,0" VerticalAlignment="Top">
                                                            <Border CornerRadius="4" ClipToBounds="True"
                                                                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                                                    Background="White"
                                                                    Visibility="{Binding ImageVis}">
                                                                <Image Source="{Binding TowarImage}"
                                                                       Stretch="Uniform"
                                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                            </Border>
                                                            <Border Width="26" Height="26" CornerRadius="13"
                                                                    Background="{StaticResource Brush.PrimarySoft}"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                    Visibility="{Binding IconVis}">
                                                                <TextBlock Text="{Binding Icon}" FontSize="14"
                                                                           Foreground="{StaticResource Brush.PrimaryDark}"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </Grid>

                                                        <!-- Pole + zmiana + meta -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock TextWrapping="Wrap" FontSize="{StaticResource Font.Sm}">
                                                                <Run Text="{Binding Pole, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}"/><Run Text="   "/><Run Text="{Binding Bylo, Mode=OneWay}" Foreground="{StaticResource Brush.TextSecondary}"/><Run Text=" → " Foreground="{StaticResource Brush.TextMuted}"/><Run Text="{Binding Jest, Mode=OneWay}" FontWeight="Medium" Foreground="{StaticResource Brush.Text}"/>
                                                            </TextBlock>
                                                            <TextBlock Margin="0,3,0,0"
                                                                       FontSize="{StaticResource Font.Xs}"
                                                                       Foreground="{StaticResource Brush.TextMuted}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Visibility="{Binding HasMeta, Converter={StaticResource BoolToVis}}">
                                                                <Run Text="{Binding Kto, Mode=OneWay}"/><Run Text="  ·  "/><Run Text="{Binding Kiedy, Mode=OneWay}"/>
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <TextBlock Grid.Column="2" Text="{Binding Delta}"
                                                                   FontSize="{StaticResource Font.Sm}" FontWeight="SemiBold"
                                                                   Foreground="{Binding DeltaColor}"
                                                                   VerticalAlignment="Top" Margin="10,1,0,0"
                                                                   Visibility="{Binding HasDelta, Converter={StaticResource BoolToVis}}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border Grid.Row="1" Padding="14,10"
                                        Background="{StaticResource Brush.SurfaceAlt}"
                                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0">
                                    <Button x:Name="btnAcceptChange" Content="Przyjmuję wszystkie zmiany"
                                            Style="{StaticResource BtnSuccess}"
                                            MinHeight="38"
                                            Click="BtnAcceptChange_Click"
                                            ToolTip="Potwierdź przyjęcie zmian (skrót: Spacja)"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- TAB 3: Pozycje faktury — odczyt z Symfonii (192.168.0.112) -->
                    <TabItem Header="Pozycje faktury" Style="{StaticResource DetailTabItem}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- Header z numerem + klientem faktury -->
                                <RowDefinition Height="*"/>     <!-- Grid lub placeholder -->
                            </Grid.RowDefinitions>

                            <!-- Header faktury (widoczny gdy faktura załadowana) -->
                            <Border Grid.Row="0" x:Name="invoiceHeader" Visibility="Collapsed"
                                    Background="{StaticResource Brush.SurfaceAlt}"
                                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1"
                                    Padding="14,10">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Faktura: " FontSize="{StaticResource Font.Sm}"
                                               Foreground="{StaticResource Brush.TextMuted}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtInvoiceNumer" Text=""
                                               FontSize="{StaticResource Font.Md}" FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Text}"
                                               VerticalAlignment="Center" Margin="0,0,18,0"/>
                                    <TextBlock Text="Klient: " FontSize="{StaticResource Font.Sm}"
                                               Foreground="{StaticResource Brush.TextMuted}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtInvoiceKlient" Text=""
                                               FontSize="{StaticResource Font.Md}" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtInvoiceMatchTag" Text=""
                                               FontSize="{StaticResource Font.Xs}" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Padding="6,2"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1">
                                <StackPanel x:Name="panelInvoiceEmpty" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="{StaticResource Brush.SurfaceAlt}" HorizontalAlignment="Center">
                                        <TextBlock Text="📄" FontSize="22"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Brak danych faktury"
                                               FontSize="{StaticResource Font.Md}" FontWeight="Medium"
                                               Foreground="{StaticResource Brush.Text}"
                                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                    <TextBlock x:Name="txtInvoiceHint" Text="Zamówienie jeszcze nie zafakturowane"
                                               FontSize="{StaticResource Font.Sm}" Foreground="{StaticResource Brush.TextMuted}"
                                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                </StackPanel>
                                <DataGrid x:Name="dgInvoiceItems" Visibility="Collapsed"
                                          Style="{StaticResource ProDataGrid}"
                                          ColumnHeaderStyle="{StaticResource DetailColHeader}"
                                          CellStyle="{StaticResource DetailCell}"
                                          RowStyle="{StaticResource CompactRow}"/>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>

                <!-- Notatki zamowienia (kolumna Uwagi z dbo.ZamowieniaMieso) — TYLKO PODGLAD -->
                <Border Grid.Row="1" Background="{StaticResource Brush.Surface}" Padding="14,10"
                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="NOTATKI ZAMÓWIENIA (tylko podgląd)" FontSize="{StaticResource Font.Xs}" FontWeight="Bold"
                                   Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtNotatki"
                                 IsReadOnly="True"
                                 MinHeight="50" MaxHeight="100"
                                 FontSize="{StaticResource Font.Sm}"
                                 Background="{StaticResource Brush.SurfaceAlt}"
                                 Foreground="{StaticResource Brush.Text}"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                 Padding="8,6"/>
                    </StackPanel>
                </Border>

                <!-- Akcje główne na dole -->
                <Border Grid.Row="2" Background="{StaticResource Brush.SurfaceAlt}" Padding="14,12"
                        CornerRadius="{StaticResource Radius.CardBottom}"
                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnMarkFakturowane" Grid.Column="0"
                                Content="Zafakturowane"
                                Style="{StaticResource BtnPrimary}"
                                MinHeight="40" Margin="0,0,5,0"
                                Click="BtnMarkFakturowane_Click" IsEnabled="False"
                                ToolTip="Oznacz zamówienie jako zafakturowane (skrót: F)"/>
                        <Button x:Name="btnCofnijFakturowanie" Grid.Column="1"
                                Content="Cofnij"
                                Style="{StaticResource BtnWarning}"
                                MinHeight="40" Margin="5,0,0,0"
                                Click="BtnCofnijFakturowanie_Click" IsEnabled="False"
                                ToolTip="Cofnij status zafakturowane (skrót: U)"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>
