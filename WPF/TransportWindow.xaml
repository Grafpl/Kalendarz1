<Window x:Class="Kalendarz1.WPF.TransportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transport - Przegląd wysyłek"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="#F0F2F5" FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFBFC"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E8E8E8"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="ModernDataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2C3E50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#34495E"/>
        </Style>
        <Style x:Key="RightAlignedCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Padding" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="CenterAlignedCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BoldCellStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ NAGŁÓWEK z filtrami ═══ -->
        <Border Grid.Row="0" CornerRadius="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1ABC9C" Offset="0"/>
                    <GradientStop Color="#16A085" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="20,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Tytuł + statystyki -->
                <DockPanel Grid.Row="0">
                    <StackPanel>
                        <TextBlock Text="TRANSPORT — PRZEGLĄD WYSYŁEK" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="txtSelectedDate" Text="" FontSize="11" Foreground="#A3E4D7" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#27AE60" CornerRadius="6" Padding="10,5" Margin="4,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Przyd:" FontSize="11" Foreground="White"/>
                                <TextBlock x:Name="txtPrzypisanych" Text="0" FontSize="14" Foreground="White" FontWeight="Bold" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#E74C3C" CornerRadius="6" Padding="10,5" Margin="4,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Brak:" FontSize="11" Foreground="White"/>
                                <TextBlock x:Name="txtBezTransportu" Text="0" FontSize="14" Foreground="White" FontWeight="Bold" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#3498DB" CornerRadius="6" Padding="10,5" Margin="4,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="kg:" FontSize="11" Foreground="White"/>
                                <TextBlock x:Name="txtSumaKg" Text="0" FontSize="14" Foreground="White" FontWeight="Bold" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>
                <!-- Filtry + przyciski -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Data:" Foreground="#A3E4D7" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker x:Name="dpData" Width="120" FontSize="11" SelectedDateChanged="DpData_SelectedDateChanged"/>
                    <TextBlock Text="Filtr:" Foreground="#A3E4D7" FontSize="11" VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <TextBox x:Name="txtFilterOdbiorca" Width="160" Height="26" FontSize="11" VerticalContentAlignment="Center"
                             TextChanged="TxtFilterOdbiorca_TextChanged" Background="White" BorderBrush="#4DB6AC" Padding="6,0"/>
                    <TextBlock Text="Status:" Foreground="#A3E4D7" FontSize="11" VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <ComboBox x:Name="cmbFilterStatus" Width="110" Height="26" FontSize="11" SelectionChanged="CmbFilterStatus_SelectionChanged">
                        <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                        <ComboBoxItem Content="Przypisany"/>
                        <ComboBoxItem Content="Brak"/>
                    </ComboBox>
                    <Button Content="Debug" Click="BtnDebug_Click" Background="#37474F" Foreground="White" BorderThickness="0"
                            Padding="10,4" Margin="16,0,0,0" Cursor="Hand" FontSize="10">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Zamknij" Click="BtnClose_Click" Background="#7F8C8D" Foreground="White" BorderThickness="0"
                            Padding="10,4" Margin="6,0,0,0" Cursor="Hand" FontSize="10">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ TABELA ═══ -->
        <Grid Grid.Row="1" Margin="12,8,12,0">
            <DataGrid x:Name="dgTransport"
                      Style="{StaticResource ModernDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource ModernDataGridHeaderStyle}"
                      AutoGenerateColumns="False" CanUserSortColumns="True"/>
            <!-- Loader overlay -->
            <Border x:Name="LoaderOverlay" Background="#80FFFFFF" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Ładowanie danych..." FontSize="16" Foreground="#2C3E50" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LoaderDetail" Text="" FontSize="11" Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ STOPKA ═══ -->
        <Border Grid.Row="2" Background="White" Padding="16,6" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Wierszy:" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtLiczbaWierszy" Text="0" FontSize="12" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <TextBlock Text="  |  Palet:" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock x:Name="txtSumaPalet" Text="0" FontSize="12" FontWeight="Bold" Foreground="#1ABC9C" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
                <TextBlock x:Name="txtStatus" Text="Gotowy" DockPanel.Dock="Right" HorizontalAlignment="Right" Foreground="#7F8C8D" FontSize="10" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
