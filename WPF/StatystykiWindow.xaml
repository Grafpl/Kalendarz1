<Window x:Class="Kalendarz1.WPF.StatystykiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transparentność klientów"
        Width="1520" Height="860"
        MinWidth="1180" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFBFC"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E8E8E8"/>
            <Setter Property="RowHeight" Value="25"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontSize" Value="11.5"/>
        </Style>

        <Style x:Key="PanelHeader" TargetType="Border">
            <Setter Property="CornerRadius" Value="8,8,0,0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- nagłówek (kompakt) -->
            <RowDefinition Height="Auto"/>   <!-- filtry -->
            <RowDefinition Height="*"/>      <!-- treść -->
            <RowDefinition Height="Auto"/>   <!-- stopka -->
        </Grid.RowDefinitions>

        <!-- ═══ Nagłówek (kompakt — podsumowanie w jednej linii) ═══ -->
        <Border Grid.Row="0" CornerRadius="8" Padding="14,7" Margin="0,0,0,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#2C3E50" Offset="0"/>
                    <GradientStop Color="#4A6491" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍 Transparentność klientów" FontSize="14.5" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtDateRange" Text="—" FontSize="11" Foreground="#BDC9D8"
                               Margin="14,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="txtHeaderStats" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="11.5" FontWeight="SemiBold" Foreground="White" Text=""/>
            </Grid>
        </Border>

        <!-- ═══ Filtry ═══ -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12,9" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" Opacity="0.1" BlurRadius="5"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,18,0">
                    <TextBlock Text="Okres:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cmbOkres" Width="116" Height="29"
                              SelectionChanged="CmbOkres_SelectionChanged">
                        <ComboBoxItem Content="Rok" Tag="Year"/>
                        <ComboBoxItem Content="3 miesiące" Tag="Quarter"/>
                        <ComboBoxItem Content="Miesiąc" Tag="Month" IsSelected="True"/>
                        <ComboBoxItem Content="Tydzień" Tag="Week"/>
                        <ComboBoxItem Content="Dzień" Tag="Day"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,18,0">
                    <TextBlock Text="Od:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker x:Name="dpOd" Width="126" Height="29"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,18,0">
                    <TextBlock Text="Do:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker x:Name="dpDo" Width="126" Height="29"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,18,0">
                    <TextBlock Text="Handlowiec:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="cmbHandlowiec" Width="124" Height="29"
                              SelectionChanged="CmbHandlowiec_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <TextBlock Text="Klient:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="txtSzukaj" Width="160" Height="29" VerticalContentAlignment="Center"
                             ToolTip="Szukaj odbiorcy po nazwie" TextChanged="TxtSzukaj_TextChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="6" Orientation="Horizontal">
                    <Button x:Name="btnRefresh" Content="🔄 Odśwież" Padding="14,7"
                            Background="#3498DB" Foreground="White" BorderThickness="0"
                            Click="BtnRefresh_Click" Cursor="Hand" Margin="0,0,8,0"/>
                    <Button Content="Zamknij" Padding="14,7"
                            Background="#95A5A6" Foreground="White" BorderThickness="0"
                            Click="BtnClose_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Treść: klienci | przyczyny + incydenty ═══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="430"/>
            </Grid.ColumnDefinitions>

            <!-- Lewa: tabela klientów -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="10" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="10"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2C3E50" Offset="0"/>
                                <GradientStop Color="#4A6491" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <TextBlock Text="WIARYGODNOŚĆ WG ODBIORCY" FontSize="13" Foreground="White" FontWeight="Bold"/>
                            <TextBlock x:Name="txtKlienciInfo" HorizontalAlignment="Right" FontSize="11"
                                       Foreground="#BDC9D8" Text=""/>
                        </Grid>
                    </Border>
                    <DataGrid Grid.Row="1" x:Name="dgKlienci"
                              Style="{StaticResource ModernDataGridStyle}"
                              AutoGenerateColumns="False"
                              CanUserSortColumns="True"
                              SelectionChanged="DgKlienci_SelectionChanged"
                              MouseDoubleClick="DgKlienci_MouseDoubleClick"
                              ToolTip="2× klik — pełna karta klienta (Customer 360)"/>
                </Grid>
            </Border>

            <!-- Prawa: przyczyny + incydenty -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" MinHeight="150"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="3*" MinHeight="200"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="10">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="10"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#9B59B6" Offset="0"/>
                                    <GradientStop Color="#8E44AD" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="PRZYCZYNY ANULOWAŃ" FontSize="13" Foreground="White" FontWeight="Bold"/>
                        </Border>
                        <DataGrid Grid.Row="1" x:Name="dgPrzyczyny"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True"/>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="10"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#D35400" Offset="0"/>
                                    <GradientStop Color="#E67E22" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <TextBlock x:Name="txtIncydentyHeader" Text="OSTATNIE INCYDENTY"
                                           FontSize="13" Foreground="White" FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis"/>
                                <Button x:Name="btnIncydentyWszyscy" Content="✕ wszyscy" HorizontalAlignment="Right"
                                        FontSize="10.5" Padding="7,2" Visibility="Collapsed"
                                        Background="#00000040" Foreground="White" BorderThickness="0"
                                        Cursor="Hand" Click="BtnIncydentyWszyscy_Click"/>
                            </Grid>
                        </Border>
                        <DataGrid Grid.Row="1" x:Name="dgIncydenty"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══ Stopka ═══ -->
        <Border Grid.Row="3" Margin="0,12,0,0" Background="White" CornerRadius="8" Padding="14,9">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" Opacity="0.1" BlurRadius="5"/>
            </Border.Effect>
            <TextBlock FontSize="11" Foreground="#7F8C8D" TextWrapping="Wrap"
                       Text="2× klik na odbiorcę → pełna karta klienta (Customer 360).  Incydenty: 🚫 anulacja  📉 redukcja kg  🔁 przesunięcie terminu  📦 niedobór przy odbiorze  ⚠️ reklamacja.  Wiarygodność = 100 − 0,8/% anulacji − 2/redukcję(max 20) − 1/przesunięcie(max 10) − 3/niedobór(max 15) − 3/reklamację(max 15).  🟢 ≥85  🟡 60–84  🔴 &lt;60"/>
        </Border>
    </Grid>
</Window>
