<Window x:Class="Kalendarz1.WPF.SzczegolyDniaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kalendarz1.WPF"
        Title="Szczegóły dnia"
        Width="1280" Height="780"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#F2F4F7"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Reused palette -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2E7D32"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1B5E20"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5B6772"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8B95A0"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D7DBE0"/>
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="#EAEDF0"/>
        <SolidColorBrush x:Key="HandelText" Color="#1B5E20"/>
        <SolidColorBrush x:Key="LibraText" Color="#0D47A1"/>
        <SolidColorBrush x:Key="SpecText" Color="#4A148C"/>

        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#27602A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TabControl -->
        <Style x:Key="DetailsTab" TargetType="TabItem">
            <Setter Property="Padding" Value="22,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="Transparent" BorderBrush="Transparent"
                                BorderThickness="0,0,0,3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7F9FB"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,11"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="SeparatorVisibility" Value="Collapsed"/>
        </Style>

        <Style x:Key="DgHeaderRight" TargetType="DataGridColumnHeader" BasedOn="{StaticResource DgHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="Padding" Value="10,11,14,11"/>
        </Style>

        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F8FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NumCell" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{x:Static local:SzczegolyDniaWindow.CloseCmd}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <!-- title bar -->
            <RowDefinition Height="Auto"/>
            <!-- summary strip -->
            <RowDefinition Height="*"/>
            <!-- tabs + data -->
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Szczegóły dnia" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" · " FontSize="13" Foreground="#B7D5BB" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblTitleDate" Text="—" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblTitleDow" Text="" FontSize="12" Foreground="#B7D5BB" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource CloseButton}" Click="BtnClose_Click" ToolTip="Zamknij (Esc)">
                    <Path Width="10" Height="10" Stretch="Uniform" Stroke="White" StrokeThickness="1.4"
                          Data="M 0,0 L 10,10 M 10,0 L 0,10"/>
                </Button>
            </Grid>
        </Border>

        <!-- Summary strip — szybkie podsumowanie dnia (3 źródła + delta) -->
        <Border Grid.Row="1" Background="White" Padding="20,12" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="HANDEL .112" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource HandelText}" Opacity="0.75"/>
                    <TextBlock x:Name="sumHandelKg" Text="—" FontSize="18" FontWeight="Bold" Foreground="{StaticResource HandelText}"/>
                    <TextBlock x:Name="sumHandelW" Text="—" FontSize="11" Foreground="{StaticResource HandelText}" Opacity="0.85"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="LIBRANET .109" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource LibraText}" Opacity="0.75"/>
                    <TextBlock x:Name="sumLibraKg" Text="—" FontSize="18" FontWeight="Bold" Foreground="{StaticResource LibraText}"/>
                    <TextBlock x:Name="sumLibraInfo" Text="—" FontSize="11" Foreground="{StaticResource LibraText}" Opacity="0.85"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="SPECYFIKACJA PDF" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource SpecText}" Opacity="0.75"/>
                    <TextBlock x:Name="sumSpecKg" Text="—" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SpecText}"/>
                    <TextBlock x:Name="sumSpecW" Text="—" FontSize="11" Foreground="{StaticResource SpecText}" Opacity="0.85"/>
                </StackPanel>
                <Border Grid.Column="3" x:Name="sumDeltaBorder" Background="#E8F5E9" CornerRadius="4" Padding="12,8">
                    <StackPanel>
                        <TextBlock Text="Δ HANDEL-SPEC" FontSize="10" FontWeight="SemiBold" Foreground="#1B5E20" Opacity="0.85"/>
                        <TextBlock x:Name="sumDelta" Text="—" FontSize="18" FontWeight="Bold" Foreground="#1B5E20"/>
                        <TextBlock x:Name="sumDeltaProc" Text="—" FontSize="11" Foreground="#1B5E20" Opacity="0.85"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- TabControl with 3 sources -->
        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0" Padding="0">
            <TabItem Header="📥 HANDEL — Faktury zakupu" Style="{StaticResource DetailsTab}">
                <Border Background="White" Margin="16" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="6">
                    <DataGrid x:Name="dgHandel" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False"
                              GridLinesVisibility="None" HeadersVisibility="Column" RowHeaderWidth="0"
                              Background="White" BorderThickness="0"
                              CellStyle="{StaticResource DgCell}" RowStyle="{StaticResource DgRow}"
                              ColumnHeaderStyle="{StaticResource DgHeader}"
                              SelectionMode="Single" IsReadOnly="True"
                              VirtualizingPanel.IsVirtualizing="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NR FAKTURY" Binding="{Binding Kod}" Width="160">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="TYP" Binding="{Binding TypDk}" Width="60"/>
                            <DataGridTextColumn Header="DOSTAWCA" Binding="{Binding Dostawca}" Width="*"/>
                            <DataGridTextColumn Header="TOWAR" Binding="{Binding Towar}" Width="160"/>
                            <DataGridTextColumn Header="kg" Binding="{Binding Kg, StringFormat={}{0:N0}}" Width="100"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                            <DataGridTextColumn Header="zł/kg" Binding="{Binding Cena, StringFormat={}{0:N2}}" Width="80"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                            <DataGridTextColumn Header="WARTOŚĆ NETTO" Binding="{Binding Wartosc, StringFormat={}{0:N2} zł}" Width="140"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="📋 LIBRANET — Plan dostaw" Style="{StaticResource DetailsTab}">
                <Border Background="White" Margin="16" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="6">
                    <DataGrid x:Name="dgLibra" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False"
                              GridLinesVisibility="None" HeadersVisibility="Column" RowHeaderWidth="0"
                              Background="White" BorderThickness="0"
                              CellStyle="{StaticResource DgCell}" RowStyle="{StaticResource DgRow}"
                              ColumnHeaderStyle="{StaticResource DgHeader}"
                              SelectionMode="Single" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="LP" Binding="{Binding LP}" Width="60"/>
                            <DataGridTextColumn Header="DOSTAWCA" Binding="{Binding Dostawca}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="SZTUK" Binding="{Binding Sztuki, StringFormat={}{0:N0}}" Width="90"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                            <DataGridTextColumn Header="WAGA/SZT" Binding="{Binding Waga, StringFormat={}{0:N3} kg}" Width="100"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                            <DataGridTextColumn Header="ŁĄCZNIE kg" Binding="{Binding RazemKg, StringFormat={}{0:N0}}" Width="120"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                            <DataGridTextColumn Header="CENA" Binding="{Binding Cena, StringFormat={}{0:N2}}" Width="80"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                            <DataGridTextColumn Header="TYP CENY" Binding="{Binding TypCeny}" Width="120"/>
                            <DataGridTextColumn Header="AUT" Binding="{Binding Auta}" Width="60"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                            <DataGridTextColumn Header="UWAGI" Binding="{Binding Uwagi}" Width="180"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="📊 SPECYFIKACJA PDF — Rozliczenie hodowców" Style="{StaticResource DetailsTab}">
                <Border Background="White" Margin="16" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="6">
                    <DataGrid x:Name="dgSpec" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False"
                              GridLinesVisibility="None" HeadersVisibility="Column" RowHeaderWidth="0"
                              Background="White" BorderThickness="0"
                              CellStyle="{StaticResource DgCell}" RowStyle="{StaticResource DgRow}"
                              ColumnHeaderStyle="{StaticResource DgHeader}"
                              SelectionMode="Single" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="HODOWCA" Binding="{Binding Hodowca}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="NETTO kg" Binding="{Binding Netto, StringFormat={}{0:N0}}" Width="100"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                            <DataGridTextColumn Header="PADŁE" Binding="{Binding Padle, StringFormat={}{0:N0}}" Width="80"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                            <DataGridTextColumn Header="KONF." Binding="{Binding Konf, StringFormat={}{0:N0}}" Width="80"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                            <DataGridTextColumn Header="UBYTEK" Binding="{Binding Ubytek, StringFormat={}{0:N0}}" Width="80"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                            <DataGridTextColumn Header="OPAS." Binding="{Binding Opasienie, StringFormat={}{0:N0}}" Width="80"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                            <DataGridTextColumn Header="KL.B" Binding="{Binding KlasaB, StringFormat={}{0:N0}}" Width="70"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                            <DataGridTextColumn Header="DO ZAPŁ. kg" Binding="{Binding DoZaplaty, StringFormat={}{0:N0}}" Width="110"
                                                HeaderStyle="{StaticResource DgHeaderRight}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource NumCell}">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource SpecText}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="CENA" Binding="{Binding Cena, StringFormat={}{0:N2}}" Width="80"
                                                HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                            <DataGridTextColumn Header="WARTOŚĆ" Binding="{Binding Wartosc, StringFormat={}{0:N2} zł}" Width="140"
                                                HeaderStyle="{StaticResource DgHeaderRight}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource NumCell}">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Loading overlay -->
        <Border x:Name="loadingOverlay" Grid.Row="0" Grid.RowSpan="3" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="220" Height="6"/>
                <TextBlock Text="Pobieranie szczegółów..." Margin="0,8,0,0" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
