<Window x:Class="Kalendarz1.WPF.CyclicOrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zamówienia cykliczne"
        Height="850" Width="820"
        WindowStartupLocation="CenterScreen"
        MinHeight="700" MinWidth="700"
        Background="#F0F2F5"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- ToggleButton as day pill -->
        <Style x:Key="DayPill" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="38"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="15" Padding="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3498DB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Preset link button -->
        <Style x:Key="PresetLink" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#3498DB"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#EBF5FB" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D4E6F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" Color="#000" Opacity="0.15" BlurRadius="6"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2ECC71"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#229954"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#95A5A6"/>
            <Setter Property="Padding" Value="20,10"/>
        </Style>

        <!-- Card border -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" Color="#000" Opacity="0.06" BlurRadius="6"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16,12,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0: Source order + offset rules ═══ -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="8" Padding="16,12" Margin="0,0,0,10">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" Color="#000" Opacity="0.15" BlurRadius="10"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header + odbiorca -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="DUPLIKOWANIE ZAMÓWIENIA" FontSize="10" Foreground="#95A5A6"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"
                               />
                    <TextBlock x:Name="lblSourceId" FontSize="10" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Odbiorca + produkty -->
                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                    <TextBlock x:Name="lblSourceOdbiorca" FontSize="16" FontWeight="Bold"
                               Foreground="White" Margin="0,0,0,2"/>
                    <TextBlock x:Name="lblSourceProdukty" FontSize="11" Foreground="#85C1E9"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Offset rules - transparentne -->
                <Border Grid.Row="2" Background="#34495E" CornerRadius="5" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="AWIZACJA" FontSize="9" Foreground="#7F8C8D" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock x:Name="lblOffsetAwizacja" FontSize="12" Foreground="#F39C12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="GODZINA" FontSize="9" Foreground="#7F8C8D" FontWeight="Bold"/>
                            <TextBlock x:Name="lblOffsetGodzina" FontSize="12" Foreground="#1ABC9C" FontWeight="SemiBold" Margin="0,2,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="PRODUKCJA" FontSize="9" Foreground="#7F8C8D" FontWeight="Bold"/>
                            <TextBlock x:Name="lblOffsetProdukcja" FontSize="12" Foreground="#E74C3C" FontWeight="SemiBold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ ROW 1: Date range + frequency (side by side) ═══ -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Date range card -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Zakres dat" FontSize="11" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Od:" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                            <DatePicker x:Name="dpStartDate" SelectedDateChanged="DateRange_Changed" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="—" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                   FontSize="14" Foreground="#BDC3C7" Margin="0,0,0,6"/>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Do:" FontSize="10" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                            <DatePicker x:Name="dpEndDate" SelectedDateChanged="DateRange_Changed" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                    <!-- Quick presets -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="1 tydz." Style="{StaticResource PresetLink}" Click="Preset1Week_Click" Margin="0,0,4,0"/>
                        <Button Content="2 tyg." Style="{StaticResource PresetLink}" Click="Preset2Weeks_Click" Margin="0,0,4,0"/>
                        <Button Content="Miesiąc" Style="{StaticResource PresetLink}" Click="Preset1Month_Click" Margin="0,0,4,0"/>
                        <Button Content="Do końca mies." Style="{StaticResource PresetLink}" Click="PresetEndOfMonth_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Frequency card -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Width="330">
                <StackPanel>
                    <TextBlock Text="Częstotliwość" FontSize="11" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,6"/>
                    <RadioButton x:Name="rbDaily" Content="Codziennie (Pn-Pt)" IsChecked="True"
                                 FontSize="11" Margin="0,2" Checked="RbFrequency_Changed"/>
                    <RadioButton x:Name="rbSelectedDays" Content="Wybrane dni tygodnia"
                                 FontSize="11" Margin="0,2" Checked="RbFrequency_Changed"/>
                    <RadioButton x:Name="rbWeekly" Content="Co tydzień (1x w tygodniu)"
                                 FontSize="11" Margin="0,2" Checked="RbFrequency_Changed"/>

                    <!-- Day pills -->
                    <StackPanel x:Name="spDayPills" Orientation="Horizontal" Margin="0,8,0,0"
                                HorizontalAlignment="Center">
                        <ToggleButton x:Name="pillMon" Content="Pon" Style="{StaticResource DayPill}"
                                      Checked="DayPill_Changed" Unchecked="DayPill_Changed"/>
                        <ToggleButton x:Name="pillTue" Content="Wt" Style="{StaticResource DayPill}"
                                      Checked="DayPill_Changed" Unchecked="DayPill_Changed"/>
                        <ToggleButton x:Name="pillWed" Content="Śr" Style="{StaticResource DayPill}"
                                      Checked="DayPill_Changed" Unchecked="DayPill_Changed"/>
                        <ToggleButton x:Name="pillThu" Content="Czw" Style="{StaticResource DayPill}"
                                      Checked="DayPill_Changed" Unchecked="DayPill_Changed"/>
                        <ToggleButton x:Name="pillFri" Content="Pt" Style="{StaticResource DayPill}"
                                      Checked="DayPill_Changed" Unchecked="DayPill_Changed"/>
                        <ToggleButton x:Name="pillSat" Content="So" Style="{StaticResource DayPill}"
                                      Checked="DayPill_Changed" Unchecked="DayPill_Changed"/>
                        <ToggleButton x:Name="pillSun" Content="Nd" Style="{StaticResource DayPill}"
                                      Checked="DayPill_Changed" Unchecked="DayPill_Changed"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ ROW 2: Copy options (compact) ═══ -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Kopiuj:" FontSize="11" FontWeight="Bold"
                           Foreground="#2C3E50" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <CheckBox x:Name="chkCopyNotes" Content="Notatki" FontSize="11" Margin="0,0,16,0" IsChecked="False"
                              ToolTip="Skopiuje pole Uwagi z zamówienia źródłowego"/>
                    <CheckBox x:Name="chkCopyKlasyWagowe" Content="Klasy wagowe (Kurczak A)" FontSize="11"
                              Margin="0,0,16,0" IsChecked="True"
                              ToolTip="Skopiuje rozdzielenie na klasy 5-12 z RezerwacjeKlasWagowych"/>
                    <CheckBox x:Name="chkCopyDataProdukcji" Content="Data produkcji" FontSize="11"
                              Margin="0,0,16,0" IsChecked="True"
                              Checked="CopyOption_Changed" Unchecked="CopyOption_Changed"
                              ToolTip="DataProdukcji przesunięta o tę samą liczbę dni"/>
                    <CheckBox x:Name="chkCopyStrefa" Content="Strefa" FontSize="11" IsChecked="True"
                              ToolTip="Skopiuje flagę Strefa (ptasia grypa)"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- ═══ ROW 3: Preview table ═══ -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Margin="0,0,0,10" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" Color="#000" Opacity="0.06" BlurRadius="6"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Preview header -->
                <Border Grid.Row="0" Background="#F8F9FA" Padding="14,8"
                        CornerRadius="8,8,0,0" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="PODGLĄD ZAMÓWIEŃ" FontSize="10" FontWeight="Bold"
                                       Foreground="#7F8C8D" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Background="#E67E22" CornerRadius="10" Padding="8,2">
                                <TextBlock x:Name="lblPreviewCount" FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Zaznacz wszystkie" Style="{StaticResource PresetLink}"
                                    Click="SelectAll_Click" Margin="0,0,4,0" FontSize="10"/>
                            <Button Content="Odznacz wszystkie" Style="{StaticResource PresetLink}"
                                    Click="DeselectAll_Click" FontSize="10"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Preview DataGrid -->
                <DataGrid x:Name="dgPreview" Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserSortColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          RowHeight="28"
                          FontSize="11"
                          SelectionMode="Single"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#FAFCFE"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsWeekend}" Value="True">
                                    <Setter Property="Background" Value="#FFF8E1"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasCollision}" Value="True">
                                    <Setter Property="Background" Value="#FFEBEE"/>
                                    <Setter Property="Foreground" Value="#C62828"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                    <Setter Property="FontStyle" Value="Italic"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="#7F8C8D"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="BorderBrush" Value="#F0F0F0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="6,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF5FB"/>
                                    <Setter Property="Foreground" Value="#2C3E50"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                </DataGrid>

                <!-- Summary footer -->
                <Border Grid.Row="2" Background="#F8F9FA" Padding="14,6"
                        CornerRadius="0,0,8,8" BorderBrush="#E8E8E8" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="lblSummary" Grid.Column="0" FontSize="10" Foreground="#7F8C8D"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblWarning" Grid.Column="1" FontSize="10" Foreground="#E74C3C"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ ROW 4: Action bar ═══ -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="lblTotalInfo" Grid.Column="0" FontSize="12" Foreground="#2C3E50"
                       FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Zapisz szablon" Style="{StaticResource PresetLink}" Click="SaveTemplate_Click"
                        FontSize="10" Margin="0,0,6,0" ToolTip="Zapisz bieżące ustawienia jako szablon dla tego klienta"/>
                <Button Content="Załaduj szablon" Style="{StaticResource PresetLink}" Click="LoadTemplate_Click"
                        FontSize="10" ToolTip="Załaduj zapisany szablon dla tego klienta"/>
            </StackPanel>
            <Button Grid.Column="1" x:Name="btnOk" Content="Utwórz zamówienia"
                    Style="{StaticResource PrimaryButton}" Click="BtnOk_Click"/>
            <Button Grid.Column="3" Content="Anuluj"
                    Style="{StaticResource SecondaryButton}" Click="BtnCancel_Click"/>
        </Grid>
    </Grid>
</Window>
