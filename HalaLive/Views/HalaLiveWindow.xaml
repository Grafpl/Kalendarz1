<Window x:Class="Kalendarz1.HalaLive.Views.HalaLiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZPSP — Hala LIVE"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0B1220"
        FontFamily="Segoe UI"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- KOLORY -->
        <SolidColorBrush x:Key="BgDark" Color="#0B1220"/>
        <SolidColorBrush x:Key="BgCard" Color="#0F172A"/>
        <SolidColorBrush x:Key="BgCardHover" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#22C55E"/>
        <SolidColorBrush x:Key="AccentAmber" Color="#F59E0B"/>
        <SolidColorBrush x:Key="AccentRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#8B5CF6"/>

        <!-- STYLES -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="TileLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="TileValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="64"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="TileSubtitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Główne kafelki -->
            <RowDefinition Height="Auto"/>
            <!-- Hodowcy banner -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ═══════════════ HEADER ═══════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🐔" FontSize="42" VerticalAlignment="Center"/>
                    <TextBlock Text="PIÓRKOWSCY"
                               FontSize="38" FontWeight="Black"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" • HALA LIVE"
                               FontSize="28" FontWeight="Light"
                               Foreground="{StaticResource AccentGreen}"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="DateSubtitle"
                           Text="—"
                           FontSize="18"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="4,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock x:Name="ClockText"
                           Text="00:00:00"
                           FontSize="64" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Right"/>
                <TextBlock x:Name="WeekdayText"
                           Text="—"
                           FontSize="18"
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Right"
                           Margin="0,-8,4,0"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════ GŁÓWNA SIATKA KAFELKÓW ═══════════════ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- WIERSZ 1: PROGRESS BAR PLANU (4 kolumny) -->
            <Border Grid.Row="0" Grid.ColumnSpan="4"
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,0,20"
                    Padding="32,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PLAN DZIŚ — PRZYCHÓD ŻYWCA"
                                   Style="{StaticResource TileLabel}"/>
                        <Grid Margin="0,12,0,0">
                            <Border Background="#1E293B" CornerRadius="8" Height="28"/>
                            <Border x:Name="PlanProgressBar"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource AccentGreen}"
                                    CornerRadius="8"
                                    Height="28"
                                    Width="0"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="32,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="PlanPercentText"
                                   Text="0%"
                                   FontSize="48" FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreen}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock x:Name="PlanKgText"
                                   Text="0 / 200 t"
                                   FontSize="16"
                                   Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Right"
                                   Margin="0,-6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- WIERSZ 2: 4 KAFELKI -->
            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👥 " FontSize="24"/>
                        <TextBlock Text="PRACOWNICY" Style="{StaticResource TileLabel}"/>
                    </StackPanel>
                    <TextBlock x:Name="PracownicyText" Text="—" Style="{StaticResource TileValue}"
                               Foreground="{StaticResource AccentBlue}"/>
                    <TextBlock Text="osób w pracy" Style="{StaticResource TileSubtitle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="10,0,10,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🐔 " FontSize="24"/>
                        <TextBlock Text="ŻYWIEC DZIŚ" Style="{StaticResource TileLabel}"/>
                    </StackPanel>
                    <TextBlock x:Name="ZywiecText" Text="—" Style="{StaticResource TileValue}"
                               Foreground="{StaticResource AccentGreen}"/>
                    <TextBlock x:Name="ZywiecSubText" Text="ton" Style="{StaticResource TileSubtitle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CardBorder}" Margin="10,0,10,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📦 " FontSize="24"/>
                        <TextBlock Text="WYDANIA DZIŚ" Style="{StaticResource TileLabel}"/>
                    </StackPanel>
                    <TextBlock x:Name="WydaniaText" Text="—" Style="{StaticResource TileValue}"
                               Foreground="{StaticResource AccentPurple}"/>
                    <TextBlock x:Name="WydaniaSubText" Text="ton" Style="{StaticResource TileSubtitle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="3" Style="{StaticResource CardBorder}" Margin="10,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚛 " FontSize="24"/>
                        <TextBlock Text="DOSTAWY DZIŚ" Style="{StaticResource TileLabel}"/>
                    </StackPanel>
                    <TextBlock x:Name="DostawyText" Text="—" Style="{StaticResource TileValue}"
                               Foreground="{StaticResource AccentAmber}"/>
                    <TextBlock Text="hodowców" Style="{StaticResource TileSubtitle}"/>
                </StackPanel>
            </Border>

            <!-- WIERSZ 3: 4 KAFELKI -->
            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,10,10,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊 " FontSize="24"/>
                        <TextBlock Text="KLASY DROBIU" Style="{StaticResource TileLabel}"/>
                    </StackPanel>
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DUŻY (4-7)"
                                       Foreground="{StaticResource TextSecondary}" FontSize="14"/>
                            <TextBlock x:Name="KlasaDuzyText" Grid.Row="0" Grid.Column="1" Text="—"
                                       Foreground="{StaticResource AccentBlue}"
                                       FontSize="22" FontWeight="Bold"/>
                            <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,6,0,12">
                                <Border Background="#1E293B" CornerRadius="4" Height="10"/>
                                <Border x:Name="KlasaDuzyBar"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource AccentBlue}"
                                        CornerRadius="4" Height="10" Width="0"/>
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="MAŁY (8-12)"
                                       Foreground="{StaticResource TextSecondary}" FontSize="14"/>
                            <TextBlock x:Name="KlasaMalyText" Grid.Row="0" Grid.Column="1" Text="—"
                                       Foreground="{StaticResource AccentAmber}"
                                       FontSize="22" FontWeight="Bold"/>
                            <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,6,0,0">
                                <Border Background="#1E293B" CornerRadius="4" Height="10"/>
                                <Border x:Name="KlasaMalyBar"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource AccentAmber}"
                                        CornerRadius="4" Height="10" Width="0"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="10,10,10,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📥 " FontSize="24"/>
                        <TextBlock Text="PARTIE DZIŚ" Style="{StaticResource TileLabel}"/>
                    </StackPanel>
                    <TextBlock x:Name="PaletyText" Text="—" Style="{StaticResource TileValue}"
                               Foreground="{StaticResource AccentPurple}"/>
                    <TextBlock x:Name="PaletySubText" Text="partii" Style="{StaticResource TileSubtitle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource CardBorder}" Margin="10,10,10,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📜 " FontSize="24"/>
                        <TextBlock Text="DOKUMENTY WZ" Style="{StaticResource TileLabel}"/>
                    </StackPanel>
                    <TextBlock x:Name="DokumentyText" Text="—" Style="{StaticResource TileValue}"
                               Foreground="{StaticResource AccentBlue}"/>
                    <TextBlock Text="wystawione" Style="{StaticResource TileSubtitle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="3" Style="{StaticResource CardBorder}" Margin="10,10,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚖️ " FontSize="24"/>
                        <TextBlock Text="WAŻENIA DZIŚ" Style="{StaticResource TileLabel}"/>
                    </StackPanel>
                    <TextBlock x:Name="WazeniaText" Text="—" Style="{StaticResource TileValue}"
                               Foreground="{StaticResource AccentGreen}"/>
                    <TextBlock Text="wpisów In0E" Style="{StaticResource TileSubtitle}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════ HODOWCY BANNER ═══════════════ -->
        <Border Grid.Row="2"
                Style="{StaticResource CardBorder}"
                Margin="0,24,0,0"
                Padding="32,20">
            <StackPanel>
                <TextBlock Text="🏆 TOP HODOWCY DZIŚ" Style="{StaticResource TileLabel}"/>
                <TextBlock x:Name="HodowcyText"
                           Text="—"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════ FOOTER ═══════════════ -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="10" Height="10" Fill="{StaticResource AccentGreen}" Margin="0,0,8,0"/>
                <TextBlock x:Name="StatusText" Text="Ładowanie..."
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="13"/>
            </StackPanel>

            <TextBlock Grid.Column="1" x:Name="LastUpdateText"
                       Text="—"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="2"
                       Text="ESC — wyjście  •  F11 — pełen ekran"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="13"
                       VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
