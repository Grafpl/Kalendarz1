<Window x:Class="Kalendarz1.MarketIntelligence.Views.BriefingOnePagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📋 Briefing dnia — One-Pager"
        Width="1100" Height="780"
        WindowStartupLocation="CenterScreen"
        Background="#15120D"
        Foreground="#D5CCC0"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D5CCC0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="Hdr1" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#F5EDE0"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Hdr2" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#C9A96E"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="HdrCritical" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#E85D5D"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="Subtle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#7A6F63"/>
        </Style>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="#2A2520"/>
            <Setter Property="Foreground" Value="#D5CCC0"/>
            <Setter Property="BorderBrush" Value="#3F3830"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="MoodBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1F1A14" Padding="24,16" BorderBrush="#3F3830" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="txtHeadline" Style="{StaticResource Hdr1}" Text="Brak danych — uruchom fetch"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock x:Name="txtDate" Style="{StaticResource Subtle}" Text=""/>
                        <TextBlock Text="  •  " Style="{StaticResource Subtle}"/>
                        <TextBlock x:Name="txtArticlesAnalyzed" Style="{StaticResource Subtle}" Text=""/>
                        <TextBlock Text="  •  " Style="{StaticResource Subtle}"/>
                        <Border x:Name="moodBadge" Style="{StaticResource MoodBadge}" Background="#3F3830">
                            <TextBlock x:Name="txtMood" Text="?" Foreground="#F5EDE0" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="txtSeverityCounts" Style="{StaticResource Subtle}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource ToolBtn}" Content="📋 Kopiuj" Click="BtnCopy_Click" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource ToolBtn}" Content="💾 Zapisz MD" Click="BtnExportMd_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BODY -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16,24,16">
            <StackPanel>

                <!-- TOP 3 KRYTYCZNE -->
                <TextBlock Style="{StaticResource HdrCritical}" Text="🔴 TOP 3 KRYTYCZNE DZIŚ"/>
                <ItemsControl x:Name="lstCritical">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1F1A14" BorderBrush="#5A2828" BorderThickness="1" CornerRadius="4" Padding="14,10" Margin="0,0,0,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Background="#E85D5D" CornerRadius="2" Padding="6,2" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Severity}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Text="{Binding Category}" Foreground="#C9A96E" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Text="  •  " Foreground="#7A6F63" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SourceName}" Foreground="#7A6F63" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Title}" Foreground="#F5EDE0" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding WhatItMeans}" Foreground="#D5CCC0" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="txtNoCritical" Text="Brak krytycznych alertów dziś." Style="{StaticResource Subtle}" Visibility="Collapsed"/>

                <!-- CO ROBIĆ DZIŚ -->
                <TextBlock Style="{StaticResource Hdr2}" Text="📋 CO ROBIĆ DZIŚ (top 5 action items)"/>
                <ItemsControl x:Name="lstActions">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{Binding PriorityColor}" CornerRadius="2" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Priority}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="{Binding Owner}" Foreground="#C9A96E" FontSize="12" FontWeight="SemiBold" Margin="0,0,12,0" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="2" Text="{Binding Action}" Foreground="#D5CCC0" FontSize="12"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="txtNoActions" Text="Brak action items — uruchom pełne pobranie." Style="{StaticResource Subtle}" Visibility="Collapsed"/>

                <!-- STRESZCZENIA -->
                <TextBlock Style="{StaticResource Hdr2}" Text="🎯 Streszczenia rolowe"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#1F1A14" CornerRadius="4" Padding="12,10" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="👔 CEO" Foreground="#C9A96E" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtCeo" Text="—" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#1F1A14" CornerRadius="4" Padding="12,10" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="💼 Sales" Foreground="#C9A96E" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtSales" Text="—" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#1F1A14" CornerRadius="4" Padding="12,10" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="🛒 Buyer" Foreground="#C9A96E" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtBuyer" Text="—" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- TYDZIEŃ -->
                <TextBlock Style="{StaticResource Hdr2}" Text="📅 Prognoza tygodniowa"/>
                <Border Background="#1F1A14" CornerRadius="4" Padding="14,10">
                    <TextBlock x:Name="txtWeekly" Text="—" FontSize="12"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="#1F1A14" Padding="24,8" BorderBrush="#3F3830" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="txtFooter" Style="{StaticResource Subtle}" HorizontalAlignment="Left" VerticalAlignment="Center" Text=""/>
                <Button HorizontalAlignment="Right" Style="{StaticResource ToolBtn}" Content="Zamknij" Click="BtnClose_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
