<Window x:Class="Kalendarz1.MarketIntelligence.Views.PorannyBriefingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kalendarz1.MarketIntelligence.Views"
        xmlns:vm="clr-namespace:Kalendarz1.MarketIntelligence.ViewModels"
        xmlns:models="clr-namespace:Kalendarz1.MarketIntelligence.Models"
        Title="Centrum Wiadomości AI - Piorkowscy"
        Height="900" Width="1400"
        MinHeight="650" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#0C0A07">

    <Window.DataContext>
        <vm:PorannyBriefingViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/BriefingStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <local:SeverityToColorConverter x:Key="SeverityToColor"/>
            <local:SeverityToBgConverter x:Key="SeverityToBg"/>
            <local:RoleBasedAnalysisConverter x:Key="RoleAnalysisConverter"/>

            <Style x:Key="ToolbarBtn" TargetType="Button">
                <Setter Property="Background" Value="#2A2520"/>
                <Setter Property="Foreground" Value="#D5CCC0"/>
                <Setter Property="BorderBrush" Value="#3F3830"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="14,7"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Margin" Value="0,0,8,0"/>
            </Style>
            <Style x:Key="ToolbarBtnPrimary" TargetType="Button" BasedOn="{StaticResource ToolbarBtn}">
                <Setter Property="Background" Value="#3D2F1F"/>
                <Setter Property="Foreground" Value="#F5EDE0"/>
                <Setter Property="BorderBrush" Value="#C9A96E"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>
            <Style x:Key="ChatQuickBtn" TargetType="Button">
                <Setter Property="Background" Value="#2A2520"/>
                <Setter Property="Foreground" Value="#D5CCC0"/>
                <Setter Property="BorderBrush" Value="#3F3830"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="9,5"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Margin" Value="0,0,6,6"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#15120D" BorderBrush="#2A2520" BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="📰 Wiadomości z branży" FontFamily="Georgia" FontSize="19" FontWeight="Bold" Foreground="#F5EDE0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="{Binding TotalArticles, StringFormat={}{0} newsów}" FontSize="10" Foreground="#7A6F63"/>
                        <TextBlock Text="  ·  " FontSize="10" Foreground="#5A5248"/>
                        <TextBlock Text="{Binding CriticalCount, StringFormat=🔴 {0} ważnych}" FontSize="10" Foreground="#A8726B"/>
                        <!-- Loading -->
                        <TextBlock Text="{Binding LoadingStatus}" FontSize="10" Foreground="#C9A96E" Margin="14,0,0,0"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                   MaxWidth="280" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>

                <!-- Toolbar: minimal -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnRefresh" Style="{StaticResource ToolbarBtnPrimary}"
                            Content="🔄 Pobierz nowe" Command="{Binding RefreshFromInternetCommand}"
                            ToolTip="Pobierz najnowsze wiadomości z internetu (~3-5 min)"/>
                    <Button x:Name="btnOnePager" Style="{StaticResource ToolbarBtn}"
                            Content="📋 Podsumowanie" Click="btnOnePager_Click"
                            ToolTip="Esencja dnia: TOP 3 ważne + co robić + chat AI"/>
                    <Button x:Name="btnChatToggle" Style="{StaticResource ToolbarBtn}"
                            Content="💬 Zapytaj AI" Click="BtnChatToggle_Click"
                            ToolTip="Otwórz/schowaj asystenta AI (zna wszystkie newsy i firmę)"/>
                    <Button x:Name="btnMore" Style="{StaticResource ToolbarBtn}"
                            Content="⚙ Więcej ▾" Click="BtnMore_Click"
                            ToolTip="Źródła, tematy, diagnostyka, pomoc">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="moreMenu">
                                <MenuItem Header="🌐 Moje źródła" Click="btnSources_Click"/>
                                <MenuItem Header="🎯 Moje tematy" Click="btnQueries_Click"/>
                                <Separator/>
                                <MenuItem Header="🛠 Diagnostyka" Click="btnDiagnostics_Click"/>
                                <MenuItem Header="❓ Jak to działa?" Click="btnHelp_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ BODY: News (left) | Chat (right, chowany) ═══ -->
        <Grid Grid.Row="1" Margin="16,14,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="chatGap" Width="0"/>
                <ColumnDefinition x:Name="chatCol" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ NEWS ═══ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filtry (prostsze: 5 kategorii + szukaj) -->
                <Border Grid.Row="0" Background="#15120D" CornerRadius="6,6,0,0" BorderBrush="#2A2520" BorderThickness="1,1,1,0" Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <ToggleButton Content="Wszystkie" IsChecked="True" Style="{StaticResource FilterButton}" Click="FilterButton_Click" Tag="Wszystkie"/>
                            <ToggleButton Content="HPAI" Margin="4,0,0,0" Style="{StaticResource FilterButton}" Click="FilterButton_Click" Tag="HPAI"/>
                            <ToggleButton Content="Ceny" Margin="4,0,0,0" Style="{StaticResource FilterButton}" Click="FilterButton_Click" Tag="Ceny"/>
                            <ToggleButton Content="Konkurencja" Margin="4,0,0,0" Style="{StaticResource FilterButton}" Click="FilterButton_Click" Tag="Konkurencja"/>
                            <ToggleButton Content="Klienci" Margin="4,0,0,0" Style="{StaticResource FilterButton}" Click="FilterButton_Click" Tag="Klienci"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Grid Width="170">
                                <TextBox x:Name="txtSearch" Style="{StaticResource SearchTextBox}" TextChanged="SearchBox_TextChanged"/>
                                <TextBlock Text="Szukaj..." IsHitTestVisible="False" Foreground="#5A5248" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Lista newsów -->
                <Border Grid.Row="1" Background="#15120D" CornerRadius="0,0,6,6" BorderBrush="#2A2520" BorderThickness="1,0,1,1">
                    <Grid>
                        <!-- Empty state -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding TotalArticles, Converter={StaticResource InverseBoolToVis}}">
                            <TextBlock Text="📭" FontSize="42" HorizontalAlignment="Center" Opacity="0.5"/>
                            <TextBlock Text="Brak newsów" FontSize="16" Foreground="#7A6F63" HorizontalAlignment="Center" Margin="0,10,0,4"/>
                            <TextBlock Text="Kliknij 🔄 Pobierz nowe u góry" FontSize="12" Foreground="#5A5248" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <ScrollViewer Style="{StaticResource BriefingScrollViewer}" VerticalScrollBarVisibility="Auto" Padding="12">
                            <ItemsControl x:Name="icArticles" ItemsSource="{Binding FilteredArticles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ArticleCard}" MouseLeftButtonUp="Article_Click">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" CornerRadius="2,0,0,2" Background="{Binding Severity, Converter={StaticResource SeverityToColor}}"/>

                                                <StackPanel Grid.Column="1" Margin="14,12,12,12">
                                                    <!-- ═ Collapsed ═ -->
                                                    <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource InverseBoolToVis}}">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                            <Ellipse Width="6" Height="6" Fill="{Binding Severity, Converter={StaticResource SeverityToColor}}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="SemiBold" Foreground="#C9A96E"/>
                                                            <TextBlock Text=" · " Foreground="#5A5248"/>
                                                            <TextBlock Text="{Binding Source}" FontSize="10" Foreground="#7A6F63"/>
                                                            <!-- 🤖 badge tylko gdy ma analizę AI -->
                                                            <Border Background="#1E1A14" CornerRadius="3" Padding="5,1" Margin="8,0,0,0"
                                                                    Visibility="{Binding HasAiAnalysis, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="🤖 AI" FontSize="8" Foreground="#C9A96E"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Title}" Style="{StaticResource SerifArticleTitle}" Margin="0,0,0,4"/>
                                                        <TextBlock Text="{Binding ShortPreview}" Style="{StaticResource PreviewText}"/>
                                                        <!-- data dodania do bazy -->
                                                        <TextBlock Text="{Binding AddedToDbDisplay}" FontSize="9" Foreground="#5A5248" Margin="0,6,0,0"/>
                                                    </StackPanel>

                                                    <!-- ═ Expanded ═ -->
                                                    <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                            <Border Background="{Binding Severity, Converter={StaticResource SeverityToBg}}" CornerRadius="3" Padding="8,3">
                                                                <TextBlock Text="{Binding SeverityText}" FontSize="9" FontWeight="Bold" Foreground="{Binding Severity, Converter={StaticResource SeverityToColor}}"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="SemiBold" Foreground="#C9A96E" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text=" · " Foreground="#5A5248" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Source}" FontSize="10" Foreground="#7A6F63" VerticalAlignment="Center"/>
                                                        </StackPanel>

                                                        <TextBlock Text="{Binding Title}" Style="{StaticResource SerifArticleTitleFeatured}" Margin="0,0,0,4"/>
                                                        <!-- daty: publikacji + dodania do bazy -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                            <TextBlock Text="{Binding FormattedDate, StringFormat=📅 publikacja {0}}" FontSize="9" Foreground="#5A5248"/>
                                                            <TextBlock Text="   ·   " FontSize="9" Foreground="#5A5248"/>
                                                            <TextBlock Text="{Binding AddedToDbDisplay}" FontSize="9" Foreground="#5A5248"/>
                                                        </StackPanel>

                                                        <TextBlock Text="{Binding FullContent}" Style="{StaticResource BodyText}" Margin="0,0,0,16"/>

                                                        <!-- Educational — tylko gdy jest -->
                                                        <Border Background="#1E1A14" CornerRadius="6" Padding="14" Margin="0,0,0,16" BorderBrush="#2A2520" BorderThickness="1"
                                                                Visibility="{Binding HasEducational, Converter={StaticResource BoolToVis}}">
                                                            <StackPanel>
                                                                <TextBlock Text="ℹ KIM JEST / CO TO JEST" FontSize="9" FontWeight="Bold" Foreground="#8B7355" Margin="0,0,0,8"/>
                                                                <TextBlock Text="{Binding EducationalSection}" Style="{StaticResource BodyTextSmall}" Foreground="#D5CCC0"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- Analiza AI — tylko gdy jest -->
                                                        <Border Background="#1E1A14" CornerRadius="6" Padding="14" Margin="0,0,0,16" BorderBrush="#C9A96E" BorderThickness="0,0,0,2"
                                                                Visibility="{Binding HasAiAnalysis, Converter={StaticResource BoolToVis}}">
                                                            <StackPanel>
                                                                <TextBlock Text="🤖 ANALIZA AI — CO TO ZNACZY DLA PIORKOWSCY" FontSize="9" FontWeight="Bold" Foreground="#C9A96E" Margin="0,0,0,8"/>
                                                                <TextBlock Style="{StaticResource BodyTextSmall}" FontStyle="Italic" Foreground="#F5EDE0" TextWrapping="Wrap">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding Converter="{StaticResource RoleAnalysisConverter}" ConverterParameter="Analysis">
                                                                            <Binding/>
                                                                            <Binding Path="DataContext.CurrentRole" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                                <StackPanel Visibility="{Binding HasActions, Converter={StaticResource BoolToVis}}">
                                                                    <TextBlock Text="ZALECANE DZIALANIA:" FontSize="9" FontWeight="Bold" Foreground="#8B7355" Margin="0,12,0,6"/>
                                                                    <TextBlock Style="{StaticResource BodyTextSmall}" Foreground="#D5CCC0" TextWrapping="Wrap">
                                                                        <TextBlock.Text>
                                                                            <MultiBinding Converter="{StaticResource RoleAnalysisConverter}" ConverterParameter="Actions">
                                                                                <Binding/>
                                                                                <Binding Path="DataContext.CurrentRole" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- Source link -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                            <TextBlock Text="🔗 Źródło: " Foreground="#7A6F63" FontSize="11"/>
                                                            <TextBlock>
                                                                <Hyperlink Style="{StaticResource SourceLink}" NavigateUri="{Binding SourceUrl}" RequestNavigate="Hyperlink_RequestNavigate">
                                                                    <Run Text="{Binding SourceUrl}"/>
                                                                </Hyperlink>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ CHAT (chowany — domyślnie width 0) ═══ -->
            <Border Grid.Column="2" x:Name="chatPanel" Background="#15120D" CornerRadius="6" BorderBrush="#2A2520" BorderThickness="1" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1F1A14" CornerRadius="6,6,0,0" Padding="14,10" BorderBrush="#2A2520" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="💬 Asystent AI" FontSize="14" FontWeight="SemiBold" Foreground="#F5EDE0"/>
                                <TextBlock Text="Zna newsy, firmę i historię" FontSize="10" Foreground="#7A6F63" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="✕" Click="BtnChatToggle_Click" Background="Transparent" Foreground="#7A6F63"
                                    BorderThickness="0" FontSize="14" Cursor="Hand" Padding="6,0" ToolTip="Schowaj chat"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Padding="12,10,12,4">
                        <WrapPanel>
                            <Button Content="🦠 HPAI?" Style="{StaticResource ChatQuickBtn}" Click="BtnQuickPrompt_Click"
                                    Tag="Czy HPAI mnie zagraża dziś? Spójrz na ostatnie 7 dni ognisk, szczególnie łódzkie i sąsiednie. Konkretnie TAK/NIE + 1 akcja."/>
                            <Button Content="💰 Ceny żywca" Style="{StaticResource ChatQuickBtn}" Click="BtnQuickPrompt_Click"
                                    Tag="Co dzieje się z cenami skupu żywca drobiowego? Liczby z ostatnich artykułów. Czy mam ruszać nasze 4.72 zł/kg?"/>
                            <Button Content="🏢 Cedrob" Style="{StaticResource ChatQuickBtn}" Click="BtnQuickPrompt_Click"
                                    Tag="Co dzieje się z Cedrob i przejęciem przez ADQ? Status, ryzyko dla nas, scenariusze."/>
                            <Button Content="📊 Esencja" Style="{StaticResource ChatQuickBtn}" Click="BtnQuickPrompt_Click"
                                    Tag="Daj mi esencję ostatnich 7 dni w MAKSYMALNIE 3 zdaniach. Konkretne liczby, konkretne akcje."/>
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="2" Background="#0C0A07" BorderBrush="#2A2520" BorderThickness="0,1,0,1" Margin="0,4,0,0">
                        <ScrollViewer x:Name="chatScroll" VerticalScrollBarVisibility="Auto" Padding="10,8">
                            <ItemsControl x:Name="lstChat">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding BgColor}" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Author}" Foreground="{Binding AuthorColor}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding Content}" Foreground="#F5EDE0" FontSize="12" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="3" Padding="12,10" Background="#15120D" CornerRadius="0,0,6,6">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtChatInput" Grid.Column="0" Background="#0C0A07" Foreground="#F5EDE0"
                                         BorderBrush="#3F3830" BorderThickness="1" Padding="10,8" FontSize="12" CaretBrush="#F5EDE0"
                                         TextWrapping="Wrap" AcceptsReturn="False" KeyDown="TxtChatInput_KeyDown"
                                         ToolTip="Enter wysyła"/>
                                <Button x:Name="btnChatSend" Grid.Column="1" Content="➤" Click="BtnChatSend_Click"
                                        Background="#3D2F1F" Foreground="#F5EDE0" BorderBrush="#C9A96E" BorderThickness="1"
                                        Padding="12,8" FontSize="12" Cursor="Hand" Margin="8,0,0,0"/>
                            </Grid>
                            <TextBlock x:Name="txtChatStatus" Text="" FontSize="10" Foreground="#7A6F63" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
