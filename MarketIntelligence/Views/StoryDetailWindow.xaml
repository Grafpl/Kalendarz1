<Window x:Class="Kalendarz1.MarketIntelligence.Views.StoryDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🧵 Wątek"
        Width="760" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#15120D" Foreground="#D5CCC0" FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F1A14" Padding="22,16" BorderBrush="#3F3830" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock x:Name="txtMeta" FontSize="11" Foreground="#7A6F63"/>
                <TextBlock x:Name="txtTitle" FontSize="19" FontWeight="Bold" Foreground="#F5EDE0" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,16">
            <StackPanel>
                <Border x:Name="impactBox" Background="#1C2017" CornerRadius="4" Padding="14,10" Margin="0,0,0,16" BorderBrush="#3A4A30" BorderThickness="0,0,0,2" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="💼 CO TO ZNACZY DLA PIÓRKOWSCY" FontSize="10" FontWeight="Bold" Foreground="#8FB87A" Margin="0,0,0,6"/>
                        <TextBlock x:Name="txtImpact" Foreground="#E8F0E0" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="📖 PRZEBIEG WĄTKU" FontSize="10" FontWeight="Bold" Foreground="#8B7355" Margin="0,0,0,6"/>
                <TextBlock x:Name="txtDigest" Foreground="#D5CCC0" FontSize="13" TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,18"/>

                <TextBlock Text="📎 ARTYKUŁY ŹRÓDŁOWE" FontSize="10" FontWeight="Bold" Foreground="#8B7355" Margin="0,0,0,8"/>
                <ItemsControl x:Name="lstArticles">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1611" CornerRadius="4" Padding="10,8" Margin="0,0,0,6" BorderBrush="#2A2520" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="{Binding SourceName}" FontSize="10" Foreground="#C9A96E"/>
                                        <TextBlock Text=" · " FontSize="10" Foreground="#5A5248"/>
                                        <TextBlock Text="{Binding DateDisplay}" FontSize="10" Foreground="#5A5248"/>
                                    </StackPanel>
                                    <TextBlock>
                                        <Hyperlink NavigateUri="{Binding Url}" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#D5CCC0">
                                            <Run Text="{Binding Title}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#1F1A14" Padding="22,10" BorderBrush="#3F3830" BorderThickness="0,1,0,0">
            <Button HorizontalAlignment="Right" Content="Zamknij" Click="BtnClose_Click"
                    Background="#3D2F1F" Foreground="#F5EDE0" BorderBrush="#C9A96E" BorderThickness="1"
                    Padding="20,7" FontSize="12" Cursor="Hand"/>
        </Border>
    </Grid>
</Window>
