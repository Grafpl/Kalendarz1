<Window x:Class="Kalendarz1.ZSRIR.Views.ZsrirDebugDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZSRIR — Debugger"
        Width="1180" Height="860"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#F2F4F7"
        FontFamily="Segoe UI"
        UseLayoutRounding="True">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#7B1FA2"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5B6772"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8B95A0"/>
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="#EAEDF0"/>
        <SolidColorBrush x:Key="CodeBgBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="CodeFgBrush" Color="#D4D4D4"/>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D32F2F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LblKey" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="LblVal" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D7DBE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="4" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F7FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#7B1FA2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#7B1FA2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6A1B9A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MegaButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1B5E20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1B5E20"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#D7DBE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="CodeBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Background" Value="{StaticResource CodeBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource CodeFgBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="ApplicationCommands.Close"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="🐛" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="ZSRIR Debugger" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblOkres" Text="" FontSize="12" Foreground="#E1BEE7" VerticalAlignment="Center" Margin="14,0,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource CloseButton}" Click="BtnClose_Click">
                    <Path Width="10" Height="10" Stretch="Uniform" Stroke="White" StrokeThickness="1.4"
                          Data="M 0,0 L 10,10 M 10,0 L 0,10"/>
                </Button>
            </Grid>
        </Border>

        <!-- TOP MEGA BAR -->
        <Border Grid.Row="1" Background="#FFFDE7" BorderBrush="#FBC02D" BorderThickness="0,0,0,2" Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="📤 Wysyłka diagnostyki" FontWeight="Bold" FontSize="13" Foreground="#5D4037"/>
                    <TextBlock x:Name="lblMegaHint" FontSize="11.5" Foreground="#6D4C41" Margin="0,2,0,0"
                               Text="Kliknij jeden guzik → cała diagnostyka (kontekst, IDs, payload, response, raw API) do schowka jako markdown."/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnCopyAll" Style="{StaticResource MegaButton}" Click="BtnCopyAll_Click" MinWidth="280" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋 " FontSize="15"/>
                            <TextBlock Text="SKOPIUJ WSZYSTKO DLA CLAUDE"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnSaveAll" Style="{StaticResource ActionButton}" Click="BtnSaveAll_Click" ToolTip="Zapis do pliku .md na pulpicie">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾 " FontSize="13"/>
                            <TextBlock Text="Zapisz .md"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="14">
            <StackPanel>

                <!-- BANNER: brak okresów / brak konfiguracji -->
                <Border x:Name="bannerOstrzezenie" Background="#FFEBEE" BorderBrush="#C62828" BorderThickness="2" CornerRadius="6"
                        Padding="14" Margin="0,0,0,12" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="🚨 OSTRZEŻENIE Z API ZSRIR" FontWeight="Bold" FontSize="13" Foreground="#B71C1C"/>
                        <TextBlock x:Name="lblBannerTresc" TextWrapping="Wrap" FontSize="12" Foreground="#5D2424" Margin="0,6,0,0"
                                   Text=""/>
                    </StackPanel>
                </Border>


                <!-- Parametry + ID pól -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="📊 KALKULACJA (z HANDEL / Sage Symfonia — faktury skupu)" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Kategoria:" Style="{StaticResource LblKey}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="lblKategoria" Style="{StaticResource LblVal}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Okres:" Style="{StaticResource LblKey}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="lblOkres2" Style="{StaticResource LblVal}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="kg razem:" Style="{StaticResource LblKey}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="lblKg" Style="{StaticResource LblVal}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Wartość netto:" Style="{StaticResource LblKey}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="lblWartosc" Style="{StaticResource LblVal}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Cena (zł/kg):" Style="{StaticResource LblKey}"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="lblCenaKg" Style="{StaticResource LblVal}"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Tony (kg/1000):" Style="{StaticResource LblKey}"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="lblTony" Style="{StaticResource LblVal}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔧 KONFIGURACJA API" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <Button Grid.Column="1" Style="{StaticResource ActionButton}" Click="BtnReloadConfig_Click" Padding="8,3" FontSize="11">
                                    <TextBlock Text="↻ Odśwież z API"/>
                                </Button>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="32"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="32"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="FormId:" Style="{StaticResource LblKey}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="lblFormId" Style="{StaticResource LblVal}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="DataSupplierId:" Style="{StaticResource LblKey}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="lblDataSupplierId" Style="{StaticResource LblVal}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="FormReportingPeriodId:" Style="{StaticResource LblKey}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="lblFormReportingPeriodId" Style="{StaticResource LblVal}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="↳ Wybierz / wpisz ID:" Style="{StaticResource LblKey}"/>
                                <Grid Grid.Row="3" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" x:Name="cmbOkresManualny"
                                              SelectionChanged="CmbOkresManualny_SelectionChanged"
                                              VerticalAlignment="Center" Height="26" FontSize="11.5"
                                              ToolTip="Wybierz okres z listy zwróconej przez API"/>
                                    <TextBox Grid.Column="2" x:Name="txtRecznyPeriodId"
                                             TextChanged="TxtRecznyPeriodId_Changed"
                                             VerticalAlignment="Center" Height="26" FontSize="12"
                                             FontFamily="Cascadia Mono, Consolas, monospace"
                                             Padding="6,3" BorderBrush="#D7DBE0" BorderThickness="1"
                                             ToolTip="Wpisz ID ręcznie (jeśli MRiRW podało Ci numer telefonicznie)"
                                             Text=""/>
                                </Grid>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="CommodityGroup:" Style="{StaticResource LblKey}"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="lblCommodityGroupId" Style="{StaticResource LblVal}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="↳ Wybierz ręcznie:" Style="{StaticResource LblKey}"/>
                                <ComboBox Grid.Row="5" Grid.Column="1" x:Name="cmbKategoriaManualne"
                                          SelectionChanged="CmbKategoriaManualne_SelectionChanged"
                                          VerticalAlignment="Center" Height="26" FontSize="11.5"
                                          ToolTip="Wybierz ręcznie z kandydatów (kurcz/brojler)"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="PriceFieldId:" Style="{StaticResource LblKey}"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="lblPriceFieldId" Style="{StaticResource LblVal}"/>
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="AmountFieldId:" Style="{StaticResource LblKey}"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" x:Name="lblAmountFieldId" Style="{StaticResource LblVal}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Edytowalne wartości -->
                <Border Style="{StaticResource SectionCard}" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="✏️ WARTOŚCI DO WYSŁANIA (PL format, przecinek dziesiętny)"
                                       FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Button Grid.Column="1" Style="{StaticResource ActionButton}" Click="BtnReloadValues_Click" Padding="8,3" FontSize="11">
                                <TextBlock Text="↻ Przelicz z kalkulacji"/>
                            </Button>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="62"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Cena (zł/tona):" Style="{StaticResource LblKey}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtCenaTona" Style="{StaticResource EditBox}" TextChanged="EditValue_Changed"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="(np. 5099,12)" Style="{StaticResource LblKey}" Margin="10,0,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ilość (tony):" Style="{StaticResource LblKey}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtTony" Style="{StaticResource EditBox}" TextChanged="EditValue_Changed"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="(np. 5,291)" Style="{StaticResource LblKey}" Margin="10,0,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Komentarz (opcjonalny):" Style="{StaticResource LblKey}" VerticalAlignment="Top" Margin="0,6,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" x:Name="txtKomentarz"
                                     Style="{StaticResource EditBox}" TextChanged="EditValue_Changed"
                                     AcceptsReturn="True" TextWrapping="Wrap" Height="56" VerticalAlignment="Top" Margin="0,2,0,0"
                                     ToolTip="Trafi do MRiRW jako pole 'Komentarz' (id 270, Description). Użyj np. do informacji o korekcie."/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Payload + Response (side-by-side, kompaktowo) -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SectionCard}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="200"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="14,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📤 PAYLOAD" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Style="{StaticResource ActionButton}" Click="BtnCopyPayload_Click" Padding="8,3" FontSize="11">
                                    <TextBlock Text="📋 Kopiuj"/>
                                </Button>
                            </Grid>
                            <TextBox Grid.Row="1" x:Name="txtPayload" Style="{StaticResource CodeBox}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource SectionCard}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="200"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="14,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="📥 ODPOWIEDŹ" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <Border x:Name="badgeStatus" CornerRadius="3" Padding="8,2" Margin="10,0,0,0" Background="#ECEFF1" Visibility="Collapsed">
                                        <TextBlock x:Name="lblStatusCode" Text="" FontSize="11" FontWeight="SemiBold" Foreground="#37474F"/>
                                    </Border>
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource ActionButton}" Click="BtnCopyResponse_Click" Padding="8,3" FontSize="11">
                                    <TextBlock Text="📋 Kopiuj"/>
                                </Button>
                            </Grid>
                            <TextBox Grid.Row="1" x:Name="txtResponse" Style="{StaticResource CodeBox}"
                                     Text="(brak — kliknij '🚀 Wyślij próbnie')"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- TABS z surowymi danymi z API -->
                <Border Style="{StaticResource SectionCard}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="280"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="🔍 SUROWE DANE Z API (do diagnostyki — wszystko, co zwróciły GetReportingPeriods + GetFormConfiguration)"
                                   FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="14,12"/>
                        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="6">
                            <TabItem Header="Okresy (tabela)">
                                <TextBox x:Name="txtPeriodsTable" Style="{StaticResource CodeBox}"/>
                            </TabItem>
                            <TabItem Header="Kategorie (spłaszczone)">
                                <TextBox x:Name="txtCategoriesTable" Style="{StaticResource CodeBox}"/>
                            </TabItem>
                            <TabItem Header="Pola formularza">
                                <TextBox x:Name="txtFormFieldsTable" Style="{StaticResource CodeBox}"/>
                            </TabItem>
                            <TabItem Header="GetReportingPeriods (raw)">
                                <TextBox x:Name="txtPeriodsRaw" Style="{StaticResource CodeBox}"/>
                            </TabItem>
                            <TabItem Header="GetFormConfiguration (raw)">
                                <TextBox x:Name="txtConfigRaw" Style="{StaticResource CodeBox}"/>
                            </TabItem>
                            <TabItem Header="GetDataSuppliers (raw)">
                                <TextBox x:Name="txtSuppliersRaw" Style="{StaticResource CodeBox}"/>
                            </TabItem>
                            <TabItem Header="GetForms (raw)">
                                <TextBox x:Name="txtFormsRaw" Style="{StaticResource CodeBox}"/>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom action bar -->
        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0" Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="lblHint" VerticalAlignment="Center"
                           FontSize="11.5" Foreground="{StaticResource TextMutedBrush}"
                           Text="Tip: 'Wyślij próbnie' robi REALNĄ wysyłkę. UWAŻAJ z kategorią — może być gęś/indyk."/>

                <!-- Karta kontaktowa MRiRW -->
                <Border Grid.Column="1" Background="#E3F2FD" BorderBrush="#1565C0" BorderThickness="1" CornerRadius="4"
                        Padding="8,4" Margin="0,0,10,0" VerticalAlignment="Center"
                        ToolTip="Kontakt MRiRW (Departament Rynków Rolnych)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📞" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <StackPanel>
                            <TextBlock Text="Małgorzata Czeczko" FontSize="10.5" FontWeight="SemiBold" Foreground="#0D47A1"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource ActionButton}" Padding="4,1" FontSize="10" Click="BtnCopyPhone_Click"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <TextBlock Text="22 623-16-06" Foreground="#1565C0" TextDecorations="Underline"/>
                                </Button>
                                <TextBlock Text=" · " FontSize="10" Foreground="#90CAF9" VerticalAlignment="Center"/>
                                <Button Style="{StaticResource ActionButton}" Padding="4,1" FontSize="10" Click="BtnCopyEmail_Click"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <TextBlock Text="malgorzata.czeczko@minrol.gov.pl" Foreground="#1565C0" TextDecorations="Underline"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="btnSendZero" Style="{StaticResource ActionButton}" Click="BtnSendZero_Click" MinWidth="120" Margin="0,0,8,0"
                            ToolTip="AddFormZero — formularz zerowy (zero skupu). Czasem odblokowuje zamknięty okres po stronie ZSRIR.">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="0️⃣ " FontSize="12"/>
                            <TextBlock Text="Wyślij ZERO"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnSendTest" Style="{StaticResource PrimaryButton}" Click="BtnSendTest_Click" MinWidth="160" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚀 " FontSize="13"/>
                            <TextBlock Text="Wyślij próbnie"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ActionButton}" Click="BtnClose_Click" MinWidth="100">
                        <TextBlock Text="Zamknij"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Border x:Name="overlay" Grid.RowSpan="4" Background="#80000000" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="6" Foreground="#7B1FA2" Background="#3A3A3A"/>
                <TextBlock x:Name="lblOverlayMsg" Text="Ładowanie..." Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="12"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
