<Window x:Class="Kalendarz1.ZSRIR.Views.ZsrirWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kalendarz1.ZSRIR.Views"
        Title="ZSRIR — wysyłka raportów do MRiRW"
        Width="1200" Height="780"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#F2F4F7"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2E7D32"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1B5E20"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#256528"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5B6772"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8B95A0"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D7DBE0"/>
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="#EAEDF0"/>
        <SolidColorBrush x:Key="OkBg" Color="#E8F5E9"/>
        <SolidColorBrush x:Key="OkFg" Color="#1B5E20"/>
        <SolidColorBrush x:Key="FailBg" Color="#FDEAEA"/>
        <SolidColorBrush x:Key="FailFg" Color="#B72A2A"/>
        <SolidColorBrush x:Key="PendingBg" Color="#FFF4E0"/>
        <SolidColorBrush x:Key="PendingFg" Color="#8A5500"/>

        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#27602A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F2F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7F9FB"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,11"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="SeparatorVisibility" Value="Collapsed"/>
        </Style>

        <Style x:Key="DgHeaderRight" TargetType="DataGridColumnHeader" BasedOn="{StaticResource DgHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>

        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F8FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NumCell" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="34"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{x:Static local:ZsrirWindow.CloseCmd}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="📡" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="ZSRIR" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" · Zintegrowany System Rolniczej Informacji Rynkowej · MRiRW"
                               FontSize="12" Foreground="#B7D5BB" VerticalAlignment="Center"/>
                    <Border x:Name="connBadge" Background="#27602A" CornerRadius="3" Padding="8,3" Margin="18,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" x:Name="connDot" Fill="#FFB400" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="lblConn" Text="Nieskonfigurowane" FontSize="11.5" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource CloseButton}" Click="BtnClose_Click" ToolTip="Zamknij (Esc)">
                    <Path Width="10" Height="10" Stretch="Uniform" Stroke="White" StrokeThickness="1.4"
                          Data="M 0,0 L 10,10 M 10,0 L 0,10"/>
                </Button>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="White" Padding="20,14" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Text="OKRES OD" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <DatePicker x:Name="dpFrom" Width="140" SelectedDateFormat="Short"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Text="OKRES DO" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <DatePicker x:Name="dpTo" Width="140" SelectedDateFormat="Short"/>
                    </StackPanel>
                    <Button Style="{StaticResource SecondaryButton}" Click="BtnPreviousWeek_Click"
                            VerticalAlignment="Bottom" Padding="11,7"
                            ToolTip="Wczytaj zakres poprzedniego tygodnia (Pon-Niedz)">
                        <TextBlock Text="⚡ Poprzedni tydzień"/>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Click="BtnRefreshPreview_Click"
                            VerticalAlignment="Bottom" Padding="11,7" Margin="6,0,0,0"
                            ToolTip="Przelicz podgląd raportu">
                        <TextBlock Text="🔄 Odśwież podgląd"/>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button x:Name="btnSettings" Style="{StaticResource SecondaryButton}" Click="BtnSettings_Click"
                            Padding="11,7" Margin="0,0,6,0" ToolTip="Konfiguracja API (login, hasło, dostawca)">
                        <TextBlock Text="⚙ Ustawienia"/>
                    </Button>
                    <Button x:Name="btnTest" Style="{StaticResource SecondaryButton}" Click="BtnTestConnection_Click"
                            Padding="11,7" Margin="0,0,6,0" ToolTip="Test logowania do API">
                        <TextBlock Text="🔌 Test połączenia"/>
                    </Button>
                    <Button x:Name="btnSend" Style="{StaticResource PrimaryButton}" Click="BtnSend_Click"
                            ToolTip="Wyślij raport do ZSRIR przez API">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📤" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Wyślij do ZSRIR"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Preview card — podgląd raportu który zostanie wysłany -->
        <Border Grid.Row="2" Background="White" Padding="20,16" Margin="20,16,20,0"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="6">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="📊 PODGLĄD RAPORTU" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="lblKategoria" Text="Kurczak typu Broiler" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="lblOkres" Text="—" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Kg" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="lblKg" Text="—" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="Tony" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="lblTony" Text="—" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <TextBlock Text="Wartość netto" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="lblWartosc" Text="—" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                    <TextBlock Text="Cena (do API)" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="lblCenaTona" Text="—" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}"/>
                    <TextBlock x:Name="lblCenaKg" Text="—" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Historia wysyłek -->
        <Border Grid.Row="3" Background="White" Margin="20,16,20,20"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#FAFBFC" Padding="18,10" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1" CornerRadius="6,6,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📜 Historia wysyłek" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblHistCount" Text="" FontSize="11.5"
                                   Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </Border>
                <DataGrid x:Name="dgHistory" Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False"
                          GridLinesVisibility="None" HeadersVisibility="Column" RowHeaderWidth="0"
                          Background="White" BorderThickness="0"
                          CellStyle="{StaticResource DgCell}" RowStyle="{StaticResource DgRow}"
                          ColumnHeaderStyle="{StaticResource DgHeader}"
                          SelectionMode="Single" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="OKRES" Width="170">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding OkresOd, StringFormat='dd.MM.yy'}" FontSize="12.5" FontWeight="SemiBold"/>
                                        <TextBlock Text=" – " FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding OkresDo, StringFormat='dd.MM.yy'}" FontSize="12.5" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="KATEGORIA" Binding="{Binding KategoriaTowaru}" Width="180"/>
                        <DataGridTextColumn Header="TONY" Binding="{Binding TonyRazem, StringFormat={}{0:N3}}" Width="100"
                                            HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                        <DataGridTextColumn Header="WARTOŚĆ" Binding="{Binding WartoscNetto, StringFormat={}{0:N2} zł}" Width="140"
                                            HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                        <DataGridTextColumn Header="CENA (zł/t)" Binding="{Binding CenaZlTona, StringFormat={}{0:N2}}" Width="120"
                                            HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                        <DataGridTemplateColumn Header="STATUS" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="8,2" HorizontalAlignment="Left"
                                            Background="{Binding StatusBg}">
                                        <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{Binding StatusFg}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="WYSŁAŁ" Binding="{Binding WyslanyPrzezImie}" Width="140"/>
                        <DataGridTextColumn Header="KIEDY" Binding="{Binding WyslanyDataCzas, StringFormat='yyyy-MM-dd HH:mm'}" Width="140"
                                            HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                        <DataGridTextColumn Header="BŁĄD" Binding="{Binding ErrorMessage}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Border x:Name="loadingOverlay" Grid.Row="0" Grid.RowSpan="4" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="6"/>
                <TextBlock x:Name="lblLoading" Text="Pracuję..." Margin="0,10,0,0" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
