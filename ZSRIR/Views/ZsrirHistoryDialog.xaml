<Window x:Class="Kalendarz1.ZSRIR.Views.ZsrirHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kalendarz1.ZSRIR.Views"
        Title="ZSRIR — historia wysyłek"
        Width="1100" Height="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#F2F4F7"
        FontFamily="Segoe UI"
        UseLayoutRounding="True">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1B5E20"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5B6772"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8B95A0"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D7DBE0"/>
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="#EAEDF0"/>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D32F2F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7F9FB"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,11"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="SeparatorVisibility" Value="Collapsed"/>
        </Style>

        <Style x:Key="DgHeaderRight" TargetType="DataGridColumnHeader" BasedOn="{StaticResource DgHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>

        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F8FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NumCell" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="ApplicationCommands.Close"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="📜" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Historia wysyłek ZSRIR" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblCount" Text="" FontSize="12" Foreground="#B7D5BB" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource CloseButton}" Click="BtnClose_Click">
                    <Path Width="10" Height="10" Stretch="Uniform" Stroke="White" StrokeThickness="1.4"
                          Data="M 0,0 L 10,10 M 10,0 L 0,10"/>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" Margin="16" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="6">
            <DataGrid x:Name="dgHistory" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False"
                      GridLinesVisibility="None" HeadersVisibility="Column" RowHeaderWidth="0"
                      Background="White" BorderThickness="0"
                      CellStyle="{StaticResource DgCell}" RowStyle="{StaticResource DgRow}"
                      ColumnHeaderStyle="{StaticResource DgHeader}"
                      SelectionMode="Single" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="OKRES" Width="170">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding OkresOd, StringFormat='dd.MM.yy'}" FontSize="12.5" FontWeight="SemiBold"/>
                                    <TextBlock Text=" – " FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding OkresDo, StringFormat='dd.MM.yy'}" FontSize="12.5" FontWeight="SemiBold"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="KATEGORIA" Binding="{Binding KategoriaTowaru}" Width="180"/>
                    <DataGridTextColumn Header="TONY" Binding="{Binding TonyRazem, StringFormat={}{0:N3}}" Width="100"
                                        HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                    <DataGridTextColumn Header="WARTOŚĆ" Binding="{Binding WartoscNetto, StringFormat={}{0:N2} zł}" Width="140"
                                        HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                    <DataGridTextColumn Header="CENA (zł/t)" Binding="{Binding CenaZlTona, StringFormat={}{0:N2}}" Width="120"
                                        HeaderStyle="{StaticResource DgHeaderRight}" ElementStyle="{StaticResource NumCell}"/>
                    <DataGridTemplateColumn Header="STATUS" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="8,2" HorizontalAlignment="Left"
                                        Background="{Binding StatusBg}">
                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{Binding StatusFg}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="WYSŁAŁ" Binding="{Binding WyslanyPrzezImie}" Width="140"/>
                    <DataGridTextColumn Header="KIEDY" Binding="{Binding WyslanyDataCzas, StringFormat='yyyy-MM-dd HH:mm'}" Width="140"/>
                    <DataGridTextColumn Header="BŁĄD" Binding="{Binding ErrorMessage}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
