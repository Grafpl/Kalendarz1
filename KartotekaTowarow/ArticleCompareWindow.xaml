<Window x:Class="Kalendarz1.KartotekaTowarow.ArticleCompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Porownanie artykulow" Width="900" Height="650"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style x:Key="HeaderCell" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style x:Key="LabelCell" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ValueCell" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F3F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E3A5F" Padding="16,12">
            <TextBlock Text="Porownanie artykulow" FontFamily="Segoe UI" FontSize="16"
                       FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Compare table -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                      Margin="12">
            <Border Background="White" CornerRadius="6" BorderBrush="#DEE2E6" BorderThickness="1"
                    ClipToBounds="True">
                <Grid x:Name="CompareGrid"/>
            </Border>
        </ScrollViewer>

        <!-- Bottom -->
        <Border Grid.Row="2" Background="#F0F3F7" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="TxtDiffCount" FontFamily="Segoe UI" FontSize="11"
                           Foreground="#E74C3C" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Content="  Zamknij  " FontFamily="Segoe UI" FontSize="12"
                        Background="#1E3A5F" Foreground="White" Padding="16,6"
                        BorderThickness="0" Cursor="Hand" Click="BtnClose_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
