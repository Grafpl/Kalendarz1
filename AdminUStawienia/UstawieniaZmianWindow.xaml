<Window x:Class="Kalendarz1.UstawieniaZmianWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ustawienia Zmian Zamówień"
        Width="900" Height="720"
        MinWidth="780" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- ═══ KOLORY ═══ -->
        <Color x:Key="BgDeep">#0d1117</Color>
        <Color x:Key="BgCard">#161b22</Color>
        <Color x:Key="BgInput">#0d1117</Color>
        <Color x:Key="BorderSubtle">#30363d</Color>
        <Color x:Key="TextPrimary">#e6edf3</Color>
        <Color x:Key="TextSecondary">#8b949e</Color>
        <Color x:Key="TextMuted">#484f58</Color>
        <Color x:Key="AccentBlue">#58a6ff</Color>
        <Color x:Key="AccentGreen">#3fb950</Color>
        <Color x:Key="AccentAmber">#f59e0b</Color>
        <Color x:Key="AccentRed">#f85149</Color>

        <SolidColorBrush x:Key="BrBgDeep" Color="{StaticResource BgDeep}"/>
        <SolidColorBrush x:Key="BrBgCard" Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="BrBgInput" Color="{StaticResource BgInput}"/>
        <SolidColorBrush x:Key="BrBorder" Color="{StaticResource BorderSubtle}"/>
        <SolidColorBrush x:Key="BrTextPrimary" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="BrTextSecondary" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="BrTextMuted" Color="{StaticResource TextMuted}"/>
        <SolidColorBrush x:Key="BrAccentBlue" Color="{StaticResource AccentBlue}"/>
        <SolidColorBrush x:Key="BrAccentGreen" Color="{StaticResource AccentGreen}"/>
        <SolidColorBrush x:Key="BrAccentAmber" Color="{StaticResource AccentAmber}"/>
        <SolidColorBrush x:Key="BrAccentRed" Color="{StaticResource AccentRed}"/>

        <!-- ═══ KARTA SEKCJI ═══ -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrBgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.18" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ NAGŁÓWEK SEKCJI ═══ -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
        </Style>
        <Style x:Key="SectionSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="{StaticResource BrTextMuted}"/>
            <Setter Property="Margin" Value="0,2,0,14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- ═══ ETYKIETA POLA ═══ -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrTextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>
        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrTextMuted}"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- ═══ POLE TEKSTOWE ═══ -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BrBgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource BrAccentBlue}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BrAccentBlue}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══ COMBOBOX ═══ -->
        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BrBgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ═══ CHECKBOX ═══ -->
        <Style x:Key="SettingCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ═══ TOGGLE SWITCH ═══ -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="38" Height="20" Margin="0,0,10,0">
                                <Border x:Name="track" CornerRadius="10" Background="#21262d" BorderBrush="#30363d" BorderThickness="1"/>
                                <Border x:Name="thumb" Width="14" Height="14" CornerRadius="7"
                                        Background="#8b949e" HorizontalAlignment="Left" Margin="3,0,21,0"
                                        VerticalAlignment="Center"/>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="#1a3fb950"/>
                                <Setter TargetName="track" Property="BorderBrush" Value="#3fb950"/>
                                <Setter TargetName="thumb" Property="Background" Value="#3fb950"/>
                                <Setter TargetName="thumb" Property="Margin" Value="21,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="track" Property="BorderBrush" Value="#58a6ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ PRZYCISKI ═══ -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2ea043"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#196c2e"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrBorder}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#30363d"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#8b949e"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#161b22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrAccentRed}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#40f85149"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#20f85149"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#80f85149"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#30f85149"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnIcon" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrTextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#21262d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ DZIEŃ TOGGLE ═══ -->
        <Style x:Key="DayToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrTextMuted}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" CornerRadius="6" Background="#21262d" BorderBrush="#30363d" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1a58a6ff"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#58a6ff"/>
                                <Setter Property="Foreground" Value="#58a6ff"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#58a6ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ROW SEPARATOR ═══ -->
        <Style x:Key="RowSep" TargetType="Border">
            <Setter Property="BorderBrush" Value="#1e30363d"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════ -->
    <!-- GŁÓWNY KONTENER (BORDERLESS WINDOW)            -->
    <!-- ═══════════════════════════════════════════════ -->
    <Border CornerRadius="10" Background="{StaticResource BrBgDeep}" BorderBrush="{StaticResource BrBorder}" BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>  <!-- Pasek tytułowy -->
                <RowDefinition Height="*"/>   <!-- Treść -->
                <RowDefinition Height="60"/>  <!-- Stopka -->
            </Grid.RowDefinitions>

            <!-- ═══ PASEK TYTUŁOWY ═══ -->
            <Border Grid.Row="0" Background="#161b22" BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="28" Height="28" CornerRadius="6" Background="#1a58a6ff" Margin="0,0,10,0">
                            <TextBlock Text="⚙" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Ustawienia zmian zamówień" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrTextPrimary}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtLastModified" FontSize="10.5" Foreground="{StaticResource BrTextMuted}"
                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource BtnIcon}" Content="—" Click="BtnMinimize_Click" ToolTip="Minimalizuj"/>
                        <Button Style="{StaticResource BtnIcon}" Content="✕" Click="BtnClose_Click" ToolTip="Zamknij" Margin="4,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ TREŚĆ GŁÓWNA ═══ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="20,16,20,8">

                    <!-- ═══ AKTYWNE REGUŁY — PODGLĄD ═══ -->
                    <Border Background="#0c1824" CornerRadius="8" Padding="16,12" Margin="0,0,0,16"
                            BorderBrush="#1a3060" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Powiadomienia od -->
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="POWIADOMIENIA OD" FontSize="9.5" FontWeight="Bold"
                                           Foreground="{StaticResource BrTextMuted}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource BrAccentGreen}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtPreviewGodzina" Text="11:00" FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource BrTextPrimary}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Blokada edycji -->
                            <StackPanel Grid.Column="1" Margin="12,0">
                                <TextBlock Text="BLOKADA EDYCJI" FontSize="9.5" FontWeight="Bold"
                                           Foreground="{StaticResource BrTextMuted}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="dotBlokada" Width="8" Height="8" Fill="{StaticResource BrTextMuted}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtPreviewBlokada" Text="Wyłączona" FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource BrTextSecondary}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Wyłączeni -->
                            <StackPanel Grid.Column="2" Margin="12,0,0,0">
                                <TextBlock Text="WYŁĄCZENI UŻYTKOWNICY" FontSize="9.5" FontWeight="Bold"
                                           Foreground="{StaticResource BrTextMuted}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource BrAccentAmber}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtPreviewWylaczeni" Text="0" FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource BrTextPrimary}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ═══ 2-KOLUMNOWY UKŁAD KART ═══ -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ▸ KARTA 1: Harmonogram (lewy-górny) -->
                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="🕐" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Harmonogram" Style="{StaticResource SectionTitle}"/>
                                </StackPanel>
                                <TextBlock Text="Godziny powiadomień, blokad i aktywne dni" Style="{StaticResource SectionSubtitle}"/>

                                <!-- Godzina powiadomień -->
                                <Border Style="{StaticResource RowSep}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Godzina powiadomień" Style="{StaticResource FieldLabel}"/>
                                            <TextBlock Text="Od tej godziny pojawiają się alerty" Style="{StaticResource FieldHint}"/>
                                        </StackPanel>
                                        <TextBox x:Name="txtGodzinaPowiadomien" Grid.Column="1" Style="{StaticResource InputBox}"
                                                 Width="72" Text="11:00" TextAlignment="Center" ToolTip="Format HH:mm"/>
                                    </Grid>
                                </Border>

                                <!-- Godzina blokady -->
                                <Border Style="{StaticResource RowSep}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Godzina blokady edycji" Style="{StaticResource FieldLabel}"/>
                                            <TextBlock Text="Puste = brak blokady" Style="{StaticResource FieldHint}"/>
                                        </StackPanel>
                                        <TextBox x:Name="txtGodzinaBlokady" Grid.Column="1" Style="{StaticResource InputBox}"
                                                 Width="72" TextAlignment="Center" ToolTip="Format HH:mm, puste = wyłączone"/>
                                    </Grid>
                                </Border>

                                <!-- Blokada toggle -->
                                <Border Style="{StaticResource RowSep}">
                                    <CheckBox x:Name="chkBlokadaEdycji" Style="{StaticResource ToggleSwitch}">
                                        <TextBlock Text="Blokuj edycję po godzinie" Style="{StaticResource FieldLabel}"/>
                                    </CheckBox>
                                </Border>

                                <!-- Aktywne dni -->
                                <StackPanel Margin="0,6,0,0">
                                    <TextBlock Text="Aktywne dni" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <ToggleButton x:Name="tglPon" Style="{StaticResource DayToggle}" Content="Pn" Margin="0,0,4,0"/>
                                        <ToggleButton x:Name="tglWt"  Style="{StaticResource DayToggle}" Content="Wt" Margin="0,0,4,0"/>
                                        <ToggleButton x:Name="tglSr"  Style="{StaticResource DayToggle}" Content="Śr" Margin="0,0,4,0"/>
                                        <ToggleButton x:Name="tglCzw" Style="{StaticResource DayToggle}" Content="Cz" Margin="0,0,4,0"/>
                                        <ToggleButton x:Name="tglPt"  Style="{StaticResource DayToggle}" Content="Pt" Margin="0,0,4,0"/>
                                        <ToggleButton x:Name="tglSob" Style="{StaticResource DayToggle}" Content="So" Margin="0,0,4,0"/>
                                        <ToggleButton x:Name="tglNdz" Style="{StaticResource DayToggle}" Content="Nd"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ▸ KARTA 2: Powiadomienia (prawy-górny) -->
                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="🔔" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Powiadomienia" Style="{StaticResource SectionTitle}"/>
                                </StackPanel>
                                <TextBlock Text="Komu i jak wyświetlać powiadomienia o zmianach" Style="{StaticResource SectionSubtitle}"/>

                                <!-- Kafelki docelowe -->
                                <TextBlock Text="Powiadamiaj użytkowników z dostępem do:" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                                <Border Background="#0d1117" CornerRadius="4" BorderBrush="{StaticResource BrBorder}" BorderThickness="1"
                                        Padding="4" MaxHeight="140" Margin="0,0,0,4">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="lstKafelki">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected}" Margin="4,2" Cursor="Hand" Foreground="{StaticResource BrTextPrimary}" FontSize="12">
                                                        <CheckBox.Content>
                                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                                        </CheckBox.Content>
                                                    </CheckBox>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                                <TextBlock Text="Puste = powiadomienie dla wszystkich" Style="{StaticResource FieldHint}" Margin="0,0,0,4"/>

                                <!-- Rodzaj -->
                                <Border Style="{StaticResource RowSep}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Rodzaj powiadomienia" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox x:Name="cbRodzajPowiadomienia" Grid.Column="1" Style="{StaticResource InputCombo}" Width="130">
                                            <ComboBoxItem Content="MessageBox" IsSelected="True"/>
                                            <ComboBoxItem Content="Toast"/>
                                            <ComboBoxItem Content="StatusBar"/>
                                        </ComboBox>
                                    </Grid>
                                </Border>

                                <!-- Min kg -->
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Min. zmiana kg" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock Text="0 = powiadom przy każdej zmianie" Style="{StaticResource FieldHint}"/>
                                    </StackPanel>
                                    <TextBox x:Name="txtMinKg" Grid.Column="1" Style="{StaticResource InputBox}" Width="72" Text="0" TextAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ▸ KARTA 3: Logowanie (lewy-dolny) -->
                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="📋" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Logowanie i walidacja" Style="{StaticResource SectionTitle}"/>
                                </StackPanel>
                                <TextBlock Text="Historia zmian i wymagane pola" Style="{StaticResource SectionSubtitle}"/>

                                <CheckBox x:Name="chkLogowanie" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Loguj zmiany do historii" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock Text="Zapisuj każdą edycję zamówienia w tabeli audytu" Style="{StaticResource FieldHint}"/>
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox x:Name="chkKomentarz" Style="{StaticResource ToggleSwitch}">
                                    <StackPanel>
                                        <TextBlock Text="Wymagaj komentarza przy zmianie" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock Text="Operator musi podać powód edycji zamówienia" Style="{StaticResource FieldHint}"/>
                                    </StackPanel>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <!-- ▸ KARTA 4: Szybkie info (prawy-dolny) -->
                        <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource SectionCard}" Background="#0c1824" BorderBrush="#1a3060">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="💡" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Jak to działa?" Style="{StaticResource SectionTitle}"/>
                                </StackPanel>
                                <TextBlock Style="{StaticResource SectionSubtitle}" Margin="0,2,0,0"/>

                                <StackPanel Margin="0,0,0,0">
                                    <TextBlock Foreground="{StaticResource BrTextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10" LineHeight="20">
                                        <Run FontWeight="SemiBold" Foreground="{StaticResource BrAccentBlue}">Powiadomienia</Run>
                                        <Run> — po ustawionej godzinie system informuje o edycjach zamówień dokonanych tego dnia.</Run>
                                    </TextBlock>
                                    <TextBlock Foreground="{StaticResource BrTextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10" LineHeight="20">
                                        <Run FontWeight="SemiBold" Foreground="{StaticResource BrAccentAmber}">Blokada</Run>
                                        <Run> — po godzinie blokady edycja jest całkowicie zablokowana. Użytkownik zobaczy komunikat.</Run>
                                    </TextBlock>
                                    <TextBlock Foreground="{StaticResource BrTextSecondary}" FontSize="12" TextWrapping="Wrap" LineHeight="20">
                                        <Run FontWeight="SemiBold" Foreground="{StaticResource BrAccentGreen}">Wyłączenia</Run>
                                        <Run> — wybranych użytkowników można zwolnić z powiadomień lub nadać im indywidualną godzinę.</Run>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ═══ WYŁĄCZENI UŻYTKOWNICY (PEŁNA SZEROKOŚĆ) ═══ -->
                    <Border Style="{StaticResource SectionCard}" Margin="0,0,0,8">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👥" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Wyłączeni użytkownicy" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                                    <Border CornerRadius="10" Background="#1af59e0b" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="txtExemptCount" Text="0" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource BrAccentAmber}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Tabela -->
                            <DataGrid x:Name="dgWylaczenia" AutoGenerateColumns="False"
                                      MinHeight="80" MaxHeight="200"
                                      Background="Transparent" Foreground="{StaticResource BrTextPrimary}"
                                      RowBackground="#0d1117" AlternatingRowBackground="#111921"
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1e30363d"
                                      BorderBrush="{StaticResource BrBorder}" BorderThickness="1"
                                      HeadersVisibility="Column" IsReadOnly="True"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      SelectionMode="Single" SelectionUnit="FullRow"
                                      FontSize="12"
                                      Margin="0,0,0,14">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#161b22"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrTextMuted}"/>
                                        <Setter Property="Padding" Value="10,7"/>
                                        <Setter Property="FontSize" Value="10.5"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="BorderBrush" Value="#1e30363d"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="10,6"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                        <ContentPresenter VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#1a58a6ff"/>
                                                <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="OPERATOR" Binding="{Binding UserName}" Width="*" MinWidth="140"/>
                                    <DataGridTextColumn Header="STATUS" Binding="{Binding StatusText}" Width="100"/>
                                    <DataGridTextColumn Header="GODZ." Binding="{Binding IndywidualnaGodzinaText}" Width="70"/>
                                    <DataGridTextColumn Header="POWÓD" Binding="{Binding Powod}" Width="*" MinWidth="120"/>
                                    <DataGridTextColumn Header="DODAŁ" Binding="{Binding DodanoPrzez}" Width="110"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Formularz dodawania -->
                            <Border Background="#0d1117" CornerRadius="6" Padding="12,10" BorderBrush="{StaticResource BrBorder}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>      <!-- Operator -->
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="72"/>     <!-- Godzina -->
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>      <!-- Powód -->
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>   <!-- Zwolniony -->
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>   <!-- Dodaj -->
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="Auto"/>   <!-- Usuń -->
                                    </Grid.ColumnDefinitions>

                                    <ComboBox x:Name="cbOperator" Grid.Column="0" Style="{StaticResource InputCombo}"
                                              DisplayMemberPath="Name" SelectedValuePath="Id"/>

                                    <TextBox x:Name="txtIndGodzina" Grid.Column="2" Style="{StaticResource InputBox}"
                                             TextAlignment="Center" ToolTip="Godzina indywidualna (HH:mm)">
                                        <TextBox.Tag>
                                            <TextBlock Text="HH:mm"/>
                                        </TextBox.Tag>
                                    </TextBox>

                                    <TextBox x:Name="txtPowod" Grid.Column="4" Style="{StaticResource InputBox}" ToolTip="Powód wyłączenia"/>

                                    <CheckBox x:Name="chkZwolniony" Grid.Column="6" Style="{StaticResource SettingCheck}" IsChecked="True"
                                              Content="Zwolniony" VerticalAlignment="Center"/>

                                    <Button Grid.Column="8" Content="+ Dodaj" Style="{StaticResource BtnSecondary}" Click="BtnDodajWylaczenie_Click" Padding="14,7"/>
                                    <Button Grid.Column="10" Content="Usuń" Style="{StaticResource BtnDanger}" Click="BtnUsunWylaczenie_Click"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ STOPKA ═══ -->
            <Border Grid.Row="2" Background="#161b22" BorderBrush="{StaticResource BrBorder}" BorderThickness="0,1,0,0">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <TextBlock x:Name="txtStatus" Text="" FontSize="11.5" Foreground="{StaticResource BrTextMuted}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button Content="Odśwież" Style="{StaticResource BtnSecondary}" Click="BtnOdswiez_Click" Margin="0,0,10,0"/>
                        <Button x:Name="btnZapisz" Content="Zapisz ustawienia" Style="{StaticResource BtnPrimary}" Click="BtnZapisz_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
