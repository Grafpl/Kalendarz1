<Window x:Class="Kalendarz1.AnalitykaPelna.Windows.WazeniaPartiiDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ważenia partii"
        Width="1100" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Nagłówek -->
            <RowDefinition Height="Auto"/>
            <!-- Statystyki -->
            <RowDefinition Height="*"/>
            <!-- Tabela -->
            <RowDefinition Height="Auto"/>
            <!-- Przyciski -->
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <Border Grid.Row="0" Background="#1F2937" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="txtTytul" Text="Partia"
                               Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <TextBlock x:Name="txtPodtytul" Text="Hodowca, daty"
                               Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="📥 Eksport CSV" Padding="12,6"
                        Background="#374151" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnEksport_Click"/>
            </Grid>
        </Border>

        <!-- Statystyki strip -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="WAŻEŃ" FontSize="10" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtLiczbaWazen" Text="0" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="ANULACJI" FontSize="10" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtAnulacje" Text="0" FontSize="18" FontWeight="Bold" Foreground="#DC2626"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="SUMA KG" FontSize="10" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtSumaKg" Text="0" FontSize="18" FontWeight="Bold" Foreground="#7C3AED"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="TOWARÓW" FontSize="10" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtTowarow" Text="0" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="OPERATORÓW" FontSize="10" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtOperatorow" Text="0" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabela ważeń -->
        <Border Grid.Row="2" Background="White" Margin="20,12" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="8" ClipToBounds="True">
            <DataGrid x:Name="dgWazenia" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      RowBackground="White" AlternatingRowBackground="#FAFAFA"
                      BorderThickness="0" RowHeight="26" FontSize="11"
                      EnableRowVirtualization="True" EnableColumnVirtualization="True">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data" Binding="{Binding Data, StringFormat=dd.MM.yyyy}" Width="80"/>
                    <DataGridTextColumn Header="Godz." Binding="{Binding Godzina, StringFormat=HH:mm:ss}" Width="80"/>
                    <DataGridTextColumn Header="Towar" Binding="{Binding NazwaTowaru}" Width="*"/>
                    <DataGridTextColumn Header="Standard" Binding="{Binding Weight, StringFormat=N1}" Width="80"/>
                    <DataGridTextColumn Header="Rzecz." Binding="{Binding ActWeight, StringFormat=N1}" Width="80"/>
                    <DataGridTextColumn Header="Δ" Binding="{Binding Roznica, StringFormat=N1}" Width="60"/>
                    <DataGridTextColumn Header="Operator" Binding="{Binding Wagowy}" Width="140"/>
                    <DataGridTextColumn Header="Klasa" Binding="{Binding Klasa}" Width="50"/>
                    <DataGridTextColumn Header="Term." Binding="{Binding TermID}" Width="50"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Przyciski -->
        <Border Grid.Row="3" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="txtInfo"
                           Text="Esc — zamknij" Foreground="#94A3B8" FontSize="11"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="✕ Zamknij" Padding="14,6"
                        Background="#7C3AED" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnZamknij_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
