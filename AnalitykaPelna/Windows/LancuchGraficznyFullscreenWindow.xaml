<Window x:Class="Kalendarz1.AnalitykaPelna.Windows.LancuchGraficznyFullscreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Kalendarz1.AnalitykaPelna.Views"
        Title="Łańcuch Graficzny — pełen ekran"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#F8FAFC"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality"
        KeyDown="Window_KeyDown">
    <Grid>
        <views:WidokLancuchGraficzny x:Name="widokGraficzny"/>

        <!-- Floating exit button (top-right corner, above content) -->
        <Button x:Name="btnExit" Click="BtnExit_Click"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,12,16,0"
                Padding="14,8" Cursor="Hand"
                Background="#0F172A" Foreground="White" BorderThickness="0"
                ToolTip="Wyjdź z pełnego ekranu (Esc)">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🗗" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="  Wyjdź (Esc)" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</Window>
