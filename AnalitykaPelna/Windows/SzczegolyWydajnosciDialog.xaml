<Window x:Class="Kalendarz1.AnalitykaPelna.Windows.SzczegolyWydajnosciDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Szczegóły wydajności"
        Width="780" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1F2937" Padding="20,14">
            <StackPanel>
                <TextBlock x:Name="txtTytul" Text="Szczegóły wydajności"
                           Foreground="White" FontSize="18" FontWeight="Bold"/>
                <TextBlock x:Name="txtPodtytul" Text=""
                           Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20,14" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 1. Wejście -->
                <Border Background="#ECFCCB" BorderBrush="#84CC16" BorderThickness="1"
                        CornerRadius="8" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="🐔 1. WEJŚCIE — kurczak żywy" FontWeight="Bold" FontSize="14"
                                   Foreground="#365314" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Przyjęty na magazyn (sPZ, katalog 65882)"
                                       Foreground="#475569" FontSize="12"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtZywiecPz"
                                       Text="0 kg" FontWeight="Bold" FontSize="14"
                                       Margin="12,0,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Wzięty do uboju (sRWU, katalog 65882)"
                                       Foreground="#475569" FontSize="12" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtZywiecRwu"
                                       Text="0 kg" FontWeight="Bold" FontSize="14" Foreground="#1A2E05"
                                       Margin="12,4,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 2. Wyjście -->
                <Border Background="#FFF7ED" BorderBrush="#FB923C" BorderThickness="1"
                        CornerRadius="8" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="🔪 2. WYJŚCIE UBOJU — Tuszki + Podroby (sPWU, magazyn 65554)"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="#7C2D12" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Tuszka A (Kurczak A)" Foreground="#475569" FontSize="12"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtTuszkaA" Text="0 kg" FontWeight="SemiBold" FontSize="13" Margin="12,0,8,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="txtTuszkaAProc" Text="—" Foreground="#7C3AED" FontWeight="Bold" FontSize="13" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Tuszka B (Kurczak B)" Foreground="#475569" FontSize="12" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtTuszkaB" Text="0 kg" FontWeight="SemiBold" FontSize="13" Margin="12,4,8,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="txtTuszkaBProc" Text="—" Foreground="#7C3AED" FontWeight="Bold" FontSize="13" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Wątroba" Foreground="#475569" FontSize="12" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtWatroba" Text="0 kg" FontWeight="SemiBold" FontSize="13" Margin="12,4,8,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="txtWatrobaProc" Text="—" Foreground="#F59E0B" FontWeight="Bold" FontSize="13" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Żołądki" Foreground="#475569" FontSize="12" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtZoladki" Text="0 kg" FontWeight="SemiBold" FontSize="13" Margin="12,4,8,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="txtZoladkiProc" Text="—" Foreground="#F59E0B" FontWeight="Bold" FontSize="13" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Serce" Foreground="#475569" FontSize="12" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtSerce" Text="0 kg" FontWeight="SemiBold" FontSize="13" Margin="12,4,8,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" x:Name="txtSerceProc" Text="—" Foreground="#F59E0B" FontWeight="Bold" FontSize="13" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                            <Border Grid.Row="5" Grid.ColumnSpan="3" Background="#FED7AA" CornerRadius="4" Padding="8,4" Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="SUMA WYJŚCIA UBOJU (A + B + Podroby)" FontWeight="Bold" Foreground="#7C2D12" FontSize="12"/>
                                    <TextBlock Grid.Column="1" x:Name="txtSumaWyj" Text="0 kg" FontWeight="Bold" FontSize="14" Foreground="#7C2D12"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 3. Wzory -->
                <Border Background="White" BorderBrush="#7C3AED" BorderThickness="1"
                        CornerRadius="8" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="📐 3. WZORY WYDAJNOŚCI" FontWeight="Bold" FontSize="14"
                                   Foreground="#7C3AED" Margin="0,0,0,8"/>

                        <Border Background="#FAF5FF" CornerRadius="4" Padding="10,6" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock FontSize="11" Foreground="#475569">
                                    <Run Text="Wydajność z podrobami ="/>
                                    <Run Text=" (Tuszka A + Tuszka B + Podroby)" FontFamily="Consolas"/>
                                    <Run Text=" / Żywiec × 100"/>
                                </TextBlock>
                                <TextBlock x:Name="txtWzorZPodrobami" FontFamily="Consolas" FontSize="13"
                                           Foreground="#1F2937" Margin="0,4,0,0"/>
                                <TextBlock x:Name="txtWynikZPodrobami" FontWeight="Bold" FontSize="20"
                                           Foreground="#7C3AED" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#ECFEFF" CornerRadius="4" Padding="10,6" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock FontSize="11" Foreground="#475569">
                                    <Run Text="Wydajność bez podrobów ="/>
                                    <Run Text=" (Tuszka A + Tuszka B)" FontFamily="Consolas"/>
                                    <Run Text=" / Żywiec × 100"/>
                                </TextBlock>
                                <TextBlock x:Name="txtWzorBezPodrobow" FontFamily="Consolas" FontSize="13"
                                           Foreground="#1F2937" Margin="0,4,0,0"/>
                                <TextBlock x:Name="txtWynikBezPodrobow" FontWeight="Bold" FontSize="20"
                                           Foreground="#0891B2" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FEF3C7" CornerRadius="4" Padding="10,6">
                            <StackPanel>
                                <TextBlock FontSize="11" Foreground="#475569">
                                    <Run Text="% udziału podrobów ="/>
                                    <Run Text=" Podroby" FontFamily="Consolas"/>
                                    <Run Text=" / Żywiec × 100"/>
                                </TextBlock>
                                <TextBlock x:Name="txtWzorPodrobow" FontFamily="Consolas" FontSize="13"
                                           Foreground="#1F2937" Margin="0,4,0,0"/>
                                <TextBlock x:Name="txtWynikPodrobow" FontWeight="Bold" FontSize="20"
                                           Foreground="#F59E0B" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 4. Strata -->
                <Border Background="#FEE2E2" BorderBrush="#DC2626" BorderThickness="1"
                        CornerRadius="8" Padding="14">
                    <StackPanel>
                        <TextBlock Text="💧 4. STRATA UBOJU" FontWeight="Bold" FontSize="14"
                                   Foreground="#7F1D1D" Margin="0,0,0,4"/>
                        <TextBlock Foreground="#475569" FontSize="11" Margin="0,0,0,6">
                            <Run Text="Pióra, krew, kości głębokie, błąd pomiaru itp."/>
                        </TextBlock>
                        <TextBlock x:Name="txtWzorStraty" FontFamily="Consolas" FontSize="13"
                                   Foreground="#1F2937"/>
                        <TextBlock x:Name="txtWynikStraty" FontWeight="Bold" FontSize="18"
                                   Foreground="#DC2626" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Esc — zamknij" Foreground="#94A3B8" FontSize="11"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="✕ Zamknij" Padding="14,6"
                        Background="#7C3AED" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnZamknij_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
