<Window x:Class="Kalendarz1.AnalitykaPelna.Windows.HistoriaKlasWagowychWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:wnd="clr-namespace:Kalendarz1.AnalitykaPelna.Windows"
        Title="Historia klas wagowych"
        Width="1600" Height="980"
        MinWidth="1280" MinHeight="760"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <!-- Styl przycisków w headerze -->
        <Style x:Key="HeaderBtnStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ToggleButton kompaktowy (radio/option style) -->
        <Style x:Key="OptionToggleStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E0E7FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#818CF8"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#7C3AED"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#5B21B6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ToggleButton wyboru klas (Eksplorator-style — niebieski Duży) -->
        <Style x:Key="KlasaToggleDuzyStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DBEAFE"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2563EB"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#1E3A8A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="KlasaToggleMalyStyle" TargetType="ToggleButton" BasedOn="{StaticResource KlasaToggleDuzyStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FED7AA"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#F97316"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F97316"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#9A3412"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- KPI styles -->
        <Style x:Key="KpiLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="KpiValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>
        <Style x:Key="KpiDivider" TargetType="Rectangle">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Margin" Value="14,8"/>
            <Setter Property="Fill" Value="#E2E8F0"/>
        </Style>

        <!-- Grupa skrót-button -->
        <Style x:Key="GrupaBtnStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Header -->
            <RowDefinition Height="Auto"/>
            <!-- 1: KPI strip -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Pasek opcji (agregacja, tryb, metryka) -->
            <RowDefinition Height="Auto"/>
            <!-- 3: Pasek wyboru klas / grup -->
            <RowDefinition Height="2.2*"/>
            <!-- 4: Wykres liniowy -->
            <RowDefinition Height="*"/>
            <!-- 5: Tabela -->
            <RowDefinition Height="Auto"/>
            <!-- 6: Stopka -->
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <Border Grid.Row="0" Padding="24,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#7C3AED" Offset="0"/>
                    <GradientStop Color="#4C1D95" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.15"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="📈  Historia klas wagowych — analiza w czasie"
                               Foreground="White" FontSize="24" FontWeight="Bold">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="0" Opacity="0.4"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock x:Name="txtHeaderPodtytul"
                               Text="Wykres liniowy + tabela: ile sztuk/kg każdej klasy w wybranych okresach"
                               Foreground="#DDD6FE" FontSize="12" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📥  Eksport CSV"
                            Background="#5B21B6" Margin="0,0,8,0"
                            Click="BtnEksport_Click"
                            Style="{StaticResource HeaderBtnStyle}"/>
                    <Button Content="✕  Zamknij (Esc)"
                            Background="#DC2626"
                            Click="BtnZamknij_Click"
                            Style="{StaticResource HeaderBtnStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ KPI strip ═══ -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="📊  OKRESÓW" Style="{StaticResource KpiLabelStyle}"/>
                    <TextBlock x:Name="txtKpiOkresow" Text="0" Style="{StaticResource KpiValueStyle}"/>
                </StackPanel>
                <Rectangle Grid.Column="1" Style="{StaticResource KpiDivider}"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="🏷️  ŁĄCZNIE WAŻEŃ" Style="{StaticResource KpiLabelStyle}"/>
                    <TextBlock x:Name="txtKpiWazen" Text="0" Style="{StaticResource KpiValueStyle}"/>
                </StackPanel>
                <Rectangle Grid.Column="3" Style="{StaticResource KpiDivider}"/>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="⚖️  Σ KG" Style="{StaticResource KpiLabelStyle}"/>
                    <TextBlock x:Name="txtKpiKg" Text="0" Style="{StaticResource KpiValueStyle}"
                               Foreground="#7C3AED"/>
                </StackPanel>
                <Rectangle Grid.Column="5" Style="{StaticResource KpiDivider}"/>
                <StackPanel Grid.Column="6">
                    <TextBlock Text="🍗  Σ DUŻY (4–7)" Style="{StaticResource KpiLabelStyle}"/>
                    <TextBlock x:Name="txtKpiDuzy" Text="0" Style="{StaticResource KpiValueStyle}"
                               Foreground="#2563EB"/>
                    <TextBlock x:Name="txtKpiDuzyProc" Text="0%" FontSize="11" Foreground="#3B82F6"
                               FontWeight="SemiBold"/>
                </StackPanel>
                <Rectangle Grid.Column="7" Style="{StaticResource KpiDivider}"/>
                <StackPanel Grid.Column="8">
                    <TextBlock Text="🐥  Σ MAŁY (8–12)" Style="{StaticResource KpiLabelStyle}"/>
                    <TextBlock x:Name="txtKpiMaly" Text="0" Style="{StaticResource KpiValueStyle}"
                               Foreground="#F97316"/>
                    <TextBlock x:Name="txtKpiMalyProc" Text="0%" FontSize="11" Foreground="#FB923C"
                               FontWeight="SemiBold"/>
                </StackPanel>
                <Rectangle Grid.Column="9" Style="{StaticResource KpiDivider}"/>
                <StackPanel Grid.Column="10">
                    <TextBlock Text="🏆  TOP KLASA" Style="{StaticResource KpiLabelStyle}"/>
                    <TextBlock x:Name="txtKpiTopKlasa" Text="—" Style="{StaticResource KpiValueStyle}"/>
                    <TextBlock x:Name="txtKpiTopKlasaKg" Text="" FontSize="11" Foreground="#64748B"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Pasek opcji: agregacja czasowa + tryb + metryka ═══ -->
        <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="24,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FAFAFA" Offset="0"/>
                    <GradientStop Color="#F1F5F9" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Agregacja czasowa -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="📅 Agregacja:" FontWeight="Bold" FontSize="12" Foreground="#475569"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ToggleButton x:Name="tbDzien" Content="Dzień" Style="{StaticResource OptionToggleStyle}"
                                  PreviewMouseLeftButtonDown="OkresBtn_PreviewMouseDown" Tag="Dzienna"/>
                    <ToggleButton x:Name="tbTydzien" Content="Tydzień" Style="{StaticResource OptionToggleStyle}"
                                  PreviewMouseLeftButtonDown="OkresBtn_PreviewMouseDown" Tag="Tygodniowa" IsChecked="True"/>
                    <ToggleButton x:Name="tbMiesiac" Content="Miesiąc" Style="{StaticResource OptionToggleStyle}"
                                  PreviewMouseLeftButtonDown="OkresBtn_PreviewMouseDown" Tag="Miesieczna"/>
                    <ToggleButton x:Name="tbKwartal" Content="Kwartał" Style="{StaticResource OptionToggleStyle}"
                                  PreviewMouseLeftButtonDown="OkresBtn_PreviewMouseDown" Tag="Kwartalna"/>
                    <ToggleButton x:Name="tbRok" Content="Rok" Style="{StaticResource OptionToggleStyle}"
                                  PreviewMouseLeftButtonDown="OkresBtn_PreviewMouseDown" Tag="Roczna"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Fill="#CBD5E1" Margin="0,4,16,4"/>

                <!-- Tryb: Per-klasa / Per-grupa -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎯 Tryb:" FontWeight="Bold" FontSize="12" Foreground="#475569"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ToggleButton x:Name="tbPerKlasa" Content="Per klasa (4–12)" Style="{StaticResource OptionToggleStyle}"
                                  PreviewMouseLeftButtonDown="TrybBtn_PreviewMouseDown" Tag="PerKlasa" IsChecked="True"/>
                    <ToggleButton x:Name="tbPerGrupa" Content="Per grupa (Duży / Mały / Razem)" Style="{StaticResource OptionToggleStyle}"
                                  PreviewMouseLeftButtonDown="TrybBtn_PreviewMouseDown" Tag="PerGrupa"/>
                </StackPanel>

                <!-- Metryka: kg / szt -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock Text="📐 Wartość:" FontWeight="Bold" FontSize="12" Foreground="#475569"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ToggleButton x:Name="tbKg" Content="⚖️ kg" Style="{StaticResource OptionToggleStyle}"
                                  PreviewMouseLeftButtonDown="MetrykaBtn_PreviewMouseDown" Tag="Kg" IsChecked="True"/>
                    <ToggleButton x:Name="tbWazenia" Content="🏷️ Liczba ważeń" Style="{StaticResource OptionToggleStyle}"
                                  PreviewMouseLeftButtonDown="MetrykaBtn_PreviewMouseDown" Tag="Wazenia"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Pasek wyboru klas/grup ═══ -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock x:Name="txtNagOpcji" Text="🎯 Klasy:" FontWeight="Bold" FontSize="13"
                               Foreground="#475569"/>
                    <TextBlock Text="Klik = jedna  •  Ctrl+klik = wiele" FontSize="9"
                               Foreground="#94A3B8" FontStyle="Italic"/>
                </StackPanel>

                <!-- Per-klasa (klasy 4-12) -->
                <StackPanel x:Name="panelPerKlasa" Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ToggleButton x:Name="kbtn4" Content="4" Tag="4"
                                  Style="{StaticResource KlasaToggleDuzyStyle}"
                                  PreviewMouseLeftButtonDown="KlasaBtn_PreviewMouseDown"/>
                    <ToggleButton x:Name="kbtn5" Content="5" Tag="5"
                                  Style="{StaticResource KlasaToggleDuzyStyle}"
                                  PreviewMouseLeftButtonDown="KlasaBtn_PreviewMouseDown"/>
                    <ToggleButton x:Name="kbtn6" Content="6" Tag="6"
                                  Style="{StaticResource KlasaToggleDuzyStyle}"
                                  PreviewMouseLeftButtonDown="KlasaBtn_PreviewMouseDown"/>
                    <ToggleButton x:Name="kbtn7" Content="7" Tag="7"
                                  Style="{StaticResource KlasaToggleDuzyStyle}"
                                  PreviewMouseLeftButtonDown="KlasaBtn_PreviewMouseDown"/>
                    <Rectangle Width="1" Margin="8,4" Fill="#E2E8F0"/>
                    <ToggleButton x:Name="kbtn8" Content="8" Tag="8"
                                  Style="{StaticResource KlasaToggleMalyStyle}"
                                  PreviewMouseLeftButtonDown="KlasaBtn_PreviewMouseDown"/>
                    <ToggleButton x:Name="kbtn9" Content="9" Tag="9"
                                  Style="{StaticResource KlasaToggleMalyStyle}"
                                  PreviewMouseLeftButtonDown="KlasaBtn_PreviewMouseDown"/>
                    <ToggleButton x:Name="kbtn10" Content="10" Tag="10"
                                  Style="{StaticResource KlasaToggleMalyStyle}"
                                  PreviewMouseLeftButtonDown="KlasaBtn_PreviewMouseDown"/>
                    <ToggleButton x:Name="kbtn11" Content="11" Tag="11"
                                  Style="{StaticResource KlasaToggleMalyStyle}"
                                  PreviewMouseLeftButtonDown="KlasaBtn_PreviewMouseDown"/>
                    <ToggleButton x:Name="kbtn12" Content="12" Tag="12"
                                  Style="{StaticResource KlasaToggleMalyStyle}"
                                  PreviewMouseLeftButtonDown="KlasaBtn_PreviewMouseDown"/>
                </StackPanel>

                <!-- Per-grupa (Duży, Mały, Razem) -->
                <StackPanel x:Name="panelPerGrupa" Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Visibility="Collapsed">
                    <ToggleButton x:Name="gbtnDuzy" Content="🍗 Duży kurczak (4–7)" Tag="Duzy"
                                  Width="180" Style="{StaticResource KlasaToggleDuzyStyle}"
                                  PreviewMouseLeftButtonDown="GrupaBtn_PreviewMouseDown" IsChecked="True"/>
                    <ToggleButton x:Name="gbtnMaly" Content="🐥 Mały kurczak (8–12)" Tag="Maly"
                                  Width="180" Style="{StaticResource KlasaToggleMalyStyle}"
                                  PreviewMouseLeftButtonDown="GrupaBtn_PreviewMouseDown" IsChecked="True"/>
                    <ToggleButton x:Name="gbtnRazem" Content="📊 Razem (4–12)" Tag="Razem"
                                  Width="160" Style="{StaticResource OptionToggleStyle}"
                                  PreviewMouseLeftButtonDown="GrupaBtn_PreviewMouseDown"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🍗 4–7" Click="BtnGrupaDuzy_Click"
                            Style="{StaticResource GrupaBtnStyle}"
                            ToolTip="Zaznacz wszystkie klasy duże (4-7)"/>
                    <Button Content="🐥 8–12" Click="BtnGrupaMaly_Click"
                            Style="{StaticResource GrupaBtnStyle}"
                            ToolTip="Zaznacz wszystkie klasy małe (8-12)"/>
                    <Button Content="∑ Wszystkie" Click="BtnGrupaWszystkie_Click"
                            Style="{StaticResource GrupaBtnStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Wykres liniowy ═══ -->
        <Border Grid.Row="4" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="6" Margin="20,12,20,8" Padding="14,10">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.06"/>
            </Border.Effect>
            <lvc:CartesianChart x:Name="wykresHistoria" LegendLocation="Top">
                <lvc:CartesianChart.AxisX>
                    <lvc:Axis x:Name="osXHistoria" Title="Okres" Foreground="#475569" LabelsRotation="0"/>
                </lvc:CartesianChart.AxisX>
                <lvc:CartesianChart.AxisY>
                    <lvc:Axis x:Name="osYHistoria" Title="kg" Foreground="#475569"/>
                </lvc:CartesianChart.AxisY>
            </lvc:CartesianChart>
        </Border>

        <!-- ═══ Tabela ═══ -->
        <Border Grid.Row="5" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="6" Margin="20,0,20,12" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.06"/>
            </Border.Effect>
            <DataGrid x:Name="dgHistoria" AutoGenerateColumns="True" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      RowBackground="White" AlternatingRowBackground="#F8FAFC"
                      BorderThickness="0" RowHeight="28" FontSize="12"
                      EnableRowVirtualization="True"
                      HorizontalGridLinesBrush="#F1F5F9" VerticalGridLinesBrush="#F1F5F9"
                      AutoGeneratingColumn="DgHistoria_AutoGeneratingColumn">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1F2937"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="8,7"/>
                        <Setter Property="BorderBrush" Value="#374151"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEF2FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Border>

        <!-- ═══ Stopka ═══ -->
        <Border Grid.Row="6" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="24,8">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F1F5F9" Offset="0"/>
                    <GradientStop Color="#E2E8F0" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⌨️" FontSize="13" Margin="0,0,6,0"/>
                    <TextBlock Text="Esc — zamknij  •  Klik na klasę = jedna  •  Ctrl+klik = wiele  •  Per-grupa: zbiorczo Duży/Mały/Razem"
                               Foreground="#64748B" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⏱️" FontSize="13" Margin="0,0,4,0"/>
                    <TextBlock x:Name="txtCzasLad" Text="" Foreground="#64748B" FontSize="11"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
