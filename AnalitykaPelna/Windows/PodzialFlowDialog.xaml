<Window x:Class="Kalendarz1.AnalitykaPelna.Windows.PodzialFlowDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Podział przepływu" Height="540" Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#475569"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#0F172A" BlurRadius="10" ShadowDepth="2" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        </Style>
        <Style x:Key="HeroValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="24,18">
            <StackPanel>
                <TextBlock x:Name="txtTytul" Text="—" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock x:Name="txtPodtytul" Text="—" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,3,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,20">

                <!-- 3 KPI w rzędzie -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock x:Name="kpi1Label" Text="—" Style="{StaticResource Label}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="kpi1Value" Text="—" Style="{StaticResource HeroValue}"/>
                                <TextBlock x:Name="kpi1Unit" Text="t" FontSize="13" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                            <TextBlock x:Name="kpi1Sub" Text="" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="3,0">
                        <StackPanel>
                            <TextBlock x:Name="kpi2Label" Text="—" Style="{StaticResource Label}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="kpi2Value" Text="—" Style="{StaticResource HeroValue}"/>
                                <TextBlock x:Name="kpi2Unit" Text="t" FontSize="13" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                            <TextBlock x:Name="kpi2Sub" Text="" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" x:Name="kpi3Wrap" Style="{StaticResource Card}" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock x:Name="kpi3Label" Text="—" Style="{StaticResource Label}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="kpi3Value" Text="—" Style="{StaticResource HeroValue}"/>
                                <TextBlock x:Name="kpi3Unit" Text="t" FontSize="13" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                            <TextBlock x:Name="kpi3Sub" Text="" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Opis kontekstu (skąd / dokąd) -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="OPIS PRZEPŁYWU" Style="{StaticResource Label}"/>
                        <TextBlock x:Name="txtOpis" Text="—" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,6,0,0" TextWrapping="Wrap" LineHeight="18"/>
                    </StackPanel>
                </Border>

                <!-- Breakdown (tylko w trybie PAKOWANIE — 5 magazynów) -->
                <Border x:Name="bdBreakdown" Style="{StaticResource Card}" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="txtBreakdownTitle" Text="ROZDYSPONOWANIE sMM−" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                        <StackPanel x:Name="panelBreakdown"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="txtFooterInfo" Text="" FontSize="11" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Zamknij" Padding="20,8" Click="BtnClose_Click"
                        Background="#0F172A" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>
