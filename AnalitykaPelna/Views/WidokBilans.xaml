<UserControl x:Class="Kalendarz1.AnalitykaPelna.Views.WidokBilans"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Kalendarz1.AnalitykaPelna.Controls"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:vw="clr-namespace:Kalendarz1.AnalitykaPelna.Views"
             Background="#F8FAFC">
    <UserControl.Resources>
        <vw:BoolToAnomaliaConverter x:Key="AnomaliaConverter"/>
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- KPI strip -->
            <RowDefinition Height="*"/>
            <!-- TabControl -->
            <RowDefinition Height="Auto"/>
            <!-- Stopka -->
        </Grid.RowDefinitions>

        <!-- ═══ 5 KPI ═══ -->
        <UniformGrid Grid.Row="0" Rows="1" Columns="5" Margin="0,0,0,16">
            <ctrl:KpiKafel x:Name="kpiProdukcja"
                           Tytul="PRODUKCJA" Wartosc="0" Jednostka="kg"
                           Ikona="🏭" Margin="0,0,8,0">
                <ctrl:KpiKafel.Kolor>
                    <SolidColorBrush Color="#0891B2"/>
                </ctrl:KpiKafel.Kolor>
            </ctrl:KpiKafel>
            <ctrl:KpiKafel x:Name="kpiSprzedaz"
                           Tytul="SPRZEDAŻ" Wartosc="0" Jednostka="kg"
                           Ikona="💰" Margin="0,0,8,0">
                <ctrl:KpiKafel.Kolor>
                    <SolidColorBrush Color="#059669"/>
                </ctrl:KpiKafel.Kolor>
            </ctrl:KpiKafel>
            <ctrl:KpiKafel x:Name="kpiRotacja"
                           Tytul="ROTACJA" Wartosc="0%" Jednostka="sprzedaż / produkcja"
                           Ikona="🔄" Margin="0,0,8,0">
                <ctrl:KpiKafel.Kolor>
                    <SolidColorBrush Color="#7C3AED"/>
                </ctrl:KpiKafel.Kolor>
            </ctrl:KpiKafel>
            <ctrl:KpiKafel x:Name="kpiAnomalie"
                           Tytul="ANOMALIE" Wartosc="0" Jednostka="dni 2σ"
                           Ikona="⚡" Margin="0,0,8,0">
                <ctrl:KpiKafel.Kolor>
                    <SolidColorBrush Color="#F59E0B"/>
                </ctrl:KpiKafel.Kolor>
            </ctrl:KpiKafel>
            <ctrl:KpiKafel x:Name="kpiMape"
                           Tytul="BŁĄD PROGNOZY" Wartosc="—" Jednostka="MAPE %"
                           Ikona="🎯">
                <ctrl:KpiKafel.Kolor>
                    <SolidColorBrush Color="#DC2626"/>
                </ctrl:KpiKafel.Kolor>
            </ctrl:KpiKafel>
        </UniformGrid>

        <!-- ═══ TabControl: Wykres / Tabela / Ranking ═══ -->
        <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent" Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#475569"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="b" Background="{TemplateBinding Background}"
                                        BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="#7C3AED"/>
                                        <Setter TargetName="b" Property="BorderBrush" Value="#7C3AED"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ─── Wykres ─── -->
            <TabItem Header="📊 Wykres">
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="8" Padding="12">
                    <lvc:CartesianChart x:Name="wykresBilans" LegendLocation="Top">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis x:Name="osX" Title="Dzień" Foreground="#475569">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="1" StrokeThickness="0"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="kg" Foreground="#475569" LabelFormatter="{Binding KgFormatter}"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </Border>
            </TabItem>

            <!-- ─── Tabela dzienna ─── -->
            <TabItem Header="📋 Bilans dzienny">
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="8" ClipToBounds="True">
                    <DataGrid x:Name="dgBilans" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              RowBackground="White" AlternatingRowBackground="#FAFAFA"
                              BorderThickness="0" RowHeight="28" FontSize="12"
                              VerticalGridLinesBrush="#F1F5F9"
                              HorizontalGridLinesBrush="#F1F5F9">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Data" Binding="{Binding Data, StringFormat=dd.MM.yyyy}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Dzień" Binding="{Binding DzienTygodnia}" Width="100"/>
                            <DataGridTextColumn Header="Produkcja" Binding="{Binding Produkcja, StringFormat=N0}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Sprzedaż" Binding="{Binding Sprzedaz, StringFormat=N0}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Prognoza" Binding="{Binding Prognoza, StringFormat=N0}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Δ Prod-Sprz" Binding="{Binding RoznicaProdSprz, StringFormat=N0}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Rotacja %" Binding="{Binding RotacjaProc, StringFormat=N1}"
                                                Width="*"/>
                            <DataGridTextColumn Header="MAPE %" Binding="{Binding MapeProc, StringFormat=N1}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Wartość zł" Binding="{Binding Wartosc, StringFormat=N0}"
                                                Width="120"/>
                            <DataGridTemplateColumn Header="⚡" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Anomalia, Converter={StaticResource AnomaliaConverter}}"
                                                   HorizontalAlignment="Center" Foreground="#F59E0B"
                                                   FontWeight="Bold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- ─── Ranking Top-N ─── -->
            <TabItem Header="🏆 Ranking">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="8" Padding="12" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="👥 Top odbiorcy" FontWeight="Bold" FontSize="14"
                                       Foreground="#0F172A" Margin="0,0,0,8"/>
                            <DataGrid Grid.Row="1" x:Name="dgRankingOdbiorcy"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      BorderThickness="0" RowHeight="26" FontSize="12">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="30"/>
                                    <DataGridTextColumn Header="Odbiorca" Binding="{Binding Nazwa}" Width="*"/>
                                    <DataGridTextColumn Header="kg" Binding="{Binding Ilosc, StringFormat=N0}" Width="80"/>
                                    <DataGridTextColumn Header="zł" Binding="{Binding Wartosc, StringFormat=N0}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="8" Padding="12" Margin="4,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="📦 Top towary" FontWeight="Bold" FontSize="14"
                                       Foreground="#0F172A" Margin="0,0,0,8"/>
                            <DataGrid Grid.Row="1" x:Name="dgRankingTowary"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      BorderThickness="0" RowHeight="26" FontSize="12">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="30"/>
                                    <DataGridTextColumn Header="Towar" Binding="{Binding Nazwa}" Width="*"/>
                                    <DataGridTextColumn Header="kg" Binding="{Binding Ilosc, StringFormat=N0}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="8" Padding="12" Margin="8,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="🏆 Handlowcy" FontWeight="Bold" FontSize="14"
                                       Foreground="#0F172A" Margin="0,0,0,8"/>
                            <DataGrid Grid.Row="1" x:Name="dgRankingHandlowcy"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      BorderThickness="0" RowHeight="26" FontSize="12">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="30"/>
                                    <DataGridTextColumn Header="Handlowiec" Binding="{Binding Nazwa}" Width="*"/>
                                    <DataGridTextColumn Header="kg" Binding="{Binding Ilosc, StringFormat=N0}" Width="80"/>
                                    <DataGridTextColumn Header="zł" Binding="{Binding Wartosc, StringFormat=N0}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ═══ Stopka ═══ -->
        <TextBlock Grid.Row="2" x:Name="txtInfo"
                   Text="Wybierz zakres i kliknij Zastosuj"
                   Foreground="#64748B" FontSize="11" FontStyle="Italic"
                   Margin="0,8,0,0" HorizontalAlignment="Right"/>
    </Grid>
</UserControl>
