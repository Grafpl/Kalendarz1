<UserControl x:Class="Kalendarz1.AnalitykaPelna.Views.WidokWydajnosc"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Kalendarz1.AnalitykaPelna.Controls"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:vw="clr-namespace:Kalendarz1.AnalitykaPelna.Views"
             xmlns:svc="clr-namespace:Kalendarz1.AnalitykaPelna.Services"
             Background="#F8FAFC">
    <UserControl.Resources>
        <vw:AlertBackgroundConverter x:Key="AlertBgConverter"/>
        <vw:AlertIconConverter x:Key="AlertIconConverter"/>
        <svc:EtapTloConverter x:Key="EtapTloConverter"/>
        <svc:EtapKolorConverter x:Key="EtapKolorConverter"/>
        <svc:GrupaPodsumowanieConverter x:Key="GrupaPodsumowanieConverter"/>
        <svc:GrupaKlasMetrykConverter x:Key="GrupaKlasMetrykConverter"/>
        <svc:KategoriaKolorConverter x:Key="KategoriaKolor"/>
        <svc:WydajnoscKolorConverter x:Key="WydajnoscKolor"/>
        <svc:HexToBrushConverter x:Key="HexToBrush"/>
        <svc:SafeImagePathConverter x:Key="SafeImage"/>
        <svc:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <svc:BoolToVisibilityInverseConverter x:Key="BoolToVisInv"/>

        <!-- Hover effect dla kafelków flow chain — DUŻO większe i premium-looking -->
        <Style x:Key="FlowCardStyle" TargetType="Border">
            <Setter Property="MinWidth" Value="210"/>
            <Setter Property="MinHeight" Value="170"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="22,18"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#25000000" BlurRadius="14" ShadowDepth="4" Direction="270"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#50000000" BlurRadius="24" ShadowDepth="6" Direction="270"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Hover dla kart towarów -->
        <Style x:Key="TowarCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAFBFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderBrush" Value="#CBD5E1"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#15000000" BlurRadius="8" ShadowDepth="2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Wspólny styl nagłówka sekcji -->
        <Style x:Key="SectionHeaderStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Toggle button dla kategorii w Szczegółach elementów (Eksplorator-style multi-select).
             Globalny zasięg w UserControl — dostępny dla code-behind przez TryFindResource. -->
        <Style x:Key="KategoriaToggleStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#7C3AED"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#5B21B6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- TabControl (full height) -->
            <RowDefinition Height="Auto"/>
            <!-- Stopka -->
        </Grid.RowDefinitions>

        <!-- KPI strip usunięty — mini-stats w każdej zakładce wystarczy. Hidden TextBlocks dla code-behind compat. -->
        <Grid Visibility="Collapsed">
            <TextBlock x:Name="kpiTuszkaB"/>
            <TextBlock x:Name="kpiWyjscie"/>
            <TextBlock x:Name="kpiWydajnosc"/>
            <TextBlock x:Name="kpiAlerty"/>
            <TextBlock x:Name="kpiTopHodowca"/>
        </Grid>

        <!-- ═══ TabControl ═══ -->
        <TabControl Grid.Row="0" BorderThickness="0" Background="Transparent" Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#475569"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="b" Background="{TemplateBinding Background}"
                                        BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="#7C3AED"/>
                                        <Setter TargetName="b" Property="BorderBrush" Value="#7C3AED"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ─── Bilans materiałowy (PIERWSZY — domyślny) ─── -->
            <TabItem Header="📊 Bilans materiałowy">
                <Grid Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <!-- Tabela (główna część) -->
                        <RowDefinition Height="Auto"/>
                        <!-- Footer z sumami live -->
                    </Grid.RowDefinitions>

                    <!-- ═══ Wewnętrzny TabControl: Pozycje + Stan magazynów ═══ -->
                    <TabControl Grid.Row="0" Background="Transparent" BorderThickness="0" Padding="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Padding" Value="14,7"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="MinWidth" Value="160"/>
                            </Style>
                        </TabControl.Resources>

                        <!-- ───── Sub-Tab 1: Pozycje (lista szczegółowa) ───── -->
                        <TabItem Header="📊 Pozycje">
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="6" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Toolbar: quick filter + przyciski -->
                            <Border Grid.Row="0" Background="#F8FAFC"
                                    BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                                    Padding="8,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <TextBox x:Name="txtBmFiltr" Padding="28,4,4,4"
                                                 BorderBrush="#E2E8F0" BorderThickness="1"
                                                 TextChanged="TxtBmFiltr_TextChanged"
                                                 ToolTip="Wpisz fragment nazwy towaru, kodu, etapu lub serii"/>
                                        <TextBlock Text="🔍" FontSize="13"
                                                   IsHitTestVisible="False" Foreground="#94A3B8"
                                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtBmFiltrPlaceholder"
                                                   Text="Filtruj po towarze, kodzie, etapie, serii…"
                                                   FontStyle="Italic" Foreground="#94A3B8"
                                                   IsHitTestVisible="False"
                                                   Margin="32,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Button Grid.Column="1" x:Name="btnBmWyczyscFiltr"
                                            Content="✕ Wyczyść filtr" Padding="10,4"
                                            Background="#F1F5F9" Foreground="#475569"
                                            BorderBrush="#E2E8F0" BorderThickness="1"
                                            Cursor="Hand" Margin="6,0,0,0"
                                            Click="BtnBmWyczyscFiltr_Click"
                                            ToolTip="Wyczyść quick filter (Esc w polu)"/>

                                    <CheckBox Grid.Column="2" x:Name="chkBmGrupowanie"
                                              Content="📦 Grupuj po etapie"
                                              IsChecked="True" Margin="12,0,0,0"
                                              VerticalAlignment="Center"
                                              Checked="ChkBmGrupowanie_Toggle"
                                              Unchecked="ChkBmGrupowanie_Toggle"
                                              ToolTip="Pokaż wiersze pogrupowane per etap z sumą kg"/>

                                    <TextBlock Grid.Column="3" x:Name="txtBmFiltrInfo"
                                               Text="" FontSize="11" Foreground="#64748B"
                                               Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1" x:Name="dgBilansMaterialowy"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      RowBackground="White" AlternatingRowBackground="#F8FAFC"
                                      BorderThickness="0" RowHeight="28" FontSize="12"
                                      EnableRowVirtualization="True" EnableColumnVirtualization="True"
                                      VerticalGridLinesBrush="#F1F5F9" HorizontalGridLinesBrush="#F1F5F9">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <!-- Hover -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#EEF2FF"/>
                                            </Trigger>
                                            <!-- MM- (przed krojeniem) — fioletowy odcień, kierunek międzymagazynowy -->
                                            <DataTrigger Binding="{Binding Etap}" Value="MM- (przed krojeniem)">
                                                <Setter Property="Background" Value="#FAF5FF"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Etap}" Value="MM- (po krojeniu)">
                                                <Setter Property="Background" Value="#FAF5FF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                        <Setter Property="Foreground" Value="#475569"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="🔍 Filtruj tylko ten towar"
                                                  Click="MenuFiltruyTowar_Click"/>
                                        <MenuItem Header="📦 Filtruj tylko ten etap"
                                                  Click="MenuFiltruyEtap_Click"/>
                                        <MenuItem Header="📄 Filtruj tylko tę serię"
                                                  Click="MenuFiltruySeria_Click"/>
                                        <Separator/>
                                        <MenuItem Header="📋 Skopiuj kg"
                                                  Click="MenuSkopiujKg_Click"/>
                                        <MenuItem Header="📋 Skopiuj wiersz (CSV)"
                                                  Click="MenuSkopiujWiersz_Click"/>
                                        <Separator/>
                                        <MenuItem Header="❌ Wyczyść wszystkie filtry"
                                                  Click="BtnBmWyczyscFiltr_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.ContainerStyle>
                                            <Style TargetType="GroupItem">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="GroupItem">
                                                            <Expander IsExpanded="True" Background="#FAF5FF"
                                                                      BorderBrush="#7C3AED"
                                                                      BorderThickness="0,1,0,1">
                                                                <Expander.Header>
                                                                    <Grid Margin="4,0">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Grid.Column="0" CornerRadius="3"
                                                                                Padding="6,2" Margin="0,2,12,2"
                                                                                Background="{Binding Name, Converter={StaticResource EtapTloConverter}}">
                                                                            <TextBlock Text="{Binding Name}"
                                                                                       FontWeight="Bold" FontSize="12"
                                                                                       Foreground="{Binding Name, Converter={StaticResource EtapKolorConverter}}"/>
                                                                        </Border>
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding Items, Converter={StaticResource GrupaPodsumowanieConverter}}"
                                                                                   FontSize="11" FontWeight="SemiBold"
                                                                                   Foreground="#475569"
                                                                                   VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </Expander.Header>
                                                                <ItemsPresenter/>
                                                            </Expander>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </GroupStyle.ContainerStyle>
                                    </GroupStyle>
                                </DataGrid.GroupStyle>
                                <DataGrid.Columns>
                                    <!-- Kolorowy pasek kategorii (4px) — szybki vizualny scan -->
                                    <DataGridTemplateColumn Header="" Width="6" CanUserResize="False" CanUserSort="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Rectangle Fill="{Binding Kategoria, Converter={StaticResource KategoriaKolor}}"
                                                           Width="4" HorizontalAlignment="Stretch"
                                                           ToolTip="{Binding Kategoria}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Kategoria" Binding="{Binding Kategoria}" Width="110"/>
                                    <DataGridTextColumn Header="Towar" Binding="{Binding Nazwa}" Width="2*"/>
                                    <DataGridTextColumn Header="Kod" Binding="{Binding Kod}" Width="110"/>
                                    <DataGridTextColumn Header="Seria" Binding="{Binding Seria}" Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="Foreground" Value="#1E40AF"/>
                                                <Setter Property="ToolTip" Value="Seria dokumentu Symfonii (sPZ/sRWU/sPWU/MM-/sRWP/sPWP)"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="🏭 Magazyn" Binding="{Binding MagazynNazwa}" Width="140"
                                                         SortMemberPath="MagazynID">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="#1F2937"/>
                                                <Setter Property="ToolTip">
                                                    <Setter.Value>
                                                        <MultiBinding StringFormat="{}{0} (ID: {1})">
                                                            <Binding Path="MagazynNazwa"/>
                                                            <Binding Path="MagazynID"/>
                                                        </MultiBinding>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="📍 Skąd (MM-)" Binding="{Binding MagazynDocelowyNazwa}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="#7C3AED"/>
                                                <Setter Property="ToolTip" Value="Magazyn źródłowy MM- (z którego towar wyszedł). W kolumnie Magazyn po lewej widać dokąd towar poszedł."/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="📄 Dok." Binding="{Binding LicznikDokumentow}" Width="80"
                                                         SortMemberPath="LiczbaDokumentow">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="#475569"/>
                                                <Setter Property="ToolTip" Value="{Binding NumeryDokumentow}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="📋 Numery dokumentów" Binding="{Binding NumeryDokumentowSkrocone}" Width="200">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Foreground" Value="#1F2937"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding NumeryDokumentow}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="kg" Binding="{Binding Kg, StringFormat=N0}" Width="110"
                                                        SortMemberPath="Kg">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="Foreground" Value="#0F172A"/>
                                                <Setter Property="Padding" Value="0,0,10,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="% bazy" Binding="{Binding ProcentBazy, StringFormat=N2}"
                                                        Width="80" SortMemberPath="ProcentBazy">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="Foreground" Value="#7C3AED"/>
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Padding" Value="0,0,10,0"/>
                                                <Setter Property="ToolTip" Value="% udziału w bazie wybranej w komparatorze (Żywiec / A+B / TuszkaA / TuszkaB)"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                        </TabItem>
                        <!-- ───── KONIEC Sub-Tab 1 ───── -->

                        <!-- ───── Sub-Tab 2: Stan magazynów (production-focused: flow + towary + dokumenty) ───── -->
                        <TabItem Header="🏭 Stan magazynów">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                                <StackPanel>

                                    <!-- ═══ SEKCJA 0: HERO KPI STRIP — USUNIĘTE NA ŻYCZENIE UŻYTKOWNIKA ═══ -->
                                    <!-- Wskaźniki przeniesione do strzałek w łańcuchu produkcji -->
                                    <Border Visibility="Collapsed">
                                        <UniformGrid Columns="6" Rows="1">
                                            <!-- Wejście żywca -->
                                            <Border Padding="16,14" BorderBrush="#334155" BorderThickness="0,0,1,0">
                                                <StackPanel>
                                                    <TextBlock Text="🐔  ŻYWIEC WEJŚCIE" FontSize="9" FontWeight="Bold"
                                                               Foreground="#F59E0B" Margin="0,0,0,2"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="txtKpiZywiecKg" Text="—"
                                                                   FontSize="26" FontWeight="Bold" FontFamily="Consolas"
                                                                   Foreground="White" VerticalAlignment="Bottom"/>
                                                        <TextBlock Text="kg" FontSize="10" Foreground="#94A3B8"
                                                                   VerticalAlignment="Bottom" Margin="3,0,0,3"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="txtKpiZywiecDok" Text="" FontSize="10"
                                                               Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </Border>
                                            <!-- Wydajność uboju -->
                                            <Border Padding="16,14" BorderBrush="#334155" BorderThickness="0,0,1,0">
                                                <StackPanel>
                                                    <TextBlock Text="⚙  WYD. UBOJU" FontSize="9" FontWeight="Bold"
                                                               Foreground="#DC2626" Margin="0,0,0,2"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="txtKpiWydUboju" Text="—"
                                                                   FontSize="26" FontWeight="Bold" FontFamily="Consolas"
                                                                   Foreground="White" VerticalAlignment="Bottom"/>
                                                        <TextBlock Text="%" FontSize="11" Foreground="#94A3B8"
                                                                   VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                                                    </StackPanel>
                                                    <Border x:Name="bdKpiWydUbojuStatus" CornerRadius="3" Padding="4,1"
                                                            HorizontalAlignment="Left" Background="#94A3B8" Margin="0,1,0,0">
                                                        <TextBlock x:Name="txtKpiWydUbojuStatus" Text="—"
                                                                   FontSize="9" FontWeight="SemiBold" Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                            <!-- Wydajność krojenia -->
                                            <Border Padding="16,14" BorderBrush="#334155" BorderThickness="0,0,1,0">
                                                <StackPanel>
                                                    <TextBlock Text="🔪  WYD. KROJENIA" FontSize="9" FontWeight="Bold"
                                                               Foreground="#7C3AED" Margin="0,0,0,2"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="txtKpiWydKrojenia" Text="—"
                                                                   FontSize="26" FontWeight="Bold" FontFamily="Consolas"
                                                                   Foreground="White" VerticalAlignment="Bottom"/>
                                                        <TextBlock Text="%" FontSize="11" Foreground="#94A3B8"
                                                                   VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                                                    </StackPanel>
                                                    <Border x:Name="bdKpiWydKrojeniaStatus" CornerRadius="3" Padding="4,1"
                                                            HorizontalAlignment="Left" Background="#94A3B8" Margin="0,1,0,0">
                                                        <TextBlock x:Name="txtKpiWydKrojeniaStatus" Text="—"
                                                                   FontSize="9" FontWeight="SemiBold" Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                            <!-- Straty -->
                                            <Border Padding="16,14" BorderBrush="#334155" BorderThickness="0,0,1,0">
                                                <StackPanel>
                                                    <TextBlock Text="📉  STRATY UBOJU" FontSize="9" FontWeight="Bold"
                                                               Foreground="#F87171" Margin="0,0,0,2"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="txtKpiStraty" Text="—"
                                                                   FontSize="26" FontWeight="Bold" FontFamily="Consolas"
                                                                   Foreground="White" VerticalAlignment="Bottom"/>
                                                        <TextBlock Text="%" FontSize="11" Foreground="#94A3B8"
                                                                   VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="txtKpiStratyKg" Text="" FontSize="10"
                                                               Foreground="#94A3B8" FontFamily="Consolas"/>
                                                </StackPanel>
                                            </Border>
                                            <!-- Klienci -->
                                            <Border Padding="16,14" BorderBrush="#334155" BorderThickness="0,0,1,0">
                                                <StackPanel>
                                                    <TextBlock Text="🚚  WYDANO KLIENTOM" FontSize="9" FontWeight="Bold"
                                                               Foreground="#10B981" Margin="0,0,0,2"/>
                                                    <StackPanel Orientation="Horizontal">
