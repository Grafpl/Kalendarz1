                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                        </Grid.RowDefinitions>
                                                                        <Border Grid.Row="0" x:Name="bdArrowDystKlienci" CornerRadius="6"
                                                                                Padding="14,7" HorizontalAlignment="Center"
                                                                                Background="#10B981" Margin="0,0,0,6">
                                                                            <Border.Effect>
                                                                                <DropShadowEffect Color="#10B981" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                                                                            </Border.Effect>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="🚚" FontSize="13" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                                <TextBlock x:Name="txtArrowDystKlienciProc" Text="—"
                                                                                           FontSize="14" FontWeight="Bold" Foreground="White"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                                                            <Border Width="100" Height="22" CornerRadius="6" VerticalAlignment="Center">
                                                                                <Border.Background>
                                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                        <GradientStop Color="#10B981" Offset="0"/>
                                                                                        <GradientStop Color="#6EE7B7" Offset="1"/>
                                                                                    </LinearGradientBrush>
                                                                                </Border.Background>
                                                                                <Border.Effect>
                                                                                    <DropShadowEffect Color="#047857" BlurRadius="6" ShadowDepth="1" Opacity="0.4"/>
                                                                                </Border.Effect>
                                                                            </Border>
                                                                            <Polygon Points="0,0 24,22 0,44" Fill="#6EE7B7" Stretch="None" VerticalAlignment="Center">
                                                                                <Polygon.Effect>
                                                                                    <DropShadowEffect Color="#047857" BlurRadius="6" ShadowDepth="2" Opacity="0.3"/>
                                                                                </Polygon.Effect>
                                                                            </Polygon>
                                                                        </StackPanel>
                                                                        <TextBlock Grid.Row="2" x:Name="txtArrowDystKlienciOpis"
                                                                                   FontSize="12" Foreground="#047857" FontWeight="Bold"
                                                                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                                                    </Grid>

                                                                    <Border Style="{StaticResource FlowCardStyle}"
                                                                            Background="#D1FAE5" BorderBrush="#10B981"
                                                                            Tag="KLIENCI" MouseLeftButtonUp="FlowCard_Click"
                                                                            ToolTip="Kliknij — szczegóły sprzedaży klientom">
                                                                        <Grid>
                                                                            <TextBlock Text="🚚" FontSize="100" Opacity="0.06"
                                                                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                                       Margin="0,-12,-8,0" IsHitTestVisible="False"/>
                                                                            <StackPanel>
                                                                                <TextBlock Text="🚚  KLIENCI" FontSize="14" FontWeight="Bold"
                                                                                           Foreground="#047857" HorizontalAlignment="Center"/>
                                                                                <Border Background="#10B981" Height="3" Width="40" CornerRadius="2"
                                                                                        Margin="0,3,0,8" HorizontalAlignment="Center" Opacity="0.5"/>
                                                                                <TextBlock x:Name="txtFlowKlienciKg" Text="—"
                                                                                           FontSize="32" FontWeight="Bold" FontFamily="Consolas"
                                                                                           HorizontalAlignment="Center" Foreground="#0F172A"/>
                                                                                <TextBlock Text="kg (sWZ)" FontSize="11" FontWeight="SemiBold"
                                                                                           HorizontalAlignment="Center" Foreground="#94A3B8"/>
                                                                                <Border Background="#D1FAE5" CornerRadius="4" Padding="6,3"
                                                                                        HorizontalAlignment="Center" Margin="0,8,0,0"
                                                                                        BorderBrush="#10B981" BorderThickness="1">
                                                                                    <TextBlock x:Name="txtFlowKlienciDok" Text=""
                                                                                               FontSize="11" FontWeight="Bold" Foreground="#047857"/>
                                                                                </Border>
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                </StackPanel>

                                                                <!-- BRANCHES jako 2x2 chip grid -->
