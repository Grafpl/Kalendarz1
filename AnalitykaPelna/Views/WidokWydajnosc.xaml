                                                                   FontSize="12" Foreground="#DC2626" FontStyle="Italic" FontWeight="Bold"
                                                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                                    </Grid>

                                                    <!-- ════════════════════════════════════════════════════════════ -->
                                                    <!-- STREFA 2: PRODUKCJA CZYSTA (ZIELONA) — UBÓJ + PROD vertical    -->
                                                    <!-- ════════════════════════════════════════════════════════════ -->
                                                    <Border Grid.Column="2" BorderBrush="#10B981" BorderThickness="2.5" CornerRadius="18"
                                                            Background="#D1FAE515" Padding="22,30,22,18" Margin="4,0,4,0">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#10B981" BlurRadius="16" ShadowDepth="2" Opacity="0.22"/>
                                                        </Border.Effect>
                                                        <Grid>
                                                            <Border Background="#10B981" CornerRadius="8" Padding="14,5"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Top"
                                                                    Margin="0,-44,0,0">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="#047857" BlurRadius="8" ShadowDepth="2" Opacity="0.5"/>
                                                                </Border.Effect>
                                                                <TextBlock Text="🏭  PRODUKCJA CZYSTA  (ubój + krojenie)"
                                                                           FontSize="12" FontWeight="Bold" Foreground="White"/>
                                                            </Border>
                                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <!-- UBÓJ card — kompaktowy układ: lewa KG | prawa dokumenty + towary (2 kolumny) -->
                                                                <Border Style="{StaticResource FlowCardStyle}"
                                                                        Background="#FEE2E2" BorderBrush="#DC2626"
                                                                        Tag="UBOJ" MouseLeftButtonUp="FlowCard_Click"
                                                                        ToolTip="Kliknij — pełen szczegół uboju"
                                                                        HorizontalAlignment="Center" Padding="14,12">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <!-- LEWA: KG + tytuł -->
                                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,14,0">
                                                                            <TextBlock Text="⚙  UBÓJ" FontSize="13" FontWeight="Bold"
                                                                                       Foreground="#7F1D1D" HorizontalAlignment="Center"/>
                                                                            <Border Background="#DC2626" Height="3" Width="40" CornerRadius="2"
                                                                                    Margin="0,3,0,6" HorizontalAlignment="Center" Opacity="0.5"/>
                                                                            <TextBlock x:Name="txtFlowUbojKg" Text="—"
                                                                                       FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                                                                                       HorizontalAlignment="Center" Foreground="#0F172A"/>
                                                                            <TextBlock Text="kg (sPWU)" FontSize="10" FontWeight="SemiBold"
                                                                                       HorizontalAlignment="Center" Foreground="#94A3B8"/>
                                                                            <Border Background="#FEE2E2" CornerRadius="4" Padding="6,3"
                                                                                    HorizontalAlignment="Center" Margin="0,6,0,0"
                                                                                    BorderBrush="#DC2626" BorderThickness="1">
                                                                                <TextBlock x:Name="txtFlowUbojDok" Text=""
                                                                                           FontSize="10" FontWeight="Bold" Foreground="#7F1D1D"/>
                                                                            </Border>
                                                                        </StackPanel>

                                                                        <!-- PRAWA: lista top towarów (2 kolumny) -->
                                                                        <Border Grid.Column="1" x:Name="bdUbojTopTowary"
                                                                                Background="#FFFBFB" BorderBrush="#FECACA" BorderThickness="1"
                                                                                CornerRadius="6" Padding="6,5" VerticalAlignment="Stretch"
                                                                                Visibility="Collapsed">
                                                                            <StackPanel>
                                                                                <TextBlock Text="🥩 WYPRODUKOWANE — z dokumentów sPWU"
                                                                                           FontSize="9" FontWeight="Bold"
                                                                                           Foreground="#991B1B" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                                                <ItemsControl x:Name="icUbojTopTowary">
                                                                                    <ItemsControl.ItemsPanel>
                                                                                        <ItemsPanelTemplate>
                                                                                            <UniformGrid Columns="2"/>
                                                                                        </ItemsPanelTemplate>
                                                                                    </ItemsControl.ItemsPanel>
                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <Border Background="White" BorderBrush="#FECACA" BorderThickness="1"
                                                                                                    CornerRadius="5" Padding="4,3" Margin="2">
                                                                                                <Grid>
                                                                                                    <Grid.ColumnDefinitions>
                                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                                        <ColumnDefinition Width="*"/>
                                                                                                    </Grid.ColumnDefinitions>
                                                                                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                                                                                            Background="#FAFBFC" BorderBrush="#FECACA" BorderThickness="1"
                                                                                                            Margin="0,0,5,0" VerticalAlignment="Center">
                                                                                                        <Grid>
                                                                                                            <Image Source="{Binding ImageSource}" Stretch="UniformToFill"
                                                                                                                   Visibility="{Binding ImageVisibility}"/>
                                                                                                            <TextBlock Text="{Binding PlaceholderEmoji}" FontSize="16"
                                                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                                       Visibility="{Binding PlaceholderVisibility}"/>
                                                                                                        </Grid>
                                                                                                    </Border>
                                                                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                                                        <TextBlock Text="{Binding Kod}" FontSize="9" FontWeight="Bold"
                                                                                                                   Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                                                                                                        <StackPanel Orientation="Horizontal">
                                                                                                            <TextBlock Text="{Binding Kg, StringFormat=N0}" FontSize="10"
                                                                                                                       FontWeight="Bold" FontFamily="Consolas" Foreground="#0F172A"/>
                                                                                                            <TextBlock Text="kg" FontSize="8" Foreground="#94A3B8"
                                                                                                                       VerticalAlignment="Bottom" Margin="2,0,3,1"/>
                                                                                                            <TextBlock Text="{Binding LiczbaDok, StringFormat='({0} dok)'}" FontSize="8"
                                                                                                                       Foreground="#94A3B8" VerticalAlignment="Bottom" Margin="0,0,3,1"/>
                                                                                                            <TextBlock Text="{Binding ProcentUdzialu, StringFormat='{}{0:F1}%'}"
                                                                                                                       FontSize="8" FontWeight="SemiBold"
                                                                                                                       Foreground="#DC2626" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                                                                                        </StackPanel>
                                                                                                    </StackPanel>
                                                                                                </Grid>
                                                                                            </Border>
                                                                                        </DataTemplate>
                                                                                    </ItemsControl.ItemTemplate>
                                                                                </ItemsControl>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </Grid>
                                                                </Border>

                                                                <!-- ▼ Vertical arrow UBÓJ → PROD with "ile na krojenie" -->
                                                                <Grid HorizontalAlignment="Center" Margin="0,12,0,12">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>
                                                                    <!-- TOP: ile poszło na krojenie -->
                                                                    <Border Grid.Row="0" Background="#7C3AED" CornerRadius="6" Padding="12,5"
                                                                            HorizontalAlignment="Center" Margin="0,0,0,4">
                                                                        <Border.Effect>
                                                                            <DropShadowEffect Color="#5B21B6" BlurRadius="8" ShadowDepth="2" Opacity="0.5"/>
                                                                        </Border.Effect>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="🔪  na krojenie:" FontSize="11" FontWeight="SemiBold"
                                                                                       Foreground="White" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                            <TextBlock x:Name="txtKrojRozchod" Text="—" FontSize="14" FontWeight="Bold"
                                                                                       Foreground="White" FontFamily="Consolas"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <!-- MIDDLE: vertical bar + arrow tip pointing down -->
                                                                    <Grid Grid.Row="1" HorizontalAlignment="Center">
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                        </Grid.RowDefinitions>
                                                                        <Border Grid.Row="0" Width="26" Height="42" CornerRadius="6"
                                                                                HorizontalAlignment="Center">
                                                                            <Border.Background>
                                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                                    <GradientStop Color="#DC2626" Offset="0"/>
                                                                                    <GradientStop Color="#10B981" Offset="1"/>
                                                                                </LinearGradientBrush>
                                                                            </Border.Background>
                                                                            <Border.Effect>
                                                                                <DropShadowEffect Color="#475569" BlurRadius="8" ShadowDepth="2" Opacity="0.4"/>
                                                                            </Border.Effect>
                                                                        </Border>
                                                                        <Polygon Grid.Row="1" Points="0,0 24,30 48,0" Fill="#10B981"
                                                                                 Stretch="None" HorizontalAlignment="Center" Margin="0,-2,0,0">
                                                                            <Polygon.Effect>
                                                                                <DropShadowEffect Color="#047857" BlurRadius="6" ShadowDepth="2" Opacity="0.4"/>
                                                                            </Polygon.Effect>
                                                                        </Polygon>
                                                                    </Grid>
                                                                    <!-- BOTTOM: wyd. krojenia -->
                                                                    <Border Grid.Row="2" Background="#10B981" CornerRadius="6" Padding="12,5"
                                                                            HorizontalAlignment="Center" Margin="0,4,0,0">
                                                                        <Border.Effect>
                                                                            <DropShadowEffect Color="#047857" BlurRadius="8" ShadowDepth="2" Opacity="0.5"/>
                                                                        </Border.Effect>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="Wyd. krojenia:" FontSize="11" FontWeight="SemiBold"
                                                                                       Foreground="White" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                            <TextBlock x:Name="txtArrowUbojProdProc" Text="—" FontSize="16" FontWeight="Bold"
                                                                                       Foreground="White" FontFamily="Consolas"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Grid>

                                                                <!-- PROD card (ZIELONA) — kompaktowy układ: lewa KG | prawa dokumenty + towary (2 kolumny) -->
                                                                <Border Style="{StaticResource FlowCardStyle}"
                                                                        Background="#D1FAE5" BorderBrush="#10B981"
                                                                        Tag="PRODUKCJA" MouseLeftButtonUp="FlowCard_Click"
                                                                        ToolTip="Kliknij — pełen szczegół produkcji"
                                                                        HorizontalAlignment="Center" Padding="14,12">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <!-- LEWA: KG + tytuł + Δ strata -->
                                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,14,0">
                                                                            <TextBlock Text="🔪  PRODUKCJA" FontSize="13" FontWeight="Bold"
                                                                                       Foreground="#047857" HorizontalAlignment="Center"/>
                                                                            <Border Background="#10B981" Height="3" Width="40" CornerRadius="2"
                                                                                    Margin="0,3,0,6" HorizontalAlignment="Center" Opacity="0.5"/>
                                                                            <TextBlock x:Name="txtFlowProdKg" Text="—"
                                                                                       FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                                                                                       HorizontalAlignment="Center" Foreground="#0F172A"/>
                                                                            <TextBlock Text="kg (sPWP)" FontSize="10" FontWeight="SemiBold"
                                                                                       HorizontalAlignment="Center" Foreground="#94A3B8"/>
                                                                            <Border Background="#D1FAE5" CornerRadius="4" Padding="6,3"
                                                                                    HorizontalAlignment="Center" Margin="0,6,0,0"
                                                                                    BorderBrush="#10B981" BorderThickness="1">
                                                                                <TextBlock x:Name="txtFlowProdDok" Text=""
                                                                                           FontSize="10" FontWeight="Bold" Foreground="#047857"/>
                                                                            </Border>
                                                                            <Border Background="#FAFBFC" BorderBrush="#CBD5E1" BorderThickness="1"
                                                                                    CornerRadius="5" Padding="6,3" Margin="0,5,0,0">
                                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                                    <TextBlock Text="Δ strata: " FontSize="9" Foreground="#64748B" VerticalAlignment="Center"/>
                                                                                    <TextBlock x:Name="txtKrojRoznica" Text="—" FontSize="10"
                                                                                               FontWeight="Bold" FontFamily="Consolas" Foreground="#7C3AED"/>
                                                                                </StackPanel>
                                                                            </Border>
                                                                        </StackPanel>

                                                                        <!-- PRAWA: lista top towarów (2 kolumny) -->
                                                                        <Border Grid.Column="1" x:Name="bdProdTopTowary"
                                                                                Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1"
                                                                                CornerRadius="6" Padding="6,5" VerticalAlignment="Stretch"
                                                                                Visibility="Collapsed">
                                                                            <StackPanel>
                                                                                <TextBlock Text="🔪 ELEMENTY PO KROJENIU — z dokumentów sPWP"
                                                                                           FontSize="9" FontWeight="Bold"
                                                                                           Foreground="#047857" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                                                <ItemsControl x:Name="icProdTopTowary">
                                                                                    <ItemsControl.ItemsPanel>
                                                                                        <ItemsPanelTemplate>
                                                                                            <UniformGrid Columns="2"/>
                                                                                        </ItemsPanelTemplate>
                                                                                    </ItemsControl.ItemsPanel>
                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <Border Background="White" BorderBrush="#86EFAC" BorderThickness="1"
                                                                                                    CornerRadius="5" Padding="4,3" Margin="2">
                                                                                                <Grid>
                                                                                                    <Grid.ColumnDefinitions>
                                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                                        <ColumnDefinition Width="*"/>
                                                                                                    </Grid.ColumnDefinitions>
                                                                                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                                                                                            Background="#FAFBFC" BorderBrush="#86EFAC" BorderThickness="1"
                                                                                                            Margin="0,0,5,0" VerticalAlignment="Center">
                                                                                                        <Grid>
                                                                                                            <Image Source="{Binding ImageSource}" Stretch="UniformToFill"
                                                                                                                   Visibility="{Binding ImageVisibility}"/>
                                                                                                            <TextBlock Text="{Binding PlaceholderEmoji}" FontSize="16"
                                                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                                       Visibility="{Binding PlaceholderVisibility}"/>
                                                                                                        </Grid>
                                                                                                    </Border>
                                                                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                                                        <TextBlock Text="{Binding Kod}" FontSize="9" FontWeight="Bold"
                                                                                                                   Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                                                                                                        <StackPanel Orientation="Horizontal">
                                                                                                            <TextBlock Text="{Binding Kg, StringFormat=N0}" FontSize="10"
                                                                                                                       FontWeight="Bold" FontFamily="Consolas" Foreground="#0F172A"/>
                                                                                                            <TextBlock Text="kg" FontSize="8" Foreground="#94A3B8"
                                                                                                                       VerticalAlignment="Bottom" Margin="2,0,3,1"/>
                                                                                                            <TextBlock Text="{Binding LiczbaDok, StringFormat='({0} dok)'}" FontSize="8"
                                                                                                                       Foreground="#94A3B8" VerticalAlignment="Bottom" Margin="0,0,3,1"/>
                                                                                                            <TextBlock Text="{Binding ProcentUdzialu, StringFormat='{}{0:F1}%'}"
