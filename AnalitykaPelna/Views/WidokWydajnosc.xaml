                                                                        <DropShadowEffect Color="#25000000" BlurRadius="14" ShadowDepth="4"/>
                                                                    </Border.Effect>
                                                                    <StackPanel>
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                                                            <TextBlock Text="↳" FontSize="16" FontWeight="Bold" Foreground="#475569" Margin="0,0,4,0"/>
                                                                            <TextBlock Text="POZOSTAŁE KIERUNKI Z PRODUKCJI" FontSize="12" FontWeight="Bold"
                                                                                       Foreground="#475569" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                        <Border Background="#475569" Height="2" Width="120" CornerRadius="1"
                                                                                HorizontalAlignment="Center" Opacity="0.3" Margin="0,0,0,10"/>

                                                                        <UniformGrid Columns="2" Rows="2">
                                                                            <!-- MROŹ chip -->
                                                                            <Border Background="#F0F9FF" BorderBrush="#0EA5E9" BorderThickness="2"
                                                                                    CornerRadius="10" Padding="10,8" Margin="3"
