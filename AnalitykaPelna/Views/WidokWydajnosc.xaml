                                                                                           HorizontalAlignment="Center" Foreground="#0F172A"/>
                                                                                <TextBlock Text="kg (na 65556)" FontSize="11" FontWeight="SemiBold"
                                                                                           HorizontalAlignment="Center" Foreground="#94A3B8"/>
                                                                                <Border Background="#DBEAFE" CornerRadius="4" Padding="6,3"
                                                                                        HorizontalAlignment="Center" Margin="0,8,0,0"
                                                                                        BorderBrush="#2563EB" BorderThickness="1">
                                                                                    <TextBlock x:Name="txtFlowDystDok" Text=""
                                                                                               FontSize="11" FontWeight="Bold" Foreground="#1E40AF"/>
                                                                                </Border>
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>

                                                                    <!-- Arrow DYST→KLIENCI -->
                                                                    <Grid VerticalAlignment="Center" Margin="6,0">
