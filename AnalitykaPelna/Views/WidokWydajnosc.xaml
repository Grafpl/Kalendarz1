                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>  <!-- 0: STREFA 1 ŻYWIEC -->
                                                        <ColumnDefinition Width="Auto"/>  <!-- 1: Arrow Z→U -->
                                                        <ColumnDefinition Width="Auto"/>  <!-- 2: STREFA 2 PRODUKCJA -->
                                                        <ColumnDefinition Width="Auto"/>  <!-- 3: Arrow fan-out -->
                                                        <ColumnDefinition Width="Auto"/>  <!-- 4: STREFA 3 DYST -->
                                                    </Grid.ColumnDefinitions>

                                                    <!-- ════════════════════════════════════════════════════════════ -->
                                                    <!-- STREFA 1: ŻYWIEC BRUDNY (CZERWONA)                            -->
                                                    <!-- ════════════════════════════════════════════════════════════ -->
                                                    <Border Grid.Column="0" BorderBrush="#DC2626" BorderThickness="2.5" CornerRadius="18"
                                                            Background="#FEE2E215" Padding="22,30,22,18" Margin="0,0,4,0">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#DC2626" BlurRadius="16" ShadowDepth="2" Opacity="0.22"/>
                                                        </Border.Effect>
                                                        <Grid>
                                                            <Border Background="#DC2626" CornerRadius="8" Padding="14,5"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Top"
                                                                    Margin="0,-44,0,0">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="#7F1D1D" BlurRadius="8" ShadowDepth="2" Opacity="0.5"/>
                                                                </Border.Effect>
                                                                <TextBlock Text="🚩  ŻYWIEC BRUDNY" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                                            </Border>
                                                            <Border Style="{StaticResource FlowCardStyle}"
                                                                    Background="#FEE2E2" BorderBrush="#DC2626"
                                                                    Tag="ZYWIEC" MouseLeftButtonUp="FlowCard_Click"
                                                                    ToolTip="Kliknij — pełen szczegół żywca"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Grid>
                                                                    <TextBlock Text="🐔" FontSize="100" Opacity="0.06"
                                                                               HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                               Margin="0,-12,-8,0" IsHitTestVisible="False"/>
                                                                    <StackPanel>
                                                                        <TextBlock Text="🐔  ŻYWIEC" FontSize="14" FontWeight="Bold"
                                                                                   Foreground="#7F1D1D" HorizontalAlignment="Center"/>
                                                                        <Border Background="#DC2626" Height="3" Width="40" CornerRadius="2"
                                                                                Margin="0,3,0,8" HorizontalAlignment="Center" Opacity="0.5"/>
                                                                        <TextBlock x:Name="txtFlowZywiecKg" Text="—"
                                                                                   FontSize="32" FontWeight="Bold" FontFamily="Consolas"
                                                                                   HorizontalAlignment="Center" Foreground="#0F172A"/>
                                                                        <TextBlock Text="kg" FontSize="11" FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Center" Foreground="#94A3B8"/>
                                                                        <Border Background="#FEE2E2" CornerRadius="4" Padding="6,3"
                                                                                HorizontalAlignment="Center" Margin="0,8,0,0"
                                                                                BorderBrush="#DC2626" BorderThickness="1">
                                                                            <TextBlock x:Name="txtFlowZywiecDok" Text=""
                                                                                       FontSize="11" FontWeight="Bold" Foreground="#7F1D1D"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </Grid>
                                                    </Border>

                                                    <!-- COL 1: Arrow Z→U (z wyd. uboju) -->
