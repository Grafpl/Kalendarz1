                                                                                    <DropShadowEffect Color="#0EA5E9" BlurRadius="6" ShadowDepth="0" Opacity="0.25"/>
                                                                                </Border.Effect>
                                                                                <StackPanel>
                                                                                    <TextBlock Text="❄  MROŹNIA" FontSize="12" FontWeight="Bold"
                                                                                               Foreground="#0E7490" HorizontalAlignment="Center"/>
                                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                                                        <TextBlock x:Name="txtFlowMrozKg" Text="—" FontSize="16" FontWeight="Bold"
                                                                                                   FontFamily="Consolas" Foreground="#0F172A"/>
                                                                                        <TextBlock Text="kg" FontSize="10" Foreground="#94A3B8"
                                                                                                   VerticalAlignment="Bottom" Margin="3,0,0,2"/>
                                                                                    </StackPanel>
                                                                                    <Border Background="#0EA5E9" CornerRadius="3" Padding="5,2"
                                                                                            HorizontalAlignment="Center" Margin="0,3,0,0">
                                                                                        <TextBlock x:Name="txtFlowMrozProc" Text="—%" FontSize="10"
                                                                                                   FontWeight="Bold" Foreground="White"/>
                                                                                    </Border>
                                                                                    <TextBlock x:Name="txtFlowMrozDok" Text="" FontSize="10" FontWeight="SemiBold"
                                                                                               Foreground="#0E7490" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                                                </StackPanel>
                                                                            </Border>

                                                                            <!-- MASARNIA chip -->
                                                                            <Border Background="#FEF7EE" BorderBrush="#9A3412" BorderThickness="2"
                                                                                    CornerRadius="10" Padding="10,8" Margin="3"
                                                                                    Tag="MASARNIA" MouseLeftButtonUp="FlowCard_Click"
                                                                                    Cursor="Hand" ToolTip="Kliknij — szczegóły masarni">
                                                                                <Border.Effect>
                                                                                    <DropShadowEffect Color="#9A3412" BlurRadius="6" ShadowDepth="0" Opacity="0.25"/>
                                                                                </Border.Effect>
                                                                                <StackPanel>
                                                                                    <TextBlock Text="🥓  MASARNIA" FontSize="12" FontWeight="Bold"
                                                                                               Foreground="#9A3412" HorizontalAlignment="Center"/>
                                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                                                        <TextBlock x:Name="txtFlowMasarKg" Text="—" FontSize="16" FontWeight="Bold"
                                                                                                   FontFamily="Consolas" Foreground="#0F172A"/>
                                                                                        <TextBlock Text="kg" FontSize="10" Foreground="#94A3B8"
                                                                                                   VerticalAlignment="Bottom" Margin="3,0,0,2"/>
                                                                                    </StackPanel>
                                                                                    <Border Background="#9A3412" CornerRadius="3" Padding="5,2"
                                                                                            HorizontalAlignment="Center" Margin="0,3,0,0">
                                                                                        <TextBlock x:Name="txtFlowMasarProc" Text="—%" FontSize="10"
                                                                                                   FontWeight="Bold" Foreground="White"/>
                                                                                    </Border>
                                                                                    <TextBlock x:Name="txtFlowMasarDok" Text="" FontSize="10" FontWeight="SemiBold"
                                                                                               Foreground="#9A3412" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                                                </StackPanel>
                                                                            </Border>

                                                                            <!-- KARMA chip -->
                                                                            <Border Background="#FEFCE8" BorderBrush="#CA8A04" BorderThickness="2"
                                                                                    CornerRadius="10" Padding="10,8" Margin="3"
                                                                                    Tag="KARMA" MouseLeftButtonUp="FlowCard_Click"
                                                                                    Cursor="Hand" ToolTip="Kliknij — szczegóły karmy">
                                                                                <Border.Effect>
                                                                                    <DropShadowEffect Color="#CA8A04" BlurRadius="6" ShadowDepth="0" Opacity="0.25"/>
                                                                                </Border.Effect>
                                                                                <StackPanel>
                                                                                    <TextBlock Text="🌾  KARMA" FontSize="12" FontWeight="Bold"
                                                                                               Foreground="#A16207" HorizontalAlignment="Center"/>
                                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                                                        <TextBlock x:Name="txtFlowKarmaKg" Text="—" FontSize="16" FontWeight="Bold"
                                                                                                   FontFamily="Consolas" Foreground="#0F172A"/>
                                                                                        <TextBlock Text="kg" FontSize="10" Foreground="#94A3B8"
                                                                                                   VerticalAlignment="Bottom" Margin="3,0,0,2"/>
                                                                                    </StackPanel>
                                                                                    <Border Background="#CA8A04" CornerRadius="3" Padding="5,2"
                                                                                            HorizontalAlignment="Center" Margin="0,3,0,0">
                                                                                        <TextBlock x:Name="txtFlowKarmaProc" Text="—%" FontSize="10"
                                                                                                   FontWeight="Bold" Foreground="White"/>
                                                                                    </Border>
                                                                                    <TextBlock x:Name="txtFlowKarmaDok" Text="" FontSize="10" FontWeight="SemiBold"
                                                                                               Foreground="#A16207" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                                                </StackPanel>
                                                                            </Border>

                                                                            <!-- ODPADY chip -->
                                                                            <Border Background="#F8FAFC" BorderBrush="#94A3B8" BorderThickness="2"
                                                                                    CornerRadius="10" Padding="10,8" Margin="3"
                                                                                    Tag="ODPADY" MouseLeftButtonUp="FlowCard_Click"
                                                                                    Cursor="Hand" ToolTip="Kliknij — szczegóły odpadów">
                                                                                <Border.Effect>
                                                                                    <DropShadowEffect Color="#475569" BlurRadius="6" ShadowDepth="0" Opacity="0.25"/>
                                                                                </Border.Effect>
                                                                                <StackPanel>
                                                                                    <TextBlock Text="🗑  ODPADY" FontSize="12" FontWeight="Bold"
                                                                                               Foreground="#475569" HorizontalAlignment="Center"/>
                                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                                                        <TextBlock x:Name="txtFlowOdpadyKg" Text="—" FontSize="16" FontWeight="Bold"
                                                                                                   FontFamily="Consolas" Foreground="#0F172A"/>
                                                                                        <TextBlock Text="kg" FontSize="10" Foreground="#94A3B8"
                                                                                                   VerticalAlignment="Bottom" Margin="3,0,0,2"/>
                                                                                    </StackPanel>
                                                                                    <Border Background="#94A3B8" CornerRadius="3" Padding="5,2"
                                                                                            HorizontalAlignment="Center" Margin="0,3,0,0">
                                                                                        <TextBlock x:Name="txtFlowOdpadyProc" Text="—%" FontSize="10"
                                                                                                   FontWeight="Bold" Foreground="White"/>
                                                                                    </Border>
                                                                                    <TextBlock x:Name="txtFlowOdpadyDok" Text="" FontSize="10" FontWeight="SemiBold"
                                                                                               Foreground="#475569" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                                                </StackPanel>
                                                                            </Border>
                                                                        </UniformGrid>
                                                                    </StackPanel>
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                </Grid>
                                            </ScrollViewer>
                                                                                    </StackPanel>
                                    </Border>

                                    <!-- ═══ SEKCJA 2: TOWARY WYPRODUKOWANE — karty z flow lifecycle ═══ -->
                                    <Border x:Name="bdTowaryWyprodukowaneSekcja"
                                            Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                            CornerRadius="10" Padding="20,16" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="🥩" FontSize="16" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Towary wyprodukowane"
                                                               FontWeight="Bold" FontSize="14" Foreground="#0F172A"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="txtTowaryInfo" Text=""
                                                               FontSize="11" Foreground="#94A3B8"
                                                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <CheckBox Grid.Column="1" x:Name="chkTowaryTylkoZSaldem"
                                                          Content="Tylko z saldem &gt; 5%"
                                                          VerticalAlignment="Center" FontSize="11" Margin="0,0,12,0"
                                                          Checked="ChkTowaryTylkoZSaldem_Toggle"
                                                          Unchecked="ChkTowaryTylkoZSaldem_Toggle"/>
                                                <ComboBox Grid.Column="2" x:Name="cbTowaryKategoria"
                                                          Width="140" SelectionChanged="CbTowaryKategoria_Changed"
                                                          ToolTip="Filtruj po kategorii towaru"/>
                                            </Grid>

                                            <ItemsControl x:Name="icTowaryProdukcji">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="3" Rows="0"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource TowarCardStyle}" Width="Auto"
                                                                Margin="0,0,8,8" MinHeight="220">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="100"/>
                                                                    <!-- Image / icon -->
                                                                    <RowDefinition Height="Auto"/>
                                                                    <!-- Title + status -->
                                                                    <RowDefinition Height="Auto"/>
                                                                    <!-- Metrics 3 mini boxes -->
                                                                    <RowDefinition Height="*"/>
                                                                    <!-- Saldo footer -->
                                                                </Grid.RowDefinitions>

                                                                <!-- ROW 0: Image area with fallback -->
                                                                <Grid Grid.Row="0" ClipToBounds="True">
                                                                    <!-- Fallback emoji background (kategoria color tinted) -->
                                                                    <Border Background="{Binding KategoriaKolor, Converter={StaticResource HexToBrush}}"
                                                                            CornerRadius="6,6,0,0" Opacity="0.18"/>
                                                                    <Border Background="{Binding KategoriaKolor, Converter={StaticResource HexToBrush}}"
                                                                            CornerRadius="6,6,0,0" Opacity="0.05"/>
                                                                    <TextBlock Text="{Binding KategoriaIkonaPelna}"
                                                                               FontSize="56" Opacity="0.5"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               Foreground="{Binding KategoriaKolor, Converter={StaticResource HexToBrush}}"/>
                                                                    <!-- Real image (loads if file exists, else null = invisible) -->
                                                                    <Image Source="{Binding ZdjecieSciezka, Converter={StaticResource SafeImage}}"
                                                                           Stretch="UniformToFill" StretchDirection="Both">
                                                                        <Image.Clip>
                                                                            <RectangleGeometry Rect="0,0,500,100" RadiusX="6" RadiusY="6"/>
                                                                        </Image.Clip>
                                                                    </Image>
                                                                    <!-- Top-left: kategoria badge -->
                                                                    <Border Background="{Binding KategoriaKolor, Converter={StaticResource HexToBrush}}"
                                                                            CornerRadius="3" Padding="5,1"
                                                                            HorizontalAlignment="Left" VerticalAlignment="Top"
                                                                            Margin="6,6,0,0">
                                                                        <TextBlock Text="{Binding Kategoria}"
                                                                                   FontSize="9" FontWeight="Bold"
                                                                                   Foreground="White"/>
                                                                    </Border>
                                                                    <!-- Top-right: status badge -->
                                                                    <Border Background="{Binding StatusKolor, Converter={StaticResource HexToBrush}}"
                                                                            CornerRadius="3" Padding="5,1"
                                                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                            Margin="0,6,6,0">
                                                                        <TextBlock Text="{Binding Status}"
                                                                                   FontSize="9" FontWeight="Bold"
                                                                                   Foreground="White"/>
                                                                    </Border>
                                                                </Grid>

                                                                <!-- ROW 1: Title -->
                                                                <StackPanel Grid.Row="1" Margin="10,8,10,4">
                                                                    <TextBlock Text="{Binding Kod}"
                                                                               FontWeight="Bold" FontSize="14"
                                                                               Foreground="#0F172A"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Text="{Binding Nazwa}" FontSize="10"
                                                                               Foreground="#64748B"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               ToolTip="{Binding Nazwa}"/>
                                                                </StackPanel>

                                                                <!-- ROW 2: 3 mini-boxes (wyprod / zużyto / sprzedano) -->
                                                                <UniformGrid Grid.Row="2" Columns="3" Rows="1" Margin="6,4,6,4">
                                                                    <Border Background="#D1FAE5" CornerRadius="4"
                                                                            Padding="4,3" Margin="2,0"
                                                                            ToolTip="{Binding NumeryDokProdukcji}">
                                                                        <StackPanel HorizontalAlignment="Center">
                                                                            <TextBlock Text="⬇ WYPROD." FontSize="8"
                                                                                       FontWeight="Bold" Foreground="#047857"
                                                                                       HorizontalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding WyprodukowanoKg, StringFormat=N0}"
                                                                                       FontSize="12" FontWeight="Bold"
                                                                                       FontFamily="Consolas" Foreground="#064E3B"
                                                                                       HorizontalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding LiczbaDokProdukcji, StringFormat='{}{0} dok'}"
                                                                                       FontSize="8" Foreground="#047857"
                                                                                       HorizontalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <Border Background="#EDE9FE" CornerRadius="4"
                                                                            Padding="4,3" Margin="2,0"
                                                                            ToolTip="{Binding NumeryDokZuzycia}">
                                                                        <StackPanel HorizontalAlignment="Center">
                                                                            <TextBlock Text="🔪 ZUŻYTO" FontSize="8"
                                                                                       FontWeight="Bold" Foreground="#5B21B6"
                                                                                       HorizontalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding ZuzytoKg, StringFormat=N0}"
                                                                                       FontSize="12" FontWeight="Bold"
                                                                                       FontFamily="Consolas" Foreground="#4C1D95"
                                                                                       HorizontalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding LiczbaDokZuzycia, StringFormat='{}{0} dok'}"
                                                                                       FontSize="8" Foreground="#5B21B6"
                                                                                       HorizontalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <Border Background="#FEE2E2" CornerRadius="4"
                                                                            Padding="4,3" Margin="2,0"
                                                                            ToolTip="{Binding NumeryDokSprzedazy}">
                                                                        <StackPanel HorizontalAlignment="Center">
                                                                            <TextBlock Text="⬆ SPRZEDANO" FontSize="8"
                                                                                       FontWeight="Bold" Foreground="#991B1B"
                                                                                       HorizontalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding SprzedanoKg, StringFormat=N0}"
                                                                                       FontSize="12" FontWeight="Bold"
                                                                                       FontFamily="Consolas" Foreground="#7F1D1D"
                                                                                       HorizontalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding LiczbaDokSprzedazy, StringFormat='{}{0} dok'}"
                                                                                       FontSize="8" Foreground="#991B1B"
                                                                                       HorizontalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </UniformGrid>

                                                                <!-- ROW 3: Saldo footer -->
                                                                <Border Grid.Row="3" Background="#F8FAFC"
                                                                        BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                                                                        CornerRadius="0,0,6,6" Padding="10,6"
                                                                        VerticalAlignment="Bottom">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0" Text="SALDO" FontSize="9"
                                                                                   FontWeight="SemiBold" Foreground="#64748B"
                                                                                   VerticalAlignment="Center"/>
                                                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding SaldoIkona}"
                                                                                       FontSize="13" FontWeight="Bold"
                                                                                       Foreground="{Binding StatusKolor, Converter={StaticResource HexToBrush}}"
                                                                                       VerticalAlignment="Center"
                                                                                       Margin="0,0,3,0"/>
                                                                            <TextBlock Text="{Binding SaldoKg, StringFormat=N0}"
                                                                                       FontSize="13" FontWeight="Bold"
                                                                                       FontFamily="Consolas"
                                                                                       Foreground="{Binding StatusKolor, Converter={StaticResource HexToBrush}}"/>
                                                                            <TextBlock Text="kg" FontSize="9"
                                                                                       Foreground="#94A3B8"
                                                                                       VerticalAlignment="Bottom"
                                                                                       Margin="2,0,0,2"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock x:Name="txtTowaryEmpty"
                                                       Text="Brak towarów wyprodukowanych w tym okresie. Wybierz inny zakres dat."
                                                       FontStyle="Italic" Foreground="#94A3B8"
                                                       HorizontalAlignment="Center" Margin="0,16"
                                                       Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- ═══ SEKCJA 3: PRZEPŁYWY MIĘDZY MAGAZYNAMI (Sankey-style) ═══ -->
                                    <Border x:Name="bdSankeySekcja"
                                            Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                            CornerRadius="10" Padding="20,16" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="🔀" FontSize="16" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Przepływy między magazynami (MM-)"
                                                               FontWeight="Bold" FontSize="14" Foreground="#0F172A"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="txtPrzeplywyInfoVisible" Text=""
                                                               FontSize="11" Foreground="#94A3B8"
                                                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>

                                            <ItemsControl x:Name="icPrzeplywyVisible">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#F8FAFC" CornerRadius="6"
                                                                Padding="10,6" Margin="0,0,0,4"
                                                                BorderBrush="#E2E8F0" BorderThickness="1"
                                                                ToolTip="{Binding NumeryDok}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="120"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="120"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0" Background="#FEF3C7"
                                                                        BorderBrush="#F59E0B" BorderThickness="1"
                                                                        CornerRadius="4" Padding="8,3"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding MagazynZNazwa}"
                                                                               FontSize="11" FontWeight="Bold"
                                                                               Foreground="#92400E"
                                                                               HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                                            VerticalAlignment="Center" Margin="6,0">
                                                                    <Rectangle Width="10" Height="3" Fill="#7C3AED" VerticalAlignment="Center"/>
                                                                    <Polygon Points="0,0 10,7 0,14" Fill="#7C3AED" Stretch="None" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                                <Border Grid.Column="2" Background="#DBEAFE"
                                                                        BorderBrush="#2563EB" BorderThickness="1"
                                                                        CornerRadius="4" Padding="8,3"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding MagazynDoNazwa}"
                                                                               FontSize="11" FontWeight="Bold"
                                                                               Foreground="#1E40AF"
                                                                               HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <Rectangle Grid.Column="3" Height="10"
                                                                           Fill="#7C3AED"
                                                                           Width="{Binding KgPasek}"
                                                                           HorizontalAlignment="Left"
                                                                           VerticalAlignment="Center"
                                                                           Margin="14,0,14,0" RadiusX="4" RadiusY="4">
                                                                    <Rectangle.Effect>
                                                                        <DropShadowEffect Color="#7C3AED" BlurRadius="6"
                                                                                          ShadowDepth="0" Opacity="0.3"/>
                                                                    </Rectangle.Effect>
                                                                </Rectangle>
                                                                <TextBlock Grid.Column="4"
                                                                           Text="{Binding KgFormatted}"
                                                                           FontFamily="Consolas" FontWeight="Bold"
                                                                           FontSize="14" Foreground="#0F172A"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,12,0"/>
                                                                <Border Grid.Column="5" Background="#EDE9FE"
                                                                        CornerRadius="3" Padding="4,1"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding DokFormatted}"
                                                                               FontSize="10" FontWeight="SemiBold"
                                                                               Foreground="#5B21B6"/>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock x:Name="txtPrzeplywyEmptyVisible"
                                                       Text="Brak przepływów MM- w wybranym okresie"
                                                       FontStyle="Italic" Foreground="#94A3B8"
                                                       HorizontalAlignment="Center" Margin="0,16"
                                                       Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- LEGACY (HIDDEN): keeping bindings to avoid removing code-behind references -->
                                    <ItemsControl x:Name="icMagazynyKafelki" Visibility="Collapsed">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="240" Margin="0,0,8,8"
                                                            Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                                            CornerRadius="8" Padding="0">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#15000000" BlurRadius="8"
                                                                              ShadowDepth="2" Direction="270"/>
                                                        </Border.Effect>
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Header: kolorowy pasek + nazwa + status badge -->
                                                            <Border Grid.Row="0"
                                                                    Background="{Binding MagazynKolorHex, Converter={StaticResource HexToBrush}}"
                                                                    CornerRadius="8,8,0,0" Padding="10,6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0">
                                                                        <TextBlock Text="{Binding MagazynNazwa}"
                                                                                   FontWeight="Bold" FontSize="14"
                                                                                   Foreground="White"
                                                                                   ToolTip="{Binding MagazynPelnaNazwa}"/>
                                                                        <TextBlock Text="{Binding MagazynID, StringFormat='ID: {0}'}"
                                                                                   FontSize="9" Foreground="#FFFFFF99"/>
                                                                    </StackPanel>
                                                                    <Border Grid.Column="1"
                                                                            Background="{Binding StatusKolorHex, Converter={StaticResource HexToBrush}}"
                                                                            CornerRadius="3" Padding="5,2"
                                                                            VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Status}"
                                                                                   FontSize="10" FontWeight="SemiBold"
                                                                                   Foreground="White"/>
                                                                    </Border>
                                                                </Grid>
                                                            </Border>

                                                            <!-- 2 duże liczby: ⬇ Przychód / ⬆ Rozchód -->
                                                            <Grid Grid.Row="1" Margin="0,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="1"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                                    <TextBlock Text="⬇ WESZŁO" FontSize="9"
                                                                               FontWeight="SemiBold" Foreground="#10B981"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding PrzychodKg, StringFormat=N0}"
                                                                               FontSize="16" FontWeight="Bold"
                                                                               FontFamily="Consolas"
                                                                               Foreground="#0F172A"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="kg" FontSize="9" Foreground="#94A3B8"
                                                                               HorizontalAlignment="Center"/>
                                                                </StackPanel>

                                                                <Border Grid.Column="1" Background="#E2E8F0" Width="1"
                                                                        VerticalAlignment="Stretch" Margin="0,4"/>

                                                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                                    <TextBlock Text="⬆ WYSZŁO" FontSize="9"
                                                                               FontWeight="SemiBold" Foreground="#DC2626"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding RozchodKg, StringFormat=N0}"
                                                                               FontSize="16" FontWeight="Bold"
                                                                               FontFamily="Consolas"
                                                                               Foreground="#0F172A"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="kg" FontSize="9" Foreground="#94A3B8"
                                                                               HorizontalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <!-- Saldo (duży akcent) -->
                                                            <Border Grid.Row="2" Background="#F8FAFC" Padding="10,6"
                                                                    BorderBrush="#E2E8F0" BorderThickness="0,1,0,1">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0">
                                                                        <TextBlock Text="SALDO" FontSize="9"
                                                                                   FontWeight="SemiBold" Foreground="#64748B"/>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding KierunekIkona}"
                                                                                       FontSize="14" FontWeight="Bold"
                                                                                       Foreground="{Binding StatusKolorHex, Converter={StaticResource HexToBrush}}"
                                                                                       Margin="0,0,4,0"/>
                                                                            <TextBlock Text="{Binding Saldo, StringFormat=N0}"
                                                                                       FontSize="15" FontWeight="Bold"
                                                                                       FontFamily="Consolas"
                                                                                       Foreground="{Binding StatusKolorHex, Converter={StaticResource HexToBrush}}"/>
                                                                            <TextBlock Text="kg" FontSize="9"
                                                                                       Foreground="#94A3B8"
                                                                                       VerticalAlignment="Bottom"
                                                                                       Margin="3,0,0,2"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding SaldoProcent, StringFormat='{}{0:F1}%'}"
                                                                               FontSize="20" FontWeight="Bold"
                                                                               FontFamily="Consolas"
                                                                               Foreground="{Binding StatusKolorHex, Converter={StaticResource HexToBrush}}"
                                                                               HorizontalAlignment="Right"
                                                                               VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </Border>

                                                            <!-- Footer: opis + liczba dokumentów -->
                                                            <Grid Grid.Row="3" Margin="10,6,10,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding SaldoOpis}"
                                                                           FontSize="10" Foreground="#475569"
                                                                           TextWrapping="Wrap"
                                                                           ToolTip="{Binding SaldoOpis}"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding LiczbaDokumentow, StringFormat='📄 {0} dok.'}"
                                                                           FontSize="10" FontWeight="SemiBold"
                                                                           Foreground="#64748B"
                                                                           VerticalAlignment="Top" Margin="6,0,0,0"/>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- PRZEPŁYWY MIĘDZY MAGAZYNAMI (mini-Sankey) -->
                                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                                CornerRadius="6" Padding="12,10" Margin="0,8,0,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="🔀" FontSize="14" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Przepływy między magazynami (MM-)"
                                                               FontWeight="Bold" FontSize="13" Foreground="#0F172A"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="txtPrzeplywyInfo" Text=""
                                                               FontSize="11" Foreground="#94A3B8"
                                                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <ItemsControl x:Name="icPrzeplywy">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#F8FAFC" CornerRadius="4"
                                                                    Padding="10,6" Margin="0,0,0,4"
                                                                    BorderBrush="#E2E8F0" BorderThickness="1">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Grid.Column="0" Background="#FEF3C7"
                                                                            CornerRadius="3" Padding="5,2"
                                                                            VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding MagazynZNazwa}"
                                                                                   FontSize="11" FontWeight="SemiBold"
                                                                                   Foreground="#92400E"/>
                                                                    </Border>
                                                                    <TextBlock Grid.Column="1" Text="  →  "
                                                                               FontSize="14" FontWeight="Bold"
                                                                               Foreground="#7C3AED"
                                                                               VerticalAlignment="Center"
                                                                               Margin="6,0"/>
                                                                    <Border Grid.Column="2" Background="#DBEAFE"
                                                                            CornerRadius="3" Padding="5,2"
                                                                            VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding MagazynDoNazwa}"
                                                                                   FontSize="11" FontWeight="SemiBold"
                                                                                   Foreground="#1E40AF"/>
                                                                    </Border>
                                                                    <!-- Pasek proporcjonalny do kg (max width 200) -->
                                                                    <Rectangle Grid.Column="3" Height="6"
                                                                               Fill="#7C3AED"
                                                                               Width="{Binding KgPasek}"
                                                                               HorizontalAlignment="Left"
                                                                               VerticalAlignment="Center"
                                                                               Margin="12,0,12,0" RadiusX="3" RadiusY="3"/>
                                                                    <TextBlock Grid.Column="4"
                                                                               Text="{Binding KgFormatted}"
                                                                               FontFamily="Consolas" FontWeight="Bold"
                                                                               FontSize="13" Foreground="#0F172A"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,12,0"/>
                                                                    <TextBlock Grid.Column="5"
                                                                               Text="{Binding DokFormatted}"
                                                                               FontSize="11" Foreground="#64748B"
                                                                               VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock x:Name="txtPrzeplywyEmpty"
                                                           Text="Brak przepływów MM- w wybranym okresie"
                                                           FontStyle="Italic" Foreground="#94A3B8"
                                                           HorizontalAlignment="Center" Margin="0,12"
                                                           Visibility="Collapsed"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- TABELA SZCZEGÓŁOWA: rozkład per seria -->
                                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                                CornerRadius="6" Padding="12,10" Margin="0,0,0,4">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="📋" FontSize="14" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Rozkład per magazyn × seria"
                                                               FontWeight="Bold" FontSize="13" Foreground="#0F172A"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <DataGrid x:Name="dgStanRozklad" AutoGenerateColumns="False"
                                                          IsReadOnly="True" HeadersVisibility="Column"
                                                          GridLinesVisibility="Horizontal" RowBackground="White"
                                                          AlternatingRowBackground="#F8FAFC"
                                                          BorderThickness="0" RowHeight="26" FontSize="11"
                                                          MaxHeight="400" EnableRowVirtualization="True">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Magazyn" Binding="{Binding Magazyn}" Width="140">
                                                            <DataGridTextColumn.ElementStyle>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    <Setter Property="Foreground" Value="#1F2937"/>
                                                                </Style>
                                                            </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>
                                                        <DataGridTextColumn Header="Kierunek" Binding="{Binding Kierunek}" Width="80">
                                                            <DataGridTextColumn.ElementStyle>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Kierunek}" Value="⬇ IN">
                                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Kierunek}" Value="⬆ OUT">
                                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>
                                                        <DataGridTextColumn Header="Seria" Binding="{Binding Seria}" Width="70">
                                                            <DataGridTextColumn.ElementStyle>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="FontFamily" Value="Consolas"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    <Setter Property="Foreground" Value="#1E40AF"/>
                                                                </Style>
                                                            </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>
                                                        <DataGridTextColumn Header="Opis" Binding="{Binding OpisSerii}" Width="*"/>
                                                        <DataGridTextColumn Header="kg" Binding="{Binding Kg, StringFormat=N0}" Width="100">
                                                            <DataGridTextColumn.ElementStyle>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="FontFamily" Value="Consolas"/>
                                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                    <Setter Property="Padding" Value="0,0,8,0"/>
                                                                </Style>
                                                            </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>
                                                        <DataGridTextColumn Header="Dok." Binding="{Binding LiczbaDok, StringFormat=N0}" Width="60">
                                                            <DataGridTextColumn.ElementStyle>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                                </Style>
                                                            </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </StackPanel>
                                        </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <!-- ───── KONIEC Sub-Tab 2 ───── -->

                        <!-- ───── Sub-Tab 3: Łańcuch Graficzny (czysto wizualny, bez tabel) ───── -->
                        <TabItem Header="🎨 Łańcuch Graficzny">
                            <vw:WidokLancuchGraficzny x:Name="widokLancuch"/>
                        </TabItem>
                        <!-- ───── KONIEC Sub-Tab 3 ───── -->

                        <!-- ───── Sub-Tab 4: Fabryka — widok z góry (SCADA/MES) ───── -->
                        <TabItem Header="🏭 Fabryka">
                            <vw:WidokFabryka x:Name="widokFabryka"/>
                        </TabItem>
                        <!-- ───── KONIEC Sub-Tab 4 ───── -->

                        <!-- ───── Sub-Tab 5: Sankey — przepływ masy ───── -->
                        <TabItem Header="🌊 Sankey">
                            <vw:WidokSankey x:Name="widokSankey"/>
                        </TabItem>
                        <!-- ───── KONIEC Sub-Tab 5 ───── -->
                    </TabControl>

                    <!-- Stopka tabeli z sumami live (tylko widoczne pozycje po filtrach) -->
                    <Border Grid.Row="1" Background="#0F172A" CornerRadius="0,0,6,6" Padding="14,8" Margin="0,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Σ Razem (widoczne):"
                                       FontWeight="Bold" FontSize="12" Foreground="#E2E8F0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="txtBmFooterCount"
                                       Text="0 pozycji" FontSize="11" Foreground="#94A3B8"
                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="kg:"
                                       FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <TextBlock Grid.Column="3" x:Name="txtBmFooterKg"
                                       Text="0 kg" FontSize="13" FontWeight="Bold" Foreground="White"
                                       VerticalAlignment="Center" Margin="0,0,16,0"
                                       FontFamily="Consolas"/>
                            <TextBlock Grid.Column="4" Text="📄"
                                       FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <TextBlock Grid.Column="5" x:Name="txtBmFooterDok"
                                       Text="0 dok." FontSize="13" FontWeight="Bold"
                                       Foreground="#A78BFA" VerticalAlignment="Center"
                                       FontFamily="Consolas"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ─── Uzyski hodowców (cross-DB raport) ─── -->
            <TabItem Header="🥇 Uzyski hodowców">
                <Grid Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Toolbar: agregacja + filter + eksport -->
                        <RowDefinition Height="Auto"/>
                        <!-- Mini stats summary -->
                        <RowDefinition Height="*"/>
                        <!-- Tabela -->
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Background="White" BorderBrush="#7C3AED" BorderThickness="1"
                            CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="📅 Okres:"
                                       FontWeight="SemiBold" Foreground="#7C3AED"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" x:Name="cbUzyskiAgregacja"
                                      Width="160" SelectionChanged="UzyskiAgregacja_Changed"
                                      VerticalAlignment="Center"
                                      ToolTip="Wybierz agregację czasu (jak grupować wiersze)">
                                <ComboBoxItem Content="📆 Per dzień" Tag="Dzienna"/>
                                <ComboBoxItem Content="🗓️ Per tydzień (ISO)" Tag="Tygodniowa" IsSelected="True"/>
                                <ComboBoxItem Content="📅 Per miesiąc" Tag="Miesieczna"/>
                                <ComboBoxItem Content="📊 Per kwartał" Tag="Kwartalna"/>
                                <ComboBoxItem Content="🏷 Cały okres" Tag="CalyOkres"/>
                            </ComboBox>

                            <Separator Grid.Column="2" Width="1" Background="#E2E8F0" Margin="12,4"/>

                            <Grid Grid.Column="3">
                                <TextBox x:Name="txtUzyskiFiltr" Padding="28,4,4,4"
                                         BorderBrush="#E2E8F0" BorderThickness="1"
                                         TextChanged="TxtUzyskiFiltr_TextChanged"/>
                                <TextBlock Text="🔍" FontSize="13" IsHitTestVisible="False"
                                           Foreground="#94A3B8" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtUzyskiFiltrPlaceholder"
                                           Text="Filtruj hodowcę po nazwie / ID…"
                                           FontStyle="Italic" Foreground="#94A3B8"
                                           IsHitTestVisible="False"
                                           Margin="32,0,0,0" VerticalAlignment="Center"/>
                            </Grid>

                            <Button Grid.Column="4" Content="✕" Padding="8,4" Margin="6,0,0,0"
                                    Background="#F1F5F9" Foreground="#475569"
                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                    Cursor="Hand" Click="BtnUzyskiWyczyscFiltr_Click"
                                    ToolTip="Wyczyść filtr"/>
                            <CheckBox Grid.Column="5" x:Name="chkUzyskiGrupowanie"
                                      Content="📦 Grupuj po okresie"
                                      IsChecked="True" Margin="12,0,0,0"
                                      VerticalAlignment="Center"
                                      Checked="ChkUzyskiGrupowanie_Toggle"
                                      Unchecked="ChkUzyskiGrupowanie_Toggle"/>
                            <Button Grid.Column="6" Content="📥 CSV" Padding="10,4" Margin="6,0,0,0"
                                    Background="#F1F5F9" Foreground="#475569"
                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                    Cursor="Hand" Click="BtnEksportUzyski_Click"/>
                        </Grid>
                    </Border>

                    <!-- Mini stats -->
                    <Border Grid.Row="1" Background="#FAF5FF" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
                        <TextBlock x:Name="txtUzyskiStats"
                                   Text="Wybierz zakres dat i Zastosuj"
                                   FontSize="12" Foreground="#475569"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Tabela -->
                    <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="6" ClipToBounds="True">
                        <DataGrid x:Name="dgUzyski" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowBackground="White" AlternatingRowBackground="#FAFAFA"
                                  BorderThickness="0" RowHeight="26" FontSize="11"
                                  EnableRowVirtualization="True">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="Foreground" Value="#475569"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Padding" Value="6,6"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="GroupItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="GroupItem">
                                                        <Expander IsExpanded="True"
                                                                  Background="#FAF5FF"
                                                                  BorderBrush="#7C3AED"
                                                                  BorderThickness="0,1,0,1">
                                                            <Expander.Header>
                                                                <Grid Margin="4,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                                               FontWeight="Bold" FontSize="12"
                                                                               Foreground="#7C3AED"/>
                                                                    <TextBlock Grid.Column="1" FontSize="11"
                                                                               Foreground="#64748B" Margin="12,0,8,0"
                                                                               VerticalAlignment="Center">
                                                                        <Run Text="{Binding ItemCount, Mode=OneWay}"/><Run Text=" hodowców"/>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </Expander.Header>
                                                            <ItemsPresenter/>
                                                        </Expander>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </DataGrid.GroupStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Okres" Binding="{Binding EtykietaOkresu}" Width="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="#7C3AED"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Hodowca" Binding="{Binding Hodowca}" Width="*" MinWidth="160"/>
                                <DataGridTextColumn Header="Dni" Binding="{Binding LiczbaDniDostaw}" Width="50">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="🐔 Żywiec kg" Binding="{Binding ZywiecKg, StringFormat=N0}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Tuszka A" Binding="{Binding TuszkaAKg, StringFormat=N0}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Tuszka B" Binding="{Binding TuszkaBKg, StringFormat=N0}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="A+B kg" Binding="{Binding SumaTuszekAB, StringFormat=N0}" Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Wątroba" Binding="{Binding WatrobaKg, StringFormat=N0}" Width="70">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="#475569"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Żołądki" Binding="{Binding ZoladkiKg, StringFormat=N0}" Width="70">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="#475569"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Serce" Binding="{Binding SerceKg, StringFormat=N0}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="#475569"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Wyd. tusz. %" Binding="{Binding WydajnoscTuszekProc, StringFormat=N1}" Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#7C3AED"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Wyd. ogóln. %" Binding="{Binding WydajnoscCalkowitaProc, StringFormat=N1}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#059669"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="% Wątr." Binding="{Binding ProcWatroba, StringFormat=N2}" Width="70">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="% Żoł." Binding="{Binding ProcZoladki, StringFormat=N2}" Width="65">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="% Serc." Binding="{Binding ProcSerce, StringFormat=N2}" Width="65">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="🔍 Filtruj tylko tego hodowcę" Click="MenuFiltruyUzyskHodowca_Click"/>
                                    <Separator/>
                                    <MenuItem Header="📋 Skopiuj nazwę hodowcy" Click="MenuSkopiujUzyskHodowcaNazwa_Click"/>
                                    <MenuItem Header="📋 Skopiuj wiersz (CSV)" Click="MenuSkopiujUzyskWiersz_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ─── Trend dzienny ─── -->
            <TabItem Header="📈 Trend wydajności">
                <Grid Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Mini stats + filter -->
                        <RowDefinition Height="2*"/>
                        <!-- Wykres -->
                        <RowDefinition Height="3*"/>
                        <!-- Tabela -->
                    </Grid.RowDefinitions>

                    <!-- Mini stats + opcje widoku -->
                    <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
                        <StackPanel Orientation="Vertical">
                            <TextBlock x:Name="txtTrendStats"
                                       Text="—" FontSize="12" Foreground="#475569"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="📅 Okres:" FontWeight="SemiBold" Foreground="#7C3AED"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="cbTrendAgregacja" Width="160"
                                          SelectionChanged="TrendAgregacja_Changed"
                                          VerticalAlignment="Center" Margin="0,0,16,0">
                                    <ComboBoxItem Content="📆 Per dzień" Tag="Dzienna" IsSelected="True"/>
                                    <ComboBoxItem Content="🗓️ Per tydzień (ISO)" Tag="Tygodniowa"/>
                                    <ComboBoxItem Content="📅 Per miesiąc" Tag="Miesieczna"/>
                                    <ComboBoxItem Content="📊 Per kwartał" Tag="Kwartalna"/>
                                    <ComboBoxItem Content="🗓 Per rok" Tag="Roczna"/>
                                    <ComboBoxItem Content="🏷 Cały okres" Tag="CalyOkres"/>
                                </ComboBox>
                                <Separator Width="1" Background="#E2E8F0" Margin="0,0,16,0"/>
                                <TextBlock Text="Widok:" FontWeight="SemiBold" Foreground="#475569"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <RadioButton x:Name="rbTrendZPodrobami" Content="🍗+🫀 Tuszki + podroby"
                                             GroupName="TrendWidok" IsChecked="True"
                                             Margin="0,0,12,0" VerticalAlignment="Center"
                                             Checked="OpcjeTrend_Changed"
                                             ToolTip="Wykres % wydajności = (A+B+podroby) / żywiec, norma 78%"/>
                                <RadioButton x:Name="rbTrendTylkoTuszki" Content="🍗 Tylko tuszki"
                                             GroupName="TrendWidok"
                                             Margin="0,0,12,0" VerticalAlignment="Center"
                                             Checked="OpcjeTrend_Changed"
                                             ToolTip="Wykres % wydajności = (A+B) / żywiec, norma 78%"/>
                                <RadioButton x:Name="rbTrendTylkoPodroby" Content="🫀 Tylko podroby"
                                             GroupName="TrendWidok"
                                             Margin="0,0,16,0" VerticalAlignment="Center"
                                             Checked="OpcjeTrend_Changed"
                                             ToolTip="Wykres % udziału podrobów / żywiec, norma 1.75%"/>
                                <Separator Width="1" Background="#E2E8F0" Margin="0,0,16,0"/>
                                <CheckBox x:Name="chkTrendTylkoAlerty"
                                          Content="⚠ Tylko alerty" Margin="0,0,16,0"
                                          VerticalAlignment="Center"
                                          Checked="ChkTrendTylkoAlerty_Toggle"
                                          Unchecked="ChkTrendTylkoAlerty_Toggle"
                                          ToolTip="Pokaż tylko okresy z odchyleniem od normy"/>
                                <Button Content="📥 CSV" Padding="10,4"
                                        Background="#F1F5F9" Foreground="#475569"
                                        BorderBrush="#E2E8F0" BorderThickness="1"
                                        Cursor="Hand" Click="BtnEksportTrend_Click"/>
                            </StackPanel>
                            <TextBlock Text="💡 Dwuklik na wiersz → szczegóły wyliczenia"
                                       FontSize="10" FontStyle="Italic" Foreground="#94A3B8"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Wykres -->
                    <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="6" Padding="10" Margin="0,0,0,6">
                        <lvc:CartesianChart x:Name="wykresTrend" LegendLocation="Top">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis x:Name="osXTrend" Title="Dzień" Foreground="#475569">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Step="1" StrokeThickness="0"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis x:Name="osYTrend" Title="Wydajność %" Foreground="#475569"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Border>

                    <!-- Tabela -->
                    <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="6" ClipToBounds="True">
                        <DataGrid x:Name="dgTrend" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowBackground="White" AlternatingRowBackground="#FAFAFA"
                                  BorderThickness="0" RowHeight="26" FontSize="12"
                                  MouseDoubleClick="DgTrend_MouseDoubleClick">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background"
                                            Value="{Binding CzyAlert, Converter={StaticResource AlertBgConverter}}"/>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="Foreground" Value="#475569"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Padding" Value="6,6"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Okres" Binding="{Binding EtykietaOkresu}" Width="200">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="#7C3AED"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="🐔 Żywiec" Binding="{Binding ZywiecKg, StringFormat=N0}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Tuszka A" Binding="{Binding TuszkaAKg, StringFormat=N0}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Tuszka B" Binding="{Binding TuszkaBKg, StringFormat=N0}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Podroby" Binding="{Binding PodrobyKg, StringFormat=N0}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="#475569"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Suma wyj." Binding="{Binding SumaWyjscia, StringFormat=N0}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="% z podr." Binding="{Binding WydajnoscZPodrobamiProc, StringFormat=N1}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#7C3AED"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="% bez podr." Binding="{Binding WydajnoscBezPodrobowProc, StringFormat=N1}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="#0891B2"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="% podr." Binding="{Binding WydajnoscPodrobowProc, StringFormat=N2}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,6,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ─── Hodowcy ─── -->
            <TabItem Header="🐔 Hodowcy">
                <Grid Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Mini stats + filter -->
                    <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtHodowcyStats" Grid.Column="0"
                                       Text="—" FontSize="12" Foreground="#475569"
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <Grid Grid.Column="1">
                                <TextBox x:Name="txtHodowcyFiltr" Padding="28,4,4,4"
                                         BorderBrush="#E2E8F0" BorderThickness="1"
                                         TextChanged="TxtHodowcyFiltr_TextChanged"/>
                                <TextBlock Text="🔍" FontSize="13" IsHitTestVisible="False"
                                           Foreground="#94A3B8" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtHodowcyFiltrPlaceholder"
                                           Text="Filtruj hodowcę…" FontStyle="Italic"
                                           Foreground="#94A3B8" IsHitTestVisible="False"
                                           Margin="32,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                            <Button Grid.Column="2" Content="✕" Padding="8,4" Margin="6,0,0,0"
                                    Background="#F1F5F9" Foreground="#475569"
                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                    Cursor="Hand" Click="BtnHodowcyWyczyscFiltr_Click"
                                    ToolTip="Wyczyść filtr"/>
                            <Button Grid.Column="3" Content="📥 CSV" Padding="10,4" Margin="6,0,0,0"
                                    Background="#F1F5F9" Foreground="#475569"
                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                    Cursor="Hand" Click="BtnEksportHodowcy_Click"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="6" ClipToBounds="True">
                        <DataGrid x:Name="dgHodowcy" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowBackground="White" AlternatingRowBackground="#FAFAFA"
                                  BorderThickness="0" RowHeight="28" FontSize="12"
                                  Cursor="Hand" MouseDoubleClick="DgHodowcy_MouseDoubleClick"
                                  ToolTip="Kliknij dwukrotnie na hodowcę aby otworzyć Kartę Hodowcy 360°">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="Foreground" Value="#475569"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="ID" Binding="{Binding CustomerID}" Width="80"/>
                                <DataGridTextColumn Header="Hodowca" Binding="{Binding Hodowca}" Width="2*"/>
                                <DataGridTextColumn Header="Partii" Binding="{Binding LiczbaPartii, StringFormat=N0}" Width="70">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaWyjscieKg, StringFormat=N0}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#7C3AED"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Udział %" Binding="{Binding ProcentUdzialu, StringFormat=N2}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="#475569"/>
                                            <Setter Property="Padding" Value="0,0,8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="% lidera" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid Margin="6,3">
                                                <ProgressBar Value="{Binding ProcentLidera, Mode=OneWay}" Maximum="100"
                                                             Height="14" Foreground="#7C3AED" Background="#F1F5F9"
                                                             BorderThickness="0"/>
                                                <TextBlock Text="{Binding ProcentLidera, StringFormat='{}{0:N0}%'}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontSize="10" FontWeight="SemiBold" Foreground="#0F172A"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="🔍 Filtruj tylko tego hodowcę" Click="MenuFiltruyHodowca_Click"/>
                                    <Separator/>
                                    <MenuItem Header="📋 Skopiuj nazwę" Click="MenuSkopiujHodowcaNazwa_Click"/>
                                    <MenuItem Header="📋 Skopiuj kg" Click="MenuSkopiujHodowcaKg_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ─── Klasy wagowe ─── -->
            <TabItem Header="⚖ Klasy wagowe">
                <Grid Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- 0: Mini stats -->
                        <RowDefinition Height="2*"/>
                        <!-- 1: Wykres (lewa) + KPI panele (prawa) -->
                        <RowDefinition Height="3*"/>
                        <!-- 2: Tabela -->
                    </Grid.RowDefinitions>

                    <!-- Mini stats -->
                    <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
                        <TextBlock x:Name="txtKlasyStats"
                                   Text="—" FontSize="12" Foreground="#475569"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- 2 KPI panele Duży/Mały (lewa) + Wykres (prawa) — w jednym wierszu -->
                    <Grid Grid.Row="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Wykres dwukolorowy -->
                        <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                CornerRadius="6" Padding="10" Margin="6,0,0,0">
                            <lvc:CartesianChart x:Name="wykresKlasy" LegendLocation="Top">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis x:Name="osXKlasy" Title="Klasa" Foreground="#475569">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="1" StrokeThickness="0"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis x:Name="osYKlasy" Title="Suma kg" Foreground="#475569"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Border>

                        <!-- 2 KPI panele Duży/Mały + przycisk Eksport — pionowo, obok wykresu -->
                        <Grid Grid.Column="0" Margin="0,0,6,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Duży -->
                            <Border Grid.Row="0" Background="#EFF6FF" BorderBrush="#3B82F6"
                                    BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="8"
                                                Background="#3B82F6" Margin="0,0,10,0">
                                            <TextBlock Text="🍗" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="DUŻY KURCZAK"
                                                       FontSize="10" FontWeight="Bold" Foreground="#1E3A8A"/>
                                            <TextBlock Text="klasy 4–7"
                                                       FontSize="9" Foreground="#475569"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Grid Grid.Row="1" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" x:Name="txtKlasyKpiDuzy" Text="0 kg"
                                                   FontSize="22" FontWeight="Bold" Foreground="#0F172A"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" x:Name="txtKlasyKpiDuzyProc"
                                                   Text="—" FontSize="22" FontWeight="Bold"
                                                   Foreground="#3B82F6" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Grid.Row="2" x:Name="txtKlasyKpiDuzyDetal" Text=""
                                               FontSize="10" Foreground="#475569" Margin="0,4,0,0"/>
                                </Grid>
                            </Border>

                            <!-- Mały -->
                            <Border Grid.Row="1" Background="#FFF7ED" BorderBrush="#FB923C"
                                    BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="8"
                                                Background="#FB923C" Margin="0,0,10,0">
                                            <TextBlock Text="🐥" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="MAŁY KURCZAK"
                                                       FontSize="10" FontWeight="Bold" Foreground="#7C2D12"/>
                                            <TextBlock Text="klasy 8–12"
                                                       FontSize="9" Foreground="#475569"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Grid Grid.Row="1" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" x:Name="txtKlasyKpiMaly" Text="0 kg"
                                                   FontSize="22" FontWeight="Bold" Foreground="#0F172A"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" x:Name="txtKlasyKpiMalyProc"
                                                   Text="—" FontSize="22" FontWeight="Bold"
                                                   Foreground="#FB923C" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Grid.Row="2" x:Name="txtKlasyKpiMalyDetal" Text=""
                                               FontSize="10" Foreground="#475569" Margin="0,4,0,0"/>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Row="2">
                                <Button Content="📈  Historia klas (tygodnie / miesiące / lata)"
                                        Padding="14,10" Margin="0,0,0,6"
                                        Background="#7C3AED" Foreground="White" FontWeight="SemiBold"
                                        BorderThickness="0"
                                        Cursor="Hand" Click="BtnHistoriaKlas_Click"
                                        HorizontalAlignment="Stretch"
                                        ToolTip="Otwórz okno historii: jak udział klas zmieniał się w czasie (wykres liniowy)"/>
                                <Button Content="📥  Eksport CSV" Padding="14,8"
                                        Background="#F1F5F9" Foreground="#475569" FontWeight="SemiBold"
                                        BorderBrush="#CBD5E1" BorderThickness="1"
                                        Cursor="Hand" Click="BtnEksportKlasy_Click"
                                        HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- ═══ TABELA: 3 osobne panele Σ + 2 DataGridy ═══ -->
                    <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="6" ClipToBounds="True">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <StackPanel x:Name="panelKlasyTabela">
                                <!-- Header strip (kolumny stałe pikselowe) -->
                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,2" Padding="0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="280"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="220"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Klasa  /  Σ Podsumowanie"
                                                   FontWeight="SemiBold" Foreground="#475569" FontSize="11"
                                                   Padding="14,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Ważeń (szt.)"
                                                   FontWeight="SemiBold" Foreground="#475569" FontSize="11"
                                                   HorizontalAlignment="Right" Padding="0,0,16,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Suma (kg)"
                                                   FontWeight="SemiBold" Foreground="#475569" FontSize="11"
                                                   HorizontalAlignment="Right" Padding="0,0,16,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="Średnia (kg/ważenie)"
                                                   FontWeight="SemiBold" Foreground="#475569" FontSize="11"
                                                   HorizontalAlignment="Right" Padding="0,0,16,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="Udział %"
                                                   FontWeight="SemiBold" Foreground="#475569" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Σ Duży panel (gradient niebieski, biały tekst) -->
                                <Border Padding="0,4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#1E40AF" Offset="0"/>
                                            <GradientStop Color="#2563EB" Offset="0.5"/>
                                            <GradientStop Color="#1E40AF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="280"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="220"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="🍗  Σ DUŻY KURCZAK (klasy 4–7)"
                                                   Foreground="White" FontWeight="Bold" FontSize="15"
                                                   Padding="14,0" VerticalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="0" Opacity="0.4"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" x:Name="txtSumDuzyWazen" Text="0"
                                                   Foreground="White" FontWeight="Bold" FontSize="15"
                                                   HorizontalAlignment="Right" Padding="0,0,16,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" x:Name="txtSumDuzyKg" Text="0"
                                                   Foreground="White" FontWeight="Bold" FontSize="17"
                                                   HorizontalAlignment="Right" Padding="0,0,16,0" VerticalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="0" Opacity="0.4"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock Grid.Column="3" x:Name="txtSumDuzySrednia" Text="0"
                                                   Foreground="White" FontWeight="Bold" FontSize="15"
                                                   HorizontalAlignment="Right" Padding="0,0,16,0" VerticalAlignment="Center"/>
                                        <Grid Grid.Column="4" Margin="14,4">
                                            <ProgressBar x:Name="pbSumDuzy" Value="0" Maximum="100"
                                                         Height="24" Foreground="White" Background="#1E3A8A"
                                                         BorderThickness="0"/>
                                            <TextBlock x:Name="txtSumDuzyProc" Text="0%"
                                                       Foreground="White" FontWeight="Bold" FontSize="13"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="0" Opacity="0.7"/>
                                                </TextBlock.Effect>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- DataGrid: klasy 4-7 (bez headerów, bez Σ wierszy) -->
                                <DataGrid x:Name="dgKlasyDuzy" AutoGenerateColumns="False" IsReadOnly="True"
                                          HeadersVisibility="None" GridLinesVisibility="Horizontal"
                                          RowBackground="White" AlternatingRowBackground="#EFF6FF"
                                          BorderThickness="0" RowHeight="38" FontSize="13"
                                          Cursor="Hand"
                                          MouseDoubleClick="DgKlasy_MouseDoubleClick"
                                          ToolTip="Kliknij dwukrotnie wiersz, aby zobaczyć szczegóły wszystkich ważeń tej klasy">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#DBEAFE"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding Klasa, StringFormat='Klasa {0}'}" Width="280">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="#1F2937"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Padding" Value="14,0"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding LiczbaWazen, StringFormat=N0}" Width="180">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter Property="Foreground" Value="#1F2937"/>
                                                    <Setter Property="Padding" Value="0,0,16,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding SumaActWeightKg, StringFormat=N0}" Width="200">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#7C3AED"/>
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter Property="Padding" Value="0,0,16,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding SredniaWagaSzt, StringFormat=N1}" Width="220">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#475569"/>
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter Property="Padding" Value="0,0,16,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTemplateColumn Width="220">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="14,5">
                                                        <ProgressBar Value="{Binding ProcentUdzialu, Mode=OneWay}" Maximum="100"
                                                                     Height="18" Foreground="#7C3AED"
                                                                     Background="#F1F5F9" BorderThickness="0"/>
                                                        <TextBlock Text="{Binding ProcentUdzialu, StringFormat='{}{0:N1}%'}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontSize="11" FontWeight="Bold" Foreground="#0F172A"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Σ Mały panel (gradient pomarańczowy, biały tekst) -->
                                <Border Padding="0,4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#9A3412" Offset="0"/>
                                            <GradientStop Color="#F97316" Offset="0.5"/>
                                            <GradientStop Color="#9A3412" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="280"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="220"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="🐥  Σ MAŁY KURCZAK (klasy 8–12)"
                                                   Foreground="White" FontWeight="Bold" FontSize="15"
                                                   Padding="14,0" VerticalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="0" Opacity="0.4"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" x:Name="txtSumMalyWazen" Text="0"
                                                   Foreground="White" FontWeight="Bold" FontSize="15"
                                                   HorizontalAlignment="Right" Padding="0,0,16,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" x:Name="txtSumMalyKg" Text="0"
                                                   Foreground="White" FontWeight="Bold" FontSize="17"
                                                   HorizontalAlignment="Right" Padding="0,0,16,0" VerticalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="0" Opacity="0.4"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock Grid.Column="3" x:Name="txtSumMalySrednia" Text="0"
                                                   Foreground="White" FontWeight="Bold" FontSize="15"
                                                   HorizontalAlignment="Right" Padding="0,0,16,0" VerticalAlignment="Center"/>
                                        <Grid Grid.Column="4" Margin="14,4">
                                            <ProgressBar x:Name="pbSumMaly" Value="0" Maximum="100"
                                                         Height="24" Foreground="White" Background="#7C2D12"
                                                         BorderThickness="0"/>
                                            <TextBlock x:Name="txtSumMalyProc" Text="0%"
                                                       Foreground="White" FontWeight="Bold" FontSize="13"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect Color="Black" BlurRadius="3"
                                                                      ShadowDepth="0" Opacity="0.7"/>
                                                </TextBlock.Effect>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- DataGrid: klasy 8-12 -->
                                <DataGrid x:Name="dgKlasyMaly" AutoGenerateColumns="False" IsReadOnly="True"
                                          HeadersVisibility="None" GridLinesVisibility="Horizontal"
                                          RowBackground="White" AlternatingRowBackground="#FFF7ED"
                                          BorderThickness="0" RowHeight="38" FontSize="13"
                                          Cursor="Hand"
                                          MouseDoubleClick="DgKlasy_MouseDoubleClick"
                                          ToolTip="Kliknij dwukrotnie wiersz, aby zobaczyć szczegóły wszystkich ważeń tej klasy">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FED7AA"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding Klasa, StringFormat='Klasa {0}'}" Width="280">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="#1F2937"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Padding" Value="14,0"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding LiczbaWazen, StringFormat=N0}" Width="180">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter Property="Foreground" Value="#1F2937"/>
                                                    <Setter Property="Padding" Value="0,0,16,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding SumaActWeightKg, StringFormat=N0}" Width="200">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="#7C3AED"/>
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter Property="Padding" Value="0,0,16,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding SredniaWagaSzt, StringFormat=N1}" Width="220">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#475569"/>
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter Property="Padding" Value="0,0,16,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTemplateColumn Width="220">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="14,5">
                                                        <ProgressBar Value="{Binding ProcentUdzialu, Mode=OneWay}" Maximum="100"
                                                                     Height="18" Foreground="#7C3AED"
                                                                     Background="#F1F5F9" BorderThickness="0"/>
                                                        <TextBlock Text="{Binding ProcentUdzialu, StringFormat='{}{0:N1}%'}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontSize="11" FontWeight="Bold" Foreground="#0F172A"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Σ RAZEM panel (gradient fiolet, biały tekst — wyróżniony pogrubieniem) -->
                                <Border Padding="0,6">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#5B21B6" Offset="0"/>
                                            <GradientStop Color="#7C3AED" Offset="0.5"/>
                                            <GradientStop Color="#5B21B6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#7C3AED" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="280"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="220"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="📊  Σ RAZEM (4–12)"
                                                   Foreground="White" FontWeight="Bold" FontSize="17"
                                                   Padding="14,0" VerticalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="0" Opacity="0.4"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" x:Name="txtSumRazemWazen" Text="0"
                                                   Foreground="White" FontWeight="Bold" FontSize="17"
                                                   HorizontalAlignment="Right" Padding="0,0,16,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" x:Name="txtSumRazemKg" Text="0"
                                                   Foreground="White" FontWeight="Bold" FontSize="19"
                                                   HorizontalAlignment="Right" Padding="0,0,16,0" VerticalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="0" Opacity="0.4"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock Grid.Column="3" x:Name="txtSumRazemSrednia" Text="0"
                                                   Foreground="White" FontWeight="Bold" FontSize="17"
                                                   HorizontalAlignment="Right" Padding="0,0,16,0" VerticalAlignment="Center"/>
                                        <Grid Grid.Column="4" Margin="14,4">
                                            <ProgressBar Value="100" Maximum="100"
                                                         Height="26" Foreground="White" Background="#4C1D95"
                                                         BorderThickness="0"/>
                                            <TextBlock Text="100.0%"
                                                       Foreground="White" FontWeight="Bold" FontSize="14"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="0" Opacity="0.7"/>
                                                </TextBlock.Effect>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ─── Szczegóły elementów (zaprojektowane na nowo: 2-kolumny + filtry + wykresy) ─── -->
            <TabItem Header="📋 Szczegóły elementów">
                <Grid Margin="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="7*"/>
                        <ColumnDefinition Width="3*" MinWidth="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- ═════════ LEWA: KPI strip + toolbar + DataGrid ═════════ -->
                    <Grid Grid.Column="0" Margin="0,0,6,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <!-- Footer z sumami -->
                        </Grid.RowDefinitions>

                        <!-- KPI strip (5 kafelków) -->
                        <UniformGrid Grid.Row="0" Columns="5" Rows="1" Margin="0,0,0,6">
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="14,8" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Σ PRZYCHÓD" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                    <TextBlock x:Name="txtElKpiPrzychod" Text="0" FontSize="20" FontWeight="Bold"
                                               Foreground="#0F172A"/>
                                    <TextBlock x:Name="txtElKpiPrzychodSub" Text="kg" FontSize="10" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="14,8" Margin="2,0,2,0">
                                <StackPanel>
                                    <TextBlock Text="Σ KROJENIE" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                    <TextBlock x:Name="txtElKpiKrojenie" Text="0" FontSize="20" FontWeight="Bold"
                                               Foreground="#7C3AED"/>
                                    <TextBlock x:Name="txtElKpiKrojenieSub" Text="kg" FontSize="10" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="14,8" Margin="2,0,2,0">
                                <StackPanel>
                                    <TextBlock Text="📦 KATEGORII" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                    <TextBlock x:Name="txtElKpiKategorii" Text="0" FontSize="20" FontWeight="Bold"
                                               Foreground="#059669"/>
                                    <TextBlock x:Name="txtElKpiTowarow" Text="—" FontSize="10" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="14,8" Margin="2,0,2,0">
                                <StackPanel>
                                    <TextBlock Text="📈 % WYDAJNOŚĆ" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"
                                               ToolTip="Σ Krojenie / Σ Przychód × 100% — wskaźnik efektywności krojenia"/>
                                    <TextBlock x:Name="txtElKpiWydaj" Text="—" FontSize="20" FontWeight="Bold"
                                               Foreground="#059669"/>
                                    <TextBlock x:Name="txtElKpiWydajSub" Text="" FontSize="10" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="14,8" Margin="4,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="🏆 TOP KATEGORIA" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"/>
                                    <TextBlock x:Name="txtElKpiTop" Text="—" FontSize="14" FontWeight="Bold"
                                               Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="txtElKpiTopProc" Text="" FontSize="10" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Toolbar (filtr + grupowanie + eksport) -->
                        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <TextBox x:Name="txtElementyFiltr" Padding="28,5,4,5"
                                             BorderBrush="#CBD5E1" BorderThickness="1" FontSize="12"
                                             TextChanged="TxtElementyFiltr_TextChanged"/>
                                    <TextBlock Text="🔍" FontSize="13" IsHitTestVisible="False"
                                               Foreground="#94A3B8" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtElementyFiltrPlaceholder"
                                               Text="Filtruj po towarze, kodzie, kategorii, serii…"
                                               FontStyle="Italic" Foreground="#94A3B8" FontSize="12"
                                               IsHitTestVisible="False"
                                               Margin="32,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                                <Button Grid.Column="1" Content="✕" Padding="8,5" Margin="6,0,0,0"
                                        Background="#F1F5F9" Foreground="#475569" FontWeight="Bold"
                                        BorderBrush="#CBD5E1" BorderThickness="1"
                                        Cursor="Hand" Click="BtnElementyWyczyscFiltr_Click"
                                        ToolTip="Wyczyść filtr tekstowy"/>
                                <Button Grid.Column="2" x:Name="btnElResetFiltry" Content="↺ Reset"
                                        Padding="10,5" Margin="6,0,0,0" FontSize="11"
                                        Background="#F1F5F9" Foreground="#475569" FontWeight="SemiBold"
                                        BorderBrush="#CBD5E1" BorderThickness="1"
                                        Cursor="Hand" Click="BtnElResetFiltry_Click"
                                        ToolTip="Wyczyść wszystkie filtry (tekst + kategorie + serie)"/>
                                <CheckBox Grid.Column="3" x:Name="chkElementyGrupowanie"
                                          Content="📦 Grupuj"
                                          Margin="12,0,6,0" VerticalAlignment="Center" FontSize="12"
                                          ToolTip="Grupuj wiersze po kategorii"
                                          Checked="ChkElementyGrupowanie_Toggle"
                                          Unchecked="ChkElementyGrupowanie_Toggle"/>
                                <CheckBox x:Name="chkElTylkoZKrojeniem" Grid.Column="4"
                                          Content="✂️ Tylko z krojeniem"
                                          Margin="6,0,6,0" VerticalAlignment="Center" FontSize="12"
                                          ToolTip="Pokaż tylko pozycje gdzie Krojenie > 0"
                                          Checked="ChkElTylkoKrojenie_Toggle"
                                          Unchecked="ChkElTylkoKrojenie_Toggle"/>
                                <Button Grid.Column="5" Content="📥 CSV" Padding="12,5" Margin="6,0,0,0"
                                        Background="#1E40AF" Foreground="White" FontWeight="SemiBold"
                                        BorderThickness="0" FontSize="11"
                                        Cursor="Hand" Click="BtnEksportElementy_Click"/>
                            </Grid>
                        </Border>

                    <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="6" ClipToBounds="True">
                    <DataGrid x:Name="dgElementy" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              RowBackground="White" AlternatingRowBackground="#F8FAFC"
                              BorderThickness="0" RowHeight="28" FontSize="12"
                              EnableRowVirtualization="True" EnableColumnVirtualization="True"
                              VerticalGridLinesBrush="#F1F5F9" HorizontalGridLinesBrush="#F1F5F9">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EEF2FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <!-- Kolorowy pasek kategorii (4px) — szybki vizualny scan -->
                            <DataGridTemplateColumn Header="" Width="6" CanUserResize="False" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Rectangle Fill="{Binding Kategoria, Converter={StaticResource KategoriaKolor}}"
                                                   Width="4" HorizontalAlignment="Stretch"
                                                   ToolTip="{Binding Kategoria}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Data" Binding="{Binding Data, StringFormat=dd.MM.yyyy}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#475569"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Kod" Binding="{Binding KodTowaru}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#1F2937"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Towar" Binding="{Binding NazwaTowaru}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="ToolTip" Value="{Binding NazwaTowaru}"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Seria" Binding="{Binding Seria}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#1E40AF"/>
                                        <Setter Property="ToolTip" Value="Seria dokumentu Symfonii: PWP=krojenie wyjście, RWP=krojenie wejście, sPWU=ubój wyjście"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="🏭 Magazyn" Binding="{Binding MagazynNazwa}" Width="110"
                                                 SortMemberPath="MagazynID">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#1F2937"/>
                                        <Setter Property="ToolTip">
                                            <Setter.Value>
                                                <MultiBinding StringFormat="{}{0} (ID: {1})">
                                                    <Binding Path="MagazynNazwa"/>
                                                    <Binding Path="MagazynID"/>
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="📄 Dok." Binding="{Binding LicznikDokumentow}" Width="70"
                                                 SortMemberPath="LiczbaDokumentow">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#475569"/>
                                        <Setter Property="ToolTip" Value="{Binding NumeryDokumentow}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="📋 Numery dokumentów" Binding="{Binding NumeryDokumentowSkrocone}" Width="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="Foreground" Value="#1F2937"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="ToolTip" Value="{Binding NumeryDokumentow}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Przychód kg" Binding="{Binding Przychod, StringFormat=N0}" Width="100"
                                                 SortMemberPath="Przychod">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="Foreground" Value="#0F172A"/>
                                        <Setter Property="Padding" Value="0,0,10,0"/>
                                        <Setter Property="ToolTip" Value="Suma przychodu (PWP, sPWU) — co weszło na magazyn"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Krojenie kg" Binding="{Binding Krojenie, StringFormat=N0}" Width="100"
                                                 SortMemberPath="Krojenie">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="Foreground" Value="#7C3AED"/>
                                        <Setter Property="Padding" Value="0,0,10,0"/>
                                        <Setter Property="ToolTip" Value="Suma RWP (rozchód do krojenia) — co poszło na linię"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Wyd. %" Binding="{Binding WydajnoscProc, StringFormat=N1}" Width="80"
                                                 SortMemberPath="WydajnoscProc">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Background"
                                                Value="{Binding WydajnoscProc, Converter={StaticResource WydajnoscKolor}}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#0F172A"/>
                                        <Setter Property="Padding" Value="0,0,8,0"/>
                                        <Setter Property="ToolTip" Value="Krojenie / Przychód × 100% — kolor: czerwony &lt; 30%, żółty 30–60%, zielony &gt; 60%"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Bilans kg" Binding="{Binding Bilans, StringFormat=N0}" Width="90"
                                                 SortMemberPath="Bilans">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0,0,8,0"/>
                                        <Setter Property="Foreground" Value="#475569"/>
                                        <Setter Property="ToolTip" Value="Przychód − Krojenie (dodatni = nadwyżka magazynowa, ujemny = przerób)"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="🔍 Filtruj tylko ten towar" Click="MenuFiltruyElementTowar_Click"/>
                                <MenuItem Header="📦 Filtruj tylko tę kategorię" Click="MenuFiltruyElementKategoria_Click"/>
                                <Separator/>
                                <MenuItem Header="📋 Skopiuj wiersz (CSV)" Click="MenuSkopiujElement_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                    </Border>

                    <!-- Stopka tabeli z sumami live (tylko widoczne pozycje po filtrach) -->
                    <Border Grid.Row="3" Background="#0F172A" CornerRadius="0,0,6,6" Padding="14,8" Margin="0,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Σ Razem (widoczne):"
                                       FontWeight="Bold" FontSize="12" Foreground="#E2E8F0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="txtElFooterCount"
                                       Text="0 pozycji" FontSize="11" Foreground="#94A3B8"
                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="Przychód:"
                                       FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <TextBlock Grid.Column="3" x:Name="txtElFooterPrz"
                                       Text="0 kg" FontSize="13" FontWeight="Bold" Foreground="White"
                                       VerticalAlignment="Center" Margin="0,0,16,0"
                                       FontFamily="Consolas"/>
                            <TextBlock Grid.Column="4" x:Name="txtElFooterKr"
                                       Text="Krojenie: 0 kg" FontSize="13" FontWeight="Bold"
                                       Foreground="#A78BFA" VerticalAlignment="Center" Margin="0,0,16,0"
                                       FontFamily="Consolas"/>
                            <TextBlock Grid.Column="5" x:Name="txtElFooterWyd"
                                       Text="Wyd. —" FontSize="13" FontWeight="Bold"
                                       Foreground="#10B981" VerticalAlignment="Center"
                                       FontFamily="Consolas"/>
                        </Grid>
                    </Border>
                    </Grid>
                    <!-- ═════════ Koniec lewej kolumny ═════════ -->

                    <!-- ═════════ PRAWA: filtry + wykresy ═════════ -->
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="6,0,0,0">
                        <StackPanel>
                            <!-- ─── Filtry kategorii ─── -->
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="🎛️" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Filtruj kategorie" FontWeight="Bold" FontSize="13"
                                                   Foreground="#1F2937" VerticalAlignment="Center"/>
                                        <TextBlock Text="(klik = wyłącznie, Ctrl+klik = wiele)" FontSize="9"
                                                   FontStyle="Italic" Foreground="#94A3B8" Margin="6,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="kategMieso" Content="🥩  Mięso" Tag="Mięso"
                                                  Style="{StaticResource KategoriaToggleStyle}"
                                                  PreviewMouseLeftButtonDown="ElKategoriaBtn_PreviewMouseDown"/>
                                    <ToggleButton x:Name="kategMrozony" Content="❄️  Mrożony" Tag="Mrozony"
                                                  Style="{StaticResource KategoriaToggleStyle}"
                                                  PreviewMouseLeftButtonDown="ElKategoriaBtn_PreviewMouseDown"/>
                                    <ToggleButton x:Name="kategZywy" Content="🐔  Żywy" Tag="Zywy"
                                                  Style="{StaticResource KategoriaToggleStyle}"
                                                  PreviewMouseLeftButtonDown="ElKategoriaBtn_PreviewMouseDown"/>
                                    <ToggleButton x:Name="kategOdpady" Content="♻️  Odpady" Tag="Odpady"
                                                  Style="{StaticResource KategoriaToggleStyle}"
                                                  PreviewMouseLeftButtonDown="ElKategoriaBtn_PreviewMouseDown"/>
                                    <ToggleButton x:Name="kategInne" Content="📦  Inne" Tag="Inne"
                                                  Style="{StaticResource KategoriaToggleStyle}"
                                                  PreviewMouseLeftButtonDown="ElKategoriaBtn_PreviewMouseDown"/>
                                </StackPanel>
                            </Border>

                            <!-- ─── Filtry serii (PWP/RWP/sPWU) ─── -->
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="📋" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Seria dokumentów" FontWeight="Bold" FontSize="13"
                                                   Foreground="#1F2937" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel x:Name="panelSerie" Orientation="Vertical">
                                        <!-- Toggle buttons dla serii dynamicznie generowane w code-behind -->
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ─── Wykres donut: rozkład kategorii ─── -->
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                                <Grid Height="240">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="📊  Rozkład kategorii (kg krojenia)"
                                               FontWeight="Bold" FontSize="12" Foreground="#1F2937"
                                               Margin="0,0,0,6"/>
                                    <lvc:PieChart Grid.Row="1" x:Name="wykresElKategorii" LegendLocation="Right"
                                                  InnerRadius="35" StartingRotationAngle="270"
                                                  Hoverable="True" DataTooltip="{x:Null}"/>
                                </Grid>
                            </Border>

                            <!-- ─── Wykres trend efektywności (linia % wydajności w czasie) ─── -->
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                                <Grid Height="200">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="📈  Trend efektywności krojenia (%)"
                                               FontWeight="Bold" FontSize="12" Foreground="#1F2937"
                                               Margin="0,0,0,6"/>
                                    <lvc:CartesianChart Grid.Row="1" x:Name="wykresElTrend" LegendLocation="None">
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis x:Name="osXElTrend" Foreground="#475569" LabelsRotation="0"/>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis x:Name="osYElTrend" Foreground="#475569" Title="Wyd. %"/>
                                        </lvc:CartesianChart.AxisY>
                                    </lvc:CartesianChart>
                                </Grid>
                            </Border>

                            <!-- ─── Wykres bar: top 10 towarów (krojenie) ─── -->
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="6" Padding="14,10">
                                <Grid Height="320">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="🏆  Top 10 towarów (krojenie kg)"
                                               FontWeight="Bold" FontSize="12" Foreground="#1F2937"
                                               Margin="0,0,0,6"/>
                                    <lvc:CartesianChart Grid.Row="1" x:Name="wykresElTop10" LegendLocation="None">
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis x:Name="osXElTop10" Foreground="#475569"
                                                      Title="Krojenie kg"/>
                                        </lvc:CartesianChart.AxisX>
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis x:Name="osYElTop10" Foreground="#475569"/>
                                        </lvc:CartesianChart.AxisY>
                                    </lvc:CartesianChart>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ═══ Stopka ═══ -->
        <TextBlock Grid.Row="1" x:Name="txtInfo"
                   Text="Wybierz zakres i kliknij Zastosuj"
                   Foreground="#64748B" FontSize="11" FontStyle="Italic"
                   Margin="0,8,0,0" HorizontalAlignment="Right"/>
    </Grid>
</UserControl>
