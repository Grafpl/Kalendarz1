                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Border Grid.Row="0" x:Name="bdArrowZywiecUboj" CornerRadius="6"
                                                                Padding="14,7" HorizontalAlignment="Center"
                                                                Background="#10B981" Margin="0,0,0,6">
                                                            <Border.Effect>
                                                                <DropShadowEffect Color="#10B981" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                                                            </Border.Effect>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="⚙ wyd." FontSize="11" FontWeight="SemiBold"
                                                                           Foreground="#FFFFFF" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                                <TextBlock x:Name="txtArrowZywiecUbojProc" Text="—"
                                                                           FontSize="18" FontWeight="Bold" Foreground="White"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Border Width="120" Height="22" CornerRadius="6" VerticalAlignment="Center">
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                        <GradientStop Color="#DC2626" Offset="0"/>
                                                                        <GradientStop Color="#FCD34D" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="#7F1D1D" BlurRadius="6" ShadowDepth="1" Opacity="0.4"/>
                                                                </Border.Effect>
                                                            </Border>
                                                            <Polygon Points="0,0 24,22 0,44" Fill="#FCD34D" Stretch="None" VerticalAlignment="Center">
                                                                <Polygon.Effect>
                                                                    <DropShadowEffect Color="#92400E" BlurRadius="6" ShadowDepth="2" Opacity="0.3"/>
                                                                </Polygon.Effect>
                                                            </Polygon>
                                                        </StackPanel>
