<UserControl x:Class="Kalendarz1.AnalitykaPelna.Views.WidokLancuchGraficzny"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             Background="#F8FAFC"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             RenderOptions.BitmapScalingMode="HighQuality"
             Focusable="True"
             KeyDown="UserControl_KeyDown">
    <UserControl.Resources>
        <!-- ───── Design tokens ───── -->
        <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#475569"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Border" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Success" Color="#10B981"/>
        <SolidColorBrush x:Key="Danger" Color="#EF4444"/>
        <SolidColorBrush x:Key="Warning" Color="#F59E0B"/>
        <SolidColorBrush x:Key="Accent" Color="#2563EB"/>

        <!-- ───── Typography ───── -->
        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        </Style>
        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        </Style>
        <Style x:Key="KpiUnit" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SectionSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <!-- ───── Card style — subtle elevation ───── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#0F172A" BlurRadius="20" ShadowDepth="2" Opacity="0.04"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ───── Status pill ───── -->
        <Style x:Key="StatusPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ───── KPI hover lift effect ───── -->
        <Style x:Key="KpiHoverColumn" TargetType="StackPanel">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ───── Breakdown row hover highlight ───── -->
        <Style x:Key="BreakdownRowStyle" TargetType="Border">
            <Setter Property="Padding" Value="6,8"/>
            <Setter Property="BorderBrush" Value="#F1F5F9"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ───── Button style ───── -->
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Empty state overlay -->
        <Border x:Name="bdEmptyState" Background="#F8FAFC" Visibility="Collapsed" Panel.ZIndex="100">
            <Border Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1"
                    CornerRadius="12" Padding="40,32" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" BlurRadius="24" ShadowDepth="4" Opacity="0.06"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="📭" FontSize="54" HorizontalAlignment="Center" Opacity="0.35"/>
                    <TextBlock Text="Brak danych w wybranym zakresie" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,14,0,6"/>
                    <TextBlock x:Name="txtEmptyHint" FontSize="12" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="380"/>
                </StackPanel>
            </Border>
        </Border>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1400" HorizontalAlignment="Center" Margin="24,16,24,24">

                <!-- ═══════════════ HEADER ═══════════════ -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Łańcuch Graficzny" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock x:Name="txtZakres" Text="—" FontSize="12"
                                   Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ToggleButton x:Name="btnPorownaj" Click="BtnPorownaj_Click"
                                      Padding="12,7" Cursor="Hand" Margin="0,0,6,0"
                                      Background="White" Foreground="{StaticResource TextSecondary}"
                                      BorderBrush="{StaticResource Border}" BorderThickness="1"
                                      FontSize="12" FontWeight="SemiBold"
                                      ToolTip="Porównaj z poprzednim okresem (C)">
                            <TextBlock Text="📊  Porównaj"/>
                        </ToggleButton>
                        <Button x:Name="btnSnapshot" Click="BtnSnapshot_Click"
                                Padding="12,7" Cursor="Hand" Margin="0,0,6,0"
                                Background="White" Foreground="{StaticResource TextSecondary}"
                                BorderBrush="{StaticResource Border}" BorderThickness="1"
                                FontSize="12" FontWeight="SemiBold"
                                ToolTip="Snapshot do schowka (S)">
                            <TextBlock Text="📷  Snapshot"/>
                        </Button>
                        <Button x:Name="btnFullscreen" Click="BtnFullscreen_Click"
                                Padding="12,7" Cursor="Hand"
                                Background="#0F172A" Foreground="White" BorderThickness="0"
                                FontSize="12" FontWeight="SemiBold"
                                ToolTip="Pełny ekran (F11)">
                            <TextBlock Text="⛶  Pełny ekran"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ═══════════════ HERO KPI BAR (5 metryk) ═══════════════ -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- KPI 1: ŻYWIEC -->
                        <StackPanel Grid.Column="0" Tag="ZYWIEC" MouseLeftButtonUp="Kpi_Click" Style="{StaticResource KpiHoverColumn}"
                                    ToolTip="Kliknij — szczegóły dokumentów sPZ (żywiec)">
                            <TextBlock Text="ŻYWIEC PRZYJĘTO" Style="{StaticResource KpiLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="kpiZywiec" Text="—" Style="{StaticResource KpiValue}" Margin="0"/>
                                <TextBlock x:Name="kpiZywiecJedn" Text="t" FontSize="14" Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Bottom" Margin="6,0,0,8"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock x:Name="kpiZywiecDelta" Text="" FontSize="11" FontWeight="SemiBold" Visibility="Collapsed"/>
                                <TextBlock x:Name="kpiZywiecMeta" Text="—" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="6,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1" Width="1" Background="{StaticResource Border}" Margin="20,8"/>

                        <!-- KPI 2: UBÓJ + wyd -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="UBÓJ — WYDAJNOŚĆ" Style="{StaticResource KpiLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="kpiWydUboj" Text="—" Style="{StaticResource KpiValue}" Margin="0"/>
                                <TextBlock Text="%" FontSize="14" Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Bottom" Margin="2,0,0,8"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border x:Name="bdKpiWydUbojStatus" Style="{StaticResource StatusPill}" Background="{StaticResource Success}">
                                    <TextBlock x:Name="kpiWydUbojStatus" Text="—" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="norma 85%" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="3" Width="1" Background="{StaticResource Border}" Margin="20,8"/>

                        <!-- KPI 3: KROJENIE wyd -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="KROJENIE — WYDAJNOŚĆ" Style="{StaticResource KpiLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="kpiWydKroj" Text="—" Style="{StaticResource KpiValue}" Margin="0"/>
                                <TextBlock Text="%" FontSize="14" Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Bottom" Margin="2,0,0,8"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border x:Name="bdKpiWydKrojStatus" Style="{StaticResource StatusPill}" Background="{StaticResource Success}">
                                    <TextBlock x:Name="kpiWydKrojStatus" Text="—" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="norma 62%" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="5" Width="1" Background="{StaticResource Border}" Margin="20,8"/>

                        <!-- KPI 4: SPRZEDANE -->
                        <StackPanel Grid.Column="6" Tag="KLIENCI" MouseLeftButtonUp="Kpi_Click" Style="{StaticResource KpiHoverColumn}"
                                    ToolTip="Kliknij — szczegóły dokumentów sprzedaży (sWZ)">
                            <TextBlock Text="SPRZEDANO KLIENTOM" Style="{StaticResource KpiLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="kpiKlienci" Text="—" Style="{StaticResource KpiValue}" Margin="0"/>
                                <TextBlock x:Name="kpiKlienciJedn" Text="t" FontSize="14" Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Bottom" Margin="6,0,0,8"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock x:Name="kpiKlienciDelta" Text="" FontSize="11" FontWeight="SemiBold" Visibility="Collapsed"/>
                                <TextBlock x:Name="kpiKlienciMeta" Text="—" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="6,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="7" Width="1" Background="{StaticResource Border}" Margin="20,8"/>

                        <!-- KPI 5: ZOSTAŁO -->
                        <StackPanel Grid.Column="8">
                            <TextBlock Text="ZOSTAŁO W PROD" Style="{StaticResource KpiLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="kpiZostalo" Text="—" Style="{StaticResource KpiValue}" Margin="0"/>
                                <TextBlock x:Name="kpiZostaloJedn" Text="t" FontSize="14" Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Bottom" Margin="6,0,0,8"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border x:Name="bdKpiZostaloStatus" Style="{StaticResource StatusPill}" Background="{StaticResource Success}">
                                    <TextBlock x:Name="kpiZostaloStatus" Text="—" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock x:Name="kpiZostaloMeta" Text="" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══════════════ FLOW DIAGRAM (poziomy, czysty) ═══════════════ -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="PRZEPŁYW PRODUKCJI" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Od żywca do klienta — grubość pasa proporcjonalna do kg"
                                   Style="{StaticResource SectionSubtitle}"/>

                        <!-- Flow: 4 etapy poziome z proporcjonalnymi pasami -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Col 0: ŻYWIEC + wizualizacja straty uboju -->
                            <StackPanel Grid.Column="0" Tag="ZYWIEC" MouseLeftButtonUp="Kpi_Click" Cursor="Hand"
                                        ToolTip="Kliknij — szczegóły żywca">
                                <TextBlock Text="🐔  ŻYWIEC" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="dokumenty sPZ" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,1,0,8"/>
                                <Grid VerticalAlignment="Top">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" x:Name="bdFlowZywiec" Background="#FCA5A5" CornerRadius="4" Height="60">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock x:Name="flowZywiecKg" Text="—" FontSize="20" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="flowZywiecDok" Text="" FontSize="10" Foreground="#7F1D1D" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Mini-pasek strata uboju (pióra/krew/woda) -->
                                    <Border Grid.Row="1" x:Name="bdStrataUboju" Background="#FECACA" CornerRadius="0,0,4,4"
                                            Padding="6,3" Margin="0,1,0,0" ToolTip="Strata uboju: pióra/krew/woda/jelita (~15%)">
                                        <TextBlock x:Name="flowStrataUboju" Text="" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="#7F1D1D" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </StackPanel>

                            <!-- Arrow Z→U -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,18,0,0">
                                <TextBlock x:Name="flowArrowZUProc" Text="—" FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="wyd. uboju" FontSize="9" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,2,0,4"/>
                                <Path Stroke="{StaticResource TextMuted}" StrokeThickness="2" Data="M 0,10 L 40,10 M 32,4 L 40,10 L 32,16"
                                      HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Col 2: UBÓJ -->
                            <StackPanel Grid.Column="2" Tag="UBOJ" MouseLeftButtonUp="Kpi_Click" Cursor="Hand"
                                        ToolTip="Kliknij — szczegóły uboju (sPWU)">
                                <TextBlock Text="⚙  UBÓJ" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="dokumenty sPWU" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,1,0,8"/>
                                <Border x:Name="bdFlowUboj" Background="#FCD34D" CornerRadius="4" Height="60" VerticalAlignment="Top">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock x:Name="flowUbojKg" Text="—" FontSize="20" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="flowUbojDok" Text="" FontSize="10" Foreground="#92400E" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Arrow U→P -->
                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="0,18,0,0">
                                <TextBlock x:Name="flowArrowUPProc" Text="—" FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="wyd. krojenia" FontSize="9" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,2,0,4"/>
                                <Path Stroke="{StaticResource TextMuted}" StrokeThickness="2" Data="M 0,10 L 40,10 M 32,4 L 40,10 L 32,16"
                                      HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Col 4: PRODUKCJA -->
                            <StackPanel Grid.Column="4" Tag="PRODUKCJA" MouseLeftButtonUp="Kpi_Click" Cursor="Hand"
                                        ToolTip="Kliknij — szczegóły produkcji (sPWP)">
                                <TextBlock Text="🔪  PRODUKCJA" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="dokumenty sPWP" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,1,0,8"/>
                                <Border x:Name="bdFlowProd" Background="#86EFAC" CornerRadius="4" Height="60" VerticalAlignment="Top">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock x:Name="flowProdKg" Text="—" FontSize="20" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="flowProdDok" Text="" FontSize="10" Foreground="#047857" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Arrow P→K -->
                            <StackPanel Grid.Column="5" VerticalAlignment="Center" Margin="0,18,0,0">
                                <TextBlock x:Name="flowArrowPKProc" Text="—" FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="% sprzedaży" FontSize="9" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,2,0,4"/>
                                <Path Stroke="{StaticResource TextMuted}" StrokeThickness="2" Data="M 0,10 L 40,10 M 32,4 L 40,10 L 32,16"
                                      HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Col 6: KLIENCI -->
                            <StackPanel Grid.Column="6" Tag="KLIENCI" MouseLeftButtonUp="Kpi_Click" Cursor="Hand"
                                        ToolTip="Kliknij — szczegóły sprzedaży (sWZ)">
                                <TextBlock Text="🚚  KLIENCI" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="dokumenty sWZ" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,1,0,8"/>
                                <Border x:Name="bdFlowKlienci" Background="#6EE7B7" CornerRadius="4" Height="60" VerticalAlignment="Top">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock x:Name="flowKlienciKg" Text="—" FontSize="20" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="flowKlienciDok" Text="" FontSize="10" Foreground="#047857" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Sub-strzałka: ile z UBÓJ poszło na krojenie vs bezpośrednio -->
                        <Border Background="#F8FAFC" CornerRadius="6" Padding="14,10" Margin="0,16,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📤  Podział uboju:" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1" x:Name="txtPodzialUboju" Text="—" FontSize="12"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══════════════ BREAKDOWN — gdzie poszedł towar z PROD ═══════════════ -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="GDZIE TRAFIŁ TOWAR Z PRODUKCJI" Style="{StaticResource SectionTitle}"/>
                        <TextBlock x:Name="txtBreakdownSuma" Text="—" Style="{StaticResource SectionSubtitle}"/>
                        <StackPanel x:Name="panelBreakdown"/>
                    </StackPanel>
                </Border>

                <!-- ═══════════════ ALERTY / STATUS ═══════════════ -->
                <Border x:Name="bdAlerty" Style="{StaticResource Card}" Margin="0,0,0,24">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="txtAlertyIkona" Text="✓" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{StaticResource Success}"/>
                            <TextBlock Grid.Column="1" x:Name="txtAlertyTytul" Text="WSZYSTKO W NORMIE" Style="{StaticResource SectionTitle}"
                                       Foreground="{StaticResource Success}" Margin="0" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" x:Name="bdAlertyCount" CornerRadius="10" Padding="8,2" Background="#10B981" VerticalAlignment="Center" Visibility="Collapsed">
                                <TextBlock x:Name="txtAlertyCount" Text="0" FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="txtAlertyOpis" Text="Wszystkie wskaźniki w granicach norm operacyjnych."
                                   Style="{StaticResource SectionSubtitle}"/>
                        <ItemsControl x:Name="icAlerty">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                                            CornerRadius="6" Padding="14,10" Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Ikona}" FontSize="18"
                                                       Margin="0,0,12,0" VerticalAlignment="Top"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Tytul}" FontSize="13" FontWeight="Bold"
                                                           Foreground="#991B1B"/>
                                                <TextBlock Text="{Binding Opis}" FontSize="11"
                                                           Foreground="#7F1D1D" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ═══════════════ FOOTER meta ═══════════════ -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Ellipse Width="6" Height="6" Fill="{StaticResource Success}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="txtFooter" Text="—" FontSize="11"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
