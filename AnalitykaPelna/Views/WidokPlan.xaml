<UserControl x:Class="Kalendarz1.AnalitykaPelna.Views.WidokPlan"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Kalendarz1.AnalitykaPelna.Controls"
             Background="#F8FAFC">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- KPI strip -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Tabela -->
            <RowDefinition Height="Auto"/>
            <!-- Stopka info -->
        </Grid.RowDefinitions>

        <!-- ═══ 5 KPI ═══ -->
        <UniformGrid Grid.Row="0" Rows="1" Columns="5" Margin="0,0,0,16">
            <ctrl:KpiKafel x:Name="kpiSumaTygodnia"
                           Tytul="ŚREDNIA TYGODNIOWA" Wartosc="0" Jednostka="kg"
                           Ikona="∑" Margin="0,0,8,0">
                <ctrl:KpiKafel.Kolor>
                    <SolidColorBrush Color="#7C3AED"/>
                </ctrl:KpiKafel.Kolor>
            </ctrl:KpiKafel>
            <ctrl:KpiKafel x:Name="kpiDzienMax"
                           Tytul="DZIEŃ MAX" Wartosc="—" Jednostka=""
                           Ikona="🔝" Margin="0,0,8,0">
                <ctrl:KpiKafel.Kolor>
                    <SolidColorBrush Color="#059669"/>
                </ctrl:KpiKafel.Kolor>
            </ctrl:KpiKafel>
            <ctrl:KpiKafel x:Name="kpiDzienMin"
                           Tytul="DZIEŃ MIN" Wartosc="—" Jednostka=""
                           Ikona="📉" Margin="0,0,8,0">
                <ctrl:KpiKafel.Kolor>
                    <SolidColorBrush Color="#DC2626"/>
                </ctrl:KpiKafel.Kolor>
            </ctrl:KpiKafel>
            <ctrl:KpiKafel x:Name="kpiTygodni"
                           Tytul="TYGODNI W PRÓBCE" Wartosc="0" Jednostka="tygodni"
                           Ikona="📅" Margin="0,0,8,0">
                <ctrl:KpiKafel.Kolor>
                    <SolidColorBrush Color="#0891B2"/>
                </ctrl:KpiKafel.Kolor>
            </ctrl:KpiKafel>
            <ctrl:KpiKafel x:Name="kpiLiczbaPozycji"
                           Tytul="POZYCJI" Wartosc="0" Jednostka=""
                           Ikona="📦">
                <ctrl:KpiKafel.Kolor>
                    <SolidColorBrush Color="#F59E0B"/>
                </ctrl:KpiKafel.Kolor>
            </ctrl:KpiKafel>
        </UniformGrid>

        <!-- ═══ Toolbar: 3 widoki + eksport ═══ -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Widok:" FontWeight="SemiBold" Foreground="#475569"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <RadioButton x:Name="rbTowary" Content="📦 Towary"
                                 IsChecked="True" GroupName="WidokPrognozy"
                                 Margin="0,0,16,0" Checked="WidokRadio_Checked"
                                 VerticalAlignment="Center"/>
                    <RadioButton x:Name="rbOdbiorcy" Content="👥 Odbiorcy"
                                 GroupName="WidokPrognozy"
                                 Margin="0,0,16,0" Checked="WidokRadio_Checked"
                                 VerticalAlignment="Center"/>
                    <RadioButton x:Name="rbHandlowcy" Content="🏆 Handlowcy"
                                 GroupName="WidokPrognozy"
                                 Margin="0,0,16,0" Checked="WidokRadio_Checked"
                                 VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="📥 Eksport CSV"
                        Padding="10,4" Background="#F1F5F9" Foreground="#475569"
                        BorderBrush="#E2E8F0" BorderThickness="1"
                        Cursor="Hand" Click="BtnEksport_Click"/>
            </Grid>
        </Border>

        <!-- ═══ Tabela prognozy ═══ -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="8" ClipToBounds="True">
            <DataGrid x:Name="dgPrognoza" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      RowBackground="White" AlternatingRowBackground="#FAFAFA"
                      BorderThickness="0" RowHeight="28" FontSize="12"
                      VerticalGridLinesBrush="#F1F5F9"
                      HorizontalGridLinesBrush="#F1F5F9">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Pozycja" Binding="{Binding Etykieta}" Width="*"
                                        MinWidth="200"/>
                    <DataGridTextColumn Header="Pn" Binding="{Binding Pn, StringFormat=N0}" Width="80"/>
                    <DataGridTextColumn Header="Wt" Binding="{Binding Wt, StringFormat=N0}" Width="80"/>
                    <DataGridTextColumn Header="Śr" Binding="{Binding Sr, StringFormat=N0}" Width="80"/>
                    <DataGridTextColumn Header="Cz" Binding="{Binding Cz, StringFormat=N0}" Width="80"/>
                    <DataGridTextColumn Header="Pt" Binding="{Binding Pt, StringFormat=N0}" Width="80"/>
                    <DataGridTextColumn Header="So" Binding="{Binding So, StringFormat=N0}" Width="80"/>
                    <DataGridTextColumn Header="Nd" Binding="{Binding Nd, StringFormat=N0}" Width="80"/>
                    <DataGridTextColumn Header="Suma tyg." Binding="{Binding SumaTygodnia, StringFormat=N0}"
                                        Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#7C3AED"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ═══ Stopka info ═══ -->
        <TextBlock Grid.Row="3" x:Name="txtInfo"
                   Text="Wybierz zakres i kliknij Zastosuj"
                   Foreground="#64748B" FontSize="11" FontStyle="Italic"
                   Margin="0,8,0,0" HorizontalAlignment="Right"/>
    </Grid>
</UserControl>
