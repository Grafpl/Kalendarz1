<UserControl x:Class="Kalendarz1.AnalitykaPelna.Views.WidokUdzialPrzychodu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:svc="clr-namespace:Kalendarz1.AnalitykaPelna.Services"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             Background="White"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#475569"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Surface" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="Accent" Color="#7C3AED"/>

        <svc:HexToBrushConverter x:Key="HexToBrush"/>

        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ToggleButton dla granulacji D/T/M -->
        <Style x:Key="GranToggleStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E0E7FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#818CF8"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#7C3AED"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#5B21B6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Wiersz towaru w pickerze -->
        <DataTemplate x:Key="TowarItemTemplate">
            <Border Padding="8,6" BorderThickness="0,0,0,1" BorderBrush="#F1F5F9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" IsChecked="{Binding Zaznaczony, Mode=TwoWay}"
                              VerticalAlignment="Center" Margin="0,0,8,0"
                              Checked="Towar_Toggled" Unchecked="Towar_Toggled"/>
                    <StackPanel Grid.Column="1" Orientation="Vertical">
                        <TextBlock Text="{Binding Kod}" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="{Binding Nazwa}" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding PrzychodFormatted}" FontSize="11"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                               FontFamily="Consolas"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="💹 Udział towarów w przychodzie"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Porównywarka: zaznacz towary po lewej, zobacz % udziału w czasie. Źródło: HANDEL Sage (FVS/FVR/FVZ)."
                               FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnWyczyscWybor" Content="✕ Wyczyść wybór" Padding="12,6"
                            Margin="0,0,8,0" Click="BtnWyczyscWybor_Click"/>
                    <Button x:Name="btnEksport" Content="📥 CSV" Padding="12,6" Click="BtnEksport_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- KPI -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="20,12,20,4">
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="PRZYCHÓD CAŁKOWITY" FontSize="10.5" Foreground="{StaticResource TextMuted}"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="kpiPrzychodCalk" Text="—" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="PRZYCHÓD ZAZNACZONYCH" FontSize="10.5" Foreground="{StaticResource TextMuted}"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="kpiPrzychodZazn" Text="—" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource Accent}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="UDZIAŁ ZAZNACZONYCH" FontSize="10.5" Foreground="{StaticResource TextMuted}"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="kpiUdzialZazn" Text="—" FontSize="22" FontWeight="Bold"
                               Foreground="#10B981"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="LICZBA WYBRANYCH TOWARÓW" FontSize="10.5" Foreground="{StaticResource TextMuted}"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="kpiLiczbaTowarow" Text="0" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- CONTENT: lewa = picker, prawa = wykres + tabela -->
        <Grid Grid.Row="2" Margin="20,8,20,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ Lewa kolumna: lista towarów z checkboxami ═══ -->
            <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1" CornerRadius="8" Padding="0" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.06"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Tytuł + licznik -->
                    <Border Grid.Row="0" Background="{StaticResource Surface}"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <StackPanel>
                            <TextBlock Text="LISTA TOWARÓW" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock x:Name="txtLicznikTowarow" Text="—"
                                       FontSize="10" Foreground="{StaticResource TextMuted}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Wyszukiwarka -->
                    <Border Grid.Row="1" Padding="8,8" BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtSzukaj" Grid.Column="0" Height="28"
                                     VerticalContentAlignment="Center" Padding="6,0" FontSize="12"
                                     TextChanged="TxtSzukaj_TextChanged"
                                     ToolTip="Wyszukaj po kodzie lub nazwie"/>
                            <TextBlock Grid.Column="0" Text="🔍 szukaj kod / nazwa…" FontSize="11"
                                       Foreground="{StaticResource TextMuted}" Margin="8,0,0,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False"
                                       x:Name="txtSzukajPlaceholder"/>
                            <Button Grid.Column="1" x:Name="btnSzukajClear" Content="✕"
                                    Width="26" Height="28" Margin="4,0,0,0"
                                    Click="BtnSzukajClear_Click"
                                    Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- Lista -->
                    <ListBox Grid.Row="2" x:Name="lstTowary"
                             ItemTemplate="{StaticResource TowarItemTemplate}"
                             BorderThickness="0" Padding="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Footer: zaznacz top N -->
                    <Border Grid.Row="3" Background="{StaticResource Surface}"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0"
                            Padding="8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Top 5" Padding="10,5" Margin="2,0" Tag="5"
                                    Click="BtnTopN_Click" FontSize="11"/>
                            <Button Content="Top 10" Padding="10,5" Margin="2,0" Tag="10"
                                    Click="BtnTopN_Click" FontSize="11"/>
                            <Button Content="Top 20" Padding="10,5" Margin="2,0" Tag="20"
                                    Click="BtnTopN_Click" FontSize="11"/>
                            <Button Content="✕" Padding="10,5" Margin="2,0"
                                    Click="BtnWyczyscWybor_Click" FontSize="11"
                                    ToolTip="Odznacz wszystkie"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ Prawa kolumna: granulacja + wykres + tabela ═══ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Toolbar: granulacja + metryka -->
                <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Granulacja:" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ToggleButton x:Name="tbDzien" Content="📅 Dzień" Style="{StaticResource GranToggleStyle}"
                                          Click="Granulacja_Click" Tag="Dzien" IsChecked="True"/>
                            <ToggleButton x:Name="tbTydzien" Content="📆 Tydzień" Style="{StaticResource GranToggleStyle}"
                                          Click="Granulacja_Click" Tag="Tydzien"/>
                            <ToggleButton x:Name="tbMiesiac" Content="🗓 Miesiąc" Style="{StaticResource GranToggleStyle}"
                                          Click="Granulacja_Click" Tag="Miesiac"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Metryka:" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ToggleButton x:Name="tbMetrykaProc" Content="% udział" Style="{StaticResource GranToggleStyle}"
                                          Click="Metryka_Click" Tag="Proc" IsChecked="True"/>
                            <ToggleButton x:Name="tbMetrykaPLN" Content="zł" Style="{StaticResource GranToggleStyle}"
                                          Click="Metryka_Click" Tag="PLN"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Wykres + tabela w splitterze -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="260"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="220" MinHeight="120"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1" CornerRadius="8" Padding="12">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.06"/>
                        </Border.Effect>
                        <Grid>
                            <lvc:CartesianChart x:Name="wykres" LegendLocation="Top">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis x:Name="osX" Title="Okres" Foreground="#475569" LabelsRotation="0"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis x:Name="osY" Title="% udział" Foreground="#475569"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>

                            <!-- Empty state -->
                            <Border x:Name="emptyState" Background="#F8FAFC" CornerRadius="6"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Padding="24,16" Visibility="Visible">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📈" FontSize="38" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="emptyStateText"
                                               Text="Wybierz daty i kliknij Zastosuj, a następnie zaznacz towary po lewej."
                                               FontSize="13" Foreground="{StaticResource TextSecondary}"
                                               TextWrapping="Wrap" MaxWidth="380" TextAlignment="Center"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                  Height="6" Background="Transparent" ShowsPreview="True"
                                  ResizeBehavior="PreviousAndNext"/>

                    <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                        <DataGrid x:Name="dgTabela" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowBackground="White" AlternatingRowBackground="#F8FAFC"
                                  BorderThickness="0" RowHeight="26" FontSize="11.5"
                                  EnableRowVirtualization="True"
                                  HorizontalGridLinesBrush="#F1F5F9" VerticalGridLinesBrush="#F1F5F9">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="" Width="14" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding Kolor, Converter={StaticResource HexToBrush}}"
                                                    Width="10" Height="10" CornerRadius="2"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Kod" Binding="{Binding Kod}" Width="100"/>
                                <DataGridTextColumn Header="Nazwa" Binding="{Binding Nazwa}" Width="*"/>
                                <DataGridTextColumn Header="Przychód [zł]"
                                                    Binding="{Binding SumaWartosci, StringFormat=N0}"
                                                    Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Średni % udział"
                                                    Binding="{Binding SredniUdzialProc, StringFormat=F2}"
                                                    Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- (rezerwa) -->
                <Grid Grid.Row="2"/>
            </Grid>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="3" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0" Padding="24,8">
            <TextBlock x:Name="txtStopka" FontSize="11" Foreground="{StaticResource TextMuted}"
                       Text="% udział = przychód towaru / przychód wszystkich towarów w danym okresie × 100. Pomijamy korekty (typ_dk poza FVS/FVR/FVZ) i dokumenty anulowane."/>
        </Border>
    </Grid>
</UserControl>
