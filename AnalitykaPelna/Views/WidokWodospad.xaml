<UserControl x:Class="Kalendarz1.AnalitykaPelna.Views.WidokWodospad"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:svc="clr-namespace:Kalendarz1.AnalitykaPelna.Services"
             Background="White"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#475569"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Surface" Color="#F8FAFC"/>

        <svc:HexToBrushConverter x:Key="HexToBrush"/>

        <!-- Karta KPI -->
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#0F172A" BlurRadius="10" ShadowDepth="2" Opacity="0.10"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Wiersz wodospadu — POZIOM -->
        <DataTemplate x:Key="PoziomTemplate">
            <Grid Margin="0,3" Height="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Ikona}" FontSize="18" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding Nazwa}" FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="1" HorizontalAlignment="Left"
                        Width="{Binding SzerokoscPx}"
                        Background="{Binding Kolor, Converter={StaticResource HexToBrush}}"
                        CornerRadius="6" MinWidth="40">
                    <TextBlock Text="{Binding KgFormatted}" Foreground="White" FontWeight="Bold"
                               FontSize="13" Margin="10,0" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ProcBazyFormatted}" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding StatusIkona}" FontSize="14"
                               Foreground="{Binding StatusKolor, Converter={StaticResource HexToBrush}}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Wiersz wodospadu — STRATA (wcięty, mniejszy, czerwonawy) -->
        <DataTemplate x:Key="StrataTemplate">
            <Grid Margin="24,2,0,2" Height="30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="206"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Ikona}" FontSize="14" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding Nazwa}" FontSize="11.5"
                               Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border Grid.Column="1" HorizontalAlignment="Left"
                        Width="{Binding SzerokoscPx}"
                        Background="{Binding Kolor, Converter={StaticResource HexToBrush}}"
                        CornerRadius="4" Opacity="0.65" MinWidth="20" Height="18" VerticalAlignment="Center">
                    <TextBlock Text="{Binding KgFormatted}" Foreground="White" FontSize="10"
                               Margin="6,0" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="#FEE2E2" CornerRadius="4" Padding="5,1" Margin="0,0,6,0">
                        <TextBlock Text="{Binding ProcStratyFormatted}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#B91C1C"/>
                    </Border>
                    <TextBlock Text="{Binding Kierunek}" FontSize="10" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Selektor: Poziom vs Strata -->
        <svc:WaterfallStepTemplateSelector x:Key="StepSelector"
                                           PoziomTemplate="{StaticResource PoziomTemplate}"
                                           StrataTemplate="{StaticResource StrataTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER: tytuł + ceny -->
        <Border Grid.Row="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="💧 Wodospad uzysku" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock x:Name="txtPodtytul" Text="Gdzie znika mięso — od żywca (100%) do gotowych elementów"
                               FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Ceny opcjonalne -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Cena żywca zł/kg" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                        <TextBox x:Name="txtCenaZywca" Width="80" Height="26" FontSize="13"
                                 VerticalContentAlignment="Center" TextChanged="Ceny_TextChanged"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Cena gotowego zł/kg" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                        <TextBox x:Name="txtCenaGotowego" Width="90" Height="26" FontSize="13"
                                 VerticalContentAlignment="Center" TextChanged="Ceny_TextChanged"/>
                    </StackPanel>
                    <Button x:Name="btnEksport" Content="📥 CSV" Padding="12,6" Click="BtnEksport_Click"
                            VerticalAlignment="Bottom"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- KPI -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="20,16,20,8">
            <Border Style="{StaticResource KpiCard}" Background="#FEF3C7">
                <StackPanel>
                    <TextBlock Text="WEJŚCIE (żywiec)" FontSize="10.5" Foreground="#92400E" FontWeight="SemiBold"/>
                    <TextBlock x:Name="kpiWejscie" Text="—" FontSize="22" FontWeight="Bold" Foreground="#78350F"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Background="#EDE9FE">
                <StackPanel>
                    <TextBlock Text="WYJŚCIE (elementy)" FontSize="10.5" Foreground="#5B21B6" FontWeight="SemiBold"/>
                    <TextBlock x:Name="kpiWyjscie" Text="—" FontSize="22" FontWeight="Bold" Foreground="#4C1D95"/>
                </StackPanel>
            </Border>
            <Border x:Name="kpiYieldCard" Style="{StaticResource KpiCard}" Background="#D1FAE5">
                <StackPanel>
                    <TextBlock Text="YIELD UZYSKU" FontSize="10.5" Foreground="#065F46" FontWeight="SemiBold"/>
                    <TextBlock x:Name="kpiYield" Text="—" FontSize="22" FontWeight="Bold" Foreground="#064E3B"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Background="#FEE2E2">
                <StackPanel>
                    <TextBlock Text="MARŻA BRUTTO" FontSize="10.5" Foreground="#991B1B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="kpiMarza" Text="podaj ceny →" FontSize="18" FontWeight="Bold" Foreground="#7F1D1D"/>
                    <TextBlock x:Name="kpiKoszt" Text="" FontSize="10" Foreground="#991B1B"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="20,8,20,8">
            <StackPanel>
                <!-- Wodospad -->
                <Border Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                        CornerRadius="12" Padding="20,16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="ŁAŃCUCH STRAT (żywiec → elementy)" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="lstWodospad"
                                      ItemTemplateSelector="{StaticResource StepSelector}"/>
                    </StackPanel>
                </Border>

                <!-- Rozejście -->
                <Border Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                        CornerRadius="12" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="GDZIE POSZŁY ELEMENTY (rozejście produkcji)" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="lstRozejscie">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3" Height="34">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Ikona}" FontSize="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Nazwa}" FontWeight="SemiBold" FontSize="12.5"
                                                       Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" HorizontalAlignment="Left"
                                                Width="{Binding SzerokoscPx}"
                                                Background="{Binding Kolor, Converter={StaticResource HexToBrush}}"
                                                CornerRadius="5" MinWidth="30" Height="22" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding KgFormatted}" Foreground="White" FontSize="11.5"
                                                       FontWeight="SemiBold" Margin="8,0" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProcBazyFormatted}" FontWeight="Bold" FontSize="13"
                                                       Foreground="{StaticResource TextPrimary}" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Kierunek}" FontSize="10" Foreground="{StaticResource TextMuted}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="3" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0" Padding="24,8">
            <TextBlock x:Name="txtStopka" FontSize="11" Foreground="{StaticResource TextMuted}"
                       Text="Dane z łańcucha produkcji (HANDEL + LibraNet). Podaj ceny aby zobaczyć marżę."/>
        </Border>
    </Grid>
</UserControl>
