                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.4*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ❄ MROŹNIA -->
                    <Border Grid.Column="0" Style="{StaticResource SiloCard}" BorderBrush="#BAE6FD" Margin="0,0,6,0"
                            Tag="MROZNIA" MouseLeftButtonUp="Step_Click">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="❄" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="  MROŹNIA" FontSize="12" FontWeight="Bold" Foreground="#0E7490" VerticalAlignment="Center"/>
