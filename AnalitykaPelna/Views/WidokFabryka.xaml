                                <TextBlock x:Name="silMrozProc" Text="—%" FontSize="11" FontWeight="SemiBold" Foreground="#0E7490" VerticalAlignment="Bottom" Margin="8,0,0,4"/>
                            </StackPanel>
                            <TextBlock x:Name="silMrozDok" Text="" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            <TextBlock Text="sMM− → 65552" FontSize="9" Foreground="#0E7490" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 🥓 MASARNIA -->
                    <Border Grid.Column="1" Style="{StaticResource SiloCard}" BorderBrush="#FED7AA" Margin="3,0"
                            Tag="MASARNIA" MouseLeftButtonUp="Step_Click">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🥓" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="  MASARNIA" FontSize="12" FontWeight="Bold" Foreground="#9A3412" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="wędliny  ·  wyroby" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="silMasarKg" Text="—" FontSize="24" FontWeight="Bold" FontFamily="Segoe UI" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="t" FontSize="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="3,0,0,3"/>
                                <TextBlock x:Name="silMasarProc" Text="—%" FontSize="11" FontWeight="SemiBold" Foreground="#9A3412" VerticalAlignment="Bottom" Margin="8,0,0,4"/>
                            </StackPanel>
                            <TextBlock x:Name="silMasarDok" Text="" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            <TextBlock Text="sMM− → 65562" FontSize="9" Foreground="#9A3412" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 🌾 KARMA -->
                    <Border Grid.Column="2" Style="{StaticResource SiloCard}" BorderBrush="#FDE68A" Margin="3,0"
                            Tag="KARMA" MouseLeftButtonUp="Step_Click">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌾" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="  KARMA" FontSize="12" FontWeight="Bold" Foreground="#A16207" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="dla zwierząt  ·  pasze" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="silKarmaKg" Text="—" FontSize="24" FontWeight="Bold" FontFamily="Segoe UI" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="t" FontSize="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="3,0,0,3"/>
                                <TextBlock x:Name="silKarmaProc" Text="—%" FontSize="11" FontWeight="SemiBold" Foreground="#A16207" VerticalAlignment="Bottom" Margin="8,0,0,4"/>
                            </StackPanel>
                            <TextBlock x:Name="silKarmaDok" Text="" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            <TextBlock Text="sMM− → 65547" FontSize="9" Foreground="#A16207" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 🗑 ODPADY -->
                    <Border Grid.Column="3" Style="{StaticResource SiloCard}" BorderBrush="#CBD5E1" Margin="3,0"
                            Tag="ODPADY" MouseLeftButtonUp="Step_Click">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="  ODPADY" FontSize="12" FontWeight="Bold" Foreground="#475569" VerticalAlignment="Center"/>
                                <Ellipse x:Name="silOdpadyDot" Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="utylizacja  ·  norma ≤5%" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="silOdpadyKg" Text="—" FontSize="24" FontWeight="Bold" FontFamily="Segoe UI" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="t" FontSize="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="3,0,0,3"/>
                                <TextBlock x:Name="silOdpadyProc" Text="—%" FontSize="11" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Bottom" Margin="8,0,0,4"/>
                            </StackPanel>
                            <TextBlock x:Name="silOdpadyDok" Text="" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            <TextBlock Text="sMM− → 65551" FontSize="9" Foreground="#475569" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 📦 DYSTRYBUCJA -->
                    <Border Grid.Column="4" Style="{StaticResource SiloCard}" BorderBrush="#BFDBFE" Margin="6,0,0,0"
                            Background="#F0F9FF"
                            Tag="DYSTRYBUCJA" MouseLeftButtonUp="Step_Click">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="  DYSTRYBUCJA  (gł. magazyn)" FontSize="12" FontWeight="Bold" Foreground="#1E40AF" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="gotowe do wysyłki klientom" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="silDystKg" Text="—" FontSize="28" FontWeight="Bold" FontFamily="Segoe UI" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="t" FontSize="14" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="3,0,0,4"/>
                                <TextBlock x:Name="silDystProc" Text="—%" FontSize="13" FontWeight="SemiBold" Foreground="#1E40AF" VerticalAlignment="Bottom" Margin="10,0,0,5"/>
                            </StackPanel>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="sMM− → 65556 (M.DYST)" FontSize="9" Foreground="#1E40AF" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="→ sWZ:" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="silDystDoKli" Text="—" FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" Foreground="#1E40AF" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Grid>
