                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🚛" FontSize="28" HorizontalAlignment="Center"/>
                                <TextBlock Text="06" FontSize="9" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Opacity="0.85"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="WYSYŁKA" Style="{StaticResource StepLabel}" Margin="0,8,0,0"/>
                        <TextBlock Text="do klientów" Style="{StaticResource StepLabel}" FontWeight="Normal" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </Grid>

                <!-- ═══════════════ KARTY SZCZEGÓŁOWE 6 etapów ═══════════════ -->
                <Grid Margin="0,0,0,40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ① Detail: ŻYWIEC -->
                    <Border Grid.Column="0" Style="{StaticResource DetailCard}" Margin="0,0,6,0"
                            Tag="ZYWIEC" MouseLeftButtonUp="Step_Click"
                            ToolTip="Kliknij — pełen szczegół przyjęcia">
                        <StackPanel>
                            <TextBlock Text="ZAKUPIONO ŻYWCA" Style="{StaticResource StepLabel}" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="kpi1Value" Text="—" Style="{StaticResource StepValue}" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="kpi1Unit" Text="t" FontSize="13" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                            <TextBlock x:Name="kpi1Sub" Text="—" Style="{StaticResource StepLabel}" Foreground="{StaticResource TextSecondary}" FontWeight="Normal" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                            <Border Background="#FED7AA" Style="{StaticResource DocPill}" HorizontalAlignment="Left">
                                <TextBlock Text="📄 sPZ" FontSize="10" FontWeight="Bold" Foreground="#9A3412"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ② Detail: UBÓJ -->
                    <Border Grid.Column="1" Style="{StaticResource DetailCard}" Margin="3,0"
                            Tag="UBOJ" MouseLeftButtonUp="Step_Click"
                            ToolTip="Kliknij — pełen szczegół uboju">
                        <StackPanel>
                            <TextBlock Text="PO UBOJU" Style="{StaticResource StepLabel}" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="kpi2Value" Text="—" Style="{StaticResource StepValue}" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="kpi2Unit" Text="t" FontSize="13" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="kpi2WydVal" Text="—" FontSize="13" FontWeight="Bold" Foreground="#DC2626"/>
                                <TextBlock Text="% wyd." FontSize="11" Foreground="{StaticResource TextMuted}" Margin="3,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Text=" · norma 85%" FontSize="11" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="kpi2Strata" Text="" FontSize="11" Foreground="#9A1B1B" Margin="0,3,0,0" TextWrapping="Wrap"/>
                            <Border Background="#FEE2E2" Style="{StaticResource DocPill}" HorizontalAlignment="Left">
                                <TextBlock Text="📄 sPWU" FontSize="10" FontWeight="Bold" Foreground="#7F1D1D"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ③ Detail: KROJENIE -->
                    <Border Grid.Column="2" Style="{StaticResource DetailCard}" Margin="3,0"
                            Tag="PRODUKCJA" MouseLeftButtonUp="Step_Click"
                            ToolTip="Kliknij — pełen szczegół krojenia">
                        <StackPanel>
                            <TextBlock Text="ELEMENTY PO KROJENIU" Style="{StaticResource StepLabel}" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="kpi3Value" Text="—" Style="{StaticResource StepValue}" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="kpi3Unit" Text="t" FontSize="13" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="kpi3WydVal" Text="—" FontSize="13" FontWeight="Bold" Foreground="#7C3AED"/>
                                <TextBlock Text="% wyd." FontSize="11" Foreground="{StaticResource TextMuted}" Margin="3,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Text=" · norma 62%" FontSize="11" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="kpi3Strata" Text="" FontSize="11" Foreground="#9A1B1B" Margin="0,3,0,0" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border Background="#EDE9FE" Style="{StaticResource DocPill}" Margin="0,0,3,0">
                                    <TextBlock Text="📄 sRWP" FontSize="10" FontWeight="Bold" Foreground="#5B21B6"/>
                                </Border>
                                <Border Background="#EDE9FE" Style="{StaticResource DocPill}" Margin="0">
                                    <TextBlock Text="→ sPWP" FontSize="10" FontWeight="Bold" Foreground="#5B21B6"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ④ Detail: PAKOWANIE — klikalne -->
                    <Border Grid.Column="3" Style="{StaticResource DetailCard}" Margin="3,0"
                            MouseLeftButtonUp="Pakowanie_Click"
                            ToolTip="Kliknij — bilans pakowania i przesunięć sMM−">
                        <StackPanel>
                            <TextBlock Text="SPAKOWANO ŁĄCZNIE" Style="{StaticResource StepLabel}" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock x:Name="kpi4Value" Text="—" Style="{StaticResource StepValue}" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="kpi4Unit" Text="t" FontSize="13" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                            <TextBlock x:Name="kpi4Sub" Text="—" Style="{StaticResource StepLabel}" Foreground="{StaticResource TextSecondary}" FontWeight="Normal" HorizontalAlignment="Left" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            <Border Background="#DBEAFE" Style="{StaticResource DocPill}" HorizontalAlignment="Left">
                                <TextBlock Text="📄 sMM−" FontSize="10" FontWeight="Bold" Foreground="#1E40AF"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ⑤ Detail: MAGAZYNY (summary) -->
                    <Border Grid.Column="4" Style="{StaticResource DetailCard}" Margin="3,0"
