                                <TextBlock Text="📄 sMM− → 5 magazynów" FontSize="10" FontWeight="Bold" Foreground="#1E40AF"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ⑥ Detail: KLIENCI -->
                    <Border Grid.Column="5" Style="{StaticResource DetailCard}" Margin="6,0,0,0"
                            Tag="KLIENCI" MouseLeftButtonUp="Step_Click"
                            ToolTip="Kliknij — pełen szczegół sprzedaży">
                        <StackPanel>
                            <TextBlock Text="WYSYŁKA KLIENTOM" Style="{StaticResource StepLabel}" HorizontalAlignment="Left"/>
