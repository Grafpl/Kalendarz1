                                <TextBlock x:Name="kpi6Value" Text="—" Style="{StaticResource StepValue}" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="kpi6Unit" Text="t" FontSize="13" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                            <TextBlock x:Name="kpi6Sub" Text="—" Style="{StaticResource StepLabel}" Foreground="{StaticResource TextSecondary}" FontWeight="Normal" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                            <Border Background="#D1FAE5" Style="{StaticResource DocPill}" HorizontalAlignment="Left">
                                <TextBlock Text="📄 sWZ" FontSize="10" FontWeight="Bold" Foreground="#047857"/>
                            </Border>
                        </StackPanel>
                    </Border>
