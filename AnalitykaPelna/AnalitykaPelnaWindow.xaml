<Window x:Class="Kalendarz1.AnalitykaPelna.AnalitykaPelnaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Kalendarz1.AnalitykaPelna.Views"
        xmlns:ctrl="clr-namespace:Kalendarz1.AnalitykaPelna.Controls"
        Title="Analityka Pełna"
        Width="1600" Height="950"
        MinWidth="1280" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F8FAFC"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <Style x:Key="TabHeaderStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="22,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#7C3AED"/>
                                <Setter Property="Foreground" Value="#7C3AED"/>
                                <Setter Property="Background" Value="#FAF5FF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="#7C3AED"/>
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Styl dla przycisków w nagłówku -->
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#4B5563"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#1F2937"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabControl ze split-headerem: tab panel po lewej, FiltryPasek po prawej -->
        <Style x:Key="TabControlSplitHeaderStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TabPanel Grid.Column="0" x:Name="HeaderPanel"
                                              Background="Transparent"
                                              IsItemsHost="True" Panel.ZIndex="1"
                                              VerticalAlignment="Bottom"/>
                                    <ContentPresenter Grid.Column="1"
                                                      Content="{TemplateBinding Tag}"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- (rezerwa, niewidoczny) -->
            <RowDefinition Height="*"/>
            <!-- Zakładki + FiltryPasek w nagłówku -->
            <RowDefinition Height="Auto"/>
            <!-- Pasek statusu -->
        </Grid.RowDefinitions>

        <!-- Nagłówek usunięty — przyciski przeniesione do FiltryPasek; tytuł = ramka okna -->
        <TextBlock x:Name="txtPodtytul" Grid.Row="0" Visibility="Collapsed" Text=""/>

        <!-- ═══ Zakładki (FiltryPasek osadzony w split-header obok tabów) ═══ -->
        <TabControl x:Name="tabGlowny" Grid.Row="1"
                    Style="{StaticResource TabControlSplitHeaderStyle}"
                    SelectionChanged="TabGlowny_SelectionChanged">
            <TabControl.Tag>
                <ctrl:FiltryPasek x:Name="filtryPasek"/>
            </TabControl.Tag>

            <TabItem Header="📅 Plan" Style="{StaticResource TabHeaderStyle}">
                <views:WidokPlan x:Name="widokPlan"/>
            </TabItem>

            <TabItem Header="⚡ Realizacja" Style="{StaticResource TabHeaderStyle}">
                <views:WidokRealizacja x:Name="widokRealizacja"/>
            </TabItem>

            <TabItem Header="⚖ Bilans" Style="{StaticResource TabHeaderStyle}">
                <views:WidokBilans x:Name="widokBilans"/>
            </TabItem>

            <TabItem Header="📈 Wydajność" Style="{StaticResource TabHeaderStyle}">
                <views:WidokWydajnosc x:Name="widokWydajnosc"/>
            </TabItem>

            <TabItem Header="💧 Wodospad" Style="{StaticResource TabHeaderStyle}">
                <views:WidokWodospad x:Name="widokWodospad"/>
            </TabItem>
        </TabControl>

        <!-- ═══ Loading overlay (nad TabControl) ═══ -->
        <ctrl:LoadingOverlay x:Name="loadingOverlay" Grid.Row="1"/>

        <!-- ═══ Pasek statusu ═══ -->
        <Border Grid.Row="2" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="24,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtStatus" Grid.Column="0"
                           Text="Gotowe" Foreground="#475569" FontSize="11"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <Border x:Name="badgeFiltry" Grid.Column="1" Visibility="Collapsed"
                        Background="#7C3AED" CornerRadius="10" Padding="10,3"
                        Margin="0,0,12,0">
                    <TextBlock x:Name="txtBadgeFiltry" Text="" Foreground="White" FontSize="10"
                               FontWeight="SemiBold"/>
                </Border>
                <TextBlock x:Name="txtCzasOdswiezenia" Grid.Column="2"
                           Text="" Foreground="#94A3B8" FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
