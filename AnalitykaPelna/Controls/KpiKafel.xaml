<UserControl x:Class="Kalendarz1.AnalitykaPelna.Controls.KpiKafel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="kpiRoot">
    <Border x:Name="border"
            Background="White"
            BorderBrush="#E2E8F0" BorderThickness="1"
            CornerRadius="10" Padding="14"
            Cursor="Hand"
            MouseLeftButtonUp="Border_MouseLeftButtonUp"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TranslateTransform x:Name="kpiTrans" Y="0"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect x:Name="kpiShadow" Color="#0F172A" BlurRadius="8"
                              ShadowDepth="0" Opacity="0.06"/>
        </Border.Effect>

        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{Binding Kolor, ElementName=kpiRoot}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Border.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="kpiTrans"
                                         Storyboard.TargetProperty="Y"
                                         To="-2" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetName="kpiShadow"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0.18" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetName="kpiShadow"
                                         Storyboard.TargetProperty="BlurRadius"
                                         To="14" Duration="0:0:0.15"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="kpiTrans"
                                         Storyboard.TargetProperty="Y"
                                         To="0" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetName="kpiShadow"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0.06" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetName="kpiShadow"
                                         Storyboard.TargetProperty="BlurRadius"
                                         To="8" Duration="0:0:0.15"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Górny rząd: ikona + tytuł -->
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8"
                        Background="{Binding Kolor, ElementName=kpiRoot}"
                        Margin="0,0,8,0">
                    <TextBlock Text="{Binding Ikona, ElementName=kpiRoot}"
                               FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="White"/>
                </Border>
                <TextBlock Grid.Column="1"
                           Text="{Binding Tytul, ElementName=kpiRoot}"
                           Foreground="#64748B" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Grid>

            <!-- Wartość główna -->
            <TextBlock Grid.Row="1"
                       Text="{Binding Wartosc, ElementName=kpiRoot}"
                       FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>

            <!-- Trend % + jednostka -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Text="{Binding Jednostka, ElementName=kpiRoot}"
                           FontSize="11" Foreground="#94A3B8"
                           Margin="0,0,8,0"/>
                <TextBlock x:Name="txtTrend"
                           Text="{Binding Trend, ElementName=kpiRoot}"
                           FontSize="11" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
