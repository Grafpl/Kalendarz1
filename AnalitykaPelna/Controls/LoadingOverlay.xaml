<UserControl x:Class="Kalendarz1.AnalitykaPelna.Controls.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed"
             IsHitTestVisible="True">
    <Grid Background="#80FFFFFF">
        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="8" Padding="20"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#0F172A" BlurRadius="12" ShadowDepth="0" Opacity="0.15"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="txtIcon" Text="⏳" FontSize="20"
                           VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="iconRotate" CenterX="14" CenterY="14"/>
                    </TextBlock.RenderTransform>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="iconRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:1.5"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                <TextBlock x:Name="txtKomunikat" Text="Ładowanie danych…"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#475569" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
