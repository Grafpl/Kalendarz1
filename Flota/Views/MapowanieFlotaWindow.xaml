<Window x:Class="Kalendarz1.Flota.Views.MapowanieFlotaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mapowanie systemów — TransportPL ↔ Flota (LibraNet)"
        Width="1100" Height="720" MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#f5f5f8">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Mapowanie systemów" FontSize="20" FontWeight="Bold" Foreground="#1a237e"/>
            <TextBlock TextWrapping="Wrap" Foreground="#78909c" FontSize="12" Margin="0,4,0,0">
                Linkuje rekordy z <Run FontWeight="Bold">TransportPL.Pojazd/Kierowca</Run>
                (wpięte w kursy + Webfleet) z <Run FontWeight="Bold">LibraNet.CarTrailer/Driver</Run>
                (Flota — master z dokumentami, badaniami, OC). Jednorazowa procedura — po zmapowaniu
                dane z Floty (przebieg, polisa, badania) będą dostępne wszędzie gdzie używa się Transport.
            </TextBlock>
        </StackPanel>

        <!-- Statystyki -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Background="#e8f5e9" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Pojazdy zmapowane: " Foreground="#388e3c" FontSize="12"/>
                    <TextBlock x:Name="PojazdyMappedCount" Text="0" Foreground="#2e7d32" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text=" / " Foreground="#388e3c" FontSize="12"/>
                    <TextBlock x:Name="PojazdyTotalCount" Text="0" Foreground="#2e7d32" FontWeight="Bold" FontSize="12"/>
                </StackPanel>
            </Border>
            <Border Background="#e8eaf6" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Kierowcy zmapowani: " Foreground="#3949ab" FontSize="12"/>
                    <TextBlock x:Name="KierowcyMappedCount" Text="0" Foreground="#283593" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text=" / " Foreground="#3949ab" FontSize="12"/>
                    <TextBlock x:Name="KierowcyTotalCount" Text="0" Foreground="#283593" FontWeight="Bold" FontSize="12"/>
                </StackPanel>
            </Border>
            <Border Background="#fff3e0" CornerRadius="6" Padding="12,6">
                <TextBlock x:Name="StatusText" Text="Gotowy" Foreground="#e65100" FontSize="12" FontWeight="SemiBold"/>
            </Border>
        </StackPanel>

        <!-- TabControl -->
        <TabControl Grid.Row="2" Background="White" BorderBrush="#e0e0e0" BorderThickness="1">
            <TabItem Header="🚛 Pojazdy">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="🔗 Auto-mapuj po rejestracji" Click="BtnAutoMapPojazdy_Click"
                            HorizontalAlignment="Left" Margin="0,0,0,8" Padding="14,6"
                            Background="#1976d2" Foreground="White" BorderThickness="0" Cursor="Hand"
                            FontSize="12" FontWeight="SemiBold"
                            ToolTip="Łączy automatycznie Transport.Pojazd z Flota.CarTrailer po polu Rejestracja (case-insensitive, ignoruje spacje i myślniki)."/>
                    <DataGrid Grid.Row="1" x:Name="PojazdyGrid" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              RowBackground="White" AlternatingRowBackground="#fafafa"
                              BorderThickness="0" FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding PojazdID}" IsReadOnly="True" Width="60"/>
                            <DataGridTextColumn Header="Rejestracja" Binding="{Binding Rejestracja}" IsReadOnly="True" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="8,4"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Marka + Model" Binding="{Binding MarkaModelDisplay}" IsReadOnly="True" Width="200"/>
                            <DataGridCheckBoxColumn Header="Aktywny" Binding="{Binding Aktywny}" IsReadOnly="True" Width="70"/>
                            <DataGridTemplateColumn Header="Flota (LibraNet.CarTrailer)" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.FlotaPojazdyCombo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedValue="{Binding LibraNetCarTrailerID, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="ID" DisplayMemberPath="Display"
                                                  FontSize="11" Padding="6,3" Margin="2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="👤 Kierowcy">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="🔗 Auto-mapuj po Imię + Nazwisko" Click="BtnAutoMapKierowcy_Click"
                            HorizontalAlignment="Left" Margin="0,0,0,8" Padding="14,6"
                            Background="#7b1fa2" Foreground="White" BorderThickness="0" Cursor="Hand"
                            FontSize="12" FontWeight="SemiBold"
                            ToolTip="Łączy automatycznie Transport.Kierowca z Flota.Driver po FirstName + LastName (case-insensitive). Fallback do split'a Driver.Name."/>
                    <DataGrid Grid.Row="1" x:Name="KierowcyGrid" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              RowBackground="White" AlternatingRowBackground="#fafafa"
                              BorderThickness="0" FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding KierowcaID}" IsReadOnly="True" Width="60"/>
                            <DataGridTextColumn Header="Imię + Nazwisko" Binding="{Binding Display}" IsReadOnly="True" Width="200">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="8,4"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" IsReadOnly="True" Width="120"/>
                            <DataGridCheckBoxColumn Header="Aktywny" Binding="{Binding Aktywny}" IsReadOnly="True" Width="70"/>
                            <DataGridTemplateColumn Header="Flota (LibraNet.Driver)" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.FlotaKierowcyCombo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedValue="{Binding LibraNetDriverGID, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="GID" DisplayMemberPath="Display"
                                                  FontSize="11" Padding="6,3" Margin="2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Zapisz zmiany" Click="BtnSave_Click"
                    Background="#2e7d32" Foreground="White" BorderThickness="0"
                    Padding="24,9" Margin="0,0,8,0" Cursor="Hand" FontSize="13" FontWeight="Bold"/>
            <Button Content="Zamknij" Click="BtnClose_Click"
                    Background="#eceff1" Foreground="#546e7a" BorderBrush="#cfd8dc" BorderThickness="1"
                    Padding="18,9" Cursor="Hand" FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
