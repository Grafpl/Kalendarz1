<UserControl x:Class="Kalendarz1.Flota.Views.WidokFlota"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1400"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Solid action button -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A237E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost button (subtle border) -->
        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}"
                                BorderBrush="#CFD8DC" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#ECEFF1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- KPI card -->
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderBrush" Value="#E0E3EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.08" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search box -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#CFD8DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- Status filter ComboBox -->
        <Style x:Key="StatusCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Foreground" Value="#90A4AE"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>

        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#263238"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <!-- TabItem accent -->
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#546E7A"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#1A237E"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="0,0,0,3"/>
                                <Setter Property="Foreground" Value="#1A237E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#3949AB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F5F7FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="MainTabs" Grid.Row="0" Background="#F5F7FA" BorderThickness="0" Margin="0">

            <!-- ═══════════════ TAB 1: KIEROWCY ═══════════════ -->
            <TabItem Header="👤  KIEROWCY  ">
                <Grid Background="#F5F7FA">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- KPI cards -->
                    <Grid Grid.Row="0" Margin="14,14,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource KpiCard}">
                            <StackPanel>
                                <TextBlock Text="WSZYSCY KIEROWCY" Foreground="#90A4AE" FontSize="10.5" FontWeight="SemiBold"/>
                                <TextBlock x:Name="KpiKierTotal" Text="0" Foreground="#1A237E" FontSize="32" FontWeight="Bold" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource KpiCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="9" Height="9" Fill="#43A047" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="AKTYWNI" Foreground="#90A4AE" FontSize="10.5" FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock x:Name="KpiKierAktywni" Text="0" Foreground="#2E7D32" FontSize="32" FontWeight="Bold" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource KpiCard}" Margin="0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="9" Height="9" Fill="#E65100" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="WSTRZYMANI" Foreground="#90A4AE" FontSize="10.5" FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock x:Name="KpiKierWstrzymani" Text="0" Foreground="#E65100" FontSize="32" FontWeight="Bold" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Toolbar: search + filter + actions -->
                    <Border Grid.Row="1" Background="White" Padding="14,10" BorderBrush="#E0E3EA" BorderThickness="0,1,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="TxtSzukajKierowce" Width="280"
                                         TextChanged="TxtSzukajKierowce_TextChanged">
                                    <TextBox.Resources>
                                        <VisualBrush x:Key="hintKier" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="  🔍  Szukaj po imieniu, nazwisku, telefonie..."
                                                           FontFamily="Segoe UI" FontSize="12.5" Foreground="#B0BEC5"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </TextBox.Resources>
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource SearchBox}">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background" Value="{StaticResource hintKier}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <ComboBox x:Name="CmbStatusKierowcy" Style="{StaticResource StatusCombo}" Margin="10,0,0,0"
                                          SelectionChanged="FilterKierowcy_Changed">
                                    <ComboBoxItem Content="Aktywni" IsSelected="True"/>
                                    <ComboBoxItem Content="Wstrzymani"/>
                                    <ComboBoxItem Content="Wszyscy"/>
                                </ComboBox>
                                <!-- Compat: ukryty stub Typ (uzywany przez code-behind ApplyDriverFilter) -->
                                <ComboBox x:Name="CmbTypKierowcy" Visibility="Collapsed">
                                    <ComboBoxItem Content="Wszyscy" IsSelected="True"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnDodajKierowce" Content="＋ Dodaj kierowcę" Style="{StaticResource ActionBtn}"
                                        Background="#2E7D32" Click="BtnDodajKierowce_Click"/>
                                <Button x:Name="BtnEdytujKierowce" Content="✎ Edytuj" Style="{StaticResource ActionBtn}"
                                        Click="BtnEdytujKierowce_Click"/>
                                <Button x:Name="BtnWstrzymajKierowce" Content="⏸ Wstrzymaj / aktywuj" Style="{StaticResource ActionBtn}"
                                        Background="#EF6C00" Click="BtnWstrzymajKierowce_Click"/>
                                <Button Content="↻" Style="{StaticResource GhostBtn}" ToolTip="Odśwież listę"
                                        Click="BtnOdswiezKierowcy_Click" Padding="14,7"/>
                                <Button x:Name="BtnExcelKierowcy" Content="⬇ Excel" Style="{StaticResource GhostBtn}"
                                        Click="BtnExcelKierowcy_Click" ToolTip="Eksport do Excela"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Content: Grid + Detail Panel -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="35*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" Margin="14,8,4,14" CornerRadius="8"
                                BorderBrush="#E0E3EA" BorderThickness="1">
                            <dxg:GridControl x:Name="GridKierowcy" SelectionMode="Row"
                                             SelectedItemChanged="GridKierowcy_SelectedItemChanged"
                                             MouseDoubleClick="GridKierowcy_MouseDoubleClick"
                                             Background="Transparent">
                                <dxg:GridControl.Columns>
                                    <dxg:GridColumn FieldName="GID" Header="ID" Width="55" ReadOnly="True"/>
                                    <dxg:GridColumn FieldName="Imie" Header="Imię" Width="140" ReadOnly="True"/>
                                    <dxg:GridColumn FieldName="Nazwisko" Header="Nazwisko" Width="180" ReadOnly="True"/>
                                    <dxg:GridColumn FieldName="Telefon" Header="Telefon" Width="140" ReadOnly="True"/>
                                    <dxg:GridColumn FieldName="Aktywny" Header="Status" Width="90" ReadOnly="True"/>
                                </dxg:GridControl.Columns>
                                <dxg:GridControl.View>
                                    <dxg:TableView AutoWidth="True"
                                                   AllowEditing="False"
                                                   ShowGroupPanel="False"
                                                   NavigationStyle="Row"
                                                   ShowIndicator="False"
                                                   RowMinHeight="32"
                                                   x:Name="ViewKierowcy"/>
                                </dxg:GridControl.View>
                            </dxg:GridControl>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                                      HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

                        <!-- Detail Panel -->
                        <Border Grid.Column="2" Background="White" Margin="4,8,14,14" CornerRadius="8"
                                BorderBrush="#E0E3EA" BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,16">
                                <StackPanel x:Name="PanelSzczegolyKierowcy">
                                    <!-- Hero header: name + status pill -->
                                    <TextBlock Text="SZCZEGÓŁY KIEROWCY" Foreground="#90A4AE" FontSize="9.5" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="TxtKierowcaNazwa" FontSize="22" FontWeight="Bold"
                                               Foreground="#1A237E" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                                    <Border x:Name="KierStatusPill" Background="#C8E6C9" CornerRadius="11" Padding="10,3"
                                            HorizontalAlignment="Left" Margin="0,8,0,0">
                                        <TextBlock x:Name="TxtKierowcaTyp" Text="Aktywny" Foreground="#2E7D32" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>

                                    <Border Height="1" Background="#E0E3EA" Margin="0,16,0,8"/>

                                    <TextBlock Text="TELEFON" Style="{StaticResource DetailLabel}"/>
                                    <TextBlock x:Name="TxtKierowcaTelefon" Style="{StaticResource DetailValue}"/>

                                    <TextBlock Text="ID W BAZIE" Style="{StaticResource DetailLabel}"/>
                                    <TextBlock x:Name="TxtKierowcaOd" Style="{StaticResource DetailValue}"/>

                                    <TextBlock Text="DODANY" Style="{StaticResource DetailLabel}"/>
                                    <TextBlock x:Name="TxtKierowcaPJ" Style="{StaticResource DetailValue}"/>

                                    <TextBlock Text="OSTATNIA ZMIANA" Style="{StaticResource DetailLabel}"/>
                                    <TextBlock x:Name="TxtKierowcaBadania" Style="{StaticResource DetailValue}"/>

                                    <!-- Compat: ukryte TextBlocks dla legacy code-behind -->
                                    <TextBlock x:Name="TxtKierowcaBHP" Visibility="Collapsed"/>
                                    <TextBlock x:Name="TxtKierowcaPojazdy" Visibility="Collapsed"/>
                                    <TextBlock x:Name="TxtKierowcaStats" Visibility="Collapsed"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- Status bar -->
                    <Border Grid.Row="3" Background="White" Padding="14,6" BorderBrush="#E0E3EA" BorderThickness="0,1,0,0">
                        <TextBlock x:Name="TxtStatusKierowcy" VerticalAlignment="Center"
                                   FontFamily="Segoe UI" FontSize="11" Foreground="#546E7A"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════ TAB 2: POJAZDY ═══════════════ -->
            <TabItem Header="🚚  POJAZDY  ">
                <Grid Background="#F5F7FA">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- KPI cards -->
                    <Grid Grid.Row="0" Margin="14,14,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource KpiCard}">
                            <StackPanel>
                                <TextBlock Text="WSZYSTKIE POJAZDY" Foreground="#90A4AE" FontSize="10.5" FontWeight="SemiBold"/>
                                <TextBlock x:Name="KpiPojTotal" Text="0" Foreground="#1A237E" FontSize="32" FontWeight="Bold" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource KpiCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="9" Height="9" Fill="#43A047" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="AKTYWNE" Foreground="#90A4AE" FontSize="10.5" FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock x:Name="KpiPojAktywne" Text="0" Foreground="#2E7D32" FontSize="32" FontWeight="Bold" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource KpiCard}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="SUMA PALET (H1)" Foreground="#90A4AE" FontSize="10.5" FontWeight="SemiBold"/>
                                <TextBlock x:Name="KpiPojPalety" Text="0" Foreground="#1565C0" FontSize="32" FontWeight="Bold" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Toolbar -->
                    <Border Grid.Row="1" Background="White" Padding="14,10" BorderBrush="#E0E3EA" BorderThickness="0,1,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="TxtSzukajPojazdy" Width="280"
                                         TextChanged="TxtSzukajPojazdy_TextChanged">
                                    <TextBox.Resources>
                                        <VisualBrush x:Key="hintPoj" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="  🔍  Szukaj po rejestracji, marce, modelu..."
                                                           FontFamily="Segoe UI" FontSize="12.5" Foreground="#B0BEC5"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </TextBox.Resources>
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource SearchBox}">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background" Value="{StaticResource hintPoj}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <!-- Compat: ukryty stub Typ (uzywany przez code-behind ApplyVehicleFilter) -->
                                <ComboBox x:Name="CmbTypPojazdu" Visibility="Collapsed">
                                    <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnDodajPojazd" Content="＋ Dodaj pojazd" Style="{StaticResource ActionBtn}"
                                        Background="#2E7D32" Click="BtnDodajPojazd_Click"/>
                                <Button x:Name="BtnEdytujPojazd" Content="✎ Edytuj" Style="{StaticResource ActionBtn}"
                                        Click="BtnEdytujPojazd_Click"/>
                                <!-- Compat: BtnSerwis i BtnTankowanie ukryte (LibraNet legacy) -->
                                <Button x:Name="BtnSerwis" Visibility="Collapsed" Click="BtnSerwis_Click"/>
                                <Button x:Name="BtnTankowanie" Visibility="Collapsed" Click="BtnTankowanie_Click"/>
                                <Button Content="↻" Style="{StaticResource GhostBtn}" ToolTip="Odśwież listę"
                                        Click="BtnOdswiezPojazdy_Click" Padding="14,7"/>
                                <Button Content="⬇ Excel" Style="{StaticResource GhostBtn}"
                                        Click="BtnExcelPojazdy_Click" ToolTip="Eksport do Excela"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="35*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" Margin="14,8,4,14" CornerRadius="8"
                                BorderBrush="#E0E3EA" BorderThickness="1">
                            <dxg:GridControl x:Name="GridPojazdy" SelectionMode="Row"
                                             SelectedItemChanged="GridPojazdy_SelectedItemChanged"
                                             MouseDoubleClick="GridPojazdy_MouseDoubleClick"
                                             Background="Transparent">
                                <dxg:GridControl.Columns>
                                    <dxg:GridColumn FieldName="ID" Header="ID" Width="55" ReadOnly="True"/>
                                    <dxg:GridColumn FieldName="Registration" Header="Rejestracja" Width="140" ReadOnly="True"/>
                                    <dxg:GridColumn FieldName="Brand" Header="Marka" Width="130" ReadOnly="True"/>
                                    <dxg:GridColumn FieldName="Model" Header="Model" Width="170" ReadOnly="True"/>
                                    <dxg:GridColumn FieldName="MaxPaletH1" Header="Palety H1" Width="100" ReadOnly="True"/>
                                    <dxg:GridColumn FieldName="Aktywny" Header="Status" Width="90" ReadOnly="True"/>
                                </dxg:GridControl.Columns>
                                <dxg:GridControl.View>
                                    <dxg:TableView AutoWidth="True"
                                                   AllowEditing="False"
                                                   ShowGroupPanel="False"
                                                   NavigationStyle="Row"
                                                   ShowIndicator="False"
                                                   RowMinHeight="32"
                                                   x:Name="ViewPojazdy"/>
                                </dxg:GridControl.View>
                            </dxg:GridControl>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                                      HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

                        <Border Grid.Column="2" Background="White" Margin="4,8,14,14" CornerRadius="8"
                                BorderBrush="#E0E3EA" BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,16">
                                <StackPanel x:Name="PanelSzczegolyPojazdu">
                                    <TextBlock Text="SZCZEGÓŁY POJAZDU" Foreground="#90A4AE" FontSize="9.5" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="TxtPojazdNazwa" FontSize="22" FontWeight="Bold"
                                               Foreground="#1A237E" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="TxtPojazdRejestracja" FontSize="14" Foreground="#37474F" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                    <Border x:Name="PojStatusPill" Background="#C8E6C9" CornerRadius="11" Padding="10,3"
                                            HorizontalAlignment="Left" Margin="0,8,0,0">
                                        <TextBlock x:Name="TxtPojazdTyp" Text="Aktywny" Foreground="#2E7D32" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>

                                    <Border Height="1" Background="#E0E3EA" Margin="0,16,0,8"/>

                                    <TextBlock Text="PALETY H1" Style="{StaticResource DetailLabel}"/>
                                    <TextBlock x:Name="TxtPojazdVIN" Style="{StaticResource DetailValue}"/>

                                    <TextBlock Text="ID W BAZIE" Style="{StaticResource DetailLabel}"/>
                                    <TextBlock x:Name="TxtPojazdPrzeglad" Style="{StaticResource DetailValue}"/>

                                    <TextBlock Text="DODANY" Style="{StaticResource DetailLabel}"/>
                                    <TextBlock x:Name="TxtPojazdOC" Style="{StaticResource DetailValue}"/>

                                    <TextBlock Text="OSTATNIA ZMIANA" Style="{StaticResource DetailLabel}"/>
                                    <TextBlock x:Name="TxtPojazdKierowca" Style="{StaticResource DetailValue}"/>

                                    <!-- Compat: ukryte TextBlocks dla legacy code-behind -->
                                    <TextBlock x:Name="TxtPojazdSerwis" Visibility="Collapsed"/>
                                    <TextBlock x:Name="TxtPojazdKoszty" Visibility="Collapsed"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3" Background="White" Padding="14,6" BorderBrush="#E0E3EA" BorderThickness="0,1,0,0">
                        <TextBlock x:Name="TxtStatusPojazdy" VerticalAlignment="Center"
                                   FontFamily="Segoe UI" FontSize="11" Foreground="#546E7A"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab Przypisania — ukryty (LibraNet legacy) -->
            <TabItem Header="  PRZYPISANIA  " Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Height="50">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="DEBUG" Click="BtnDebug_Click"/>
                            <Button Content="Odswiez" Click="BtnOdswiezPrzypisania_Click"/>
                            <Button x:Name="BtnPrzypiszKierowce" Content="Przypisz" Click="BtnPrzypiszKierowce_Click"/>
                            <ComboBox x:Name="CmbHistoriaPrzyp">
                                <ComboBoxItem Content="Aktualne" IsSelected="True"/>
                                <ComboBoxItem Content="Historia"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                    <dxg:GridControl x:Name="GridPrzypisania" Grid.Row="1" MouseDoubleClick="GridPrzypisania_MouseDoubleClick"/>
                    <TextBlock x:Name="TxtStatusPrzypisania" Grid.Row="2"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Alerts panel — ukryty (LibraNet legacy) -->
        <Border x:Name="PanelAlerty" Grid.Row="1" Visibility="Collapsed">
            <ItemsControl x:Name="ItemsAlerty"/>
        </Border>
    </Grid>
</UserControl>
