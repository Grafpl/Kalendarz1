<Window x:Class="Kalendarz1.Flota.Windows.DriverEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        Title="Kierowca" Width="720" Height="680"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        FontFamily="Segoe UI" FontSize="12" Background="#F0F3F7"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#5D6D7E"/>
            <Setter Property="Margin" Value="0,6,8,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,2,0,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,4,0,8"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="TabsDriver" Grid.Row="0" Margin="8">

            <!-- ═══ TAB: Dane osobowe ═══ -->
            <TabItem Header="  Dane osobowe  ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Imie *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtImie" Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldInput}" Margin="0,2,8,4"/>

                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Telefon 1" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtTelefon1" Grid.Row="1" Grid.Column="1" Style="{StaticResource FieldInput}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Nazwisko *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtNazwisko" Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldInput}" Margin="0,2,8,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Telefon 2" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtTelefon2" Grid.Row="3" Grid.Column="1" Style="{StaticResource FieldInput}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Email" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtEmail" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource FieldInput}"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="PESEL" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtPESEL" Grid.Row="7" Grid.Column="0" Style="{StaticResource FieldInput}" MaxLength="11" Margin="0,2,8,4"/>

                        <TextBlock Grid.Row="6" Grid.Column="1" Text="Typ zatrudnienia" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbTypZatrudnienia" Grid.Row="7" Grid.Column="1" Height="28" Margin="0,2,0,4"
                                  VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Etat" IsSelected="True"/>
                            <ComboBoxItem Content="Zlecenie"/>
                            <ComboBoxItem Content="B2B"/>
                            <ComboBoxItem Content="Agencja"/>
                        </ComboBox>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Data zatrudnienia" Style="{StaticResource FieldLabel}"/>
                        <DatePicker x:Name="DpDataZatrudnienia" Grid.Row="9" Grid.Column="0" Height="28" Margin="0,2,8,4"/>

                        <TextBlock Grid.Row="8" Grid.Column="1" Text="Data zwolnienia" Style="{StaticResource FieldLabel}"/>
                        <DatePicker x:Name="DpDataZwolnienia" Grid.Row="9" Grid.Column="1" Height="28" Margin="0,2,0,4"/>

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Uwagi" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtUwagi" Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2"
                                 Height="60" Margin="0,22,0,4" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ TAB: Dokumenty ═══ -->
            <TabItem Header="  Dokumenty  ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <!-- Prawo jazdy -->
                        <Border Style="{StaticResource SectionBorder}">
                            <StackPanel>
                                <TextBlock Text="Prawo jazdy" FontWeight="Bold" FontSize="13" Foreground="#1E3A5F" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Numer PJ" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="TxtNrPJ" Grid.Row="1" Style="{StaticResource FieldInput}" Margin="0,2,8,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Kategorie (np. B,C,C+E)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="TxtKategoriePJ" Grid.Row="1" Grid.Column="1" Style="{StaticResource FieldInput}"/>
                                    <TextBlock Grid.Row="2" Text="Wazne do" Style="{StaticResource FieldLabel}"/>
                                    <DatePicker x:Name="DpDataPJ" Grid.Row="3" Height="28" Margin="0,2,8,4"/>
                                    <TextBlock x:Name="TxtPJStatus" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center"
                                               FontWeight="SemiBold" FontSize="12"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Badania lekarskie -->
                        <Border Style="{StaticResource SectionBorder}">
                            <StackPanel>
                                <TextBlock Text="Badania lekarskie" FontWeight="Bold" FontSize="13" Foreground="#1E3A5F" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Numer" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="TxtNrBadan" Grid.Row="1" Style="{StaticResource FieldInput}" Margin="0,2,8,4"/>
                                    <TextBlock Grid.Row="2" Text="Wazne do" Style="{StaticResource FieldLabel}"/>
                                    <DatePicker x:Name="DpDataBadan" Grid.Row="3" Height="28" Margin="0,2,8,4"/>
                                    <TextBlock x:Name="TxtBadaniaStatus" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center"
                                               FontWeight="SemiBold" FontSize="12"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- BHP -->
                        <Border Style="{StaticResource SectionBorder}">
                            <StackPanel>
                                <TextBlock Text="Szkolenie BHP" FontWeight="Bold" FontSize="13" Foreground="#1E3A5F" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Numer" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="TxtNrBHP" Grid.Row="1" Style="{StaticResource FieldInput}" Margin="0,2,8,4"/>
                                    <TextBlock Grid.Row="2" Text="Wazne do" Style="{StaticResource FieldLabel}"/>
                                    <DatePicker x:Name="DpDataBHP" Grid.Row="3" Height="28" Margin="0,2,8,4"/>
                                    <TextBlock x:Name="TxtBHPStatus" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center"
                                               FontWeight="SemiBold" FontSize="12"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ TAB: Pojazdy i historia ═══ -->
            <TabItem Header="  Pojazdy i historia  ">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Aktualnie przypisane pojazdy:" FontWeight="Bold" FontSize="13"
                               Foreground="#1E3A5F" Margin="0,4,0,6"/>

                    <dxg:GridControl x:Name="GridAktualnePojazdy" Grid.Row="1" MaxHeight="150">
                        <dxg:GridControl.Columns>
                            <dxg:GridColumn FieldName="CarTrailerID" Header="Symbol" Width="60" ReadOnly="True"/>
                            <dxg:GridColumn FieldName="Registration" Header="Rejestracja" Width="100" ReadOnly="True"/>
                            <dxg:GridColumn FieldName="PojazdMarka" Header="Pojazd" Width="150" ReadOnly="True"/>
                            <dxg:GridColumn FieldName="Rola" Header="Rola" Width="80" ReadOnly="True"/>
                            <dxg:GridColumn FieldName="DataOd" Header="Od" Width="100" ReadOnly="True"/>
                        </dxg:GridControl.Columns>
                        <dxg:GridControl.View>
                            <dxg:TableView AutoWidth="True" AllowEditing="False" ShowGroupPanel="False"/>
                        </dxg:GridControl.View>
                    </dxg:GridControl>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6">
                        <Button x:Name="BtnPrzypiszPojazd" Content="Przypisz nowy pojazd"
                                Padding="12,4" Background="#1E3A5F" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="BtnPrzypiszPojazd_Click"/>
                        <Button x:Name="BtnZakonczPrzypisanie" Content="Zakoncz przypisanie"
                                Padding="12,4" Background="#E74C3C" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Margin="8,0,0,0" Click="BtnZakonczPrzypisanie_Click"/>
                    </StackPanel>

                    <TextBlock Grid.Row="3" Text="Historia przypisan:" FontWeight="Bold" FontSize="13"
                               Foreground="#1E3A5F" Margin="0,4,0,0" VerticalAlignment="Top"/>
                    <dxg:GridControl x:Name="GridHistoriaPojazdy" Grid.Row="3" Margin="0,24,0,0">
                        <dxg:GridControl.Columns>
                            <dxg:GridColumn FieldName="CarTrailerID" Header="Symbol" Width="60" ReadOnly="True"/>
                            <dxg:GridColumn FieldName="PojazdMarka" Header="Pojazd" Width="150" ReadOnly="True"/>
                            <dxg:GridColumn FieldName="Rola" Header="Rola" Width="80" ReadOnly="True"/>
                            <dxg:GridColumn FieldName="DataOd" Header="Od" Width="100" ReadOnly="True"/>
                            <dxg:GridColumn FieldName="DataDo" Header="Do" Width="100" ReadOnly="True"/>
                            <dxg:GridColumn FieldName="Dni" Header="Dni" Width="60" ReadOnly="True"/>
                        </dxg:GridControl.Columns>
                        <dxg:GridControl.View>
                            <dxg:TableView AutoWidth="True" AllowEditing="False" ShowGroupPanel="False"/>
                        </dxg:GridControl.View>
                    </dxg:GridControl>
                </Grid>
            </TabItem>

            <!-- ═══ TAB: Statystyki ═══ -->
            <TabItem Header="  Statystyki  ">
                <StackPanel Margin="16">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Od:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker x:Name="DpStatsOd" Height="28" Width="140"/>
                        <TextBlock Text="Do:" VerticalAlignment="Center" Margin="16,0,6,0"/>
                        <DatePicker x:Name="DpStatsDo" Height="28" Width="140"/>
                        <Button Content="Pokaz" Padding="12,4" Margin="12,0,0,0"
                                Background="#1E3A5F" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="BtnPokazStats_Click"/>
                    </StackPanel>

                    <Border Background="White" CornerRadius="6" Padding="16" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Kursy skupowe (z FarmerCalc):" FontWeight="Bold" FontSize="13"
                                       Foreground="#1E3A5F" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtStatKursySkup" FontSize="14" Margin="0,0,0,16"/>

                            <TextBlock Text="Podsumowanie:" FontWeight="Bold" FontSize="13"
                                       Foreground="#1E3A5F" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtStatPodsumowanie" FontSize="14" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Bottom buttons -->
        <Border Grid.Row="1" Background="#ECF0F1" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <CheckBox x:Name="ChkHalt" Content="Wstrzymany (Halt)" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <Button x:Name="BtnZapisz" Content="ZAPISZ" Width="120" Height="36"
                        Background="#27AE60" Foreground="White" FontWeight="Bold" FontSize="14"
                        BorderThickness="0" Cursor="Hand" Click="BtnZapisz_Click"/>
                <Button Content="ANULUJ" Width="100" Height="36" Margin="8,0,0,0"
                        Background="#95A5A6" Foreground="White" FontWeight="Bold" FontSize="14"
                        BorderThickness="0" Cursor="Hand" Click="BtnAnuluj_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
