<Window x:Class="Kalendarz1.Flota.Windows.AssignDriverDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Przypisz kierowce do pojazdu" Width="500" Height="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="12" Background="#F0F3F7"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#5D6D7E"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Kierowca *" Style="{StaticResource FieldLabel}"/>
        <ComboBox x:Name="CmbKierowca" Grid.Row="1" Height="28"
                  VerticalContentAlignment="Center" DisplayMemberPath="Name" SelectedValuePath="GID"
                  SelectionChanged="CmbKierowca_SelectionChanged"/>

        <TextBlock Grid.Row="2" Text="Pojazd *" Style="{StaticResource FieldLabel}"/>
        <ComboBox x:Name="CmbPojazd" Grid.Row="3" Height="28"
                  VerticalContentAlignment="Center" DisplayMemberPath="Display" SelectedValuePath="ID"/>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Rola" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="CmbRola" Grid.Row="1" Height="28" Margin="0,0,8,0"
                      VerticalContentAlignment="Center">
                <ComboBoxItem Content="Glowny" IsSelected="True"/>
                <ComboBoxItem Content="Zastepczy"/>
                <ComboBoxItem Content="Tymczasowy"/>
            </ComboBox>
            <TextBlock Grid.Column="1" Text="Od daty *" Style="{StaticResource FieldLabel}"/>
            <DatePicker x:Name="DpDataOd" Grid.Row="1" Grid.Column="1" Height="28"/>
        </Grid>

        <TextBlock Grid.Row="5" Text="Powod" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="TxtPowod" Grid.Row="6" Height="28" Padding="6,2" VerticalContentAlignment="Center"/>

        <!-- Warning about existing assignment -->
        <Border x:Name="PanelWarning" Grid.Row="7" Background="#FFF9C4" CornerRadius="4"
                Padding="10,8" Margin="0,8,0,0" Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="TxtWarning" TextWrapping="Wrap" FontSize="11" Foreground="#E65100"/>
                <CheckBox x:Name="ChkCloseExisting" Content="Tak, zamknij poprzednie przypisania"
                          Margin="0,6,0,0" IsChecked="True"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnPrzypisz" Content="PRZYPISZ" Width="120" Height="36"
                    Background="#1E3A5F" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="BtnPrzypisz_Click"/>
            <Button Content="ANULUJ" Width="100" Height="36" Margin="8,0,0,0"
                    Background="#95A5A6" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="BtnAnuluj_Click"/>
        </StackPanel>
    </Grid>
</Window>
