<Window x:Class="Kalendarz1.Admin.LimitProdukcyjnyEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edycja grupy limitu"
        Width="880" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="#F7F8FA"
        FontFamily="Segoe UI" FontSize="13"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#4F46E5"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#3730A3"/>
        <SolidColorBrush x:Key="Border" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>

        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White" CornerRadius="8" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryDark}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="HelpLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Slider polished -->
        <Style x:Key="ProcentSlider" TargetType="Slider">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource Primary}"/>
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="8" Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="8" Background="{StaticResource Primary}" CornerRadius="4,0,0,4"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid Width="24" Height="24">
                                                    <Ellipse Fill="White" Stroke="{StaticResource Primary}" StrokeThickness="3">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#4F46E5" Opacity="0.4" BlurRadius="8" ShadowDepth="0"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,16"/>
        </Style>

        <!-- Radio jako klikalna karta — wybrana ma indigo border + tło -->
        <Style x:Key="CardRadio" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="White" CornerRadius="10" BorderBrush="{StaticResource Border}" BorderThickness="1.5" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Width="20" Height="20" VerticalAlignment="Top" Margin="0,2,12,0">
                                    <Ellipse x:Name="outer" Stroke="#94A3B8" StrokeThickness="2" Fill="White"/>
                                    <Ellipse x:Name="inner" Width="10" Height="10" Fill="{StaticResource Primary}" Opacity="0"/>
                                </Grid>
                                <ContentPresenter Grid.Column="1"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                <Setter TargetName="outer" Property="Stroke" Value="{StaticResource Primary}"/>
                                <Setter TargetName="inner" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="24,16" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <TextBlock x:Name="DlgHeader" Text="➕ Nowa grupa limitu" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20,24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Form -->
                <StackPanel Grid.Column="0">
                    <!-- Quick presets — one-click wypełnia formę -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="⚡ Szybki wybór" Style="{StaticResource Label}" FontSize="14"/>
                            <TextBlock Style="{StaticResource HelpLabel}" Text="Kliknij gotowy szablon — wypełni formularz za ciebie."/>
                            <WrapPanel>
                                <Button Tag="Kurczak A|🍗|KURCZAK A|H|92"  Click="BtnPreset_Click" Content="🍗 Kurczak A"  Style="{StaticResource GhostButton}" Margin="0,4,6,0"/>
                                <Button Tag="Filet A|🍖|FILET A|K|92"      Click="BtnPreset_Click" Content="🍖 Filet A"   Style="{StaticResource GhostButton}" Margin="0,4,6,0"/>
                                <Button Tag="Ćwiartka|🍗|ĆWIARTKA|K|92"     Click="BtnPreset_Click" Content="🍗 Ćwiartka"  Style="{StaticResource GhostButton}" Margin="0,4,6,0"/>
                                <Button Tag="Skrzydło|🐔|SKRZYDŁO|K|92"     Click="BtnPreset_Click" Content="🐔 Skrzydło"  Style="{StaticResource GhostButton}" Margin="0,4,6,0"/>
                                <Button Tag="Nóżka|🍗|NÓŻKA|K|92"           Click="BtnPreset_Click" Content="🍗 Nóżka"     Style="{StaticResource GhostButton}" Margin="0,4,6,0"/>
                                <Button Tag="Korpus|🦴|KORPUS|K|92"          Click="BtnPreset_Click" Content="🦴 Korpus"    Style="{StaticResource GhostButton}" Margin="0,4,6,0"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Ikona" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="TxtIkona" Text="🍗" FontSize="22" HorizontalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Nazwa" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="TxtNazwa" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Szukaj towaru" Style="{StaticResource Label}" Margin="0,12,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="CmbWzorzec" IsEditable="True" StaysOpenOnEdit="True"
                                          FontFamily="Consolas" MinHeight="36"
                                          IsTextSearchEnabled="False"
                                          SelectionChanged="CmbWzorzec_SelectionChanged"
                                          Loaded="CmbWzorzec_Loaded">
                                    <ComboBox.Resources>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Padding" Value="8,6"/>
                                            <Setter Property="Margin" Value="4,2"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ComboBoxItem">
                                                        <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                                                            </Trigger>
                                                            <Trigger Property="IsHighlighted" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#E0E7FF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ComboBox.Resources>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ToolTip="{Binding Nazwa}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="30" Height="30" CornerRadius="4" ClipToBounds="True" Background="#F1F5F9" VerticalAlignment="Center">
                                                    <Grid>
                                                        <Image Source="{Binding Image}" Stretch="UniformToFill" Visibility="{Binding HasImageVisibility}"/>
                                                        <TextBlock Text="🍗" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding PlaceholderVisibility}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Nazwa}" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock FontSize="10" Foreground="#64748B" FontFamily="Consolas">
                                                        <Run Text="{Binding Kod}"/><Run Text=" · #"/><Run Text="{Binding Id}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Grid.Column="2" Click="BtnPickTowar_Click" Cursor="Hand" MinHeight="36" Padding="14,0" Background="#F1F5F9" BorderThickness="1" BorderBrush="{StaticResource Border}" ToolTip="Otwórz wybierak towaru z bazy">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="📋 Z bazy" FontSize="12" FontWeight="SemiBold"/>
                                </Button>
                            </Grid>
                            <TextBlock Style="{StaticResource HelpLabel}" Text="Wpisz fragment nazwy lub wybierz z listy."/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="📊 Jak liczyć ile mamy do dyspozycji" Style="{StaticResource Label}" FontSize="14"/>

                            <RadioButton x:Name="RbKonfiguracja" GroupName="Sposob" Style="{StaticResource CardRadio}" Checked="Sposob_Checked">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="✅ Z Podsumowania dnia (zalecane)"/>
                                    <TextBlock Style="{StaticResource HelpLabel}" Margin="0,2,0,0" Text="Plan i stan dokładnie takie jak w panelu 'Podsumowanie dnia' (KonfiguracjaProduktow). Najprostsze i najpewniejsze."/>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="RbHarmonogram" GroupName="Sposob" Style="{StaticResource CardRadio}" Checked="Sposob_Checked">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="🐔 Tak jak Kurczak A"/>
                                    <TextBlock Style="{StaticResource HelpLabel}" Margin="0,2,0,0" Text="Plan z HarmonogramDostaw × WspTuszki × %TuszkaA. Wybierz dla głównej grupy Kurczaka A."/>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="RbProcent" GroupName="Sposob" Style="{StaticResource CardRadio}" Checked="Sposob_Checked">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="📐 Procent z Kurczaka A"/>
                                    <TextBlock Style="{StaticResource HelpLabel}" Margin="0,2,0,4" Text="Np. Filet to ~35% tuszki, Ćwiartka ~22%."/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBox x:Name="TxtProcentZKurczakaA" Width="80" Text="35"/>
                                        <TextBlock Text="%" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="RbStaly" GroupName="Sposob" Style="{StaticResource CardRadio}" Checked="Sposob_Checked">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="💰 Stała ilość kg / dzień"/>
                                    <TextBlock Style="{StaticResource HelpLabel}" Margin="0,2,0,4" Text="Sztywna wartość niezależna od planu."/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBox x:Name="TxtPlanStaly" Width="140" Text="500"/>
                                        <TextBlock Text="kg/dzień" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="🎯 Limit (% z planu + stanu)" Style="{StaticResource Label}" FontSize="14"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="SliderLimit" Style="{StaticResource ProcentSlider}" Minimum="0" Maximum="100" Value="92"
                                        ValueChanged="SliderLimit_ValueChanged"/>
                                <Border Grid.Column="1" Background="#FEF3C7" CornerRadius="6" Padding="0,6" Margin="12,0,0,0">
                                    <TextBlock x:Name="LblLimitValue" Text="92%" FontSize="20" FontWeight="Bold" Foreground="#92400E" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <!-- Live preview: ile to kg dla dziś -->
                            <Border x:Name="LivePreviewBox" Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,10,0,0" Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock>
                                        <Run Text="💡 Dziś to limit:" Foreground="#15803D" FontSize="12"/>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" x:Name="LblLivePreviewKg" Text="—" FontWeight="Bold" FontSize="16" Foreground="#15803D"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="🟢 Aktywny" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Style="{StaticResource HelpLabel}" Text="Wyłączone grupy nie blokują zamówień."/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" x:Name="ChkAktywny" IsChecked="True" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- RIGHT: Live preview -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="🔍 Live preview" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock Style="{StaticResource HelpLabel}" Text="Towary z bazy pasujące do wzorca (max 50)."/>
                            <ScrollViewer MaxHeight="480" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="PreviewArticles">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="52"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="44" Height="44" CornerRadius="6" ClipToBounds="True" Background="#F1F5F9" VerticalAlignment="Center">
                                                        <Grid>
                                                            <Image Source="{Binding Image}" Stretch="UniformToFill" Visibility="{Binding HasImageVisibility}"/>
                                                            <TextBlock Text="🍗" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding PlaceholderVisibility}"/>
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Nazwa}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">
                                                            <Run Text="{Binding Kod}" FontFamily="Consolas"/>
                                                            <Run Text=" · #"/>
                                                            <Run Text="{Binding Id}" FontFamily="Consolas"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock x:Name="PreviewCount" Text="" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" Padding="24,12" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LblValidation" Foreground="#DC2626" FontSize="12" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource GhostButton}" Content="Anuluj" Click="BtnCancel_Click" Margin="0,0,8,0" MinWidth="100"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="✓ Zapisz" Click="BtnSave_Click" MinWidth="140"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
