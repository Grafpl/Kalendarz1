<Window x:Class="Kalendarz1.Admin.AccountManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zarządzanie kontem"
        Width="560" Height="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F1F4F8"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <!-- ═══ Paleta — spójna z AdminPermissionsWindow ═══ -->
        <SolidColorBrush x:Key="TextDarkBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextGrayBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="BorderLightBrush" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="BorderUltralightBrush" Color="#F3F4F6"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="White"/>
        <SolidColorBrush x:Key="SubtleBgBrush" Color="#F9FAFB"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#6B7280"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#EF4444"/>
        </Style>
        <Style x:Key="BtnWarning" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#F59E0B"/>
        </Style>
        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#6B7280"/>
        </Style>

        <Style x:Key="StatusRow" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="LblKey" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextGrayBrush}"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="LblVal" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#37434F"/>
                    <GradientStop Offset="1" Color="#232F3B"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔒" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Zarządzanie kontem" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="UserHeaderText" FontSize="12" Foreground="#B0BEC5" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,14">
            <StackPanel>
                <!-- Status konta -->
                <TextBlock Text="STATUS KONTA" Style="{StaticResource SectionHeader}"/>

                <Border Style="{StaticResource StatusRow}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔑 Hasło:" Style="{StaticResource LblKey}"/>
                        <TextBlock x:Name="PwdStatusText" Style="{StaticResource LblVal}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatusRow}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🕐 Ostatnie logowanie:" Style="{StaticResource LblKey}"/>
                        <TextBlock x:Name="LastLoginText" Style="{StaticResource LblVal}" Text="(brak)"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatusRow}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ Nieudane próby:" Style="{StaticResource LblKey}"/>
                        <TextBlock x:Name="FailedText" Style="{StaticResource LblVal}" Text="0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatusRow}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔒 Blokada do:" Style="{StaticResource LblKey}"/>
                        <TextBlock x:Name="LockedText" Style="{StaticResource LblVal}" Text="(odblokowane)"/>
                    </StackPanel>
                </Border>

                <!-- Uprawnienia -->
                <TextBlock Text="UPRAWNIENIA SPECJALNE" Style="{StaticResource SectionHeader}" Margin="0,16,0,6"/>

                <Border Style="{StaticResource StatusRow}">
                    <CheckBox x:Name="IsAdminCheck"
                              FontSize="12.5"
                              FontWeight="SemiBold"
                              Content="👑 Administrator (pełny dostęp do wszystkich modułów)"/>
                </Border>

                <!-- Status błędu / info -->
                <TextBlock x:Name="StatusText"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           FontSize="12"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="🔓 Odblokuj" Style="{StaticResource BtnWarning}" Click="Unlock_Click"/>
                    <Button Content="🔄 Resetuj hasło" Style="{StaticResource BtnDanger}" Click="ResetPwd_Click"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Zamknij" Style="{StaticResource BtnSecondary}" Click="Close_Click" MinWidth="100"/>
                    <Button Content="💾 Zapisz" Style="{StaticResource BtnSuccess}" Click="Save_Click" MinWidth="120"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
