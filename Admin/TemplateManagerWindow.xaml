<Window x:Class="Kalendarz1.Admin.TemplateManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Szablony uprawnień (stanowiska)"
        Width="1280" Height="780" MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="#F1F4F8"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <SolidColorBrush x:Key="TextDarkBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextGrayBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="BorderLightBrush" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="BorderUltralightBrush" Color="#F3F4F6"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="White"/>
        <SolidColorBrush x:Key="SubtleBgBrush" Color="#F9FAFB"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
        <SolidColorBrush x:Key="InfoBrush" Color="#3B82F6"/>
        <SolidColorBrush x:Key="SelectedRowBrush" Color="#DBEAFE"/>
        <SolidColorBrush x:Key="SelectedBorderBrush" Color="#3B82F6"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#6B7280"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="14,6"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        </Style>

        <Style x:Key="InfoButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource InfoBrush}"/>
        </Style>

        <Style x:Key="TemplateCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderUltralightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F9FAFB"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectedRowBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SelectedBorderBrush}"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextGrayBrush}"/>
            <Setter Property="Margin" Value="0,8,0,3"/>
        </Style>

        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="46"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#37434F"/>
                    <GradientStop Offset="1" Color="#232F3B"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📋" FontSize="18" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Szablony uprawnień" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" · komponowalne stanowiska" FontSize="12" Foreground="#B0BEC5" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main 2-col -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEWA: Lista szablonów -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="12,12,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Twoje szablony" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="{StaticResource SubtleBgBrush}" CornerRadius="10" Padding="8,2">
                            <TextBlock x:Name="LblTemplatesCount" Text="0" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextGrayBrush}"/>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,0,12,12">
                            <ItemsControl x:Name="TemplatesList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource TemplateCardBorder}" Tag="{Binding}"
                                            MouseLeftButtonDown="TemplateCard_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="6" Background="{Binding ColorBrush}">
                                                <TextBlock Text="{Binding Icon}" FontFamily="Segoe UI Emoji" FontSize="16"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                           Foreground="{StaticResource TextDarkBrush}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock FontSize="10" Foreground="{StaticResource TextGrayBrush}" Margin="0,2,0,0">
                                                    <Run Text="{Binding ModuleCount, Mode=OneWay}"/>
                                                    <Run Text=" modułów"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty state hint — widoczny gdy brak szablonów -->
                        <Border x:Name="EmptyStateHint" Visibility="Collapsed"
                                Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="12" Padding="16">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📋" FontSize="36" HorizontalAlignment="Center" Opacity="0.4"/>
                                <TextBlock Text="Brak szablonów" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextGrayBrush}" HorizontalAlignment="Center" Margin="0,8,0,4"/>
                                <TextBlock Text="Kliknij ➕ Nowy na dole&#x0a;albo zacznij wpisywać po prawej." FontSize="11"
                                           Foreground="{StaticResource TextLightBrush}" TextAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Background="{StaticResource SubtleBgBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnNew" Style="{StaticResource InfoButton}" Content="➕ Nowy" Click="BtnNew_Click"/>
                            <Button x:Name="BtnDuplicate" Style="{StaticResource ActionButton}" Content="📑 Duplikuj" Click="BtnDuplicate_Click"/>
                            <Button x:Name="BtnDelete" Style="{StaticResource DangerButton}" Content="🗑 Usuń" Click="BtnDelete_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- PRAWA: Formularz edycji szablonu -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Formularz nagłówka -->
                <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="16,10" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Ikona + kolor (lewa kolumna pod sobą) -->
                        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" Width="48" Height="48" CornerRadius="8"
                                Background="{Binding ElementName=ColorPicker, Path=SelectedItem.Tag, FallbackValue=#3B82F6}"
                                VerticalAlignment="Top" Margin="0,4,0,0">
                            <TextBox x:Name="TxtIcon" FontFamily="Segoe UI Emoji" FontSize="22"
                                     HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                     Foreground="White" Background="Transparent" BorderThickness="0"
                                     MaxLength="2" TextChanged="TxtIcon_TextChanged"/>
                        </Border>

                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="14,0,0,0">
                            <TextBlock Text="Nazwa szablonu / stanowiska" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="TxtName" Style="{StaticResource FormInput}" TextChanged="TxtName_TextChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="1" Margin="14,0,0,0">
                            <TextBlock Text="Opis (do czego służy)" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="TxtDescription" Style="{StaticResource FormInput}" TextChanged="TxtDescription_TextChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="2" Margin="14,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="Kolor" Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="ColorPicker" Width="160" SelectedIndex="0" SelectionChanged="ColorPicker_SelectionChanged">
                                <ComboBoxItem Content="🟦 Niebieski" Tag="#3B82F6"/>
                                <ComboBoxItem Content="🟢 Zielony" Tag="#10B981"/>
                                <ComboBoxItem Content="🟧 Pomarańczowy" Tag="#F59E0B"/>
                                <ComboBoxItem Content="🟥 Czerwony" Tag="#EF4444"/>
                                <ComboBoxItem Content="🟪 Fioletowy" Tag="#8B5CF6"/>
                                <ComboBoxItem Content="🟫 Brązowy" Tag="#92400E"/>
                                <ComboBoxItem Content="🩵 Turkus" Tag="#14B8A6"/>
                                <ComboBoxItem Content="🩷 Różowy" Tag="#EC4899"/>
                                <ComboBoxItem Content="⬜ Szary" Tag="#6B7280"/>
                            </ComboBox>
                        </StackPanel>

                        <Grid Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" Margin="14,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="LblModuleCount" Text="0 modułów wybranych" FontSize="11"
                                       Foreground="{StaticResource TextGrayBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="BtnSelectAll" Style="{StaticResource ActionButton}" Content="✓ Wszystkie" Click="BtnSelectAllModules_Click"/>
                                <Button x:Name="BtnSelectNone" Style="{StaticResource ActionButton}" Content="☐ Żaden" Click="BtnSelectNoneModules_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Moduły grid -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,10">
                    <StackPanel x:Name="ModulesPanel"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="LblStatus" Text="Wybierz szablon z listy po lewej, albo dodaj nowy."
                           FontSize="11" Foreground="{StaticResource TextGrayBrush}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnClose" Style="{StaticResource ActionButton}" Content="Zamknij" Click="BtnClose_Click" MinWidth="90"/>
                    <Button x:Name="BtnSave" Style="{StaticResource PrimaryButton}" Content="💾 Zapisz szablon" Click="BtnSave_Click" MinWidth="150"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
