<Window x:Class="Kalendarz1.Admin.LoginAuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historia logowań — audit log"
        Width="1100" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="#F1F4F8"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <!-- ═══ Paleta — spójna z AdminPermissionsWindow ═══ -->
        <SolidColorBrush x:Key="TextDarkBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextGrayBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="BorderLightBrush" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="BorderUltralightBrush" Color="#F3F4F6"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="White"/>
        <SolidColorBrush x:Key="SubtleBgBrush" Color="#F9FAFB"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#6B7280"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextGrayBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11.5"/>
        </Style>

        <Style x:Key="FilterInput" TargetType="Control">
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#37434F"/>
                    <GradientStop Offset="1" Color="#232F3B"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📜" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Historia logowań" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" · audit log (wymóg BRC 3.3)" FontSize="12" Foreground="#B0BEC5" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filtry -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1" Padding="14,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔍" FontSize="13" Foreground="{StaticResource TextGrayBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>

                <TextBlock Text="Login:" Style="{StaticResource FilterLabel}"/>
                <TextBox x:Name="UserFilterBox" Style="{StaticResource FilterInput}" Width="110" Margin="0,0,12,0"/>

                <TextBlock Text="Od:" Style="{StaticResource FilterLabel}"/>
                <DatePicker x:Name="DateFromPicker" Width="120" Margin="0,0,12,0" FontSize="12"/>

                <TextBlock Text="Do:" Style="{StaticResource FilterLabel}"/>
                <DatePicker x:Name="DateToPicker" Width="120" Margin="0,0,12,0" FontSize="12"/>

                <TextBlock Text="Status:" Style="{StaticResource FilterLabel}"/>
                <ComboBox x:Name="StatusFilterBox" Width="130" Margin="0,0,12,0" FontSize="12">
                    <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                    <ComboBoxItem Content="Tylko sukces"/>
                    <ComboBoxItem Content="Tylko błędy"/>
                </ComboBox>

                <Button Content="🔍 Filtruj" Style="{StaticResource BtnPrimary}" Click="ApplyFilters_Click"/>
                <Button Content="↻ Odśwież" Style="{StaticResource ActionButton}" Click="Refresh_Click"/>
                <Button Content="✖ Wyczyść" Style="{StaticResource ActionButton}" Background="#9CA3AF" Click="Clear_Click"/>
            </StackPanel>
        </Border>

        <!-- Podsumowanie -->
        <Border Grid.Row="2" Background="{StaticResource SubtleBgBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1" Padding="14,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📊" FontSize="12" Foreground="{StaticResource TextGrayBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="Statystyki: " FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextDarkBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatsText" FontSize="12" Foreground="{StaticResource TextGrayBrush}" VerticalAlignment="Center" Margin="4,0,0,0" Text="Załaduj dane..."/>
            </StackPanel>
        </Border>

        <!-- Tabela -->
        <DataGrid Grid.Row="3"
                  x:Name="AttemptsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F9FAFB"
                  Background="White"
                  BorderBrush="{StaticResource BorderLightBrush}"
                  BorderThickness="0"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  RowHeight="28"
                  FontSize="12"
                  Margin="0">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F3F4F6"/>
                    <Setter Property="Foreground" Value="#1F2937"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kiedy" Binding="{Binding AttemptedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="160"/>
                <DataGridTextColumn Header="Login" Binding="{Binding UserId}" Width="100"/>
                <DataGridTemplateColumn Header="Wynik" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SuccessText}"
                                       Foreground="{Binding SuccessColor}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="8,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Komputer" Binding="{Binding MachineName}" Width="180"/>
                <DataGridTextColumn Header="Powód błędu" Binding="{Binding FailureReason}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="14,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Zamknij" Style="{StaticResource ActionButton}" Click="Close_Click" MinWidth="100"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
