<Window x:Class="Kalendarz1.Pasza.KreatorPaszyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zakup Paszy — Paszarnia → Hodowca (z marżą z LibraNet)"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F7F8FA"
        FontFamily="Segoe UI"
        FontSize="13"
        MinWidth="1200" MinHeight="760"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#1B5E20"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#0F3D14"/>
        <SolidColorBrush x:Key="OkBrush" Color="#10B981"/>
        <SolidColorBrush x:Key="WarnBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="ErrBrush" Color="#EF4444"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderSubtle" Color="#E5E7EB"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>

        <!-- Numeryczne pola: wyrównanie prawo + monospace dla czytelności kwot -->
        <Style x:Key="NumericBox" TargetType="TextBox">
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1B5E20"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline" Cursor="Hand"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Chip-Button — używany w nowym Kreatorze (paszarnia/towar/hodowca picker) -->
        <Style x:Key="ChipBtn" TargetType="Button">
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Jeśli model ma IsSelected=true → chip robi się zielony -->
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#10B981"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7F9FB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="22,13">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🌾" FontSize="22" VerticalAlignment="Center" Margin="0,0,11,0"/>
                <TextBlock Text="Zakup Paszy" FontSize="18" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                <TextBlock Text="  ·  paszarnia → ja → hodowca z marżą" FontSize="13" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- TABS -->
        <TabControl Grid.Row="1" Margin="14,10,14,8" Background="Transparent" BorderThickness="0">

            <!-- ════════════════ TAB 1: KREATOR ════════════════ -->
            <TabItem x:Name="tabKreator" Header="📝 Nowy zakup" FontWeight="SemiBold" Padding="14,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,0,4">

                        <!-- 1. PASZARNIA — chip-buttony, jeden wybór -->
                        <Border Background="White" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="6" Padding="18" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionHeader}" Foreground="#1E3A8A" Text="1.  PASZARNIA  (kliknij jedną)"/>
                                <ItemsControl x:Name="icPaszarnie">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="PaszarniaChip_Click" Tag="{Binding}" Style="{StaticResource ChipBtn}" Content="{Binding Name}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel x:Name="lblNoPaszarni" Orientation="Horizontal" Visibility="Collapsed" Margin="0,4,0,0">
                                    <TextBlock Text="🔭 Brak paszarni w słowniku. " Foreground="{StaticResource MutedBrush}" FontStyle="Italic" FontSize="12" VerticalAlignment="Center"/>
                                    <Button Content="Idź do ⚙ Słowniki →" Click="GoToSlowniki_Click" Style="{StaticResource LinkButton}" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 2. TOWARY — chipy multi-select + karty pozycji -->
                        <Border Background="White" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="6" Padding="18" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource SectionHeader}" Foreground="#065F46" Text="2.  TOWARY  (kliknij ile chcesz)"/>
                                    <TextBlock Grid.Column="1" x:Name="lblPozycjeCount" Foreground="{StaticResource MutedBrush}" FontSize="11" VerticalAlignment="Center"/>
                                </Grid>
                                <ItemsControl x:Name="icTowary">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="TowarChip_Click" Tag="{Binding}" Style="{StaticResource ChipBtn}" Content="{Binding Nazwa}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel x:Name="lblNoTowarow" Orientation="Horizontal" Visibility="Collapsed" Margin="0,4,0,0">
                                    <TextBlock Text="🔭 Brak towarów w słowniku. " Foreground="{StaticResource MutedBrush}" FontStyle="Italic" FontSize="12" VerticalAlignment="Center"/>
                                    <Button Content="Idź do ⚙ Słowniki →" Click="GoToSlowniki_Click" Style="{StaticResource LinkButton}" FontSize="12"/>
                                </StackPanel>

                                <!-- POZYCJE: wybrane towary z polami (2 wiersze, czytelne) -->
                                <ItemsControl x:Name="icPozycje" Margin="0,12,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" BorderBrush="#86EFAC" BorderThickness="1.5" CornerRadius="8" Padding="18,14" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <!-- WIERSZ 1: nazwa + kod + usuń -->
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                            <Border Background="#10B981" CornerRadius="4" Padding="6,3" VerticalAlignment="Center">
                                                                <TextBlock Text="📦" FontSize="14"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding TowarNazwa}" FontWeight="Bold" FontSize="16" Foreground="#065F46" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                            <TextBlock Text="{Binding TowarKod}" Foreground="{StaticResource MutedBrush}" FontSize="12" FontFamily="Consolas" VerticalAlignment="Center" Margin="12,3,0,0"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="✗ usuń" Click="UsunPozycje_Click" Tag="{Binding}"
                                                                Background="#FEE2E2" Foreground="#991B1B" FontWeight="SemiBold" FontSize="12"
                                                                BorderThickness="0" Padding="12,5" Cursor="Hand"
                                                                ToolTip="Usuń tę pozycję">
                                                            <Button.Resources>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="CornerRadius" Value="4"/>
                                                                </Style>
                                                            </Button.Resources>
                                                        </Button>
                                                    </Grid>

                                                    <!-- WIERSZ 2: inputy + computed -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="140"/>
                                                            <ColumnDefinition Width="14"/>
                                                            <ColumnDefinition Width="160"/>
                                                            <ColumnDefinition Width="14"/>
                                                            <ColumnDefinition Width="160"/>
                                                            <ColumnDefinition Width="14"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Ilość -->
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Ilość" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                                                            <Grid>
                                                                <TextBox Text="{Binding IloscStr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         Tag="Ilosc" TextChanged="PozycjaInput_Changed" MaxLength="12"
                                                                         FontFamily="Consolas" FontSize="15" Padding="8,8,32,8" HorizontalContentAlignment="Right"
                                                                         ToolTip="Wpisz ilość (np. 9,98 lub 9.98)"/>
                                                                <TextBlock Text="{Binding Jm}" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0" IsHitTestVisible="False"/>
                                                            </Grid>
                                                        </StackPanel>

                                                        <!-- Cena zakupu -->
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Cena zakupu (netto)" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                                                            <Grid>
                                                                <TextBox Text="{Binding CenaZakStr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         Tag="CenaZak" TextChanged="PozycjaInput_Changed" MaxLength="12"
                                                                         FontFamily="Consolas" FontSize="15" Padding="8,8,42,8" HorizontalContentAlignment="Right"
                                                                         ToolTip="Cena zakupu od paszarni za jednostkę (np. 1625,00)"/>
                                                                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0" IsHitTestVisible="False">
                                                                    <Run Text="zł/"/><Run Text="{Binding Jm, Mode=OneWay}"/>
                                                                </TextBlock>
                                                            </Grid>
                                                        </StackPanel>

                                                        <!-- Marża -->
                                                        <StackPanel Grid.Column="4">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                <TextBlock Text="Marża" FontSize="12" FontWeight="SemiBold" Foreground="#374151"/>
                                                                <Border CornerRadius="3" Padding="6,1" Margin="6,0,0,0">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#FEF3C7"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding MarzaZCennika}" Value="True">
                                                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="{Binding MarzaSourceText}" FontSize="10" FontWeight="Bold" Foreground="{Binding MarzaSourceBrush}"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <Grid>
                                                                <TextBox Text="{Binding MarzaStr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         Tag="Marza" TextChanged="PozycjaInput_Changed" MaxLength="12"
                                                                         FontFamily="Consolas" FontSize="15" Padding="8,8,42,8" HorizontalContentAlignment="Right"
                                                                         ToolTip="Marża (autouzupełnia się z cennika; możesz nadpisać)"/>
                                                                <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0" IsHitTestVisible="False">
                                                                    <Run Text="zł/"/><Run Text="{Binding Jm, Mode=OneWay}"/>
                                                                </TextBlock>
                                                            </Grid>
                                                        </StackPanel>

                                                        <!-- Live computed (cena sprz + wartość) -->
                                                        <Border Grid.Column="6" Background="#F0FDF4" CornerRadius="6" Padding="12,8">
                                                            <Grid VerticalAlignment="Center">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <Grid Grid.Row="0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="Cena sprz. netto:" FontSize="12" Foreground="#065F46" VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding CenaSprzText}" FontWeight="SemiBold" FontSize="13" Foreground="#065F46" FontFamily="Consolas"/>
                                                                </Grid>
                                                                <Grid Grid.Row="1" Margin="0,5,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="Wartość zakupu:" FontSize="12" Foreground="#065F46" VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding WartoscZakText}" FontWeight="Bold" FontSize="15" Foreground="#064E3B" FontFamily="Consolas"/>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- 3. HODOWCA — chipy radio z filtrem -->
                        <Border Background="White" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="6" Padding="18" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="270"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource SectionHeader}" Foreground="#6B21A8" Text="3.  HODOWCA  (kupował te towary w ostatnim roku)"/>
                                    <TextBox Grid.Column="1" x:Name="txtSzukajHodowcy" Padding="10,7" FontSize="13"
                                             BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                             TextChanged="SzukajHodowcy_TextChanged"
                                             ToolTip="🔍 Filtruj listę hodowców po nazwie / NIP"/>
                                </Grid>
                                <Border MaxHeight="250" Margin="0,4,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="icHodowcy">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Click="HodowcaChip_Click" Tag="{Binding}" Style="{StaticResource ChipBtn}" Content="{Binding Name}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                                <StackPanel x:Name="lblNoHodowcow" Orientation="Horizontal" Visibility="Collapsed" Margin="0,4,0,0">
                                    <TextBlock Text="🔭 Brak hodowców kupujących te towary w 12 mc. Sprawdź słownik towarów. " Foreground="{StaticResource MutedBrush}" FontStyle="Italic" FontSize="12" VerticalAlignment="Center"/>
                                    <Button Content="Idź do ⚙ Słowniki →" Click="GoToSlowniki_Click" Style="{StaticResource LinkButton}" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 4. WSPÓLNE: data, termin, VAT, numer obcy -->
                        <Border Background="White" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="6" Padding="18" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionHeader}" Foreground="#374151" Text="4.  DOKUMENT  (wspólny dla wszystkich pozycji)"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Data wystawienia" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                                        <DatePicker x:Name="dpData" Padding="6,5" FontSize="13" SelectedDateChanged="Meta_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Termin [dni]" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtTermin" Text="45" FontFamily="Consolas" FontSize="14" Padding="8,6" HorizontalContentAlignment="Right" TextChanged="Meta_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="VAT [%]" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtVat" Text="8" FontFamily="Consolas" FontSize="14" Padding="8,6" HorizontalContentAlignment="Right" TextChanged="Meta_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="6">
                                        <TextBlock Text="Numer obcy faktury paszarni (np. SKD/FV/1291/05/26)" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtNumerObcy" Padding="8,6" FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock x:Name="lblTerminCalc" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,8,0,0" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>

                        <!-- DEDUP -->
                        <Border x:Name="banDedup" Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,10" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠ " Foreground="#92400E" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblDedup" Foreground="#92400E" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- 5. FOOTER: sumy + wyślij -->
                        <Border Background="White" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="6" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Sumy po lewej (z chipami kolorowymi) -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Border Background="#EFF6FF" CornerRadius="6" Padding="12,9" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Σ ZAKUP NETTO" FontSize="11" FontWeight="Bold" Foreground="#1E3A8A" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="lblSumaWartZakup" Text="0,00 zł" FontWeight="Bold" FontSize="17" Foreground="#1E3A8A" FontFamily="Consolas"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#F0FDF4" CornerRadius="6" Padding="12,9" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Σ SPRZ. BRUTTO" FontSize="11" FontWeight="Bold" Foreground="#065F46" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="lblSumaWartSprzedaz" Text="0,00 zł" FontWeight="Bold" FontSize="17" Foreground="#065F46" FontFamily="Consolas"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#FDF4FF" CornerRadius="6" Padding="12,9" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Σ MARŻA" FontSize="11" FontWeight="Bold" Foreground="#6B21A8" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="lblKreSumaMarza" Text="0,00 zł" FontWeight="Bold" FontSize="17" Foreground="#581C87" FontFamily="Consolas"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#F9FAFB" CornerRadius="6" Padding="12,9">
                                        <StackPanel>
                                            <TextBlock Text="Σ KG (TON)" FontSize="11" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="lblSumaKg" Text="0,000 t" FontWeight="Bold" FontSize="17" Foreground="#111827" FontFamily="Consolas"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Send button po prawej -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Button x:Name="btnWyslij"
                                            Content="🚀  Wyślij N pozycji do kolejki  (Ctrl+Enter)"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="22,12" FontSize="14"
                                            IsEnabled="False"
                                            Click="BtnWyslij_Click"/>
                                    <TextBlock x:Name="lblWalidacja" Foreground="#B91C1C" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ════════════════ TAB 2: KOLEJKA ════════════════ -->
            <TabItem x:Name="tabKolejka" Header="📋 Kolejka Symfonii" FontWeight="SemiBold" Padding="14,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,1,1,0" CornerRadius="6,6,0,0" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Status:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <ComboBox x:Name="cbStatusFilter" Width="160" Padding="8,4" SelectionChanged="CbStatusFilter_SelectionChanged">
                                    <ComboBoxItem Tag="" IsSelected="True">Wszystkie</ComboBoxItem>
                                    <ComboBoxItem Tag="NOWY">NOWY</ComboBoxItem>
                                    <ComboBoxItem Tag="IMPORTOWANE">IMPORTOWANE</ComboBoxItem>
                                    <ComboBoxItem Tag="BLAD">BLAD</ComboBoxItem>
                                    <ComboBoxItem Tag="ANULOWANE">ANULOWANE</ComboBoxItem>
                                </ComboBox>
                                <Button Content="🔄 Odśwież (F5)" Click="BtnOdswiezKolejka_Click" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"/>
                                <CheckBox x:Name="chkAutoRefresh" Content="⚡ Auto co 15s" VerticalAlignment="Center" Margin="16,0,0,0"
                                          Checked="ChkAutoRefresh_Changed" Unchecked="ChkAutoRefresh_Changed"
                                          ToolTip="Automatycznie odświeża listę co 15 sekund — przydatne gdy czekasz na import z Symfonii"/>
                                <TextBlock x:Name="lblOstatnioOdswiezone" Foreground="{StaticResource MutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" x:Name="lblKolejkaCount" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,0,1,1" CornerRadius="0,0,6,6">
                        <DataGrid x:Name="dgKolejka"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                  CanUserSortColumns="True"
                                  RowHeight="40" FontSize="12"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource BorderSubtle}"
                                  HeadersVisibility="Column" RowHeaderWidth="0"
                                  ColumnHeaderStyle="{StaticResource DgHeader}"
                                  VirtualizingPanel.IsVirtualizing="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Utworzono" Binding="{Binding UtworzonoKiedy, StringFormat='dd.MM HH:mm'}" Width="100"/>
                                <DataGridTextColumn Header="Paszarnia" Binding="{Binding PaszarniaNazwa}" Width="180"/>
                                <DataGridTextColumn Header="Hodowca" Binding="{Binding HodowcaNazwa}" Width="180"/>
                                <DataGridTextColumn Header="Towar" Binding="{Binding TowarNazwa}" Width="180"/>
                                <DataGridTextColumn Header="Ilość" Binding="{Binding IloscText}" Width="80"/>
                                <DataGridTextColumn Header="Wartość brutto" Binding="{Binding WartoscSprzBrutto, StringFormat=N2}" Width="110"/>
                                <DataGridTemplateColumn Header="Status" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="NOWY">
                                                                <Setter Property="Background" Value="#DBEAFE"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="IMPORTOWANE">
                                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="BLAD">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="ANULOWANE">
                                                                <Setter Property="Background" Value="#E5E7EB"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontWeight="Bold" FontSize="10.5"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Dokumenty Symfonii" Binding="{Binding DokumentyText}" Width="280"/>
                                <DataGridTextColumn Header="Błąd" Binding="{Binding BladKomunikat}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#B91C1C"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Akcje" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="✗" ToolTip="Anuluj (tylko NOWY)" Click="BtnAnulujKolejka_Click" Tag="{Binding}"
                                                        Background="Transparent" BorderThickness="0" Foreground="#DC2626" FontWeight="Bold" Cursor="Hand" Padding="6,2"/>
                                                <Button Content="↻" ToolTip="Wyślij ponownie (tylko BŁAD)" Click="BtnPonowKolejka_Click" Tag="{Binding}"
                                                        Background="Transparent" BorderThickness="0" Foreground="#2563EB" FontWeight="Bold" Cursor="Hand" Padding="6,2" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- STOPKA: sumy + liczniki statusów -->
                    <Border Grid.Row="2" Background="#F9FAFB" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,0,1,1" CornerRadius="0,0,6,6" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Liczniki per status (kolorowe chipy) -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Background="#DBEAFE" CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="NOWY: " FontWeight="SemiBold" Foreground="#1E40AF" FontSize="11"/>
                                        <TextBlock x:Name="lblCntNowy" Text="0" FontWeight="Bold" Foreground="#1E40AF" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#D1FAE5" CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="IMPORTOWANE: " FontWeight="SemiBold" Foreground="#065F46" FontSize="11"/>
                                        <TextBlock x:Name="lblCntImp" Text="0" FontWeight="Bold" Foreground="#065F46" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FEE2E2" CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="BŁĄD: " FontWeight="SemiBold" Foreground="#991B1B" FontSize="11"/>
                                        <TextBlock x:Name="lblCntBlad" Text="0" FontWeight="Bold" Foreground="#991B1B" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#E5E7EB" CornerRadius="4" Padding="8,3">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ANUL.: " FontWeight="SemiBold" Foreground="#374151" FontSize="11"/>
                                        <TextBlock x:Name="lblCntAnul" Text="0" FontWeight="Bold" Foreground="#374151" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Sumy: wartość brutto + marża łączna -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="Σ Wartość brutto:" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBlock x:Name="lblSumaBrutto" Text="0,00 zł" FontWeight="Bold" FontSize="13" Foreground="#065F46" VerticalAlignment="Center" Margin="6,0,16,0" FontFamily="Consolas"/>
                                <TextBlock Text="Σ Marża:" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" FontSize="12"/>
                                <TextBlock x:Name="lblSumaMarza" Text="0,00 zł" FontWeight="Bold" FontSize="13" Foreground="#581C87" VerticalAlignment="Center" Margin="6,0,0,0" FontFamily="Consolas"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ════════════════ TAB 3: CENNIK ════════════════ -->
            <TabItem x:Name="tabCennik" Header="💰 Cennik marż" FontWeight="SemiBold" Padding="14,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,1,1,0" CornerRadius="6,6,0,0" Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chkCennikTylkoAktywne" Content="Tylko aktywne" IsChecked="True" VerticalAlignment="Center" Checked="CennikFilter_Changed" Unchecked="CennikFilter_Changed"/>
                            <Button Content="🔄 Odśwież" Click="BtnOdswiezCennik_Click" Style="{StaticResource SecondaryButton}" Margin="16,0,0,0"/>
                            <Button Content="➕ Dodaj wpis cennika" Click="BtnDodajCennik_Click" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"/>
                            <TextBlock x:Name="lblCennikCount" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,0,1,1" CornerRadius="0,0,6,6">
                        <DataGrid x:Name="dgCennik"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                  CanUserSortColumns="True"
                                  RowHeight="40" FontSize="12"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource BorderSubtle}"
                                  HeadersVisibility="Column" RowHeaderWidth="0"
                                  ColumnHeaderStyle="{StaticResource DgHeader}"
                                  MouseDoubleClick="DgCennik_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Hodowca" Binding="{Binding HodowcaNazwa}" Width="220"/>
                                <DataGridTextColumn Header="Shortcut" Binding="{Binding HodowcaKhKod}" Width="100"/>
                                <DataGridTextColumn Header="Towar" Binding="{Binding TowarNazwa}" Width="200"/>
                                <DataGridTextColumn Header="Kod tow." Binding="{Binding TowarKod}" Width="100"/>
                                <DataGridTextColumn Header="Marża [zł/t]" Binding="{Binding MarzaKwota, StringFormat=N2}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#581C87"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Okres" Binding="{Binding OkresText}" Width="180"/>
                                <DataGridCheckBoxColumn Header="Aktywny" Binding="{Binding Aktywny}" Width="70"/>
                                <DataGridTextColumn Header="Uwagi" Binding="{Binding Uwagi}" Width="*"/>
                                <DataGridTemplateColumn Header="Akcje" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="✏" ToolTip="Edytuj" Click="BtnEdytujCennik_Click" Tag="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="6,2"/>
                                                <Button Content="🗑" ToolTip="Usuń" Click="BtnUsunCennik_Click" Tag="{Binding}" Background="Transparent" BorderThickness="0" Foreground="#DC2626" Cursor="Hand" Padding="6,2" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ════════════════ TAB 4: SŁOWNIKI ════════════════ -->
            <TabItem x:Name="tabSlowniki" Header="⚙ Słowniki" FontWeight="SemiBold" Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEWA: PASZARNIE -->
                    <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="6">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#EFF6FF" Padding="14,10" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" CornerRadius="6,6,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="🌾" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Moje paszarnie" FontWeight="Bold" FontSize="14" Foreground="#1E3A8A" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="lblPaszarnieCount" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" FontSize="11" Margin="10,0,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="➕ Dodaj paszarnię" Click="BtnDodajPaszarnie_Click" Style="{StaticResource PrimaryButton}" Padding="12,6"/>
                                </Grid>
                            </Border>
                            <DataGrid x:Name="dgPaszarnie"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                      CanUserSortColumns="True"
                                      RowHeight="36" FontSize="12.5"
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource BorderSubtle}"
                                      HeadersVisibility="Column" RowHeaderWidth="0"
                                      ColumnHeaderStyle="{StaticResource DgHeader}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nazwa" Binding="{Binding Nazwa}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="6,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Shortcut" Binding="{Binding KhKod}" Width="130">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="Foreground" Value="#4338CA"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="NIP" Binding="{Binding NIP}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="Akcje" Width="70" CanUserSort="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="🗑" ToolTip="Usuń ze słownika" Click="BtnUsunPaszarnie_Click" Tag="{Binding}"
                                                        Background="Transparent" BorderThickness="0" Foreground="#DC2626" Cursor="Hand" Padding="6,2" FontSize="13"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- PRAWA: TOWARY -->
                    <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="6">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#F0FDF4" Padding="14,10" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" CornerRadius="6,6,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="📦" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Moje towary pasz" FontWeight="Bold" FontSize="14" Foreground="#065F46" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="lblTowaryCount" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" FontSize="11" Margin="10,0,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="➕ Dodaj towar" Click="BtnDodajTowar_Click" Style="{StaticResource PrimaryButton}" Padding="12,6"/>
                                </Grid>
                            </Border>
                            <DataGrid x:Name="dgTowary"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                      CanUserSortColumns="True"
                                      RowHeight="36" FontSize="12.5"
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource BorderSubtle}"
                                      HeadersVisibility="Column" RowHeaderWidth="0"
                                      ColumnHeaderStyle="{StaticResource DgHeader}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nazwa" Binding="{Binding TowarNazwa}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="6,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Kod" Binding="{Binding TowarKod}" Width="140">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="Foreground" Value="#4338CA"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Jm" Binding="{Binding Jm}" Width="50">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Katalog" Binding="{Binding KatalogText}" Width="140">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="Akcje" Width="70" CanUserSort="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="🗑" ToolTip="Usuń ze słownika" Click="BtnUsunTowar_Click" Tag="{Binding}"
                                                        Background="Transparent" BorderThickness="0" Foreground="#DC2626" Cursor="Hand" Padding="6,2" FontSize="13"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,1,0,0" Padding="22,10">
            <TextBlock x:Name="txtStatus" Text="Gotowe" Foreground="{StaticResource MutedBrush}" FontSize="13"/>
        </Border>

        <!-- LOADING OVERLAY -->
        <Border x:Name="loadingOverlay" Grid.Row="0" Grid.RowSpan="3" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="220" Height="6"/>
                <TextBlock x:Name="loadingText" Text="Ładowanie..." Margin="0,8,0,0" HorizontalAlignment="Center" Foreground="#374151" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
