<Window x:Class="Kalendarz1.Pasza.DodajPaszarnieDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wybierz paszarnie ze Symfonii"
        Height="720" Width="980"
        WindowStartupLocation="CenterOwner"
        Background="#F7F8FA"
        FontFamily="Segoe UI" FontSize="13"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <SolidColorBrush x:Key="BorderSubtle" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#1B5E20"/>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7F9FB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" Padding="22,16" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🌾" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Wybierz paszarnie ze Symfonii" FontSize="17" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Lista WSZYSTKICH kontrahentów Symfonii. Filtruj nazwą / Shortcut / NIP — filtr działa lokalnie, nie traci zaznaczeń. Zaznaczaj checkboxami i dodaj hurtem."
                           Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- TOOLBAR: filtr + akcje hurtowe + licznik -->
        <Border Grid.Row="1" Background="White" Padding="22,12" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" x:Name="txtFiltr" Padding="10,8" FontSize="13"
                         BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                         TextChanged="TxtFiltr_TextChanged"
                         ToolTip="Wpisz fragment nazwy / Shortcut / NIP"/>

                <Button Grid.Column="2" Content="☑ Zaznacz widoczne" Click="BtnZaznaczWszystkie_Click"
                        Background="#DBEAFE" Foreground="#1E3A8A" FontWeight="SemiBold"
                        BorderThickness="0" Padding="12,8" Cursor="Hand" Margin="12,0,0,0"
                        ToolTip="Zaznacz wszystkie kontrahentów pasujących do bieżącego filtra"/>
                <Button Grid.Column="3" Content="☐ Wyczyść zaznaczenie" Click="BtnOdznacz_Click"
                        Background="#E5E7EB" Foreground="#374151" FontWeight="SemiBold"
                        BorderThickness="0" Padding="12,8" Cursor="Hand" Margin="8,0,0,0"/>

                <Border Grid.Column="4" Background="#EFF6FF" CornerRadius="4" Padding="12,6" Margin="14,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="lblWidocznych" Text="0" FontWeight="Bold" Foreground="#1E3A8A"/>
                        <TextBlock Text=" widocznych  ·  " Foreground="#6B7280"/>
                        <TextBlock x:Name="lblZaznaczonych" Text="0" FontWeight="Bold" Foreground="#065F46"/>
                        <TextBlock Text=" zaznaczonych" Foreground="#6B7280"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- GRID + empty state -->
        <Grid Grid.Row="2" Margin="22,12,22,8">
            <Border Background="White" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="6">
                <DataGrid x:Name="dgKontrahenci"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserSortColumns="True"
                          RowHeight="40" FontSize="13"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource BorderSubtle}"
                          HeadersVisibility="Column" RowHeaderWidth="0"
                          SelectionMode="Extended" SelectionUnit="FullRow"
                          VirtualizingPanel.IsVirtualizing="True"
                          BorderThickness="0"
                          Background="White">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Background" Value="#F0FDF4"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F3F4F6"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="46" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Shortcut (khKod)" Binding="{Binding Shortcut}" Width="180" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="Foreground" Value="#4338CA"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="NIP" Binding="{Binding NIP}" Width="150" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- EMPTY STATE — gdy filtr nic nie znajduje -->
            <Border x:Name="emptyState" Background="#F9FAFB" CornerRadius="6" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                    <TextBlock Text="🔍" FontSize="42" HorizontalAlignment="Center" Foreground="#9CA3AF"/>
                    <TextBlock Text="Brak wyników dla bieżącego filtra" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,12,0,4" Foreground="#374151"/>
                    <TextBlock x:Name="lblEmptyHint" Text="Zmień fragment lub wyczyść pole wyszukiwania." HorizontalAlignment="Center" Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="3" Background="White" Padding="22,14" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="lblFooterInfo"
                           Foreground="{StaticResource MutedBrush}" FontSize="11" VerticalAlignment="Center"/>

                <Button Grid.Column="1" Content="Anuluj" Click="BtnAnuluj_Click"
                        Background="#E5E7EB" Foreground="#111827" FontWeight="SemiBold"
                        Padding="18,10" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                <Button Grid.Column="2" x:Name="btnDodaj" Content="➕ Dodaj zaznaczone" Click="BtnDodaj_Click"
                        Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="SemiBold" FontSize="14"
                        Padding="22,10" BorderThickness="0" Cursor="Hand" IsEnabled="False"/>
            </Grid>
        </Border>
    </Grid>
</Window>
