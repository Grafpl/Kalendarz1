<Window x:Class="Kalendarz1.Pasza.CennikEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wpis cennika marży"
        Height="540" Width="640"
        WindowStartupLocation="CenterOwner"
        Background="#F7F8FA"
        FontFamily="Segoe UI" FontSize="13"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="lblTytul" Text="Nowy wpis cennika" FontSize="17" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Hodowca (kontrahent Symfonii)" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox x:Name="cbHodowca" IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                      DisplayMemberPath="Display" TextSearch.TextPath="Display"
                      MaxDropDownHeight="320" Padding="8,6" FontSize="13"/>

            <TextBlock Text="Towar (pasza)" FontWeight="SemiBold" Margin="0,14,0,4"/>
            <ComboBox x:Name="cbTowar" IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                      DisplayMemberPath="Display" TextSearch.TextPath="Display"
                      MaxDropDownHeight="320" Padding="8,6" FontSize="13"/>

            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Marża [zł/t]" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtMarza" Padding="8,6" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Data od" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <DatePicker x:Name="dpOd" Padding="6,4" FontSize="13"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Data do (puste = bezterminowo)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <DatePicker x:Name="dpDo" Padding="6,4" FontSize="13"/>
                </StackPanel>
            </Grid>

            <CheckBox x:Name="chkAktywny" Content="Aktywny" IsChecked="True" Margin="0,14,0,0"/>

            <TextBlock Text="Uwagi" FontWeight="SemiBold" Margin="0,14,0,4"/>
            <TextBox x:Name="txtUwagi" Padding="8,6" FontSize="13" AcceptsReturn="True" TextWrapping="Wrap" Height="80"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="btnAnuluj" Content="Anuluj" Click="BtnAnuluj_Click"
                    Background="#E5E7EB" Foreground="#111827" FontWeight="SemiBold" Padding="16,8" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
            <Button x:Name="btnZapisz" Content="💾 Zapisz" Click="BtnZapisz_Click"
                    Background="#1B5E20" Foreground="White" FontWeight="SemiBold" Padding="20,8" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
