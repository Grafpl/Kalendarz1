<Window x:Class="Kalendarz1.AnalizaTygodniowa.AnalizaTygodniowaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:m="clr-namespace:Kalendarz1.AnalizaTygodniowa.Models"
        Title="Dashboard Analityczny — Produkcja vs Sprzedaż"
        MinHeight="700" MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F1F5F9"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        KeyDown="Window_KeyDown">

    <Window.Resources>

        <m:ValueToSignConverter x:Key="ValueToSignConverter"/>

        <!-- ═══════════ MODERN PALETTE (Tailwind slate/blue) ═══════════ -->
        <SolidColorBrush x:Key="Accent"        Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentHover"   Color="#1D4ED8"/>
        <SolidColorBrush x:Key="AccentLight"   Color="#DBEAFE"/>
        <SolidColorBrush x:Key="TextDark"      Color="#0F172A"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#64748B"/>
        <SolidColorBrush x:Key="Border"        Color="#E2E8F0"/>
        <SolidColorBrush x:Key="BgCard"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgSubtle"      Color="#F8FAFC"/>
        <SolidColorBrush x:Key="HeaderBg"      Color="#0F172A"/>
        <SolidColorBrush x:Key="Success"       Color="#16A34A"/>
        <SolidColorBrush x:Key="SuccessLight"  Color="#DCFCE7"/>
        <SolidColorBrush x:Key="Warning"       Color="#D97706"/>
        <SolidColorBrush x:Key="WarningLight"  Color="#FEF3C7"/>
        <SolidColorBrush x:Key="Danger"        Color="#DC2626"/>
        <SolidColorBrush x:Key="DangerLight"   Color="#FEE2E2"/>
        <SolidColorBrush x:Key="Purple"        Color="#7C3AED"/>
        <SolidColorBrush x:Key="Teal"          Color="#0D9488"/>

        <!-- ═══════════ BUTTON STYLES ═══════════ -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentLight}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnHeader" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#334155"/>
        </Style>

        <Style x:Key="BtnWarning" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="{StaticResource Warning}"/>
        </Style>

        <!-- ═══════════ FORM CONTROLS ═══════════ -->
        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,4,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        </Style>

        <!-- ═══════════ KPI CARD ═══════════ -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ═══════════ DATAGRID ═══════════ -->
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Border}"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="{StaticResource BgCard}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgSubtle}"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource BgSubtle}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentLight}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CenteredCell" TargetType="DataGridCell">
            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>
        <Style x:Key="RightAlignedCell" TargetType="DataGridCell">
            <Setter Property="TextBlock.TextAlignment" Value="Right"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="Padding" Value="6,0,12,0"/>
        </Style>

        <!-- ═══════════ TAB ═══════════ -->
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid x:Name="rootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═════════ HEADER ═════════ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBg}" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📉" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Dashboard Analityczny"
                                   FontSize="17" FontWeight="SemiBold" Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Bilans produkcji vs sprzedaż dla świeżych towarów (katalog 67095)"
                               FontSize="11" Foreground="#94A3B8" Margin="26,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📥 Eksport CSV" Style="{StaticResource BtnHeader}"
                            Click="BtnExportCsv_Click" Margin="0,0,6,0"
                            ToolTip="Eksportuje tabelę dni do pliku CSV"/>
                    <Button Content="📖 Instrukcja" Style="{StaticResource BtnHeader}"
                            Click="BtnInstrukcja_Click" Margin="0,0,6,0"
                            ToolTip="Pokazuje instrukcję obsługi"/>
                    <Button Content="✕" Style="{StaticResource BtnHeader}"
                            Click="BtnClose_Click" Padding="10,6"
                            ToolTip="Zamyka okno"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═════════ FILTERS ROW 1: dates + presets ═════════ -->
        <Border Grid.Row="1" Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="14,8">
            <WrapPanel Orientation="Horizontal" ItemHeight="34">
                <TextBlock Text="Od:" Style="{StaticResource LabelStyle}"/>
                <DatePicker x:Name="dpDataOd" Style="{StaticResource ModernDatePicker}" Width="120"
                            ToolTip="Data początkowa zakresu (włącznie)"/>
                <TextBlock Text="Do:" Style="{StaticResource LabelStyle}"/>
                <DatePicker x:Name="dpDataDo" Style="{StaticResource ModernDatePicker}" Width="120"
                            ToolTip="Data końcowa zakresu (włącznie)"/>

                <Border Width="1" Background="{StaticResource Border}" Margin="8,4" Height="22"/>

                <Button Content="Wczoraj" Style="{StaticResource BtnGhost}"
                        Click="BtnPresetWczoraj_Click"
                        ToolTip="Tylko wczorajszy dzień"/>
                <Button Content="Ten tydzień" Style="{StaticResource BtnGhost}"
                        Click="BtnPresetTenTydz_Click"
                        ToolTip="Bieżący tydzień (Pn–dziś)"/>
                <Button Content="Poprz. tydzień" Style="{StaticResource BtnGhost}"
                        Click="BtnPresetPoprzTydz_Click"
                        ToolTip="Poprzedni pełny tydzień (Pn–Nd)"/>
                <Button Content="7 dni" Style="{StaticResource BtnGhost}"
                        Click="BtnPreset7Dni_Click"
                        ToolTip="Ostatnie 7 dni włącznie z dziś"/>
                <Button Content="30 dni" Style="{StaticResource BtnGhost}"
                        Click="BtnPreset30Dni_Click"
                        ToolTip="Ostatnie 30 dni włącznie z dziś"/>
                <Button Content="Bieżący mc" Style="{StaticResource BtnGhost}"
                        Click="BtnPresetMiesiac_Click"
                        ToolTip="Od pierwszego dnia bieżącego miesiąca"/>

                <Border Width="1" Background="{StaticResource Border}" Margin="8,4" Height="22"/>

                <Button x:Name="btnAnalizuj" Content="🔄 Analizuj"
                        Style="{StaticResource BtnPrimary}"
                        Click="BtnAnalizuj_Click"
                        ToolTip="Pobiera dane z bazy Handel (F5)"/>

                <CheckBox x:Name="chkUkryjKorekty" Content="Ukryj korekty"
                          VerticalAlignment="Center" Margin="14,0,0,0" FontSize="11" FontWeight="SemiBold"
                          Foreground="{StaticResource TextDark}"
                          ToolTip="Pomija ujemne pozycje (zwroty/korekty) w sumach"
                          Click="ChkUkryjKorekty_Click"/>

                <CheckBox x:Name="chkPorownajYoY" Content="Porównaj YoY"
                          VerticalAlignment="Center" Margin="10,0,0,0" FontSize="11" FontWeight="SemiBold"
                          Foreground="{StaticResource TextDark}"
                          ToolTip="Pokaż dodatkową linię — sprzedaż w analogicznym okresie rok temu"/>

                <TextBlock Text="Auto:" Style="{StaticResource LabelStyle}" Margin="14,0,4,0"/>
                <ComboBox x:Name="cmbAutoRefresh" Style="{StaticResource ModernComboBox}" Width="100"
                          SelectionChanged="CmbAutoRefresh_SelectionChanged"
                          ToolTip="Cykliczne odświeżanie danych w tle">
                    <ComboBoxItem Content="Wyłączone" IsSelected="True"/>
                    <ComboBoxItem Content="5 min"/>
                    <ComboBoxItem Content="15 min"/>
                    <ComboBoxItem Content="30 min"/>
                </ComboBox>

                <TextBlock x:Name="txtLastRefresh" Text=""
                           VerticalAlignment="Center" Margin="14,0,0,0"
                           FontSize="11" Foreground="{StaticResource TextMuted}"/>
            </WrapPanel>
        </Border>

        <!-- ═════════ FILTERS ROW 2: business filters ═════════ -->
        <Border Grid.Row="2" Background="{StaticResource BgSubtle}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="14,8">
            <WrapPanel Orientation="Horizontal" ItemHeight="34">
                <TextBlock Text="Towar:" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="cmbTowar" Style="{StaticResource ModernComboBox}" Width="280"
                          DisplayMemberPath="DisplayText" SelectedValuePath="Id"
                          ToolTip="Filtruje analizę po artykule (świeże towary, katalog 67095)"/>

                <TextBlock Text="Handlowiec:" Style="{StaticResource LabelStyle}"/>
                <Button x:Name="btnWybierzHandlowcow" Content="Wybierz…"
                        Style="{StaticResource BtnGhost}" Width="120"
                        Click="BtnWybierzHandlowcow_Click"
                        ToolTip="Otwiera multi-select handlowców"/>
                <TextBlock x:Name="txtHandlowcyBadge" Text="" VerticalAlignment="Center"
                           Margin="6,0,0,0" FontSize="11" Foreground="{StaticResource Accent}"
                           FontWeight="SemiBold" MaxWidth="220"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Text="Odbiorca:" Style="{StaticResource LabelStyle}"/>
                <Button x:Name="btnWybierzOdbiorcow" Content="Wybierz…"
                        Style="{StaticResource BtnGhost}" Width="120"
                        Click="BtnWybierzOdbiorcow_Click"
                        ToolTip="Otwiera multi-select odbiorców"/>
                <TextBlock x:Name="txtOdbiorcyBadge" Text="" VerticalAlignment="Center"
                           Margin="6,0,0,0" FontSize="11" Foreground="{StaticResource Accent}"
                           FontWeight="SemiBold" MaxWidth="220"
                           TextTrimming="CharacterEllipsis"/>

                <Button Content="Wyczyść filtry" Style="{StaticResource BtnGhost}"
                        Click="BtnResetFiltry_Click" Margin="14,0,0,0"
                        ToolTip="Resetuje filtry biznesowe"/>
            </WrapPanel>
        </Border>

        <!-- ═════════ KPI CARDS ═════════ -->
        <UniformGrid Grid.Row="3" Columns="5" Rows="1" Margin="6,8,6,0">

            <Border x:Name="kpiCardProdukcja" Style="{StaticResource StatCardStyle}"
                    ToolTip="Łączna produkcja w wybranym zakresie"
                    Cursor="Hand" MouseLeftButtonUp="KpiCardProdukcja_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource AccentLight}"
                            CornerRadius="8" Width="36" Height="36"
                            VerticalAlignment="Top" Margin="0,2,10,0">
                        <TextBlock Text="🏭" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="CAŁKOWITA PRODUKCJA" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                        <TextBlock x:Name="kpiProdukcja" Text="0 kg" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextDark}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="kpiProdukcjaInfo" Text="" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="kpiCardSprzedaz" Style="{StaticResource StatCardStyle}"
                    ToolTip="Łączna sprzedaż (po uwzględnieniu lub pominięciu korekt)"
                    Cursor="Hand" MouseLeftButtonUp="KpiCardSprzedaz_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource SuccessLight}"
                            CornerRadius="8" Width="36" Height="36"
                            VerticalAlignment="Top" Margin="0,2,10,0">
                        <TextBlock Text="💰" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="CAŁKOWITA SPRZEDAŻ" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                        <TextBlock x:Name="kpiSprzedaz" Text="0 kg" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource Success}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="kpiSprzedazInfo" Text="" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource StatCardStyle}"
                    ToolTip="Sprzedaż / Produkcja × 100%"
                    Cursor="Hand">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#EDE9FE"
                            CornerRadius="8" Width="36" Height="36"
                            VerticalAlignment="Top" Margin="0,2,10,0">
                        <TextBlock Text="📊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="WSPÓŁCZYNNIK SPRZEDAŻY" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                        <TextBlock x:Name="kpiProcent" Text="0%" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource Purple}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="kpiProcentInfo" Text="" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="kpiCardRyzyko" Style="{StaticResource StatCardStyle}"
                    ToolTip="Produkcja − Sprzedaż. Dodatnia = niesprzedany towar (ryzyko). Klik = filtruj dni z ryzykiem."
                    Cursor="Hand" MouseLeftButtonUp="KpiCardRyzyko_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource DangerLight}"
                            CornerRadius="8" Width="36" Height="36"
                            VerticalAlignment="Top" Margin="0,2,10,0">
                        <TextBlock Text="⚠️" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="POZOSTAŁO (RYZYKO)" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                        <TextBlock x:Name="kpiWariancja" Text="0 kg" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource Danger}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="kpiWariancjaInfo" Text="" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource StatCardStyle}"
                    ToolTip="MAPE — średni błąd prognozy (mniej = lepiej). Klik = filtruj dni z anomaliami.">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource WarningLight}"
                            CornerRadius="8" Width="36" Height="36"
                            VerticalAlignment="Top" Margin="0,2,10,0">
                        <TextBlock Text="🎯" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="DOKŁADNOŚĆ PROGNOZY" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                        <TextBlock x:Name="kpiMape" Text="—" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource Warning}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="kpiMapeInfo" Text="" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <!-- ═════════ MAIN CONTENT (chart + tables) ═════════ -->
        <Grid Grid.Row="4" Margin="10,8,10,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="280" MinHeight="180"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Chart: Produkcja vs Sprzedaż per dzień -->
            <Border Grid.Row="0" Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8"
                    Padding="14,10" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="📊 Produkcja vs Sprzedaż per dzień" FontWeight="Bold" FontSize="13"
                                   Foreground="{StaticResource TextDark}"/>
                        <TextBlock x:Name="chartHint" Text="" FontSize="10"
                                   Foreground="{StaticResource TextMuted}" Margin="10,2,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <lvc:CartesianChart x:Name="chartBilans" LegendLocation="Top"
                                            DataClick="ChartBilans_DataClick"
                                            Hoverable="True">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding LabelsBilans}" LabelsRotation="0" FontSize="10"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis LabelFormatter="{Binding KgFormatter}" FontSize="10"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                        <TextBlock x:Name="chartEmpty" Text="📭 Brak danych. Kliknij Analizuj."
                                   FontSize="13" Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="Visible"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Master-detail tables -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource BgCard}"
                        BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="14,12,14,4">
                            <TextBlock Text="📋 Bilans dzienny" FontWeight="Bold" FontSize="13"
                                       Foreground="{StaticResource TextDark}"/>
                            <TextBlock Text="Klik = pokaż szczegóły • zielone = niedobór, czerwone = nadwyżka"
                                       FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>

                        <DataGrid x:Name="dgPodsumowanieDni" Grid.Row="1" Margin="6"
                                  SelectionMode="Single"
                                  SelectionChanged="DgPodsumowanieDni_SelectionChanged">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="📋 Kopiuj dane wiersza" Click="MenuKopiujWiersz_Click"/>
                                    <Separator/>
                                    <MenuItem Header="🔍 Pokaż tylko ten dzień" Click="MenuFiltrujDzien_Click"/>
                                    <MenuItem Header="📅 Zakres = ten dzień" Click="MenuZakresDzien_Click"/>
                                    <Separator/>
                                    <MenuItem Header="⚡ Pokaż tylko anomalie" Click="MenuFiltrAnomalie_Click"/>
                                    <MenuItem Header="⚠️ Pokaż tylko ryzyko" Click="MenuFiltrRyzyko_Click"/>
                                    <MenuItem Header="🔄 Wyczyść lokalny filtr" Click="MenuFiltrCzysc_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="" Binding="{Binding AnomaliaIcon}" Width="28" CellStyle="{StaticResource CenteredCell}"/>
                                <DataGridTextColumn Header="Data" Binding="{Binding Data, StringFormat='yyyy-MM-dd'}" Width="95" CellStyle="{StaticResource CenteredCell}"/>
                                <DataGridTextColumn Header="Dzień" Binding="{Binding DzienTygodnia}" Width="80" CellStyle="{StaticResource CenteredCell}"/>
                                <DataGridTextColumn Header="Produkcja" Binding="{Binding IloscWyprodukowana, StringFormat='N0'}" Width="*" CellStyle="{StaticResource RightAlignedCell}" FontWeight="SemiBold"/>
                                <DataGridTextColumn Header="Sprzedaż" Binding="{Binding IloscSprzedana, StringFormat='N0'}" Width="*" CellStyle="{StaticResource RightAlignedCell}" FontWeight="SemiBold"/>
                                <DataGridTextColumn Header="Prognoza" Binding="{Binding PrognozaSprzedazy, StringFormat='N0'}" Width="*" CellStyle="{StaticResource RightAlignedCell}"/>
                                <DataGridTextColumn Header="Wariancja" Binding="{Binding Wariancja, StringFormat='N0'}" Width="*" CellStyle="{StaticResource RightAlignedCell}" FontWeight="Bold"/>
                                <DataGridTextColumn Header="MAPE %" Binding="{Binding Mape, StringFormat='N1'}" Width="70" CellStyle="{StaticResource RightAlignedCell}"/>
                                <DataGridTextColumn Header="Sprzed. %" Binding="{Binding ProcentSprzedazy, StringFormat='N1'}" Width="70" CellStyle="{StaticResource RightAlignedCell}"/>
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Wariancja, Converter={StaticResource ValueToSignConverter}}" Value="-1">
                                            <Setter Property="Background" Value="#DCFCE7"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Wariancja, Converter={StaticResource ValueToSignConverter}}" Value="1">
                                            <Setter Property="Background" Value="#FEE2E2"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentLight}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                              VerticalAlignment="Stretch" Background="{StaticResource Border}"/>

                <Border Grid.Column="2" Background="{StaticResource BgCard}"
                        BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8">
                    <TabControl x:Name="tabSzczegoly" Background="Transparent" BorderThickness="0">
                        <TabItem>
                            <TabItem.Header>
                                <TextBlock x:Name="hdrSzczegolySprzedazy" Text="Szczegóły sprzedaży"/>
                            </TabItem.Header>
                            <DataGrid x:Name="dgSzczegolySprzedazy" Margin="6">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="📄 Otwórz dokument" Click="MenuOtworzDokument_Click"/>
                                        <Separator/>
                                        <MenuItem Header="🎯 Filtruj tego odbiorcę" Click="MenuFiltrujOdbiorce_Click"/>
                                        <MenuItem Header="🎯 Filtruj tego handlowca" Click="MenuFiltrujHandlowca_Click"/>
                                        <MenuItem Header="🎯 Filtruj ten towar" Click="MenuFiltrujTowar_Click"/>
                                        <Separator/>
                                        <MenuItem Header="📋 Kopiuj wiersz" Click="MenuKopiujSprzedazRow_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Dokument" Binding="{Binding NumerDokumentu}" Width="*" MinWidth="100"/>
                                    <DataGridTextColumn Header="Odbiorca" Binding="{Binding NazwaKontrahenta}" Width="2*" MinWidth="160"/>
                                    <DataGridTextColumn Header="Towar" Binding="{Binding KodTowaru}" Width="*" MinWidth="80"/>
                                    <DataGridTextColumn Header="Nazwa" Binding="{Binding NazwaTowaru}" Width="1.5*" MinWidth="120"/>
                                    <DataGridTextColumn Header="Handlowiec" Binding="{Binding Handlowiec}" Width="*" MinWidth="100"/>
                                    <DataGridTextColumn Header="kg" Binding="{Binding Ilosc, StringFormat='N2'}" Width="80" CellStyle="{StaticResource RightAlignedCell}"/>
                                    <DataGridTextColumn Header="Cena (zł/kg)" Binding="{Binding Cena, StringFormat='N2'}" Width="90" CellStyle="{StaticResource RightAlignedCell}"/>
                                    <DataGridTextColumn Header="Wartość (zł)" Binding="{Binding Wartosc, StringFormat='N2'}" Width="100" CellStyle="{StaticResource RightAlignedCell}" FontWeight="Bold"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <TextBlock x:Name="hdrSzczegolyProdukcji" Text="Szczegóły produkcji"/>
                            </TabItem.Header>
                            <DataGrid x:Name="dgSzczegolyProdukcji" Margin="6">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Dokument PW" Binding="{Binding NumerDokumentu}" Width="*" MinWidth="120"/>
                                    <DataGridTextColumn Header="Towar" Binding="{Binding KodTowaru}" Width="*" MinWidth="100"/>
                                    <DataGridTextColumn Header="Nazwa" Binding="{Binding NazwaTowaru}" Width="2*" MinWidth="160"/>
                                    <DataGridTextColumn Header="kg" Binding="{Binding Ilosc, StringFormat='N2'}" Width="100" CellStyle="{StaticResource RightAlignedCell}" FontWeight="Bold"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <!-- ═════════ TAB: TOP-N RANKINGI ═════════ -->
                        <TabItem>
                            <TabItem.Header>
                                <TextBlock Text="🏆 Rankingi (Top-N)"/>
                            </TabItem.Header>
                            <Grid Margin="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="2,2,2,8">
                                    <TextBlock Text="Top:" Style="{StaticResource LabelStyle}"/>
                                    <ComboBox x:Name="cmbTopN" Style="{StaticResource ModernComboBox}" Width="80"
                                              SelectionChanged="CmbTopN_SelectionChanged">
                                        <ComboBoxItem Content="5"/>
                                        <ComboBoxItem Content="10" IsSelected="True"/>
                                        <ComboBoxItem Content="20"/>
                                        <ComboBoxItem Content="50"/>
                                    </ComboBox>
                                    <TextBlock Text="(suma okresu, sortowanie po kg)" Style="{StaticResource LabelStyle}" Margin="8,0,0,0"/>
                                </StackPanel>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Margin="2" BorderBrush="{StaticResource Border}"
                                            BorderThickness="1" CornerRadius="6" Padding="6">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="🏢 Top odbiorcy" FontWeight="Bold" FontSize="12"
                                                       Foreground="{StaticResource TextDark}" Margin="2,0,0,4"/>
                                            <DataGrid x:Name="dgTopOdbiorcy" Grid.Row="1">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="28" CellStyle="{StaticResource CenteredCell}"/>
                                                    <DataGridTextColumn Header="Nazwa" Binding="{Binding Nazwa}" Width="*" MinWidth="100"/>
                                                    <DataGridTextColumn Header="kg" Binding="{Binding Ilosc, StringFormat='N0'}" Width="65" CellStyle="{StaticResource RightAlignedCell}" FontWeight="SemiBold"/>
                                                    <DataGridTextColumn Header="zł" Binding="{Binding Wartosc, StringFormat='N0'}" Width="70" CellStyle="{StaticResource RightAlignedCell}"/>
                                                    <DataGridTextColumn Header="%" Binding="{Binding ProcentOgolu, StringFormat='N1'}" Width="48" CellStyle="{StaticResource RightAlignedCell}"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1" Margin="2" BorderBrush="{StaticResource Border}"
                                            BorderThickness="1" CornerRadius="6" Padding="6">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="👤 Top handlowcy" FontWeight="Bold" FontSize="12"
                                                       Foreground="{StaticResource TextDark}" Margin="2,0,0,4"/>
                                            <DataGrid x:Name="dgTopHandlowcy" Grid.Row="1">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="28" CellStyle="{StaticResource CenteredCell}"/>
                                                    <DataGridTextColumn Header="Nazwa" Binding="{Binding Nazwa}" Width="*" MinWidth="100"/>
                                                    <DataGridTextColumn Header="kg" Binding="{Binding Ilosc, StringFormat='N0'}" Width="65" CellStyle="{StaticResource RightAlignedCell}" FontWeight="SemiBold"/>
                                                    <DataGridTextColumn Header="zł" Binding="{Binding Wartosc, StringFormat='N0'}" Width="70" CellStyle="{StaticResource RightAlignedCell}"/>
                                                    <DataGridTextColumn Header="%" Binding="{Binding ProcentOgolu, StringFormat='N1'}" Width="48" CellStyle="{StaticResource RightAlignedCell}"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2" Margin="2" BorderBrush="{StaticResource Border}"
                                            BorderThickness="1" CornerRadius="6" Padding="6">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="📦 Top produkty" FontWeight="Bold" FontSize="12"
                                                       Foreground="{StaticResource TextDark}" Margin="2,0,0,4"/>
                                            <DataGrid x:Name="dgTopProdukty">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="28" CellStyle="{StaticResource CenteredCell}"/>
                                                    <DataGridTextColumn Header="Kod" Binding="{Binding Klucz}" Width="80"/>
                                                    <DataGridTextColumn Header="Nazwa" Binding="{Binding Nazwa}" Width="*" MinWidth="80"/>
                                                    <DataGridTextColumn Header="kg" Binding="{Binding Ilosc, StringFormat='N0'}" Width="65" CellStyle="{StaticResource RightAlignedCell}" FontWeight="SemiBold"/>
                                                    <DataGridTextColumn Header="%" Binding="{Binding ProcentOgolu, StringFormat='N1'}" Width="48" CellStyle="{StaticResource RightAlignedCell}"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <!-- ═════════ TAB: HEATMAPA ═════════ -->
                        <TabItem>
                            <TabItem.Header>
                                <TextBlock Text="🌡️ Heatmapa"/>
                            </TabItem.Header>
                            <Grid Margin="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="2,2,2,6">
                                    <TextBlock Text="Sprzedaż dzienna per towar" FontWeight="Bold" FontSize="12"
                                               Foreground="{StaticResource TextDark}"/>
                                    <TextBlock Text="(im ciemniejszy = więcej kg)" FontSize="11"
                                               Foreground="{StaticResource TextMuted}" Margin="10,2,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <lvc:CartesianChart x:Name="chartHeatmapa" Grid.Row="1" LegendLocation="None"
                                                    Hoverable="True">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis x:Name="heatAxisX" Labels="{Binding HeatLabelsX}"
                                                  LabelsRotation="-45" FontSize="9"/>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis x:Name="heatAxisY" Labels="{Binding HeatLabelsY}"
                                                  FontSize="10"/>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>

        <!-- ═════════ FOOTER ═════════ -->
        <Border Grid.Row="5" Background="{StaticResource BgSubtle}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="14,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="txtStatus" Text="Gotowy" FontSize="11"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="F5 = Analizuj  ·  F11 = Pełny ekran  ·  Dashboard Analityczny" FontSize="11"
                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═════════ LOADING OVERLAY ═════════ -->
        <Border x:Name="loadingOverlay" Grid.Row="0" Grid.RowSpan="6"
                Background="#80F1F5F9" Visibility="Collapsed" Panel.ZIndex="999">
            <Border Background="{StaticResource BgCard}" CornerRadius="10" Padding="32,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="280" BorderBrush="{StaticResource Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="⏳" FontSize="26" HorizontalAlignment="Center"/>
                    <TextBlock Text="Analizowanie danych…" FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,8,0,4"
                               Foreground="{StaticResource TextDark}"/>
                    <TextBlock x:Name="txtLoadingDetails" Text="Pobieram z bazy Handel"
                               FontSize="11" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <ProgressBar IsIndeterminate="True" Height="3" Width="200"
                                 Background="{StaticResource Border}"
                                 Foreground="{StaticResource Accent}"
                                 BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
