<Window x:Class="Kalendarz1.Zamowienia.Views.NoweZamowienieTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Nowe zamówienie · TEST"
        Width="1400" Height="900"
        MinWidth="1180" MinHeight="780"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{DynamicResource AppBackground}"
        FontFamily="Segoe UI"
        FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- ═══════════════ KOLORY ═══════════════ -->
        <SolidColorBrush x:Key="BrandGreen"      Color="#5C8A3A"/>
        <SolidColorBrush x:Key="BrandGreenDark"  Color="#46682C"/>
        <SolidColorBrush x:Key="BrandGreenLight" Color="#E8F1DC"/>
        <SolidColorBrush x:Key="Surface"         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceAlt"      Color="#F9FAFB"/>
        <SolidColorBrush x:Key="Border"          Color="#EAEDF1"/>
        <SolidColorBrush x:Key="BorderStrong"    Color="#D1D5DB"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary"   Color="#64748B"/>
        <SolidColorBrush x:Key="TextMuted"       Color="#94A3B8"/>
        <SolidColorBrush x:Key="Success"         Color="#10B981"/>
        <SolidColorBrush x:Key="Warning"         Color="#F59E0B"/>
        <SolidColorBrush x:Key="Danger"          Color="#EF4444"/>
        <SolidColorBrush x:Key="Info"            Color="#3B82F6"/>

        <!-- Subtelny gradient tła aplikacji -->
        <LinearGradientBrush x:Key="AppBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0" Color="#F7F8FA"/>
            <GradientStop Offset="1" Color="#EEF1F5"/>
        </LinearGradientBrush>

        <!-- Gradient na primary button (subtelny) -->
        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0" Color="#6BA044"/>
            <GradientStop Offset="1" Color="#5C8A3A"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryGradientHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0" Color="#5C8A3A"/>
            <GradientStop Offset="1" Color="#46682C"/>
        </LinearGradientBrush>

        <!-- ═══════════════ DROP-SHADOW (subtle) ═══════════════ -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="3" Color="#0F172A" Opacity="0.06"/>
        <DropShadowEffect x:Key="ElevatedShadow" BlurRadius="32" ShadowDepth="6" Color="#0F172A" Opacity="0.14"/>
        <DropShadowEffect x:Key="HoverShadow" BlurRadius="24" ShadowDepth="4" Color="#5C8A3A" Opacity="0.18"/>

        <!-- ═══════════════ SCROLLBAR (cienki, nowoczesny) ═══════════════ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
        </Style>

        <!-- ═══════════════ PRIMARY BUTTON ═══════════════ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="root" Background="{TemplateBinding Background}" CornerRadius="10" SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="2" Color="#5C8A3A" Opacity="0.30"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="root" Property="Background" Value="{StaticResource PrimaryGradientHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="root" Property="Background" Value="#CBD5E1"/>
                                <Setter TargetName="root" Property="Effect" Value="{x:Null}"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════ GHOST BUTTON ═══════════════ -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="root" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════ ICON BUTTON ═══════════════ -->
        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- ═══════════════ CARD ═══════════════ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- ═══════════════ INPUT TEXTBOX ═══════════════ -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandGreen}"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════ STEPPER STEP ═══════════════ -->
        <Style x:Key="StepCircle" TargetType="Border">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- ═══════════════ CHIP (oblique pill) ═══════════════ -->
        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ═══════════════ NUMBER STEPPER (qty editor) ═══════════════ -->
        <Style x:Key="StepperButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════ PRODUCT CARD TEMPLATE (kompaktowy kafelek z obrazkiem) ═══════════════ -->
        <DataTemplate x:Key="ProductCardTemplate">
            <Border Width="300" Margin="0,0,7,7" CornerRadius="9" Background="White"
                    BorderBrush="{Binding ProductBorder}" BorderThickness="{Binding ProductBorderThickness}" Padding="7">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Color="#0F172A" Opacity="0.04"/>
                </Border.Effect>
                <StackPanel>
                    <!-- HEADER: thumb + name + checkboxes 2x2 + cena + ✓ -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="38" Height="38" CornerRadius="6" ClipToBounds="True" VerticalAlignment="Top">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="#FAFCF7"/>
                                    <GradientStop Offset="1" Color="#F0F4EB"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <TextBlock Visibility="{Binding PlaceholderVisibility}" Text="{Binding PlaceholderEmoji}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image Source="{Binding ImageSource}" Visibility="{Binding HasImageVisibility}" Stretch="Uniform"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="7,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="{Binding Kod}" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" LineHeight="13" MaxHeight="40"/>
                            <TextBlock Text="{Binding KategoriaDisplay}" FontSize="9" Foreground="{StaticResource TextMuted}" Margin="0,1,0,0"/>
                            <!-- Przełącznik wariantu (np. Filet pojedynczy ⇄ podwójny) — tylko gdy towar ma warianty -->
                            <Button Visibility="{Binding WariantVisibility}" Content="{Binding WariantLabel}"
                                    Tag="{Binding Id}" Click="BtnWariant_Click" Cursor="Hand"
                                    HorizontalAlignment="Left" Margin="0,3,0,0"
                                    FontSize="9" FontWeight="SemiBold" Foreground="#6B21A8"
                                    Background="#F3E8FF" BorderBrush="#D8B4FE" BorderThickness="1" Padding="5,1"
                                    ToolTip="Kliknij, aby przełączyć wariant (w Symfonii zostaje ten sam towar)"/>
                        </StackPanel>
                        <!-- Checkboxes 2x2 z pełnymi nazwami (między nazwą a ✓) -->
                        <UniformGrid Grid.Column="2" Rows="2" Columns="2" Width="128" VerticalAlignment="Center" Margin="5,0,0,0">
                            <Border Background="#FEF2F2" CornerRadius="3" Margin="0,0,2,2" Padding="3,1" ToolTip="40 E2 (40 pojemników/paletę)">
                                <CheckBox Content="40 E2" IsChecked="{Binding E2, Mode=TwoWay}" Tag="{Binding Id}" Click="ChkOpcja_Click" FontSize="9" Padding="2,0,0,0" VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="#F0F7ED" CornerRadius="3" Margin="0,0,0,2" Padding="3,1" ToolTip="Pakowane w folię">
                                <CheckBox Content="Folia" IsChecked="{Binding Folia, Mode=TwoWay}" Tag="{Binding Id}" Click="ChkOpcja_Click" FontSize="9" Padding="2,0,0,0" VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="#F0FFF0" CornerRadius="3" Margin="0,2,2,0" Padding="3,1" ToolTip="Cięty zgodnie z Hallal">
                                <CheckBox Content="🔪 Hallal" IsChecked="{Binding Hallal, Mode=TwoWay}" Tag="{Binding Id}" Click="ChkOpcja_Click" FontSize="9" Padding="2,0,0,0" VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="#FFEBEE" CornerRadius="3" Margin="0,2,0,0" Padding="3,1" ToolTip="Strefa ptasiej grypy">
                                <CheckBox Content="⚠ Strefa" IsChecked="{Binding Strefa, Mode=TwoWay}" Tag="{Binding Id}" Click="ChkOpcja_Click" FontSize="9" Padding="2,0,0,0" VerticalAlignment="Center"/>
                            </Border>
                        </UniformGrid>
                        <!-- ✓ badge (gdy w koszyku) -->
                        <Border Grid.Column="3" Visibility="{Binding InCartVisibility}" CornerRadius="4" Background="{StaticResource BrandGreen}" Padding="4,1" VerticalAlignment="Center" Margin="4,0,0,0">
                            <TextBlock Text="✓" FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <!-- ⚖ Rozmiary — tylko dla kurczaków (tuszki). Klik = dialog klas wagowych (5-12) -->
                        <Button Grid.Column="4" Visibility="{Binding RozmiaryButtonVisibility}" Click="BtnRozmiary_Click" Tag="{Binding Id}"
                                Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0" Margin="4,0,0,0"
                                ToolTip="Rozdziel ilość na klasy wagowe tuszki (5-12)">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="4" Background="#FEF3F3" BorderBrush="#FECACA" BorderThickness="1" Padding="6,3">
                                        <TextBlock Text="⚖" FontSize="14" Foreground="#C0392B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#FECACA"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Badge rozkładu klas wagowych (gdy ustawiono) -->
                    <Border Visibility="{Binding RozmiaryBadgeVisibility}" Background="#FEF3F3" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,3,0,0">
                        <TextBlock Text="{Binding RozmiaryBadge}" FontSize="9" FontWeight="SemiBold" Foreground="#C0392B" TextWrapping="Wrap"/>
                    </Border>

                    <!-- 4 EDITABLE FIELDS: kg | poj | pal | cena (zielony) -->
                    <Border Margin="0,4,0,0" CornerRadius="5" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="2,1">
                                <TextBlock Text="kg" FontSize="9" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                <TextBox x:Name="FieldKg" Text="{Binding QtyKgDisplay, Mode=OneWay}" Tag="{Binding Id}"
                                         BorderThickness="0" Background="Transparent"
                                         HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                         FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimary}"
                                         TextChanged="TxtQty_TextChanged" KeyDown="TxtQty_KeyDown" LostFocus="TxtQty_LostFocus" GotFocus="TxtNumeric_GotFocus"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{StaticResource Border}"/>
                            <StackPanel Grid.Column="2" Margin="2,2">
                                <TextBlock Text="poj" FontSize="9" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                <TextBox x:Name="FieldPoj" Text="{Binding PojDisplay, Mode=OneWay}" Tag="{Binding Id}"
                                         BorderThickness="0" Background="Transparent"
                                         HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                         FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimary}"
                                         TextChanged="TxtPoj_TextChanged" KeyDown="TxtPoj_KeyDown" LostFocus="TxtPoj_LostFocus" GotFocus="TxtNumeric_GotFocus"/>
                            </StackPanel>
                            <Border Grid.Column="3" Background="{StaticResource Border}"/>
                            <StackPanel Grid.Column="4" Margin="2,2">
                                <TextBlock Text="pal" FontSize="9" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                <TextBox x:Name="FieldPal" Text="{Binding PalDisplay, Mode=OneWay}" Tag="{Binding Id}"
                                         BorderThickness="0" Background="Transparent"
                                         HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                         FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimary}"
                                         TextChanged="TxtPal_TextChanged" KeyDown="TxtPal_KeyDown" LostFocus="TxtPal_LostFocus" GotFocus="TxtNumeric_GotFocus"/>
                            </StackPanel>
                            <Border Grid.Column="5" Background="{StaticResource Border}"/>
                            <!-- CENA w zielonym slocie obok pal -->
                            <Border Grid.Column="6" Background="#F0F7ED" Padding="6,2" VerticalAlignment="Stretch" ToolTip="Cena netto zł/kg">
                                <StackPanel Margin="2,1">
                                    <TextBlock Text="cena zł" FontSize="9" Foreground="{StaticResource BrandGreenDark}" HorizontalAlignment="Center"/>
                                    <TextBox Text="{Binding CenaDisplay, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Tag="{Binding Id}" LostFocus="TxtCena_LostFocus"
                                             BorderThickness="0" Background="Transparent" MinWidth="60"
                                             HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                             FontWeight="Bold" FontSize="13" Foreground="{StaticResource BrandGreenDark}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             LEWY PANEL: WSZYSTKO (header, klient, termin, sumy, save)
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ROW 0: Header usunięty (więcej miejsca na resztę) -->
                <Border Grid.Row="0" Height="6"/>

                <!-- ROW 1: Search + tab Świeże/Mrożone -->
                <Grid Grid.Row="1" Margin="12,4,12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Margin="0,0,4,0">
                        <TextBox x:Name="TxtCustSearch" Style="{StaticResource InputBox}" TextChanged="TxtCustSearch_TextChanged" Padding="30,6,10,6" MinHeight="34" FontSize="13"/>
                        <TextBlock Text="🔍" FontSize="13" Margin="10,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="{StaticResource TextMuted}" IsHitTestVisible="False"/>
                        <TextBlock x:Name="TxtCustPlaceholder" Text="Szukaj…" FontSize="13" Margin="30,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="{StaticResource TextMuted}" IsHitTestVisible="False"/>
                    </Grid>
                    <Border Grid.Column="1" CornerRadius="6" Background="{StaticResource SurfaceAlt}"
                            BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="2"
                            Margin="4,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnSwieze" Content="🥩 Świeże" Click="BtnTypProduktu_Click" Tag="67095"
                                    Padding="9,4" Background="{StaticResource BrandGreen}" Foreground="White"
                                    FontWeight="SemiBold" FontSize="11" Cursor="Hand" BorderThickness="0"
                                    ToolTip="Ctrl+1">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="4" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="BtnMrozone" Content="❄ Mrożone" Click="BtnTypProduktu_Click" Tag="67153"
                                    Padding="9,4" Background="Transparent" Foreground="{StaticResource TextSecondary}"
                                    FontWeight="SemiBold" FontSize="11" Cursor="Hand" BorderThickness="0"
                                    ToolTip="Ctrl+2">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="4" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ROW 2: Avatary handlowców — WrapPanel (1 wiersz, zawija na 2-gi gdy nie mieści) -->
                <Border Grid.Row="2" Padding="8,6,8,6" x:Name="HandlowiecChipsContainer" Background="#F8FAFC" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,1">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="120">
                        <ItemsControl x:Name="lstHandlowiecChips">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="BtnHandlowiecChip_Click" Tag="{Binding Name}" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Padding="0" Margin="3"
                                            ToolTip="{Binding Name}" HorizontalAlignment="Center">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Width="38" Height="38" CornerRadius="19" ClipToBounds="True"
                                                        BorderBrush="{Binding BorderColor}" BorderThickness="2"
                                                        Background="{Binding InitialsBg}">
                                                    <Grid>
                                                        <TextBlock Text="{Binding Initials}" FontSize="12" FontWeight="Bold"
                                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <Image Source="{Binding Avatar}" Stretch="UniformToFill" Visibility="{Binding AvatarVisibility}"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- ROW 3+4: Klienci section (collapsible — ukrywana po wyborze, lista do samego dołu) -->
                <Border Grid.Row="3" Grid.RowSpan="2" x:Name="ClientListContainer" Visibility="Visible">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="16,6,16,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblCustListTitle" Text="Klienci" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="LblCustListCount" Grid.Column="1" Text="" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8,0">
                            <ItemsControl x:Name="ListCustomers">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Click="BtnCustomerCard_Click" Tag="{Binding Id}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,1" Cursor="Hand" HorizontalContentAlignment="Stretch">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="cardRoot" Background="Transparent" CornerRadius="5" Padding="10,7">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="cardRoot" Property="Background" Value="{StaticResource BrandGreenLight}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock Text="{Binding Nazwa}" FontSize="13" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ROW 5: Separator -->
                <Border Grid.Row="5" Height="1" Background="{StaticResource Border}" Margin="10,8"/>

                <!-- ROW 6: TERMIN INLINE (visible after customer selected) -->
                <Border Grid.Row="6" x:Name="SidebarTerminInfo" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,0">
                        <StackPanel>
                            <!-- Klient info: nazwa + limit + avatar handlowca w jednej linii (po prawej) -->
                            <Border Background="#EFF6E5" CornerRadius="6" Padding="10,8" Margin="0,0,0,8" BorderBrush="#C5DDA8" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="ChipName" Text="—" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" x:Name="ChipLimit" Text="🟢" FontSize="14" Margin="6,0,8,0" VerticalAlignment="Center" ToolTip="Limit kredytowy"/>
                                    <Border Grid.Column="2" x:Name="ChipHandlowiecAvatar" Width="28" Height="28" CornerRadius="14" ClipToBounds="True" Background="{StaticResource PrimaryGradient}"
                                            ToolTip="Handlowiec klienta">
                                        <TextBlock x:Name="ChipHandlowiecInitials" Text="?" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Data produkcji + Data odbioru side-by-side -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="🏭 Produkcja" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,3"/>
                                    <DatePicker x:Name="DpProd" Height="32" FontSize="13" SelectedDateChanged="DpProd_SelectedDateChanged"/>
                                    <TextBlock x:Name="LblProdDay" Text="" FontSize="11" Foreground="{StaticResource BrandGreenDark}" FontWeight="SemiBold" Margin="2,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <TextBlock x:Name="LblOdbiorHeader" Text="🚚 Odbiór u klienta" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,3"/>
                                    <DatePicker x:Name="DpOdbior" Height="32" FontSize="13" SelectedDateChanged="DpOdbior_SelectedDateChanged"/>
                                    <TextBlock x:Name="LblOdbiorDay" Text="" FontSize="11" Foreground="{StaticResource BrandGreenDark}" FontWeight="SemiBold" Margin="2,2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Godzina + clock-popup button -->
                            <Grid Margin="0,6,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblGodzinaHeader" Text="⏱ Godzina u klienta" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="TxtCustomHour" Width="76" Height="32" Padding="6,2" FontSize="13" FontWeight="SemiBold"
                                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                         BorderBrush="{StaticResource BorderStrong}" BorderThickness="1.5" Text="08:00"
                                         KeyDown="TxtCustomHour_KeyDown" TextChanged="TxtCustomHour_TextChanged" LostFocus="TxtCustomHour_LostFocus"/>
                                <Button Grid.Column="2" x:Name="BtnHourHelp" Click="BtnHourHelp_Click" Width="32" Height="32" Margin="4,0,0,0"
                                        Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1" Cursor="Hand"
                                        ToolTip="Pomoc z ustaleniem godziny — klik chipy">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="5" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="🕐" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Popup x:Name="HourPopup" PlacementTarget="{Binding ElementName=BtnHourHelp}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12" MinWidth="280" Effect="{StaticResource ElevatedShadow}">
                                        <StackPanel>
                                            <TextBlock Text="🕐 Wybierz godzinę" FontSize="13" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="Klikaj chipy aby ustawić — najczęstsze klienta" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                                            <ItemsControl x:Name="ListHours">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Click="BtnHourChip_Click" Tag="{Binding Hour}" Background="Transparent" BorderThickness="0" Padding="0" Margin="3" Cursor="Hand" MinWidth="64">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border CornerRadius="5" BorderThickness="1" Background="{Binding BgBrush}" BorderBrush="{Binding BorderBrush}" Padding="0,7">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                            <TextBlock Text="{Binding HourDisplay}" FontWeight="SemiBold" FontSize="13" Foreground="{Binding ForeBrush}"/>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>

                            <!-- Transport -->
                            <CheckBox x:Name="ChkWlasnyOdbior" Content="🚚 Klient własnym transportem"
                                      FontSize="12" FontWeight="SemiBold" Margin="0,4,0,8"
                                      Checked="ChkWlasnyOdbior_Changed" Unchecked="ChkWlasnyOdbior_Changed"/>

                            <!-- Notatka -->
                            <TextBlock Text="📝 Notatka" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,2"/>
                            <Border CornerRadius="5" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1">
                                <Grid>
                                    <TextBox x:Name="TxtUwagi" BorderThickness="0" Background="Transparent" AcceptsReturn="True" TextWrapping="Wrap" Padding="8,6" MinHeight="50" MaxHeight="100" VerticalScrollBarVisibility="Auto" FontSize="12" TextChanged="TxtUwagi_TextChanged"/>
                                    <TextBlock x:Name="TxtUwagiPlaceholder" Text="📝 Notatka (opcjonalnie)…" Margin="8,6,0,0" Foreground="{StaticResource TextMuted}" FontSize="12" IsHitTestVisible="False"/>
                                </Grid>
                            </Border>

                            <!-- Sugestie notatek: smart ranking (klient + recency + frequency + koszyk + szablony) -->
                            <StackPanel x:Name="NoteSuggestionsPanel" Margin="0,4,0,0" Visibility="Collapsed">
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblNoteSuggestionsHeader" Text="💡 Propozycje" FontSize="9" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" x:Name="BtnSaveNoteTemplate" Content="💾 Zapisz jako szablon"
                                            Click="BtnSaveNoteTemplate_Click" FontSize="9" Padding="5,2" Margin="4,0,3,0"
                                            Background="Transparent" BorderBrush="{StaticResource Border}" BorderThickness="1"
                                            Foreground="{StaticResource TextSecondary}" Cursor="Hand"
                                            ToolTip="Zapisz aktualną notatkę jako szablon (do wielokrotnego użycia)"/>
                                    <Button Grid.Column="2" x:Name="BtnManageNoteTemplates" Content="⚙"
                                            Click="BtnManageNoteTemplates_Click" FontSize="9" Padding="5,2"
                                            Background="Transparent" BorderBrush="{StaticResource Border}" BorderThickness="1"
                                            Foreground="{StaticResource TextSecondary}" Cursor="Hand"
                                            ToolTip="Zarządzaj szablonami notatek"/>
                                </Grid>
                                <ItemsControl x:Name="ListNoteSuggestions">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Display}" Tag="{Binding Text}" ToolTip="{Binding Tooltip}"
                                                    Click="BtnNoteSuggestion_Click"
                                                    Padding="6,2" Margin="0,0,3,3" FontSize="10"
                                                    Background="{Binding ChipBrush}" BorderBrush="{Binding ChipBorderBrush}" BorderThickness="1"
                                                    Foreground="{StaticResource TextPrimary}" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border CornerRadius="3" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ROW 7: Separator -->
                <Border Grid.Row="7" Height="1" Background="{StaticResource Border}" Margin="12,10"/>

                <!-- ROW 8: Sumy + paski palety/limit -->
                <StackPanel Grid.Row="8" Margin="14,4,14,6">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="POZ" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TotPozycje" Text="0" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="POJ" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TotPojemniki" Text="0" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="KG" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TotKg" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrandGreenDark}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,3,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🚛" FontSize="13" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Height="8" Background="#E5E7EB" CornerRadius="4" Margin="6,0" VerticalAlignment="Center">
                            <Border x:Name="HdrProgressPalety" Background="{StaticResource BrandGreen}" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                        </Border>
                        <TextBlock Grid.Column="2" x:Name="HdrTotPalety" Text="0" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="28" TextAlignment="Right"/>
                    </Grid>
                    <TextBlock x:Name="HdrLblPaletyHint" Text="Solówka 18 / TIR 33" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="20,0,0,4"/>

                    <Grid Margin="0,2,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="💳" FontSize="13" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Height="8" Background="#E5E7EB" CornerRadius="4" Margin="6,0" VerticalAlignment="Center">
                            <Border x:Name="HdrProgressLimit" Background="{StaticResource Success}" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                        </Border>
                        <TextBlock Grid.Column="2" x:Name="HdrLimitPctLabel" Text="—" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="40" TextAlignment="Right"/>
                    </Grid>
                    <TextBlock x:Name="HdrLblLimitHint" Text="" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="20,0,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- ROW 9: Buttons Anuluj/Zapisz + Skróty -->
                <StackPanel Grid.Row="9" Margin="14,8,14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource GhostButton}" Content="Anuluj" Click="BtnCancel_Click" Padding="14,9" MinHeight="40" FontSize="13" Margin="0,0,4,0" ToolTip="Esc"/>
                        <Button Grid.Column="1" x:Name="BtnSave" Style="{StaticResource PrimaryButton}" Content="✓ Zapisz" Click="BtnSave_Click" IsEnabled="False" Padding="14,9" MinHeight="40" FontSize="13" Margin="4,0,0,0" ToolTip="Ctrl+S"/>
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <ToggleButton x:Name="BtnHotkeysHelp" Content="⌨ Skróty klawiaturowe (F1)"
                                      Background="Transparent" BorderThickness="0" Cursor="Hand"
                                      FontSize="10" Foreground="{StaticResource TextMuted}"
                                      HorizontalAlignment="Center" Padding="6,3"/>
                        <Popup x:Name="PopupHotkeys" PlacementTarget="{Binding ElementName=BtnHotkeysHelp}"
                               Placement="Top" StaysOpen="False" AllowsTransparency="True"
                               IsOpen="{Binding IsChecked, ElementName=BtnHotkeysHelp, Mode=TwoWay}">
                            <Border Background="White" CornerRadius="8" Padding="14"
                                    BorderBrush="{StaticResource Border}" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Color="#0F172A" Opacity="0.15"/>
                                </Border.Effect>
                                <StackPanel MinWidth="260">
                                    <TextBlock Text="⌨ Skróty klawiaturowe" FontWeight="Bold" FontSize="13"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="78"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left"><TextBlock Text="Ctrl+S" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/></Border>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Zapisz zamówienie" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,4"/>

                                        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left"><TextBlock Text="Esc" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/></Border>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Anuluj / zamknij okno" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,4"/>

                                        <Border Grid.Row="2" Grid.Column="0" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left"><TextBlock Text="Ctrl+F" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/></Border>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Szukaj klienta (focus)" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,4"/>

                                        <Border Grid.Row="3" Grid.Column="0" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left"><TextBlock Text="Ctrl+R" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/></Border>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="Powtórz ostatnie zamówienie" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,4"/>

                                        <Border Grid.Row="4" Grid.Column="0" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left"><TextBlock Text="Ctrl+1" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/></Border>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="Katalog: 🥩 Świeże" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,4"/>

                                        <Border Grid.Row="5" Grid.Column="0" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left"><TextBlock Text="Ctrl+2" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/></Border>
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="Katalog: ❄ Mrożone" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,4"/>

                                        <Border Grid.Row="6" Grid.Column="0" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left"><TextBlock Text="Ctrl+N" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/></Border>
                                        <TextBlock Grid.Row="6" Grid.Column="1" Text="Wyczyść koszyk" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,4"/>

                                        <Border Grid.Row="7" Grid.Column="0" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left"><TextBlock Text="Tab" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/></Border>
                                        <TextBlock Grid.Row="7" Grid.Column="1" Text="Następne pole" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,4"/>

                                        <Border Grid.Row="8" Grid.Column="0" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,0" HorizontalAlignment="Left"><TextBlock Text="F1" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/></Border>
                                        <TextBlock Grid.Row="8" Grid.Column="1" Text="Pokaż / ukryj te skróty" FontSize="12" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             PRAWY PANEL: PRODUKTY
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Background="{StaticResource AppBackground}" Padding="0">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,8,4,8">
                        <!-- Smart-fill koszyka: chipy z historii klienta (klik = pre-fill ilość/cena/flagi z ostatniego zamówienia) -->
                        <Border x:Name="KoszykSuggestionsPanel" Visibility="Collapsed" Background="#F0F9FF" BorderBrush="#7DD3FC" BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,0,4,8">
                            <StackPanel>
                                <Grid Margin="2,0,2,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="📋" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LblKoszykSuggestionsHeader" Text="Smart-fill (z historii klienta)" FontSize="10" FontWeight="Bold" Foreground="#075985" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="BtnRepeatLast" Click="BtnRepeatLast_Click"
                                            FontSize="9" Padding="6,2" Margin="0,0,4,0"
                                            Background="#FFF8EA" BorderBrush="#FFD8A8" BorderThickness="1"
                                            Foreground="#92590B" Cursor="Hand"
                                            ToolTip="Powtórz ostatnie zamówienie tego klienta (Ctrl+R)">
                                        <TextBlock Text="🔄 Powtórz" FontSize="9" FontWeight="SemiBold"/>
                                    </Button>
                                    <Button Grid.Column="2" x:Name="BtnFillTypowe" Content="🪄 Wstaw typowe (top 5)"
                                            Click="BtnFillTypowe_Click"
                                            FontSize="9" Padding="6,2"
                                            Background="#0EA5E9" BorderBrush="#0284C7" BorderThickness="1"
                                            Foreground="White" Cursor="Hand"
                                            ToolTip="Wstaw 5 najczęściej zamawianych produktów tego klienta z domyślnymi ilościami z ostatniego zamówienia"/>
                                </Grid>
                                <ItemsControl x:Name="ListKoszykSuggestions">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Tag="{Binding KodTowaru}" ToolTip="{Binding Tooltip}"
                                                    Click="BtnKoszykSuggestion_Click"
                                                    Padding="4,2" Margin="0,0,4,4"
                                                    Background="White" BorderBrush="#7DD3FC" BorderThickness="1"
                                                    Foreground="#075985" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <!-- Miniatura towaru 24x24 LUB placeholder 📦 -->
                                                    <Border Width="24" Height="24" CornerRadius="4" ClipToBounds="True" VerticalAlignment="Center" Margin="0,0,5,0">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Offset="0" Color="#FAFCF7"/>
                                                                <GradientStop Offset="1" Color="#F0F4EB"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Grid>
                                                            <TextBlock Visibility="{Binding PlaceholderVisibility}" Text="📦" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            <Image Source="{Binding ImageSource}" Visibility="{Binding HasImageVisibility}" Stretch="Uniform"/>
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Text="{Binding Display}" FontSize="11" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border x:Name="FavoritesPanel" Visibility="Collapsed" Background="#FFFCF0" BorderBrush="#FFD8A8" BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,0,4,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2,0,2,6">
                                    <TextBlock Text="⭐" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="Najczęściej kupowane" FontSize="10" FontWeight="Bold" Foreground="#92590B" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="LblFavoritesCount" Text="" FontSize="9" Foreground="#92590B" Margin="6,0,0,0" Opacity="0.7" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ItemsControl x:Name="ListFavorites" ItemTemplate="{StaticResource ProductCardTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <ItemsControl x:Name="ListProducts" ItemTemplate="{StaticResource ProductCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══ HIDDEN PROXIES (legacy x:Name compatibility) ═══ -->
        <Grid Visibility="Collapsed" Width="0" Height="0">
            <StackPanel>
                <Border x:Name="HeaderChip"/>
                <TextBlock x:Name="ChipTermin"/>
                <TextBlock x:Name="ChipTransport"/>
                <TextBlock x:Name="ChipPalety"/>
                <Button x:Name="BtnTerminChip"/>
                <Button x:Name="BtnStep2"/>
                <Button x:Name="BtnPrev"/>
                <Button x:Name="BtnNext"/>
                <Border x:Name="Step1Circle"/>
                <TextBlock x:Name="Step1Num"/>
                <TextBlock x:Name="Step1Sub"/>
                <TextBlock x:Name="Step2Sub"/>
                <Border x:Name="Step3Circle"/>
                <TextBlock x:Name="Step3Num"/>
                <TextBlock x:Name="Step3Sub"/>
                <Border x:Name="CustomerStrip"/>
                <Border x:Name="CustAvatarBorder"/>
                <TextBlock x:Name="CustInitials"/>
                <TextBlock x:Name="CustName"/>
                <TextBlock x:Name="CustNip"/>
                <TextBlock x:Name="CustNipSep"/>
                <TextBlock x:Name="CustAddress"/>
                <TextBlock x:Name="CustHandlowiec"/>
                <!-- Hidden proxies dla usuniętych elementów chipa klienta — kod xaml.cs nadal je pisze (FindName) -->
                <Border x:Name="ChipAvatar"/>
                <TextBlock x:Name="ChipInitials"/>
                <StackPanel x:Name="ChipHandlowiecRow"/>
                <TextBlock x:Name="ChipHandlowiecName"/>
                <CheckBox x:Name="ChkSidebarWlasny"/>
                <Border x:Name="TerminContainer"/>
                <TextBlock x:Name="ValKlient"/>
                <Border x:Name="ValKlientChip"/>
                <TextBlock x:Name="ValTermin"/>
                <Border x:Name="ValTerminChip"/>
                <TextBlock x:Name="ValPozycje"/>
                <Border x:Name="ValPozycjeChip"/>
                <TextBlock x:Name="LblHeaderHint"/>
                <TextBlock x:Name="LblAllProducts"/>
                <TextBox x:Name="TxtProductSearch"/>
                <TextBlock x:Name="TxtProductPlaceholder"/>
                <TextBlock x:Name="TotPalety" Text="0"/>
                <Border x:Name="ProgressPalety"/>
                <TextBlock x:Name="LblPaletyHint"/>
                <TextBlock x:Name="LimitPctLabel"/>
                <Border x:Name="ProgressLimit"/>
                <TextBlock x:Name="LblLimitHint"/>
                <TextBlock x:Name="LblTerminMain"/>
                <TextBlock x:Name="LblTerminSub"/>
                <TextBlock x:Name="SbProdMain"/>
                <TextBlock x:Name="SbProdSub"/>
                <TextBlock x:Name="HdrTerminMain"/>
                <TextBlock x:Name="HdrTerminSub"/>
                <TextBlock x:Name="SbTransport"/>
                <TextBlock x:Name="LblProdSelected"/>
                <TextBlock x:Name="LblOdbiorSelected"/>
                <ItemsControl x:Name="ListDaysProd"/>
                <ItemsControl x:Name="ListDays"/>
                <ToggleButton x:Name="BtnCartToggle"/>
                <ItemsControl x:Name="ListCart"/>
                <Border x:Name="EmptyCartHint"/>
                <TextBlock x:Name="LblCartCount"/>
            </StackPanel>
        </Grid>

        <!-- TOAST -->
        <!-- ═══ CONFIRMATION DIALOG (overlay) ═══ -->
        <Border x:Name="ConfirmOverlay" Grid.ColumnSpan="2" Visibility="Collapsed" Background="#90000000">
            <Border MaxWidth="1500" Margin="30" CornerRadius="14" Background="White" Padding="22" VerticalAlignment="Stretch" HorizontalAlignment="Center" Effect="{StaticResource ElevatedShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Title -->
                        <TextBlock Text="✓ Potwierdź zamówienie" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,14"/>

                        <!-- Klient + Handlowiec -->
                        <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,12" BorderBrush="#C5DDA8" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#EFF6E5"/>
                                    <GradientStop Offset="1" Color="#E8F1DC"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ConfirmAvatar" Width="54" Height="54" CornerRadius="27" Background="{StaticResource PrimaryGradient}">
                                    <TextBlock x:Name="ConfirmInitials" Text="?" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="ConfirmCustomerName" Text="—" FontSize="17" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock x:Name="ConfirmCustomerSub" Text="" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                                    <StackPanel x:Name="ConfirmHandlowiecRow" Orientation="Horizontal" Margin="0,5,0,0" Visibility="Collapsed">
                                        <Border x:Name="ConfirmHandlowiecAvatar" Width="28" Height="28" CornerRadius="14" ClipToBounds="True" Background="{StaticResource PrimaryGradient}">
                                            <TextBlock x:Name="ConfirmHandlowiecInitials" Text="?" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock x:Name="ConfirmHandlowiecName" Text="—" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="2" x:Name="ConfirmLimitChip" Text="🟢" FontSize="18" VerticalAlignment="Center" ToolTip="Limit kredytowy"/>
                            </Grid>
                        </Border>

                        <!-- TYDZIEŃ wizualizacja -->
                        <TextBlock x:Name="ConfirmWeekTitle" Text="📆 Tydzień zamówienia" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6"/>
                        <Border x:Name="ConfirmWeekContainer" CornerRadius="10" BorderBrush="{StaticResource Border}" BorderThickness="1" Background="White" Padding="10,8" Margin="0,0,0,12">
                            <ItemsControl x:Name="ConfirmWeekItems">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><UniformGrid Columns="7"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Background="{Binding BgBrush}" BorderBrush="{Binding BorderBrush}" BorderThickness="2" Padding="4,8" Margin="3">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding DayName}" FontSize="10" FontWeight="SemiBold" Foreground="{Binding ForeBrush}" HorizontalAlignment="Center" Opacity="0.8"/>
                                                <TextBlock Text="{Binding DayNum}" FontSize="22" FontWeight="Bold" Foreground="{Binding ForeBrush}" HorizontalAlignment="Center" Margin="0,2"/>
                                                <TextBlock Text="{Binding Marker}" FontSize="14" HorizontalAlignment="Center" MinHeight="18"/>
                                                <TextBlock Text="{Binding HourLabel}" FontSize="11" FontWeight="Bold" Foreground="{Binding ForeBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding MarkerLabel}" FontSize="9" FontWeight="Bold" Foreground="{Binding ForeBrush}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Godzina (duża) + Transport -->
                        <Grid x:Name="ConfirmGodzinaTransportGrid" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="10" Padding="14,10" Margin="0,0,6,0" Background="#EFF6E5" BorderBrush="#C5DDA8" BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="⏱ Godzina" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ConfirmGodzina" Text="—" FontSize="36" FontWeight="Bold" Foreground="{StaticResource BrandGreenDark}" HorizontalAlignment="Center" LineHeight="40"/>
                                    <TextBlock x:Name="ConfirmGodzinaDay" Text="" FontSize="12" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" CornerRadius="10" Padding="14,10" Margin="6,0,0,0" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🚛 Transport" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ConfirmTransport" Text="—" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,4,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="ConfirmTransportSub" Text="" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Danger}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Notatka (tylko gdy jest) -->
                        <Border x:Name="ConfirmNotatkaContainer" CornerRadius="8" Padding="12,8" Margin="0,0,0,12" Background="#FFF8EA" BorderBrush="#FFD8A8" BorderThickness="1" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="📝 Notatka" FontSize="11" FontWeight="SemiBold" Foreground="#92590B"/>
                                <TextBlock x:Name="ConfirmNotatka" Text="" FontSize="12" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Diff panel — tylko w edit-mode + są zmiany. W tym trybie reszta widoku jest ukryta. -->
                        <Border x:Name="ConfirmDiffPanel" Visibility="Collapsed" CornerRadius="10" Padding="14,12" Margin="0,0,0,12" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="📝" FontSize="15" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ConfirmDiffHeader" Text="Zmiany w zamówieniu" FontSize="14" FontWeight="Bold" Foreground="#0F172A" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#0EA5E9" CornerRadius="12" Padding="10,3" VerticalAlignment="Center">
                                        <TextBlock x:Name="ConfirmDiffBadge" Text="0" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </Grid>
                                <ItemsControl x:Name="ConfirmDiffList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{Binding RowBorder}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,3" Background="{Binding RowBg}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="28"/>
                                                        <ColumnDefinition Width="46"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Kółko z ikoną zmiany (+ ~ −) -->
                                                    <Border Width="24" Height="24" CornerRadius="12" Background="{Binding IconBg}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding Icon}" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <!-- Miniatura towaru lub emoji dla pól (⏱ 🏭 🚚 📝) -->
                                                    <Border Grid.Column="1" Width="42" Height="42" CornerRadius="6" ClipToBounds="True" VerticalAlignment="Center" Margin="0,0,8,0" BorderBrush="#E2E8F0" BorderThickness="1">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Offset="0" Color="#FAFCF7"/>
                                                                <GradientStop Offset="1" Color="#F0F4EB"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Grid>
                                                            <TextBlock Text="{Binding PlaceholderEmoji}" Visibility="{Binding PlaceholderVisibility}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            <Image Source="{Binding ImageSource}" Visibility="{Binding HasImageVisibility}" Stretch="Uniform"/>
                                                        </Grid>
                                                    </Border>
                                                    <!-- Label + diff (before strike → after bold) -->
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Label}" Foreground="{Binding LabelColor}" FontWeight="Bold" FontSize="13"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                            <TextBlock Text="{Binding Before}" Foreground="#94A3B8" FontSize="11" TextDecorations="Strikethrough" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                            <TextBlock Text="  →  " Foreground="#475569" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="4,0"/>
                                                            <TextBlock Text="{Binding After}" Foreground="#0F172A" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Towary header -->
                        <Grid x:Name="ConfirmTowaryHeader" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📦 Zamawiane towary" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" x:Name="ConfirmBrakCenyChip" Visibility="Collapsed" CornerRadius="4" Padding="6,2" Background="#FFF3CD" BorderBrush="#FFD8A8" BorderThickness="1">
                                <TextBlock x:Name="ConfirmBrakCenyText" Text="" FontSize="11" FontWeight="SemiBold" Foreground="#92590B"/>
                            </Border>
                        </Grid>

                        <!-- Towary 4-column grid -->
                        <Border x:Name="ConfirmTowaryListContainer" CornerRadius="8" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="6">
                            <ItemsControl x:Name="ConfirmListItems">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><UniformGrid Columns="4"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="8,6" Margin="3" Background="White">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="44" Height="44" CornerRadius="6" ClipToBounds="True" VerticalAlignment="Center">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Offset="0" Color="#FAFCF7"/>
                                                            <GradientStop Offset="1" Color="#F0F4EB"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Grid>
                                                        <TextBlock Visibility="{Binding PlaceholderVisibility}" Text="{Binding PlaceholderEmoji}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <Image Source="{Binding ImageSource}" Visibility="{Binding HasImageVisibility}" Stretch="Uniform"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Kod}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Detail}" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,1,0,0"/>
                                                    <Grid Margin="0,3,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding IconE2}" Visibility="{Binding IconE2Visibility}" FontSize="10" Margin="0,0,3,0" ToolTip="40 E2"/>
                                                            <TextBlock Text="{Binding IconFolia}" Visibility="{Binding IconFoliaVisibility}" FontSize="10" Margin="0,0,3,0" ToolTip="Folia"/>
                                                            <TextBlock Text="{Binding IconHallal}" Visibility="{Binding IconHallalVisibility}" FontSize="10" Margin="0,0,3,0" ToolTip="Hallal"/>
                                                            <TextBlock Text="{Binding IconStrefa}" Visibility="{Binding IconStrefaVisibility}" FontSize="10" ToolTip="Strefa"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding WartoscDisplay}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource BrandGreenDark}" HorizontalAlignment="Right"/>
                                                            <TextBlock Text="{Binding CenaDisplay}" FontSize="9" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right" Visibility="{Binding CenaVisibility}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Sumy -->
                        <Border x:Name="ConfirmSumyContainer" CornerRadius="10" Padding="14,10" Margin="0,12,0,0" Background="#EFF6E5" BorderBrush="#C5DDA8" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ConfirmSumy" Text="—" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="ConfirmTotalWartosc" Text="" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BrandGreenDark}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Buttons sticky na dole — zawsze widoczne niezależnie od scrolla -->
                <Border Grid.Row="1" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Background="White" Padding="0,12,0,0" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource GhostButton}" Content="Anuluj" Click="BtnConfirmCancel_Click" Margin="0,0,6,0" MinHeight="48" FontSize="13"/>
                        <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="✓ Zapisz zamówienie" Click="BtnConfirmSave_Click" Margin="6,0,0,0" MinHeight="48" FontSize="15" FontWeight="Bold"/>
                    </Grid>
                </Border>
                </Grid>
            </Border>
        </Border>

        <!-- ═══════════════ LIMIT KURCZAKA A — overlay (fade-in animuje się z code-behind) ═══════════════ -->
        <Border x:Name="LimitOverlay" Grid.ColumnSpan="2" Visibility="Collapsed" Background="#B0000000" MouseDown="LimitOverlay_MouseDown">
            <Border x:Name="LimitOverlayCard" MaxWidth="640" MaxHeight="780" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="White" CornerRadius="20" Padding="0" Effect="{StaticResource ElevatedShadow}"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="LimitOverlayCardScale" ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER: czerwony pas z ostrzeżeniem -->
                    <Border Grid.Row="0" CornerRadius="20,20,0,0" Padding="28,24,28,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#DC2626"/>
                                <GradientStop Offset="1" Color="#991B1B"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="LimitOverlayIcon" Text="⚠" FontSize="48" Foreground="White" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="LimitOverlayHeader" Text="ZA DUŻO KURCZAKA A!" FontSize="26" FontWeight="Bold" Foreground="White" LineHeight="30"/>
                                <TextBlock x:Name="LimitOverlayHeaderSub" Text="Przekraczasz limit 92% planu produkcyjnego" FontSize="13" Foreground="#FECACA" Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- BODY -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="28,20,28,16">

                            <!-- Karta produktu z avatarem/zdjęciem -->
                            <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="12" Padding="16,12" Margin="0,0,0,18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="72" Height="72" CornerRadius="10" ClipToBounds="True" Background="#F1F5F9">
                                        <Grid>
                                            <Image x:Name="LimitOverlayImage" Stretch="UniformToFill"/>
                                            <TextBlock x:Name="LimitOverlayEmoji" Text="🍗" FontSize="38" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="LimitOverlayKod" Text="—" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                                        <TextBlock Text="Próbujesz dodać/zwiększyć:" FontSize="11" Foreground="#64748B" Margin="0,4,0,2"/>
                                        <TextBlock x:Name="LimitOverlayWpisano" Text="0 kg" FontSize="22" FontWeight="Bold" Foreground="#DC2626"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Wyjaśnienie — duże litery -->
                            <TextBlock x:Name="LimitOverlayExplain"
                                       Text="Łączna ilość Kurczaka A w zamówieniach na ten dzień przekroczy limit produkcyjny. Aby uniknąć konfliktu między handlowcami, MOŻESZ ZAMÓWIĆ MAKSYMALNIE 92% planowanej produkcji."
                                       FontSize="14" Foreground="#0F172A" TextWrapping="Wrap" Margin="0,0,0,18" LineHeight="22"/>

                            <!-- Tabelka KPI -->
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="0" Margin="0,0,0,16">
                                <StackPanel>
                                    <!-- Plan -->
                                    <Grid Margin="14,12,14,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="LimitOverlayPlanTitle" Text="📊 Plan produkcyjny" FontSize="12" Foreground="#64748B"/>
                                            <TextBlock x:Name="LimitOverlayPlanInfo" Text="—" FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" x:Name="LimitOverlayPlan" Text="0 kg" FontSize="16" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"/>
                                    <!-- Stan -->
                                    <Grid Margin="14,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="📦 Stan z poprzedniego dnia" FontSize="12" Foreground="#64748B"/>
                                            <TextBlock Text="zostało z wczoraj" FontSize="11" Foreground="#94A3B8"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" x:Name="LimitOverlayStan" Text="0 kg" FontSize="16" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"/>
                                    <!-- Limit 92% -->
                                    <Grid Margin="14,8" Background="#FEF3C7">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,6,0,6">
                                            <TextBlock x:Name="LimitOverlayLimitTitle" Text="🎯 LIMIT 92% (Plan + Stan)" FontSize="12" FontWeight="Bold" Foreground="#92400E"/>
                                            <TextBlock Text="maksymalne sumaryczne zamówienie na ten dzień" FontSize="11" Foreground="#92400E" Opacity="0.85"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" x:Name="LimitOverlayLimit" Text="0 kg" FontSize="18" FontWeight="Bold" Foreground="#92400E" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"/>
                                    <!-- Zamówione przez innych -->
                                    <Grid Margin="14,8,14,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="🛒 Już zamówione (inne zamówienia)" FontSize="12" Foreground="#64748B"/>
                                            <TextBlock Text="bez tego zamówienia" FontSize="11" Foreground="#94A3B8"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" x:Name="LimitOverlaySumaInnych" Text="0 kg" FontSize="16" FontWeight="Bold" Foreground="#475569" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Sugerowana wartość — zielona ramka -->
                            <Border Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="2" CornerRadius="12" Padding="18,14">
                                <StackPanel>
                                    <TextBlock Text="✓ Maksymalnie możesz zamówić:" FontSize="13" FontWeight="SemiBold" Foreground="#15803D"/>
                                    <TextBlock x:Name="LimitOverlaySuggest" Text="0 kg" FontSize="34" FontWeight="Bold" Foreground="#15803D" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="LimitOverlaySuggestHint" Text="" FontSize="11" Foreground="#15803D" Opacity="0.8" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- BUTTONS -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Background="#F9FAFB" CornerRadius="0,0,20,20" Padding="20,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource GhostButton}" Content="Anuluj" Click="BtnLimitCancel_Click" Margin="0,0,6,0" MinHeight="48" FontSize="13"/>
                            <Button Grid.Column="1" x:Name="BtnLimitAccept" Style="{StaticResource PrimaryButton}" Click="BtnLimitAccept_Click" Margin="6,0,0,0" MinHeight="48" FontSize="15" FontWeight="Bold">
                                <TextBlock x:Name="BtnLimitAcceptText" Text="✓ Wstaw 0 kg"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <Border x:Name="Toast" Grid.ColumnSpan="2" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,24" CornerRadius="8" Padding="14,10" Background="#1F2937" Effect="{StaticResource ElevatedShadow}">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ToastIcon" Text="✓" FontSize="14" Foreground="{StaticResource Success}" VerticalAlignment="Center"/>
                <TextBlock x:Name="ToastText" Text="" Foreground="White" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
