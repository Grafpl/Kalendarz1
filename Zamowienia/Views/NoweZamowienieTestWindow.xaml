<Window x:Class="Kalendarz1.Zamowienia.Views.NoweZamowienieTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Nowe zamówienie · TEST"
        Width="1400" Height="900"
        MinWidth="1180" MinHeight="780"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{DynamicResource AppBackground}"
        FontFamily="Segoe UI"
        FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- ═══════════════ KOLORY ═══════════════ -->
        <SolidColorBrush x:Key="BrandGreen"      Color="#5C8A3A"/>
        <SolidColorBrush x:Key="BrandGreenDark"  Color="#46682C"/>
        <SolidColorBrush x:Key="BrandGreenLight" Color="#E8F1DC"/>
        <SolidColorBrush x:Key="Surface"         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceAlt"      Color="#F9FAFB"/>
        <SolidColorBrush x:Key="Border"          Color="#EAEDF1"/>
        <SolidColorBrush x:Key="BorderStrong"    Color="#D1D5DB"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary"   Color="#64748B"/>
        <SolidColorBrush x:Key="TextMuted"       Color="#94A3B8"/>
        <SolidColorBrush x:Key="Success"         Color="#10B981"/>
        <SolidColorBrush x:Key="Warning"         Color="#F59E0B"/>
        <SolidColorBrush x:Key="Danger"          Color="#EF4444"/>
        <SolidColorBrush x:Key="Info"            Color="#3B82F6"/>

        <!-- Subtelny gradient tła aplikacji -->
        <LinearGradientBrush x:Key="AppBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0" Color="#F7F8FA"/>
            <GradientStop Offset="1" Color="#EEF1F5"/>
        </LinearGradientBrush>

        <!-- Gradient na primary button (subtelny) -->
        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0" Color="#6BA044"/>
            <GradientStop Offset="1" Color="#5C8A3A"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryGradientHover" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0" Color="#5C8A3A"/>
            <GradientStop Offset="1" Color="#46682C"/>
        </LinearGradientBrush>

        <!-- ═══════════════ DROP-SHADOW (subtle) ═══════════════ -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="3" Color="#0F172A" Opacity="0.06"/>
        <DropShadowEffect x:Key="ElevatedShadow" BlurRadius="32" ShadowDepth="6" Color="#0F172A" Opacity="0.14"/>
        <DropShadowEffect x:Key="HoverShadow" BlurRadius="24" ShadowDepth="4" Color="#5C8A3A" Opacity="0.18"/>

        <!-- ═══════════════ SCROLLBAR (cienki, nowoczesny) ═══════════════ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
        </Style>

        <!-- ═══════════════ PRIMARY BUTTON ═══════════════ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="root" Background="{TemplateBinding Background}" CornerRadius="10" SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="2" Color="#5C8A3A" Opacity="0.30"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="root" Property="Background" Value="{StaticResource PrimaryGradientHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="root" Property="Background" Value="#CBD5E1"/>
                                <Setter TargetName="root" Property="Effect" Value="{x:Null}"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════ GHOST BUTTON ═══════════════ -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="root" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════ ICON BUTTON ═══════════════ -->
        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- ═══════════════ CARD ═══════════════ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- ═══════════════ INPUT TEXTBOX ═══════════════ -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandGreen}"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════ STEPPER STEP ═══════════════ -->
        <Style x:Key="StepCircle" TargetType="Border">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- ═══════════════ CHIP (oblique pill) ═══════════════ -->
        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ═══════════════ NUMBER STEPPER (qty editor) ═══════════════ -->
        <Style x:Key="StepperButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════ PRODUCT CARD TEMPLATE (re-used by main list + favorites) ═══════════════ -->
        <DataTemplate x:Key="ProductCardTemplate">
            <Border Width="200" Margin="0,0,7,7" CornerRadius="10" Background="White" BorderBrush="{Binding ProductBorder}" BorderThickness="{Binding ProductBorderThickness}" Padding="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Color="#0F172A" Opacity="0.04"/>
                </Border.Effect>
                <StackPanel>
                    <!-- HEADER: thumbnail + name + cena + cart badge -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="26" Height="26" CornerRadius="5" ClipToBounds="True" VerticalAlignment="Top">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="#FAFCF7"/>
                                    <GradientStop Offset="1" Color="#F0F4EB"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <TextBlock Visibility="{Binding PlaceholderVisibility}" Text="{Binding PlaceholderEmoji}" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image Source="{Binding ImageSource}" Visibility="{Binding HasImageVisibility}" Stretch="UniformToFill"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="{Binding Kod}" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="28" LineHeight="13"/>
                            <TextBlock Text="{Binding KategoriaDisplay}" FontSize="9" Foreground="{StaticResource TextMuted}" Margin="0,1,0,0"/>
                        </StackPanel>
                        <!-- CENA obok nazwy -->
                        <Border Grid.Column="2" CornerRadius="4" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="2" VerticalAlignment="Top" Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBox BorderThickness="0" Background="Transparent" Width="38" Height="18" FontSize="10" FontWeight="SemiBold" Padding="2,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"
                                         Text="{Binding CenaDisplay, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Tag="{Binding Id}" LostFocus="TxtCena_LostFocus" ToolTip="Cena netto"/>
                                <TextBlock Text="zł" FontSize="9" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="1,0,3,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Visibility="{Binding InCartVisibility}" CornerRadius="5" Background="{StaticResource BrandGreen}" Padding="4,1" VerticalAlignment="Top" Margin="4,0,0,0">
                            <TextBlock Text="✓" FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </Grid>

                    <!-- 3 EDITABLE FIELDS: kg | poj | pal -->
                    <Border Margin="0,6,0,0" CornerRadius="6" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="2,3">
                                <TextBlock Text="kg" FontSize="9" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                <TextBox x:Name="FieldKg" Text="{Binding QtyKgDisplay, Mode=OneWay}" Tag="{Binding Id}"
                                         BorderThickness="0" Background="Transparent"
                                         HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                         FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimary}"
                                         TextChanged="TxtQty_TextChanged" KeyDown="TxtQty_KeyDown" LostFocus="TxtQty_LostFocus" GotFocus="TxtNumeric_GotFocus"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{StaticResource Border}"/>
                            <StackPanel Grid.Column="2" Margin="2,3">
                                <TextBlock Text="poj" FontSize="9" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                <TextBox x:Name="FieldPoj" Text="{Binding PojDisplay, Mode=OneWay}" Tag="{Binding Id}"
                                         BorderThickness="0" Background="Transparent"
                                         HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                         FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimary}"
                                         TextChanged="TxtPoj_TextChanged" KeyDown="TxtPoj_KeyDown" LostFocus="TxtPoj_LostFocus" GotFocus="TxtNumeric_GotFocus"/>
                            </StackPanel>
                            <Border Grid.Column="3" Background="{StaticResource Border}"/>
                            <StackPanel Grid.Column="4" Margin="2,3">
                                <TextBlock Text="pal" FontSize="9" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                <TextBox x:Name="FieldPal" Text="{Binding PalDisplay, Mode=OneWay}" Tag="{Binding Id}"
                                         BorderThickness="0" Background="Transparent"
                                         HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                         FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimary}"
                                         TextChanged="TxtPal_TextChanged" KeyDown="TxtPal_KeyDown" LostFocus="TxtPal_LostFocus" GotFocus="TxtNumeric_GotFocus"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- options (kolory zgodne z głównym widokiem zamówień) -->
                    <UniformGrid Rows="1" Columns="4" Margin="0,6,0,0">
                        <Border Background="#FEF2F2" CornerRadius="4" Padding="4,2" Margin="0,0,3,0" ToolTip="40 pojemników/paletę">
                            <CheckBox Content="40 E2" IsChecked="{Binding E2, Mode=TwoWay}" Tag="{Binding Id}" Click="ChkOpcja_Click" FontSize="9" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Background="#F0F7ED" CornerRadius="4" Padding="4,2" Margin="0,0,3,0" ToolTip="Zapakowane w folię">
                            <CheckBox Content="Folia" IsChecked="{Binding Folia, Mode=TwoWay}" Tag="{Binding Id}" Click="ChkOpcja_Click" FontSize="9" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Background="#F0FFF0" CornerRadius="4" Padding="4,2" Margin="0,0,3,0" ToolTip="Cięty zgodnie z Hallal">
                            <CheckBox Content="🔪 Hallal" IsChecked="{Binding Hallal, Mode=TwoWay}" Tag="{Binding Id}" Click="ChkOpcja_Click" FontSize="9" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Background="#FFEBEE" CornerRadius="4" Padding="4,2" ToolTip="Strefa ptasiej grypy / pomoru">
                            <CheckBox Content="⚠️ Strefa" IsChecked="{Binding Strefa, Mode=TwoWay}" Tag="{Binding Id}" Click="ChkOpcja_Click" FontSize="9" HorizontalAlignment="Center"/>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- unified top bar (title + chip + stepper + user/close) -->
            <RowDefinition Height="*"/>
            <!-- main content -->
            <RowDefinition Height="Auto"/>
            <!-- action bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             UNIFIED TOP BAR
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid Margin="20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- title -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- customer chip -->
                    <ColumnDefinition Width="*"/>
                    <!-- spacer -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- stepper -->
                    <ColumnDefinition Width="*"/>
                    <!-- spacer -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- user/close -->
                </Grid.ColumnDefinitions>

                <!-- TITLE -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="10" Background="{StaticResource PrimaryGradient}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#5C8A3A" Opacity="0.30"/>
                        </Border.Effect>
                        <TextBlock Text="🛒" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Nowe zamówienie" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock x:Name="LblHeaderHint" Text="kreator 3-krokowy" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </StackPanel>

                <!-- CUSTOMER CHIP (compact pill, visible after selection) -->
                <Border Grid.Column="1" x:Name="HeaderChip" Visibility="Collapsed" Margin="14,0,0,0"
                        CornerRadius="22" Padding="4" BorderBrush="#C5DDA8" BorderThickness="1" VerticalAlignment="Center"
                        Cursor="Hand" MouseLeftButtonUp="HeaderChip_Click" ToolTip="Zmień klienta">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="#EFF6E5"/>
                            <GradientStop Offset="1" Color="#E8F1DC"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="ChipAvatar" Width="32" Height="32" CornerRadius="16" Background="{StaticResource PrimaryGradient}">
                            <TextBlock x:Name="ChipInitials" Text="?" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="9,0,4,0" VerticalAlignment="Center">
                            <TextBlock x:Name="ChipName" Text="—" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                <TextBlock Text="🚛" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ChipPalety" Text="0/33" FontSize="10" FontWeight="SemiBold" Margin="2,0,0,0" Foreground="{StaticResource BrandGreenDark}" VerticalAlignment="Center"/>
                                <TextBlock Text="·" FontSize="10" Margin="6,0" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                <TextBlock Text="💳" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ChipLimit" Text="—" FontSize="10" FontWeight="SemiBold" Margin="2,0,0,0" Foreground="{StaticResource BrandGreenDark}" VerticalAlignment="Center"/>
                                <TextBlock Text="·" FontSize="10" Margin="6,0" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                <TextBlock Text="📅" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ChipTermin" Text="—" FontSize="10" FontWeight="SemiBold" Margin="2,0,0,0" Foreground="{StaticResource BrandGreenDark}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="↻" FontSize="13" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="6,0,8,0"/>
                    </StackPanel>
                </Border>

                <!-- STEPPER (icon-based, compact) -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button x:Name="BtnStep1" Cursor="Hand" Background="Transparent" BorderThickness="0" Click="BtnStep1_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Step1Circle" Width="34" Height="34" CornerRadius="17" Background="{StaticResource BrandGreen}">
                                <TextBlock x:Name="Step1Num" Text="👤" FontSize="15" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Klient" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock x:Name="Step1Sub" Text="Wybierz odbiorcę" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Border Width="36" Height="2" Background="{StaticResource Border}" Margin="12,0" VerticalAlignment="Center"/>

                    <Button x:Name="BtnStep2" Cursor="Hand" Background="Transparent" BorderThickness="0" Click="BtnStep2_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Step2Circle" Width="34" Height="34" CornerRadius="17" Background="#E5E7EB">
                                <TextBlock x:Name="Step2Num" Text="📅" FontSize="15" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Termin" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock x:Name="Step2Sub" Text="Data i godzina" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Border Width="36" Height="2" Background="{StaticResource Border}" Margin="12,0" VerticalAlignment="Center"/>

                    <Button x:Name="BtnStep3" Cursor="Hand" Background="Transparent" BorderThickness="0" Click="BtnStep3_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Step3Circle" Width="34" Height="34" CornerRadius="17" Background="#E5E7EB">
                                <TextBlock x:Name="Step3Num" Text="🛒" FontSize="15" Foreground="{StaticResource TextSecondary}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Pozycje" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock x:Name="Step3Sub" Text="Wybierz produkty" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- USER + CLOSE -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LblUser" Text="" FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Style="{StaticResource IconButton}" Content="✕" Click="BtnClose_Click" ToolTip="Zamknij (Esc)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             MAIN CONTENT (left = step content, right = persistent cart)
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────── KROK 1: KLIENT ─────────── -->
            <Grid x:Name="PanelStep1" Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- search bar -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.ColumnSpan="2" Text="Wybierz klienta" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>

                        <Grid Grid.Row="1" Grid.Column="0">
                            <TextBox x:Name="TxtCustSearch" Style="{StaticResource InputBox}"
                                     TextChanged="TxtCustSearch_TextChanged" Padding="40,9,12,9"/>
                            <TextBlock Text="🔍" FontSize="14" Margin="14,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="{StaticResource TextMuted}" IsHitTestVisible="False"/>
                            <TextBlock x:Name="TxtCustPlaceholder" Text="Szukaj po nazwie, NIP, mieście…" FontSize="14"
                                       Margin="40,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left"
                                       Foreground="{StaticResource TextMuted}" IsHitTestVisible="False"/>
                        </Grid>

                        <ComboBox x:Name="CmbHandlowiec" Grid.Row="1" Grid.Column="1" Margin="12,0,0,0" Width="200"
                                  Height="40" VerticalContentAlignment="Center" FontSize="13"
                                  SelectionChanged="CmbHandlowiec_SelectionChanged"/>
                    </Grid>
                </Border>

                <!-- customers list -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="20,16,20,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblCustListTitle" Text="Ostatni klienci" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="LblCustListCount" Grid.Column="1" Text="" FontSize="11" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,0,12,16">
                            <ItemsControl x:Name="ListCustomers">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Click="BtnCustomerCard_Click" Tag="{Binding Id}" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,14,14" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="cardRoot" Background="White" CornerRadius="14" BorderBrush="{StaticResource Border}" BorderThickness="1" Width="290" Padding="16">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Color="#0F172A" Opacity="0.04"/>
                                                        </Border.Effect>
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="cardRoot" Property="BorderBrush" Value="{StaticResource BrandGreen}"/>
                                                            <Setter TargetName="cardRoot" Property="Effect" Value="{StaticResource HoverShadow}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- avatar with gradient -->
                                                <Border Width="44" Height="44" CornerRadius="22" Background="{Binding AvatarBrush}" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Initials}" FontWeight="Bold" FontSize="15" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Nazwa}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                                        <Border Grid.Column="1" CornerRadius="6" Padding="6,2" Margin="6,0,0,0" Background="{Binding LimitBadgeBg}">
                                                            <TextBlock Text="{Binding LimitBadge}" FontSize="9" FontWeight="Bold" Foreground="{Binding LimitBadgeFg}"/>
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Miejscowosc}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding NipDisplay}" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,1,0,0"/>
                                                    <Border Height="1" Background="{StaticResource Border}" Margin="0,9,0,9"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="🕒" FontSize="10" VerticalAlignment="Center" Opacity="0.7"/>
                                                            <TextBlock Text="{Binding LastOrderShort}" FontSize="10" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="3,0,0,0" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                            <TextBlock Text="👤" FontSize="10" VerticalAlignment="Center" Opacity="0.7"/>
                                                            <TextBlock Text="{Binding HandlowiecShort}" FontSize="10" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="3,0,0,0" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ─────────── KROK 2: TERMIN ─────────── -->
            <Grid x:Name="PanelStep2" Grid.Column="0" Margin="0,0,16,0" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- DATA PRODUKCJI (najpierw) -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="📅 Data produkcji" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                        <TextBlock Text="Najbliższe dni · lub wybierz datę z kalendarza" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <DatePicker x:Name="DpProd" Width="140" Margin="0,0,8,0" SelectedDateChanged="DpProd_SelectedDateChanged" ToolTip="Wybierz datę produkcji z kalendarza"/>
                                        <Border CornerRadius="8" Padding="10,6" Background="{StaticResource BrandGreenLight}" VerticalAlignment="Center">
                                            <TextBlock x:Name="LblProdSelected" Text="—" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrandGreenDark}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                                <ItemsControl x:Name="ListDaysProd" Margin="0,14,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="BtnDayProdCard_Click" Tag="{Binding Date}" Background="Transparent" BorderThickness="0" Padding="0" Margin="5" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="dayRoot" CornerRadius="12" BorderThickness="2" Background="{Binding BgBrush}" BorderBrush="{Binding BorderBrush}" Padding="12,12,12,10">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#0F172A" Opacity="0.04"/>
                                                            </Border.Effect>
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="dayRoot" Property="BorderBrush" Value="{StaticResource BrandGreen}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding DayName}" FontSize="10" FontWeight="SemiBold" Foreground="{Binding ForeBrush}" HorizontalAlignment="Center" Opacity="0.85"/>
                                                    <TextBlock Text="{Binding DayNum}" FontSize="24" FontWeight="Bold" Foreground="{Binding ForeBrush}" HorizontalAlignment="Center" Margin="0,1"/>
                                                    <TextBlock Text="{Binding MonthShort}" FontSize="9" Foreground="{Binding ForeBrush}" HorizontalAlignment="Center" Opacity="0.7" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- DATA ODBIORU (po produkcji) -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="🚚 Data odbioru" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                        <TextBlock Text="Najbliższe dni · lub wybierz datę z kalendarza" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <DatePicker x:Name="DpOdbior" Width="140" Margin="0,0,8,0" SelectedDateChanged="DpOdbior_SelectedDateChanged" ToolTip="Wybierz datę odbioru z kalendarza"/>
                                        <Border CornerRadius="8" Padding="10,6" Background="{StaticResource BrandGreenLight}" VerticalAlignment="Center">
                                            <TextBlock x:Name="LblOdbiorSelected" Text="—" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrandGreenDark}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <ItemsControl x:Name="ListDays" Margin="0,14,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="BtnDayCard_Click" Tag="{Binding Date}" Background="Transparent" BorderThickness="0" Padding="0" Margin="5" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="dayRoot" CornerRadius="12" BorderThickness="2" Background="{Binding BgBrush}" BorderBrush="{Binding BorderBrush}" Padding="12,12,12,10">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#0F172A" Opacity="0.04"/>
                                                            </Border.Effect>
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="dayRoot" Property="BorderBrush" Value="{StaticResource BrandGreen}"/>
                                                                <Setter TargetName="dayRoot" Property="Effect" Value="{StaticResource HoverShadow}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding DayName}" FontSize="10" FontWeight="SemiBold" Foreground="{Binding ForeBrush}" HorizontalAlignment="Center" Opacity="0.85"/>
                                                    <TextBlock Text="{Binding DayNum}" FontSize="24" FontWeight="Bold" Foreground="{Binding ForeBrush}" HorizontalAlignment="Center" Margin="0,1"/>
                                                    <TextBlock Text="{Binding MonthShort}" FontSize="9" Foreground="{Binding ForeBrush}" HorizontalAlignment="Center" Opacity="0.7" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- GODZINA -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="LblGodzinaHeader" Text="Godzina przyjazdu" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="Wybierz najbliższy slot lub wpisz własny" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkWlasnyOdbior" Grid.Column="1" Content="Klient odbiera własnym transportem" VerticalAlignment="Center"
                                              Checked="ChkWlasnyOdbior_Changed" Unchecked="ChkWlasnyOdbior_Changed"/>
                                </Grid>

                                <ItemsControl x:Name="ListHours" Margin="0,16,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="BtnHourChip_Click" Tag="{Binding Hour}" Background="Transparent" BorderThickness="0" Padding="0" Margin="3" Cursor="Hand" MinWidth="78">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="hRoot" CornerRadius="10" BorderThickness="1.5" Background="{Binding BgBrush}" BorderBrush="{Binding BorderBrush}" Padding="0,9">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="hRoot" Property="BorderBrush" Value="{StaticResource BrandGreen}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <TextBlock Text="{Binding HourDisplay}" FontWeight="SemiBold" FontSize="13" Foreground="{Binding ForeBrush}" HorizontalAlignment="Center"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Margin="0,16,0,0" CornerRadius="12" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="18,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" VerticalAlignment="Center">
                                            <TextBlock Text="⏱" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="14,0,16,0" VerticalAlignment="Center">
                                            <TextBlock Text="Inna godzina" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="format HH:mm — automatycznie zatwierdza po wpisaniu" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <TextBox Grid.Column="2" x:Name="TxtCustomHour" Width="160" Height="48" MinHeight="48" Padding="14,4" FontSize="20" FontWeight="SemiBold"
                                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                                 Background="White" BorderBrush="{StaticResource BorderStrong}" BorderThickness="2" Text="08:00" KeyDown="TxtCustomHour_KeyDown" TextChanged="TxtCustomHour_TextChanged" LostFocus="TxtCustomHour_LostFocus">
                                            <TextBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="10"/>
                                                </Style>
                                            </TextBox.Resources>
                                        </TextBox>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- (data produkcji jest wyżej — najpierw) -->
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ─────────── KROK 3: POZYCJE ─────────── -->
            <Grid x:Name="PanelStep3" Grid.Column="0" Margin="0,0,16,0" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- proxies dla kompatybilności z code-behindem (legacy: search bar usunięty) -->
                <Border Grid.Row="0" Visibility="Collapsed" Height="0">
                    <StackPanel>
                        <TextBox x:Name="TxtProductSearch"/>
                        <TextBlock x:Name="TxtProductPlaceholder"/>
                    </StackPanel>
                </Border>

                <!-- product catalog -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,14,6,14">
                        <StackPanel>
                            <!-- ⭐ NAJCZĘŚCIEJ KUPOWANE -->
                            <Border x:Name="FavoritesPanel" Visibility="Collapsed" Margin="0,0,0,12" CornerRadius="10" Padding="11,9" BorderBrush="#FFD8A8" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Offset="0" Color="#FFF8EA"/>
                                        <GradientStop Offset="1" Color="#FFEFD0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="⭐" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Text="Najczęściej kupowane" FontSize="11.5" FontWeight="Bold" Foreground="#92590B" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LblFavoritesCount" Text="" FontSize="10" Foreground="#92590B" Margin="8,0,0,0" Opacity="0.7" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ItemsControl x:Name="ListFavorites" ItemTemplate="{StaticResource ProductCardTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- WSZYSTKIE PRODUKTY (tytuł + Świeże/Mrożone toggle inline) -->
                            <Grid Margin="2,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblAllProducts" Text="Wszystkie produkty" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                <Border Grid.Column="2" CornerRadius="6" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="2">
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="BtnSwieze" Content="🥩 Świeże" Click="BtnTypProduktu_Click" Tag="67095"
                                                Padding="9,4" Background="{StaticResource BrandGreen}" Foreground="White" FontWeight="SemiBold" FontSize="10"
                                                Cursor="Hand" BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="4" Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button x:Name="BtnMrozone" Content="❄ Mrożone" Click="BtnTypProduktu_Click" Tag="67153"
                                                Padding="9,4" Background="Transparent" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold" FontSize="10"
                                                Cursor="Hand" BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="4" Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <ItemsControl x:Name="ListProducts" ItemTemplate="{StaticResource ProductCardTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════
                 SIDEBAR: customer panel + persistent CART
                 ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- customer panel -->
                        <RowDefinition Height="Auto"/>
                        <!-- cart title -->
                        <RowDefinition Height="*"/>
                        <!-- cart list -->
                        <RowDefinition Height="Auto"/>
                        <!-- cart footer -->
                    </Grid.RowDefinitions>

                    <!-- ═══════ CUSTOMER PANEL (visible after selection) ═══════ -->
                    <Border x:Name="CustomerStrip" Grid.Row="0" Visibility="Collapsed" BorderBrush="#C5DDA8" BorderThickness="0,0,0,1" CornerRadius="12,12,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#EFF6E5"/>
                                <GradientStop Offset="1" Color="#E8F1DC"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Margin="18,14">
                            <!-- Avatar + Name -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="CustAvatarBorder" Width="42" Height="42" CornerRadius="21">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Offset="0" Color="#6BA044"/>
                                            <GradientStop Offset="1" Color="#46682C"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock x:Name="CustInitials" Text="?" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="CustName" Text="—" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                        <TextBlock x:Name="CustNip" Text="" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBlock x:Name="CustNipSep" Text=" · " FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock x:Name="CustAddress" Text="" FontSize="10" Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                        <TextBlock Text="👤 " FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock x:Name="CustHandlowiec" Text="" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="2" Style="{StaticResource IconButton}" Width="26" Height="26" Content="↻" Click="BtnChangeCustomer_Click" ToolTip="Zmień klienta" FontSize="12" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- PALETY + LIMIT obok siebie -->
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Margin="0,0,4,0" CornerRadius="8" Padding="9,7" Background="White" BorderBrush="#C5DDA8" BorderThickness="1">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🚛" FontSize="11" VerticalAlignment="Center"/>
                                                <TextBlock Text="Palety" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock x:Name="HdrTotPalety" Grid.Column="1" Text="0" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Border Margin="0,4,0,0" Height="5" Background="#E5E7EB" CornerRadius="3" HorizontalAlignment="Stretch">
                                            <Border x:Name="HdrProgressPalety" Background="{StaticResource BrandGreen}" CornerRadius="3" HorizontalAlignment="Left" Width="0"/>
                                        </Border>
                                        <TextBlock x:Name="HdrLblPaletyHint" Text="Solówka 18 / TIR 33" FontSize="9" Foreground="{StaticResource TextMuted}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Margin="4,0,0,0" CornerRadius="8" Padding="9,7" Background="White" BorderBrush="#C5DDA8" BorderThickness="1">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="💳" FontSize="11" VerticalAlignment="Center"/>
                                                <TextBlock Text="Limit" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock x:Name="HdrLimitPctLabel" Grid.Column="1" Text="—" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Border Margin="0,4,0,0" Height="5" Background="#E5E7EB" CornerRadius="3" HorizontalAlignment="Stretch">
                                            <Border x:Name="HdrProgressLimit" Background="{StaticResource Success}" CornerRadius="3" HorizontalAlignment="Left" Width="0"/>
                                        </Border>
                                        <TextBlock x:Name="HdrLblLimitHint" Text="—" FontSize="9" Foreground="{StaticResource TextMuted}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- DATA PRODUKCJI + DATA AWIZACJI obok siebie -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Margin="0,0,4,0" CornerRadius="8" Padding="9,7" Background="White" BorderBrush="#C5DDA8" BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🏭" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="Produkcja" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock x:Name="SbProdMain" Text="—" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,3,0,0"/>
                                        <TextBlock x:Name="SbProdSub" Text="" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Margin="4,0,0,0" CornerRadius="8" Padding="9,7" Background="White" BorderBrush="#C5DDA8" BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📅" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="Awizacja" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock x:Name="HdrTerminMain" Text="—" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,3,0,0"/>
                                        <TextBlock x:Name="HdrTerminSub" Text="" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- TRANSPORT WŁASNY -->
                            <Border Margin="0,8,0,0" CornerRadius="8" Padding="9,6" Background="White" BorderBrush="#C5DDA8" BorderThickness="1">
                                <CheckBox x:Name="ChkSidebarWlasny" Content="🚚 Klient odbiera własnym transportem"
                                          FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                                          Checked="ChkSidebarWlasny_Changed" Unchecked="ChkSidebarWlasny_Changed"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- title -->
                    <Border Grid.Row="1" Padding="20,16" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛒" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Koszyk" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="1" CornerRadius="10" Background="{StaticResource BrandGreenLight}" Padding="8,2">
                                <TextBlock x:Name="LblCartCount" Text="0 pozycji" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource BrandGreenDark}"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- list of cart items -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="20,12">
                        <StackPanel>
                            <ItemsControl x:Name="ListCart">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="32" Height="32" CornerRadius="5" ClipToBounds="True" VerticalAlignment="Top" Margin="0,0,8,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Offset="0" Color="#FAFCF7"/>
                                                        <GradientStop Offset="1" Color="#F0F4EB"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Grid>
                                                    <TextBlock Visibility="{Binding PlaceholderVisibility}" Text="{Binding PlaceholderEmoji}" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <Image Source="{Binding ImageSource}" Visibility="{Binding HasImageVisibility}" Stretch="UniformToFill"/>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Kod}" FontWeight="SemiBold" FontSize="11.5" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="28" LineHeight="13"/>
                                                <TextBlock Text="{Binding Detail}" FontSize="10" Foreground="{StaticResource TextSecondary}" Margin="0,1,0,0"/>
                                                <Grid Margin="0,1,0,0" Visibility="{Binding CenaVisibility}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding CenaDisplay}" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding WartoscDisplay}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource BrandGreenDark}" HorizontalAlignment="Right"/>
                                                </Grid>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <Border Background="#FEF2F2" CornerRadius="3" Padding="3,1" Margin="0,0,3,0" Visibility="{Binding IconE2Visibility}" ToolTip="40 E2">
                                                        <TextBlock Text="{Binding IconE2}" FontSize="10"/>
                                                    </Border>
                                                    <Border Background="#F0F7ED" CornerRadius="3" Padding="3,1" Margin="0,0,3,0" Visibility="{Binding IconFoliaVisibility}" ToolTip="Folia">
                                                        <TextBlock Text="{Binding IconFolia}" FontSize="10"/>
                                                    </Border>
                                                    <Border Background="#F0FFF0" CornerRadius="3" Padding="3,1" Margin="0,0,3,0" Visibility="{Binding IconHallalVisibility}" ToolTip="Hallal">
                                                        <TextBlock Text="{Binding IconHallal}" FontSize="10"/>
                                                    </Border>
                                                    <Border Background="#FFEBEE" CornerRadius="3" Padding="3,1" Visibility="{Binding IconStrefaVisibility}" ToolTip="Strefa">
                                                        <TextBlock Text="{Binding IconStrefa}" FontSize="10"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="2" Style="{StaticResource IconButton}" Width="22" Height="22" Content="✕" Tag="{Binding Id}" Click="BtnCartRemove_Click" FontSize="10" ToolTip="Usuń pozycję" VerticalAlignment="Top"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border x:Name="EmptyCartHint" Padding="16,40" HorizontalAlignment="Stretch">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource BrandGreenLight}" HorizontalAlignment="Center">
                                        <TextBlock Text="🛒" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Koszyk jest pusty" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                    <TextBlock Text="Dodaj produkty w kroku 3" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- footer with summary totals + notatka -->
                    <Border Grid.Row="3" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Background="{StaticResource SurfaceAlt}">
                        <StackPanel Margin="20,14">
                            <!-- Totals row -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="POZYCJE" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotPozycje" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="POJEMNIKI" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotPojemniki" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="KILOGRAMY" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotKg" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrandGreenDark}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="{StaticResource Border}" Margin="0,4,0,12"/>

                            <!-- ukryte legacy proxies (kompatybilność z starym kodem) -->
                            <TextBlock x:Name="TotPalety" Text="0" Visibility="Collapsed"/>
                            <Border x:Name="ProgressPalety" Visibility="Collapsed"/>
                            <TextBlock x:Name="LblPaletyHint" Text="" Visibility="Collapsed"/>
                            <TextBlock x:Name="LimitPctLabel" Text="" Visibility="Collapsed"/>
                            <Border x:Name="ProgressLimit" Visibility="Collapsed"/>
                            <TextBlock x:Name="LblLimitHint" Text="" Visibility="Collapsed"/>
                            <TextBlock x:Name="LblTerminMain" Text="" Visibility="Collapsed"/>
                            <TextBlock x:Name="LblTerminSub" Text="" Visibility="Collapsed"/>

                            <!-- NOTATKA -->
                            <Border CornerRadius="10" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1">
                                <Grid>
                                    <TextBox x:Name="TxtUwagi" BorderThickness="0" Background="Transparent" AcceptsReturn="True" TextWrapping="Wrap" Padding="10,8" MinHeight="60" MaxHeight="100" VerticalScrollBarVisibility="Auto" TextChanged="TxtUwagi_TextChanged"/>
                                    <TextBlock x:Name="TxtUwagiPlaceholder" Text="📝 Notatka do zamówienia (opcjonalnie)…" Margin="10,8,0,0" Foreground="{StaticResource TextMuted}" FontSize="12" IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             ACTION BAR
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <Grid Margin="24,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- validation indicators -->
                <Border CornerRadius="20" Padding="6" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Border}" BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="ValKlientChip" CornerRadius="14" Padding="10,5" Background="Transparent">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ValKlient" Text="○" FontSize="13" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                <TextBlock Text="Klient" FontSize="11" FontWeight="SemiBold" Margin="6,0,0,0" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="ValTerminChip" CornerRadius="14" Padding="10,5" Background="Transparent" Margin="2,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ValTermin" Text="○" FontSize="13" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                <TextBlock Text="Termin" FontSize="11" FontWeight="SemiBold" Margin="6,0,0,0" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="ValPozycjeChip" CornerRadius="14" Padding="10,5" Background="Transparent" Margin="2,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ValPozycje" Text="○" FontSize="13" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                <TextBlock Text="Pozycje" FontSize="11" FontWeight="SemiBold" Margin="6,0,0,0" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Button Grid.Column="1" Style="{StaticResource GhostButton}" Content="◀ Wstecz" Click="BtnPrev_Click" Margin="0,0,8,0" x:Name="BtnPrev" Visibility="Collapsed"/>
                <Button Grid.Column="2" Style="{StaticResource GhostButton}" Content="Anuluj" Click="BtnCancel_Click" Margin="0,0,8,0"/>
                <Button Grid.Column="3" Style="{StaticResource GhostButton}" Content="Dalej ▶" Click="BtnNext_Click" Margin="0,0,8,0" x:Name="BtnNext"/>
                <Button Grid.Column="4" Style="{StaticResource PrimaryButton}" Content="✓ Zapisz zamówienie" Click="BtnSave_Click" x:Name="BtnSave" IsEnabled="False"/>
            </Grid>
        </Border>

        <!-- TOAST OVERLAY -->
        <Border x:Name="Toast" Grid.RowSpan="5" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,32,32" CornerRadius="10" Padding="18,12" Background="#1F2937" Effect="{StaticResource ElevatedShadow}">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ToastIcon" Text="✓" FontSize="16" Foreground="{StaticResource Success}" VerticalAlignment="Center"/>
                <TextBlock x:Name="ToastText" Text="" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
