<Window x:Class="Kalendarz1.KreatorPuliBilansuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kreator Puli Bilansu — składniki towarów"
        Height="720" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">
    <Window.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <Border Grid.Row="0" CornerRadius="10,10,0,0" Padding="18,14" Margin="0,0,0,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#16A085" Offset="0"/>
                    <GradientStop Color="#2980B9" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock Text="🧩 Kreator Puli Bilansu" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="#E8F8F5" TextWrapping="Wrap"
                           Text="Doczep do towaru-rodzica (np. Ćwiartka) inne towary-składniki (np. Noga, Pałka, Udziec). W „Podsumowaniu dnia” ich zamówienia i wydania będą doliczane do puli rodzica i pokażą się w rozpisce."/>
            </StackPanel>
        </Border>

        <!-- Treść: 3 kolumny -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="330"/>
            </Grid.ColumnDefinitions>

            <!-- KOLUMNA 0: zapisane pule -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="0,0,8,0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.1" BlurRadius="8"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#34495E" CornerRadius="10,10,0,0" Padding="14,10">
                        <TextBlock Text="📋 Zapisane pule" Style="{StaticResource HeaderText}"/>
                    </Border>
                    <DataGrid x:Name="dgPule" Grid.Row="1" Margin="8"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              CanUserAddRows="False" SelectionMode="Single"
                              RowHeight="40"
                              MouseDoubleClick="DgPule_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Rodzic (pula)" Binding="{Binding ParentNazwa}" Width="*"
                                                FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="#" Binding="{Binding LiczbaSkladnikow}" Width="34"/>
                        </DataGrid.Columns>
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SkladnikiText}" FontSize="10" Foreground="#7F8C8D"
                                           TextWrapping="Wrap" Margin="6,0,6,4"/>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,0,8,8">
                        <Button x:Name="btnEdytujPule" Content="✏️ Edytuj" Click="BtnEdytujPule_Click"
                                Padding="10,6" Margin="0,0,6,0" Background="#3498DB" Foreground="White" BorderThickness="0"/>
                        <Button x:Name="btnUsunPule" Content="🗑️ Usuń pulę" Click="BtnUsunPule_Click"
                                Padding="10,6" Background="#E74C3C" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- KOLUMNA 1: edytor puli -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Margin="0,0,8,0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.1" BlurRadius="8"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#16A085" CornerRadius="10,10,0,0" Padding="14,10">
                        <TextBlock Text="🛠️ Edytor puli" Style="{StaticResource HeaderText}"/>
                    </Border>

                    <!-- Wybrany rodzic -->
                    <Border Grid.Row="1" Margin="12,12,12,6" Padding="12,10" CornerRadius="8" Background="#E8F8F5"
                            BorderBrush="#16A085" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="1️⃣ Towar nadrzędny (pula)" Style="{StaticResource SectionTitle}"/>
                            <TextBlock x:Name="txtWybranyRodzic" Text="— nie wybrano — wyszukaj po prawej i kliknij ➕"
                                       FontSize="14" FontWeight="Bold" Foreground="#16A085" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="2" Text="2️⃣ Składniki tej puli (ich zamówienia/wydania zabierają z puli rodzica):"
                               Style="{StaticResource SectionTitle}" Margin="12,4,12,4"/>

                    <!-- Lista składników -->
                    <Border Grid.Row="3" Margin="12,0,12,12" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icSkladniki">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6,4" Padding="10,8" CornerRadius="6" Background="#F8F9FA"
                                                BorderBrush="#E0E0E0" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Nazwa}" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                    <TextBlock Text="{Binding Kod}" FontSize="10" Foreground="#95A5A6"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="✕ Usuń" Tag="{Binding}"
                                                        Click="BtnUsunSkladnik_Click"
                                                        Padding="8,4" Background="#FDEDEC" Foreground="#C0392B" BorderThickness="0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- KOLUMNA 2: wyszukiwarka towarów -->
            <Border Grid.Column="2" Background="White" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.1" BlurRadius="8"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#2980B9" CornerRadius="10,10,0,0" Padding="14,10">
                        <TextBlock Text="🔎 Towary z Symfonii (.112)" Style="{StaticResource HeaderText}"/>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="10,10,10,0">
                        <TextBox x:Name="txtSzukaj" Style="{StaticResource SearchBox}"
                                 TextChanged="TxtSzukaj_TextChanged"
                                 ToolTip="Szukaj po nazwie lub kodzie"/>
                        <TextBlock Text="Kliknij ➕ aby ustawić jako RODZICA, albo ➡ aby dodać jako SKŁADNIK."
                                   FontSize="10" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,0,0,6"/>
                    </StackPanel>

                    <ListBox x:Name="lbProdukty" Grid.Row="2" Margin="10,0,10,8"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Nazwa}" FontSize="12" Foreground="#2C3E50" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Kod}" FontSize="10" Foreground="#95A5A6"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="➕ rodzic" Tag="{Binding}"
                                            Click="BtnUstawRodzica_Click"
                                            Padding="6,3" Margin="2,0" FontSize="10"
                                            Background="#E8F8F5" Foreground="#16A085" BorderThickness="0"
                                            ToolTip="Ustaw jako towar nadrzędny (pula)"/>
                                    <Button Grid.Column="2" Content="➡ składnik" Tag="{Binding}"
                                            Click="BtnDodajSkladnik_Click"
                                            Padding="6,3" Margin="2,0" FontSize="10"
                                            Background="#EBF5FB" Foreground="#2980B9" BorderThickness="0"
                                            ToolTip="Dodaj jako składnik aktualnej puli"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock x:Name="txtLicznikProduktow" Grid.Row="3" Margin="10,0,10,10"
                               FontSize="10" Foreground="#95A5A6"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Pasek akcji -->
        <Border Grid.Row="2" Background="White" CornerRadius="0,0,10,10" Padding="14,10" Margin="0,10,0,0">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" Color="#000000" Opacity="0.1" BlurRadius="6"/>
            </Border.Effect>
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnNowa" Content="🆕 Nowa pula" Click="BtnNowa_Click"
                            Padding="14,8" Margin="0,0,8,0" Background="#95A5A6" Foreground="White" BorderThickness="0"/>
                    <TextBlock x:Name="txtStatus" VerticalAlignment="Center" Margin="8,0,0,0"
                               FontSize="11" Foreground="#7F8C8D"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnZapisz" Content="💾 Zapisz pulę" Click="BtnZapisz_Click"
                            Padding="18,8" Margin="0,0,8,0" Background="#27AE60" Foreground="White"
                            FontWeight="Bold" BorderThickness="0"/>
                    <Button x:Name="btnZamknij" Content="Zamknij" Click="BtnZamknij_Click"
                            Padding="14,8" Background="#BDC3C7" Foreground="#2C3E50" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
