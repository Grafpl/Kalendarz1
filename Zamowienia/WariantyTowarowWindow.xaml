<Window x:Class="Kalendarz1.Zamowienia.WariantyTowarowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔀 Warianty towarów"
        Width="860" Height="620" MinWidth="680" MinHeight="460"
        WindowStartupLocation="CenterScreen" Background="#F4F6F8">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <Border Grid.Row="0" CornerRadius="8" Padding="16,10" Margin="0,0,0,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#6B21A8" Offset="0"/>
                    <GradientStop Color="#9333EA" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock Text="🔀 Warianty towarów" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Np. Filet A → Pojedynczy / Podwójny. W Symfonii zostaje jeden artykuł — wariant jest wewnętrzny (produkcja/magazyn)."
                           FontSize="11.5" Foreground="#E9D5FF" Margin="0,3,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Dwie kolumny: towary | warianty wybranego towaru -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Lewa: lista towarów HANDEL (z szukajką) -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="10" BorderBrush="#D5DBE0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Towary (Symfonia)" FontWeight="Bold" FontSize="13" Foreground="#2C3E50" Margin="2,0,0,6"/>
                    <TextBox Grid.Row="1" x:Name="txtSzukaj" Height="28" FontSize="12" Margin="0,0,0,8"
                             VerticalContentAlignment="Center" TextChanged="TxtSzukaj_TextChanged" ToolTip="Szukaj towaru"/>
                    <DataGrid Grid.Row="2" x:Name="dgTowary" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" CanUserAddRows="False" GridLinesVisibility="Horizontal"
                              SelectionMode="Single" SelectionUnit="FullRow" FontSize="12" RowHeight="26"
                              BorderThickness="0" SelectionChanged="DgTowary_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="56"/>
                            <DataGridTextColumn Header="Kod / nazwa" Binding="{Binding Kod}" Width="*"/>
                            <DataGridTextColumn Header="War." Binding="{Binding LiczbaWariantow}" Width="44"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Prawa: warianty wybranego towaru -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="12" BorderBrush="#D5DBE0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="txtWybranyTowar" Text="Wybierz towar z lewej listy"
                               FontWeight="Bold" FontSize="13.5" Foreground="#2C3E50" Margin="0,0,0,8" TextWrapping="Wrap"/>

                    <DataGrid Grid.Row="1" x:Name="dgWarianty" AutoGenerateColumns="False"
                              HeadersVisibility="Column" CanUserAddRows="True" GridLinesVisibility="Horizontal"
                              SelectionMode="Single" FontSize="12.5" RowHeight="30" BorderThickness="0"
                              ToolTip="Dodaj/edytuj warianty. Kod = techniczny (np. PODWOJNY), Nazwa = widoczna (Filet podwójny).">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kod" Binding="{Binding Kod}" Width="150"/>
                            <DataGridTextColumn Header="Nazwa (widoczna)" Binding="{Binding Nazwa}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2" FontSize="10.5" Foreground="#7F8C8D" Margin="0,8,0,0" TextWrapping="Wrap"
                               Text="Wskazówka: zostaw pusto = towar bez wariantu. 0–1 wariant = przełącznik się nie pojawi (sensowne od 2). Kolejność wierszy = kolejność przełączania."/>
                </Grid>
            </Border>
        </Grid>

        <!-- Stopka -->
        <Border Grid.Row="2" Margin="0,12,0,0" Background="White" CornerRadius="8" Padding="12,9" BorderBrush="#D5DBE0" BorderThickness="1">
            <Grid>
                <TextBlock x:Name="txtStatus" VerticalAlignment="Center" FontSize="11.5" Foreground="#7F8C8D"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="💾 Zapisz warianty towaru" Padding="16,8" Background="#9333EA" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontWeight="SemiBold" Click="BtnZapisz_Click" Margin="0,0,8,0"/>
                    <Button Content="Zamknij" Padding="16,8" Background="#95A5A6" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="BtnZamknij_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
