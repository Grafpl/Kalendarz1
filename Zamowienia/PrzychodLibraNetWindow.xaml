<Window x:Class="Kalendarz1.Zamowienia.PrzychodLibraNetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📦 Przychód produkcji — LibraNet"
        Width="980" Height="640" MinWidth="760" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8">
    <Window.Resources>
        <Style x:Key="HeaderTxt" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="GridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#ECF0F1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D5DBE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>
        <Style x:Key="RightCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CenterCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Pasek: data + filtr + odśwież + podsumowanie -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="10,8" Margin="0,0,0,10"
                BorderBrush="#D5DBE0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Przychód (ważenia In0E)" Style="{StaticResource HeaderTxt}" Margin="0,0,14,0"/>

                <DatePicker Grid.Column="1" x:Name="dpDzien" Width="120" Height="26" FontSize="12"
                            VerticalAlignment="Center" SelectedDateChanged="DpDzien_SelectedDateChanged"/>

                <TextBox Grid.Column="2" x:Name="txtFiltr" Width="190" Height="26" Margin="10,0,0,0"
                         FontSize="12" VerticalContentAlignment="Center"
                         ToolTip="Filtruj po nazwie lub numerze towaru (Article)"
                         TextChanged="TxtFiltr_TextChanged"/>

                <Button Grid.Column="3" x:Name="btnOdswiez" Content="🔄" Width="26" Height="26" Margin="8,0,0,0"
                        FontSize="11" ToolTip="Odśwież" Click="BtnOdswiez_Click"/>

                <TextBlock Grid.Column="5" x:Name="txtPodsumowanie" FontSize="12" FontWeight="SemiBold"
                           Foreground="#5B6FB5" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Towary (master) + rozkład godzinowy (detail) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="420"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="290"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" x:Name="dgTowary" Style="{StaticResource GridStyle}"
                      SelectionChanged="DgTowary_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nr" Binding="{Binding ArtId}" Width="56"
                                        ElementStyle="{StaticResource CenterCell}"/>
                    <DataGridTextColumn Header="Towar" Binding="{Binding Towar}" Width="*"/>
                    <DataGridTextColumn Header="Ważeń" Binding="{Binding Wazen}" Width="62"
                                        ElementStyle="{StaticResource RightCell}"/>
                    <DataGridTextColumn Header="Suma kg" Binding="{Binding SumaKg, StringFormat='#,##0 kg'}" Width="96"
                                        ElementStyle="{StaticResource RightCell}"/>
                    <DataGridTextColumn Header="Śr./waż." Binding="{Binding SrKg, StringFormat='#,##0.0 kg'}" Width="84"
                                        ElementStyle="{StaticResource RightCell}"/>
                    <DataGridTextColumn Header="Od" Binding="{Binding OdGodz}" Width="56"
                                        ElementStyle="{StaticResource CenterCell}"/>
                    <DataGridTextColumn Header="Do" Binding="{Binding DoGodz}" Width="56"
                                        ElementStyle="{StaticResource CenterCell}"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="txtDetailTowar" Text="⏱ Rozkład godzinowy"
                           FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50" Margin="2,0,0,6"
                           TextTrimming="CharacterEllipsis"/>
                <DataGrid Grid.Row="1" x:Name="dgGodziny" Style="{StaticResource GridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Godz." Binding="{Binding Godzina}" Width="64"
                                            ElementStyle="{StaticResource CenterCell}"/>
                        <DataGridTextColumn Header="Ważeń" Binding="{Binding Wazen}" Width="62"
                                            ElementStyle="{StaticResource RightCell}"/>
                        <DataGridTextColumn Header="kg" Binding="{Binding SumaKg, StringFormat='#,##0 kg'}" Width="*"
                                            ElementStyle="{StaticResource RightCell}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Stopka -->
        <TextBlock Grid.Row="2" x:Name="txtStopka" Margin="2,8,0,0" FontSize="10.5" Foreground="#7F8C8D"
                   Text="Źródło: LibraNet dbo.In0E (waga rzeczywista ActWeight). Kliknij towar, aby zobaczyć rozkład godzinowy."/>
    </Grid>
</Window>
