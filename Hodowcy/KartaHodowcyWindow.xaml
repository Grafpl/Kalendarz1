                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="#059669"/>
                                                <Setter Property="Padding" Value="0,0,8,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Śr.waga (kg/szt)" Binding="{Binding SrWagaSztPlan, StringFormat=N3}" Width="115">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Foreground" Value="#7C3AED"/>
                                                <Setter Property="Padding" Value="0,0,8,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Szt.szuflada" Binding="{Binding SztSzuflada, StringFormat=N0}" Width="95">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Padding" Value="0,0,8,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="🚛 Auta" Binding="{Binding Auta}" Width="100"/>
                                    <DataGridTextColumn Header="Typ ceny" Binding="{Binding TypCeny}" Width="110"/>
                                    <DataGridTextColumn Header="Cena bazowa" Binding="{Binding Cena, StringFormat=N2}" Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="#1E40AF"/>
                                                <Setter Property="Padding" Value="0,0,8,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Bufor" Binding="{Binding Bufor}" Width="60">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="Foreground" Value="#9A3412"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Typ umowy" Binding="{Binding TypUmowy}" Width="100"/>
                                    <DataGridTextColumn Header="Dni do" Binding="{Binding DniDoDostawy}" Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Utworzył" Binding="{Binding KtoUtw}" Width="*" MinWidth="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ─── 🏠 Fermy ─── -->
            <TabItem Header="🏠  Fermy" Style="{StaticResource TabHdr}">
                <Grid Margin="20,12">
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="6" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                                    Padding="14,10" Background="#F8FAFC">
                                <TextBlock x:Name="txtFermyInfo" FontWeight="SemiBold" Foreground="#475569"
                                           FontSize="12" Text="Adresy ferm hodowcy (DostawcyAdresy.Kind=2)"/>
                            </Border>
                            <DataGrid Grid.Row="1" x:Name="dgFermy"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      RowBackground="White" AlternatingRowBackground="#F8FAFC"
                                      BorderThickness="0" RowHeight="32" FontSize="12.5">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DgHdr}"/>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Lp" Binding="{Binding Lp}" Width="60"/>
                                    <DataGridTextColumn Header="Adres" Binding="{Binding Adres}" Width="*" MinWidth="200"/>
                                    <DataGridTextColumn Header="Kod poczt." Binding="{Binding PostalCode}" Width="110"/>
                                    <DataGridTextColumn Header="Miejscowość" Binding="{Binding City}" Width="160"/>
                                    <DataGridTextColumn Header="Nr gospod. ARiMR" Binding="{Binding AnimNo}" Width="160"/>
                                    <DataGridTextColumn Header="Uwagi" Binding="{Binding Uwagi}" Width="*" MinWidth="180"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ─── 📋 Dane podstawowe ─── -->
            <TabItem Header="📋  Dane podstawowe" Style="{StaticResource TabHdr}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="20,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Identyfikacja -->
                        <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                CornerRadius="6" Padding="16,14" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="🆔  IDENTYFIKACJA" FontWeight="Bold" Foreground="#1F2937"
                                           FontSize="13" Margin="0,0,0,10"/>

                                <TextBlock Text="ID dostawcy" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpID" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="GID" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpGID" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Nazwa pełna" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpName" Text="—" Style="{StaticResource InfoValue}" TextWrapping="Wrap"/>

                                <TextBlock Text="Skrót" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpShortName" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="NIP" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpNip" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="REGON" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpRegon" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="PESEL" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpPesel" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Dowód osobisty" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpIDCard" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Data wydania DO" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpIDCardDate" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Wydany przez" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpIDCardAuth" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Numer gospod. (ARiMR)" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpAnimNo" Text="—" Style="{StaticResource InfoValue}" FontWeight="Bold" Foreground="#059669"/>

                                <TextBlock Text="IRZPlus" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpIRZPlus" Text="—" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                        </Border>

                        <!-- Adres + kontakt -->
                        <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                CornerRadius="6" Padding="16,14" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBlock Text="📞  KONTAKT I LOKALIZACJA" FontWeight="Bold" Foreground="#1F2937"
                                           FontSize="13" Margin="0,0,0,10"/>

                                <TextBlock Text="Adres" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpAddress" Text="—" Style="{StaticResource InfoValue}" TextWrapping="Wrap"/>

                                <TextBlock Text="Kod pocztowy" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpPostal" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Miejscowość" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpCity" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Województwo" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpProv" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Odległość (km)" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpDistance" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Trasa" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpTrasa" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Telefon 1" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpPhone1" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Telefon 2" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpPhone2" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Telefon 3" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpPhone3" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Email" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpEmail" Text="—" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                        </Border>

                        <!-- Cennik + flagi + uwagi -->
                        <Border Grid.Column="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                CornerRadius="6" Padding="16,14" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="💰  CENNIK / FLAGI / UWAGI" FontWeight="Bold" Foreground="#1F2937"
                                           FontSize="13" Margin="0,0,0,10"/>

                                <TextBlock Text="Typ ceny (PriceType)" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpPriceType" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Dodatek (zł/kg)" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpAddition" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Ubytek (kg)" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpLoss" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Padłe + konfiskaty (czy odliczać)" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpIncDead" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Flagi" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpFlagi" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Status (Halt)" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpHalt" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Typ osobowości" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpOsob" Text="—" Style="{StaticResource InfoValue}"/>

                                <TextBlock Text="Notatki" Style="{StaticResource InfoLabel}"/>
                                <TextBlock x:Name="dpInfo1" Text="—" Style="{StaticResource InfoValue}" TextWrapping="Wrap"/>
                                <TextBlock x:Name="dpInfo2" Text="" Style="{StaticResource InfoValue}" TextWrapping="Wrap"/>
                                <TextBlock x:Name="dpInfo3" Text="" Style="{StaticResource InfoValue}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ═══ Stopka ═══ -->
        <Border Grid.Row="6" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="24,8">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F1F5F9" Offset="0"/>
                    <GradientStop Color="#E2E8F0" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⌨️" FontSize="13" Margin="0,0,6,0"/>
                    <TextBlock Text="Esc — zamknij  •  Karta agreguje 4 źródła: Dostawcy + listapartii + FarmerCalc + In0E + HarmonogramDostaw + DostawcyAdresy"
                               Foreground="#64748B" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⏱️" FontSize="13" Margin="0,0,4,0"/>
                    <TextBlock x:Name="txtCzasLad" Text="" Foreground="#64748B" FontSize="11"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
