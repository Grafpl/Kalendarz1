<Window x:Class="Kalendarz1.ColdChain.ColdChainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:Kalendarz1.AnalitykaPelna.Services"
        Title="Cold Chain HACCP — monitoring CCP" Height="760" Width="1240"
        WindowStartupLocation="CenterScreen" Background="White"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Surface" Color="#F8FAFC"/>
        <svc:HexToBrushConverter x:Key="HexToBrush"/>
        <svc:BoolToVisibilityConverter x:Key="BoolVis"/>

        <!-- Karta punktu CCP -->
        <DataTemplate x:Key="CCPCardTemplate">
            <Border Background="{Binding TloKolor, Converter={StaticResource HexToBrush}}"
                    CornerRadius="10" Padding="14,12" Margin="5" Cursor="Hand"
                    MouseLeftButtonUp="CCPCard_Click" Tag="{Binding}">
                <StackPanel>
                    <TextBlock Text="{Binding Nazwa}" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding OstatniaWartoscFormatted}" FontSize="22" FontWeight="Bold"
                               Foreground="{Binding StatusKolor, Converter={StaticResource HexToBrush}}" Margin="0,4,0,0"/>
                    <TextBlock FontSize="10.5" Foreground="{StaticResource TextMuted}">
                        <Run Text="norma "/><Run Text="{Binding LimitFormatted}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding Status}" FontSize="11.5" FontWeight="SemiBold"
                               Foreground="{Binding StatusKolor, Converter={StaticResource HexToBrush}}" Margin="0,4,0,0"/>
                    <TextBlock FontSize="9.5" Foreground="{StaticResource TextMuted}">
                        <Run Text="ost. "/><Run Text="{Binding OstatniPomiarFormatted}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="🛡 Cold Chain HACCP — punkty kontroli krytycznej" FontSize="20"
                           FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="Tryb manualny działa od razu. Auto (sondy Modbus) po zakupie sprzętu — patrz pomysł #9/#19."
                           FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" x:Name="btnOdswiez" Content="↻ Odśwież" Padding="14,8"
                    VerticalAlignment="Center" Click="BtnOdswiez_Click"/>
        </Grid>

        <!-- Karty CCP -->
        <ItemsControl Grid.Row="1" x:Name="lstPunkty" ItemTemplate="{StaticResource CCPCardTemplate}" Margin="0,0,0,8">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="2" Columns="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!-- Dół: wpis manualny + incydenty -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Wpis manualny -->
            <Border Grid.Column="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1" CornerRadius="10" Padding="18">
                <StackPanel>
                    <TextBlock Text="📝 Wpis pomiaru (manualny)" FontWeight="Bold" FontSize="15"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,14"/>

                    <TextBlock Text="Punkt CCP" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <ComboBox x:Name="cbPunkt" Height="34" FontSize="13" DisplayMemberPath="Nazwa" Margin="0,2,0,12"/>

                    <TextBlock Text="Wartość pomiaru" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBox x:Name="txtWartosc" Height="34" FontSize="16" VerticalContentAlignment="Center"
                             Padding="6,0" Margin="0,2,0,12"/>

                    <TextBlock Text="Uwagi (opcjonalnie)" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBox x:Name="txtUwagi" Height="50" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Padding="6,4" Margin="0,2,0,14"/>

                    <Button x:Name="btnZapisz" Content="💾 Zapisz pomiar" Height="40" FontSize="14"
                            FontWeight="SemiBold" Background="#2563EB" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="BtnZapisz_Click"/>
                    <TextBlock x:Name="txtKomunikat" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Incydenty -->
            <Border Grid.Column="2" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="10">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="14,12,14,8">
                        <TextBlock Text="🚨 Incydenty (przekroczenia limitu)" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <CheckBox x:Name="chkTylkoOtwarte" Content="tylko otwarte" HorizontalAlignment="Right"
                                  IsChecked="True" VerticalAlignment="Center" Click="ChkTylkoOtwarte_Click"/>
                    </Grid>
                    <DataGrid x:Name="dgIncydenty" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="0" RowHeight="34" FontSize="12.5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Start" Binding="{Binding StartFormatted}" Width="95"/>
                            <DataGridTextColumn Header="Punkt" Binding="{Binding PunktNazwa}" Width="*"/>
                            <DataGridTextColumn Header="Zakres" Binding="{Binding WartoscFormatted}" Width="90"/>
                            <DataGridTextColumn Header="Czas" Binding="{Binding CzasTrwania}" Width="80"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusFinal}" Width="90"/>
                            <DataGridTemplateColumn Header="Akcja" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Zamknij" Padding="8,3" Margin="2"
                                                Click="BtnZamknijInc_Click" Tag="{Binding}"
                                                Visibility="{Binding Otwarty, Converter={StaticResource BoolVis}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
