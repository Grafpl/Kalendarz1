<Window x:Class="Kalendarz1.Kontrakty.Views.KontraktPodgladWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Podgląd umowy" Height="780" Width="760"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kontrakty/Views/KontraktyTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="22,14">
            <StackPanel>
                <TextBlock Text="👁 Podgląd treści umowy" Foreground="White" FontSize="18" FontWeight="Bold"/>
                <TextBlock x:Name="txtPodtytul" Foreground="#C8E6C9" FontSize="11.5" Margin="0,3,0,0"
                           Text="Wygenerowane z szablonu z wypełnionymi danymi. To podgląd treści — formatowanie może różnić się od Worda."/>
            </StackPanel>
        </Border>

        <!-- „Kartka" dokumentu -->
        <Border Grid.Row="1" Background="White" Margin="22,16,22,8" CornerRadius="8" Effect="{StaticResource SoftShadow}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="34,28">
                <ItemsControl x:Name="icTresc"/>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Background="White" Padding="22,12" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="txtInfo" VerticalAlignment="Center" Foreground="{StaticResource Muted}" FontSize="11.5"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnWord" Content="📂 Otwórz w Wordzie" Style="{StaticResource Btn}" Click="BtnWord_Click"/>
                    <Button Content="Zamknij" Style="{StaticResource BtnPrimary}" Click="BtnZamknij_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
