<Window x:Class="Kalendarz1.Kontrakty.Views.WybierzKontraktDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wybierz kontrakt do skopiowania"
        Height="560" Width="780"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F1F5F9"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kontrakty/Views/KontraktyTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="22,14">
            <StackPanel>
                <TextBlock Text="📋  Wybierz kontrakt do skopiowania" Foreground="White" FontSize="16" FontWeight="Bold"/>
                <TextBlock x:Name="txtPodtytul" Text="Hodowca: …" Foreground="#C8E6C9" FontSize="12" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Lista -->
        <Border Grid.Row="1" Margin="16">
            <Grid>
                <ListBox x:Name="lstKontrakty" SelectionMode="Single"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="LstKontrakty_DoubleClick">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,0,0,6"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="8" Padding="14,10"
                                    BorderBrush="{StaticResource Line}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Status badge -->
                                    <Border Grid.Column="0" Width="84" CornerRadius="5" Padding="0,2" Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#94A3B8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="ACTIVE">
                                                        <Setter Property="Background" Value="#16A34A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="EXPIRING">
                                                        <Setter Property="Background" Value="#F59E0B"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="EXPIRED">
                                                        <Setter Property="Background" Value="#94A3B8"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="TERMINATED">
                                                        <Setter Property="Background" Value="#DC2626"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="DRAFT">
                                                        <Setter Property="Background" Value="#3B82F6"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding StatusLabel}" Foreground="White" FontSize="11"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    </Border>

                                    <!-- Treść -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding NumerKontraktu}" FontSize="14.5" FontWeight="Bold"
                                                       Foreground="{StaticResource Ink}"/>
                                            <TextBlock Text="  ·  " Foreground="{StaticResource Muted}"/>
                                            <TextBlock Text="{Binding TypLabel}" Foreground="{StaticResource Muted}"
                                                       FontSize="13"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding OkresLabel}" FontSize="12" Foreground="{StaticResource Muted}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Aktualna wersja -->
                                    <TextBlock Grid.Column="2" Text="{Binding WersjaLabel}" FontSize="12"
                                               Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock x:Name="txtPusto" Text="Ten hodowca nie ma jeszcze żadnych kontraktów."
                           FontSize="13" Foreground="{StaticResource Muted}" HorizontalAlignment="Center"
                           VerticalAlignment="Center" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Stopka -->
        <Border Grid.Row="2" Background="White" Padding="20,12"
                BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="txtHint" VerticalAlignment="Center"
                           Text="Wybierz kontrakt i kliknij „Skopiuj” (lub dwuklik na pozycji)."
                           FontSize="12" Foreground="{StaticResource Muted}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Anuluj" Style="{StaticResource Btn}" Click="BtnAnuluj_Click"
                            Height="40" FontSize="13" Padding="22,0"/>
                    <Button x:Name="btnOk" Content="📋  Skopiuj wybrany" Style="{StaticResource BtnPrimary}"
                            Click="BtnOk_Click" Height="40" FontSize="13" Padding="22,0" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
