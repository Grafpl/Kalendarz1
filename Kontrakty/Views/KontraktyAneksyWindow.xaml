<Window x:Class="Kalendarz1.Kontrakty.Views.KontraktyAneksyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Masowe generowanie dokumentów" Height="720" Width="900"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kontrakty/Views/KontraktyTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="22,16">
            <StackPanel>
                <TextBlock Text="📑 Masowe generowanie dokumentów Word" Foreground="White" FontSize="19" FontWeight="Bold"/>
                <TextBlock Text="Zaznacz kontrakty (Ctrl/Shift) i wygeneruj dokumenty hurtowo — np. aneksy po zmianie podmiotu."
                           Foreground="#C8E6C9" FontSize="12" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="18,11" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filtr" VerticalAlignment="Center" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,6,0"/>
                <ComboBox x:Name="cbStatus" Width="180" SelectionChanged="Filtr_Changed">
                    <ComboBoxItem Content="Aktywne" Tag="AKTYWNE" IsSelected="True"/>
                    <ComboBoxItem Content="Wygasające ≤90 dni" Tag="WYGASAJACE"/>
                    <ComboBoxItem Content="Wszystkie" Tag="WSZYSTKIE"/>
                </ComboBox>
                <ComboBox x:Name="cbTyp" Width="150" SelectionChanged="Filtr_Changed" Margin="10,0,0,0">
                    <ComboBoxItem Content="Wszystkie typy" Tag="WSZYSTKIE" IsSelected="True"/>
                    <ComboBoxItem Content="3-letni" Tag="ARIMR_3LAT"/>
                    <ComboBoxItem Content="Roczny" Tag="ROCZNY"/>
                </ComboBox>
                <Button Content="☑ Zaznacz wszystkie" Style="{StaticResource Btn}" Click="BtnZaznaczWsz_Click" Margin="14,0,0,0"/>
                <Button Content="☐ Odznacz" Style="{StaticResource Btn}" Click="BtnOdznacz_Click"/>
                <TextBlock x:Name="txtLicznik" VerticalAlignment="Center" Foreground="{StaticResource Muted}" FontSize="12" Margin="14,0,0,0"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgList" Grid.Row="2" Margin="18,12,18,8" BorderThickness="0" RowHeight="36"
                  SelectionMode="Extended" SelectionChanged="Dg_SelChanged" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="NR" Binding="{Binding NumerKontraktu}" Width="100"/>
                <DataGridTextColumn Header="HODOWCA" Binding="{Binding Hodowca}" Width="*"/>
                <DataGridTextColumn Header="TYP" Binding="{Binding TypLabel}" Width="110"/>
                <DataGridTextColumn Header="OKRES" Binding="{Binding OkresLabel}" Width="160"/>
                <DataGridTextColumn Header="DOKUMENT" Binding="{Binding WersjaLabel}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Background="White" Padding="18,12" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="txtStatus" VerticalAlignment="Center" Foreground="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnFolder" Content="📂 Otwórz folder" Style="{StaticResource Btn}" Click="BtnFolder_Click" Visibility="Collapsed"/>
                    <Button x:Name="btnGeneruj" Content="📄 Generuj zaznaczone" Style="{StaticResource BtnPrimary}" Click="BtnGeneruj_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
