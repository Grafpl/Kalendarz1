<Window x:Class="Kalendarz1.Kontrakty.Views.KontraktyNumeracjaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Numeracja kontraktów" Height="430" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F1F5F9"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kontrakty/Views/KontraktyTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="20,14">
            <StackPanel>
                <TextBlock Text="🔢 Numeracja kontraktów" Foreground="White" FontSize="17" FontWeight="Bold"/>
                <TextBlock Text="Ustal własny format numeru. Zmiana dotyczy nowych kontraktów."
                           Foreground="#D7E3EE" FontSize="11.5" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="22,18,22,8">
            <TextBlock Text="Format numeru" Style="{StaticResource Lbl}"/>
            <TextBox x:Name="txtFormat" Height="34" VerticalContentAlignment="Center"
                     FontFamily="Consolas" FontSize="13.5" TextChanged="Pole_Changed"/>
            <TextBlock Margin="2,5,0,0" FontSize="11" Foreground="{StaticResource Muted}" TextWrapping="Wrap">
                Tokeny: <Run FontWeight="Bold" FontFamily="Consolas">{ROK}</Run> = rok 4-cyfry ·
                <Run FontWeight="Bold" FontFamily="Consolas">{RR}</Run> = rok 2-cyfry ·
                <Run FontWeight="Bold" FontFamily="Consolas">{NNNN}</Run> = numer z zerami ·
                <Run FontWeight="Bold" FontFamily="Consolas">{N}</Run> = numer bez zer
            </TextBlock>

            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Rok" Style="{StaticResource Lbl}"/>
                    <TextBox x:Name="txtRok" Height="34" VerticalContentAlignment="Center" TextChanged="Pole_Changed"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Następny numer" Style="{StaticResource Lbl}"/>
                    <TextBox x:Name="txtNext" Height="34" VerticalContentAlignment="Center" TextChanged="Pole_Changed"/>
                </StackPanel>
            </Grid>

            <CheckBox x:Name="chkReset" Margin="2,16,0,0" Click="Pole_Changed"
                      Content="Resetuj numerację co rok (numer wraca do 1 na początku roku)"/>

            <Border Margin="0,18,0,0" Background="{StaticResource GreenSoft}" CornerRadius="10" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="PODGLĄD NASTĘPNEGO NUMERU" FontSize="10.5" FontWeight="Bold"
                               Foreground="{StaticResource GreenDark}"/>
                    <TextBlock x:Name="txtPodglad" FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource GreenDark}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="2" Background="White" Padding="22,12" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Anuluj" Style="{StaticResource Btn}" Click="BtnAnuluj_Click"/>
                <Button Content="💾 Zapisz" Style="{StaticResource BtnPrimary}" Click="BtnZapisz_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
