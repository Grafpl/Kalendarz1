<Window x:Class="Kalendarz1.Kontrakty.Views.KontraktyAlertyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alerty kontraktów" Height="620" Width="1000"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kontrakty/Views/KontraktyTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="22,14">
            <Grid>
                <StackPanel>
                    <TextBlock Text="🔔 Alerty kontraktów" Foreground="White" FontSize="19" FontWeight="Bold"/>
                    <TextBlock Text="Wygasające umowy i braki — do działania" Foreground="#C8E6C9" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
                <TextBlock x:Name="txtLicznik" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="White" FontWeight="SemiBold" FontSize="13"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="18,11" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="🔄 Generuj / odśwież" Style="{StaticResource BtnPrimary}" Click="BtnGeneruj_Click"/>
                <Button Content="✓ Oznacz przeczytane" Style="{StaticResource Btn}" Click="BtnOznacz_Click"/>
                <Button Content="📜 Otwórz kontrakt" Style="{StaticResource Btn}" Click="BtnOtworz_Click"/>
                <CheckBox x:Name="chkTylkoNieprzecz" Content="tylko nieprzeczytane" VerticalAlignment="Center"
                          Margin="14,0,0,0" IsChecked="True" Click="Filtr_Changed"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="18,14,18,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="bannerSzanse" Grid.Row="0" Visibility="Collapsed" Margin="0,0,0,12"
                    Background="{StaticResource OrangeAlertBg}" CornerRadius="10" Padding="14,10" Cursor="Hand"
                    MouseLeftButtonUp="BannerSzanse_Click">
                <Grid>
                    <TextBlock x:Name="txtSzanse" VerticalAlignment="Center" TextWrapping="Wrap"
                               Foreground="{StaticResource OrangeAlertFg}" FontSize="12.5" FontWeight="SemiBold"/>
                    <TextBlock Text="otwórz Ranking →" HorizontalAlignment="Right" VerticalAlignment="Center"
                               Foreground="{StaticResource OrangeAlertFg}" FontSize="12" FontWeight="Bold"/>
                </Grid>
            </Border>

            <DataGrid x:Name="dgAlerty" Grid.Row="1" MouseDoubleClick="Dg_DoubleClick">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="WAGA" Width="92">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="9,3" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E2E8F0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Severity}" Value="CRIT"><Setter Property="Background" Value="#FEE2E2"/></DataTrigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="HIGH"><Setter Property="Background" Value="#FFEDD5"/></DataTrigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="WARN"><Setter Property="Background" Value="#FEF3C7"/></DataTrigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="INFO"><Setter Property="Background" Value="#E0E7FF"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding SeverityLabel}" FontSize="11" FontWeight="SemiBold" Foreground="#0F172A"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="NR" Binding="{Binding NumerKontraktu}" Width="70"/>
                    <DataGridTextColumn Header="HODOWCA" Binding="{Binding Hodowca}" Width="1.6*"/>
                    <DataGridTextColumn Header="TYP" Binding="{Binding TypLabel}" Width="130"/>
                    <DataGridTextColumn Header="WIADOMOŚĆ" Binding="{Binding Wiadomosc}" Width="2*"/>
                    <DataGridTextColumn Header="DATA" Binding="{Binding DataLabel}" Width="120"/>
                    <DataGridTemplateColumn Header="ESK." Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="⚠" FontSize="14" HorizontalAlignment="Center" Foreground="#B45309"
                                           ToolTip="Eskalowany — nieprzeczytany ponad 7 dni">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Eskalowany}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="36">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="🔵" FontSize="10" HorizontalAlignment="Center" ToolTip="Nieprzeczytany">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Przeczytany}" Value="False"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel x:Name="txtPusto" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                <TextBlock Text="✅" FontSize="40" HorizontalAlignment="Center" Opacity="0.6"/>
                <TextBlock Text="Brak alertów — wszystko pod kontrolą" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource Muted}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="Kliknij „Generuj / odśwież”, aby sprawdzić terminy." FontSize="12.5"
                           Foreground="{StaticResource Muted}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
