<Window x:Class="Kalendarz1.Kontrakty.Views.GusWyborDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GUS / Biała Lista MF — wybór pól"
        Height="560" Width="720"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F1F5F9"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kontrakty/Views/KontraktyTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2563EB" Padding="22,14">
            <StackPanel>
                <TextBlock Text="🌐  Pobrano z Białej Listy MF" Foreground="White" FontSize="16" FontWeight="Bold"/>
                <TextBlock x:Name="txtPodtytul" Foreground="#DBEAFE" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Pola do wyboru -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,14">
            <StackPanel>
                <TextBlock Text="Zaznacz pola, które mają zostać zastąpione danymi z MF."
                           FontSize="12.5" Foreground="#475569" Margin="2,0,0,12" TextWrapping="Wrap"/>

                <!-- Nazwa -->
                <Border x:Name="boxNazwa" Background="White" CornerRadius="10" Padding="14,10" Margin="0,0,0,8"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <CheckBox x:Name="chkNazwa" FontSize="14" FontWeight="SemiBold" Checked="Chk_Changed" Unchecked="Chk_Changed">
                            <TextBlock Text="🧑 Nazwa / imię i nazwisko" Foreground="#1B5E20"/>
                        </CheckBox>
                        <Border x:Name="boxNazwaPorownanie" Background="#FEF6E7" CornerRadius="7" Padding="11,8" Margin="26,8,0,0"
                                BorderBrush="#F2DDB0" BorderThickness="1" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontSize="11" Foreground="#92400E">
                                    <Run Text="⚠ obecnie: " FontWeight="SemiBold"/>
                                    <Run x:Name="txtNazwaStara"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="txtNazwaNowa" FontSize="13" Foreground="#0F172A" Margin="26,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- REGON -->
                <Border x:Name="boxRegon" Background="White" CornerRadius="10" Padding="14,10" Margin="0,0,0,8"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <CheckBox x:Name="chkRegon" FontSize="14" FontWeight="SemiBold" Checked="Chk_Changed" Unchecked="Chk_Changed">
                            <TextBlock Text="🏢 REGON" Foreground="#1B5E20"/>
                        </CheckBox>
                        <Border x:Name="boxRegonPorownanie" Background="#FEF6E7" CornerRadius="7" Padding="11,8" Margin="26,8,0,0"
                                BorderBrush="#F2DDB0" BorderThickness="1" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontSize="11" Foreground="#92400E">
                                    <Run Text="⚠ obecnie: " FontWeight="SemiBold"/>
                                    <Run x:Name="txtRegonStary"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="txtRegonNowy" FontSize="13" Foreground="#0F172A" Margin="26,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Adres -->
                <Border x:Name="boxAdres" Background="White" CornerRadius="10" Padding="14,10" Margin="0,0,0,8"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <CheckBox x:Name="chkAdres" FontSize="14" FontWeight="SemiBold" Checked="Chk_Changed" Unchecked="Chk_Changed">
                            <TextBlock Text="📍 Adres" Foreground="#1B5E20"/>
                        </CheckBox>
                        <Border x:Name="boxAdresPorownanie" Background="#FEF6E7" CornerRadius="7" Padding="11,8" Margin="26,8,0,0"
                                BorderBrush="#F2DDB0" BorderThickness="1" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontSize="11" Foreground="#92400E" TextWrapping="Wrap">
                                    <Run Text="⚠ obecnie: " FontWeight="SemiBold"/>
                                    <Run x:Name="txtAdresStary"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="txtAdresNowy" FontSize="13" Foreground="#0F172A" Margin="26,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="txtBrakDanych" Margin="2,8,0,0" FontSize="12" Foreground="#94A3B8"
                           TextWrapping="Wrap" Visibility="Collapsed"
                           Text="ℹ MF nie zwrócił niektórych pól — wyłączono z możliwości wyboru."/>
            </StackPanel>
        </ScrollViewer>

        <!-- Stopka -->
        <Border Grid.Row="2" Background="White" Padding="20,12"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnZaznaczWszystko" Style="{StaticResource BtnLink}" Click="BtnZaznaczWszystko_Click"
                            Content="Zaznacz wszystko" FontSize="12"/>
                    <TextBlock Text="  ·  " Foreground="#94A3B8" VerticalAlignment="Center"/>
                    <Button x:Name="btnOdznaczWszystko" Style="{StaticResource BtnLink}" Click="BtnOdznaczWszystko_Click"
                            Content="Odznacz wszystko" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Anuluj" Style="{StaticResource Btn}" Click="BtnAnuluj_Click"
                            Height="40" FontSize="13" Padding="22,0"/>
                    <Button x:Name="btnOk" Content="✔  Zastosuj" Style="{StaticResource BtnPrimary}"
                            Click="BtnOk_Click" Height="40" FontSize="13" Padding="22,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
