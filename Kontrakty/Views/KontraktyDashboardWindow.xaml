<Window x:Class="Kalendarz1.Kontrakty.Views.KontraktyDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard ARiMR" Height="760" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#F1F5F9"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kontrakty/Views/KontraktyTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="22,16">
            <StackPanel>
                <TextBlock Text="🎯 Kontrakty — przegląd ARiMR" Foreground="White" FontSize="20" FontWeight="Bold"/>
                <TextBlock x:Name="txtPodtytul" Foreground="#C8E6C9" FontSize="12" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="18,16,18,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="470"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEWA -->
            <ScrollViewer Grid.Column="0" Margin="0,0,16,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="SUROWIEC POD 3-LETNIM KONTRAKTEM ARiMR" Style="{StaticResource CardTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Gauge-półkole ARiMR (strefy: <40 czerw / 40–50 żółta / ≥50 zielona) -->
                            <StackPanel Grid.Column="0" Margin="0,4,16,4" VerticalAlignment="Center">
                                <Grid Width="236" Height="158">
                                    <Canvas x:Name="gaugeCanvas" Width="236" Height="158"/>
                                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,4">
                                        <TextBlock x:Name="txtProcent" Text="—" FontSize="32" FontWeight="Bold"
                                                   Foreground="{StaticResource Ink}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="cel ≥ 50%" FontSize="11" Foreground="{StaticResource Muted}"
                                                   HorizontalAlignment="Center" Margin="0,-3,0,0"/>
                                    </StackPanel>
                                </Grid>
                                <!-- Legenda stref -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <Border Background="#FCA5A5" CornerRadius="3" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="&lt;40" FontSize="10.5" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Border Background="#FCD34D" CornerRadius="3" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="40–50" FontSize="10.5" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Border Background="#86EFAC" CornerRadius="3" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="≥50 (cel ARiMR)" FontSize="10.5" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Detale -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="txtProcentStatus" FontSize="13" FontWeight="SemiBold"
                                           TextWrapping="Wrap" Margin="0,0,0,12"/>
                                <TextBlock Text="Surowiec ogółem (12 mies.)" FontSize="11.5" Foreground="{StaticResource Muted}"/>
                                <TextBlock x:Name="txtSurowiecCalosc" FontSize="15" FontWeight="SemiBold" Margin="0,1,0,9"/>
                                <TextBlock Text="Surowiec pod ARiMR" FontSize="11.5" Foreground="{StaticResource Muted}"/>
                                <TextBlock x:Name="txtSurowiecArimr" FontSize="15" FontWeight="SemiBold" Margin="0,1,0,9"/>
                                <TextBlock Text="Hodowcy ARiMR / ogółem" FontSize="11.5" Foreground="{StaticResource Muted}"/>
                                <TextBlock x:Name="txtHodowcy" FontSize="15" FontWeight="SemiBold" Margin="0,1,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Symulator: dokontraktuj TOP X (4.2) -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="🧮 SYMULATOR — DOKONTRAKTUJ TOP HODOWCÓW" Style="{StaticResource CardTitle}"/>
                        <TextBlock x:Name="txtSymOpis" FontSize="11.5" Foreground="{StaticResource Muted}" TextWrapping="Wrap"/>
                        <Slider x:Name="sldSym" Minimum="0" Maximum="0" SmallChange="1" LargeChange="1"
                                TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,10,0,0"
                                ValueChanged="Sym_Changed"/>
                        <Border x:Name="boxSymWynik" Background="{StaticResource GreenSoft}" CornerRadius="9" Padding="13,10" Margin="0,10,0,0">
                            <TextBlock x:Name="txtSymWynik" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"
                                       Foreground="{StaticResource GreenDark}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Trend zgodności (8.1) -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📈 TREND ZGODNOŚCI ARiMR" Style="{StaticResource CardTitle}"/>
                        <UniformGrid x:Name="boxTrendKpi" Columns="3" Margin="0,-4,0,6" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Teraz" FontSize="10.5" Foreground="{StaticResource Muted}"/>
                                <TextBlock x:Name="txtTrendTeraz" FontSize="14.5" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Δ 7 dni" FontSize="10.5" Foreground="{StaticResource Muted}"/>
                                <TextBlock x:Name="txtTrend7" FontSize="14.5" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Δ 30 dni" FontSize="10.5" Foreground="{StaticResource Muted}"/>
                                <TextBlock x:Name="txtTrend30" FontSize="14.5" FontWeight="Bold"/>
                            </StackPanel>
                        </UniformGrid>
                        <Grid Height="96">
                            <Canvas x:Name="trendCanvas" ClipToBounds="True" SizeChanged="TrendCanvas_SizeChanged"/>
                            <TextBlock x:Name="txtTrendPusto" FontSize="11.5" Foreground="{StaticResource Muted}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap"
                                       Text="Brak historii — pierwszy punkt zapisał się dziś. Trend pojawi się przy kolejnych wizytach."/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="INWENTARZ KONTRAKTÓW" Style="{StaticResource CardTitle}"/>
                        <UniformGrid Columns="2" x:Name="gridInwentarz"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            </ScrollViewer>

            <!-- PRAWA -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top">
                            <TextBlock Text="⏰ DO DZIAŁANIA — WYGASAJĄ W 90 DNIACH" Style="{StaticResource CardTitle}"/>
                            <Border x:Name="badgeWygasajace" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="{StaticResource OrangeAlertBg}" CornerRadius="11" Padding="9,2" Visibility="Collapsed">
                                <TextBlock x:Name="txtBadgeWygasajace" FontSize="11.5" FontWeight="Bold"
                                           Foreground="{StaticResource OrangeAlertFg}"/>
                            </Border>
                        </Grid>
                        <TextBlock DockPanel.Dock="Top" Text="Dwuklik wiersza → otwórz kartę kontraktu"
                                   FontSize="10.5" Foreground="{StaticResource Muted}" Margin="0,-6,0,4"/>
                        <DataGrid x:Name="dgWygasajace" BorderThickness="0" RowHeight="34" MouseDoubleClick="DgWygasajace_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NR" Binding="{Binding NumerKontraktu}" Width="60"/>
                                <DataGridTextColumn Header="HODOWCA" Binding="{Binding Hodowca}" Width="*"/>
                                <DataGridTextColumn Header="TYP" Binding="{Binding TypLabel}" Width="110"/>
                                <DataGridTextColumn Header="WYGASA" Binding="{Binding WygasaLabel}" Width="95"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top">
                            <TextBlock Text="🟡 HODOWCY BEZ KONTRAKTU (dostawy 12 mies., brak umowy) — wg wolumenu" Style="{StaticResource CardTitle}"/>
                            <Border x:Name="badgeBezK" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="{StaticResource StatusInfoBg}" CornerRadius="11" Padding="9,2" Visibility="Collapsed">
                                <TextBlock x:Name="txtBadgeBezK" FontSize="11.5" FontWeight="Bold"
                                           Foreground="{StaticResource StatusInfoFg}"/>
                            </Border>
                        </Grid>
                        <TextBlock DockPanel.Dock="Top" Text="Dwuklik wiersza → kreator kontraktu (z prefillem)"
                                   FontSize="10.5" Foreground="{StaticResource Muted}" Margin="0,-6,0,4"/>
                        <DataGrid x:Name="dgBezKontraktu" BorderThickness="0" RowHeight="34" MouseDoubleClick="DgBezKontraktu_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="HODOWCA" Binding="{Binding Hodowca}" Width="*"/>
                                <DataGridTextColumn Header="DOSTAW" Binding="{Binding LiczbaDostaw}" Width="75"/>
                                <DataGridTextColumn Header="WOLUMEN 12M" Binding="{Binding WagaTonyLabel}" Width="110"/>
                                <DataGridTextColumn Header="OSTATNIA" Binding="{Binding OstatniaLabel}" Width="85"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
