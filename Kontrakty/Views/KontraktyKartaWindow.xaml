<Window x:Class="Kalendarz1.Kontrakty.Views.KontraktyKartaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Karta kontraktu" Height="720" Width="940"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kontrakty/Views/KontraktyTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="22,16">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="txtNumer" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    <TextBlock x:Name="txtHodowca" Foreground="#C8E6C9" FontSize="12.5" Margin="0,3,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border x:Name="chipStatus" CornerRadius="13" Padding="13,5" HorizontalAlignment="Right">
                        <TextBlock x:Name="txtStatus" FontWeight="Bold" FontSize="13" Foreground="#0F172A"/>
                    </Border>
                    <TextBlock x:Name="txtWygasa" Foreground="White" FontSize="12" Margin="0,5,0,0" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,16">
            <StackPanel>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="BIEŻĄCE WARUNKI" Style="{StaticResource CardTitle}"/>
                        <UniformGrid Columns="3">
                            <Border Background="{StaticResource Surface}" CornerRadius="10" Padding="13,11" Margin="0,0,5,0"
                                    BorderBrush="{StaticResource Line}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="📅  OKRES" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                                    <TextBlock x:Name="tileOkres" FontSize="14.5" FontWeight="SemiBold" Foreground="{StaticResource Ink}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="tileOkresSub" FontSize="11.5" Foreground="{StaticResource Muted}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{StaticResource Surface}" CornerRadius="10" Padding="13,11" Margin="5,0,5,0"
                                    BorderBrush="{StaticResource Line}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="💰  WARUNKI" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                                    <TextBlock x:Name="tileWarunki" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Ink}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="boxTermin" Background="{StaticResource Surface}" CornerRadius="10" Padding="13,11" Margin="5,0,0,0"
                                    BorderBrush="{StaticResource Line}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="⏰  TERMIN" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                                    <TextBlock x:Name="tileTermin" FontSize="14.5" FontWeight="Bold" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="tileTerminSub" FontSize="11.5" Foreground="{StaticResource Muted}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                        <TextBlock x:Name="txtBiezaceKlauzule" FontSize="12" Foreground="{StaticResource Muted}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        <StackPanel x:Name="panelPliki" Orientation="Horizontal" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="HISTORIA WERSJI — kliknij kafelek na osi lub wiersz w tabeli, by działać na wybranej wersji" Style="{StaticResource CardTitle}"/>

                        <!-- Pionowa oś czasu wersji (1.4) -->
                        <ItemsControl x:Name="icTimeline" Margin="2,4,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="TimelineItem_Click" Tag="{Binding}" Cursor="Hand"
                                            HorizontalContentAlignment="Stretch" BorderThickness="0" Padding="0" Background="Transparent">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- linia + kropka statusu -->
                                            <Grid Grid.Column="0">
                                                <Border Width="2" Background="{StaticResource Line}" HorizontalAlignment="Center"/>
                                                <Border Width="14" Height="14" CornerRadius="7" VerticalAlignment="Top"
                                                        Margin="0,10,0,0" BorderBrush="White" BorderThickness="2">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#94A3B8"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="ACTIVE"><Setter Property="Background" Value="#16A34A"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="SIGNED"><Setter Property="Background" Value="#16A34A"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="EXPIRING"><Setter Property="Background" Value="#D97706"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="EXPIRED"><Setter Property="Background" Value="#DC2626"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="TERMINATED"><Setter Property="Background" Value="#DC2626"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="SENT"><Setter Property="Background" Value="#2563EB"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="NEGOCJACJE"><Setter Property="Background" Value="#2563EB"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                            </Grid>
                                            <!-- karta wersji -->
                                            <Border Grid.Column="1" Margin="6,2,0,8" Background="White" CornerRadius="10"
                                                    Padding="13,9" BorderBrush="{StaticResource Line}" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAktualna}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{StaticResource Green}"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                                <Setter Property="Background" Value="{StaticResource GreenSoft}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <Grid>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding NrLabel}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource Ink}"/>
                                                            <Border CornerRadius="8" Padding="8,1" Margin="9,0,0,0" Background="{StaticResource StatusNeutralBg}">
                                                                <TextBlock Text="{Binding StatusLabel}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource StatusNeutralFg}"/>
                                                            </Border>
                                                            <Border CornerRadius="8" Padding="8,1" Margin="8,0,0,0" Background="{StaticResource GreenSoft}">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsAktualna}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="● AKTUALNA" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource GreenDark}"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding AutorLabel}" HorizontalAlignment="Right" FontSize="11" Foreground="{StaticResource TextTertiary}"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding OkresLabel}" FontSize="12.5" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/>
                                                    <TextBlock Text="{Binding WarunkiLabel}" FontSize="12" Foreground="{StaticResource Ink}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding PowodZmiany}" FontSize="11" Foreground="{StaticResource TextTertiary}" Margin="0,3,0,0"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <DataGrid x:Name="dgWersje" BorderThickness="0" RowHeight="38" MaxHeight="260"
                                  SelectionChanged="DgWersje_SelChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="WER." Binding="{Binding NrLabel}" Width="55"/>
                                <DataGridTextColumn Header="STATUS" Binding="{Binding StatusLabel}" Width="110"/>
                                <DataGridTextColumn Header="OKRES" Binding="{Binding OkresLabel}" Width="190"/>
                                <DataGridTextColumn Header="WARUNKI" Binding="{Binding WarunkiLabel}" Width="*"/>
                                <DataGridTextColumn Header="POWÓD" Binding="{Binding PowodZmiany}" Width="130"/>
                                <DataGridTextColumn Header="AUTOR" Binding="{Binding AutorLabel}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="ZAŁĄCZNIKI (skany, aneksy)" Style="{StaticResource CardTitle}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ComboBox x:Name="cbTypZal" Width="150" Margin="0,0,8,0">
                                    <ComboBoxItem Content="Skan podpisany" Tag="SKAN_PODPISANY" IsSelected="True"/>
                                    <ComboBoxItem Content="Aneks" Tag="ANEKS"/>
                                    <ComboBoxItem Content="Oświadczenie" Tag="OSWIADCZENIE"/>
                                    <ComboBoxItem Content="Korespondencja" Tag="KORESPONDENCJA"/>
                                    <ComboBoxItem Content="Inny" Tag="INNE"/>
                                </ComboBox>
                                <Button Content="📎 Dodaj plik" Style="{StaticResource Btn}" Click="BtnDodajZal_Click"/>
                                <Button Content="📂 Otwórz" Style="{StaticResource Btn}" Click="BtnOtworzZal_Click"/>
                            </StackPanel>
                        </Grid>
                        <DataGrid x:Name="dgZalaczniki" BorderThickness="0" RowHeight="34" MaxHeight="200" Margin="0,8,0,0"
                                  MouseDoubleClick="DgZalaczniki_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TYP" Binding="{Binding TypLabel}" Width="150"/>
                                <DataGridTextColumn Header="PLIK" Binding="{Binding NazwaPliku}" Width="*"/>
                                <DataGridTextColumn Header="DODANO" Binding="{Binding DodanyLabel}" Width="150"/>
                                <DataGridTextColumn Header="DODAŁ" Binding="{Binding DodalUserId}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Transformacja JDG → sp. z o.o. (9.2) -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="🔁 TRANSFORMACJA s.c. → sp. z o.o. (decyzja: aport / dzierżawa)" Style="{StaticResource CardTitle}"/>
                        <TextBlock Text="Jak przenieść ten kontrakt na nowy podmiot po przekształceniu (01.08.2026)."
                                   FontSize="11.5" Foreground="{StaticResource Muted}" Margin="0,-4,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/><ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Decyzja" Style="{StaticResource Lbl}"/>
                                <ComboBox x:Name="cbTransform">
                                    <ComboBoxItem Content="Nieokreślona" Tag="NIEOKRESLONE" IsSelected="True"/>
                                    <ComboBoxItem Content="Aport do sp. z o.o." Tag="APORT"/>
                                    <ComboBoxItem Content="Dzierżawa / cesja" Tag="DZIERZAWA"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Uzasadnienie / notatka" Style="{StaticResource Lbl}"/>
                                <TextBox x:Name="txtTransformUzas"/>
                            </StackPanel>
                            <Button Grid.Column="4" Content="💾 Zapisz decyzję" Style="{StaticResource Btn}"
                                    VerticalAlignment="Bottom" Click="BtnZapiszTransform_Click"/>
                        </Grid>
                        <TextBlock x:Name="txtTransformInfo" FontSize="11" Foreground="{StaticResource Muted}" Margin="2,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Audyt (8.3) -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="🕓 HISTORIA ZMIAN (audyt)" Style="{StaticResource CardTitle}"/>
                        <DataGrid x:Name="dgAudyt" BorderThickness="0" RowHeight="32" MaxHeight="220" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="KIEDY" Binding="{Binding KiedyLabel}" Width="130"/>
                                <DataGridTextColumn Header="OPERACJA" Binding="{Binding OpisLabel}" Width="180"/>
                                <DataGridTextColumn Header="SZCZEGÓŁ" Binding="{Binding SzczegolLabel}" Width="*"/>
                                <DataGridTextColumn Header="KTO" Binding="{Binding UserId}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock x:Name="txtAudytPusto" Text="Brak zapisów audytu dla tego kontraktu." FontSize="11.5"
                                   Foreground="{StaticResource Muted}" Margin="2,8,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Akcje -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="18,12">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnPrzedluz" Content="🔄 Przedłuż" Style="{StaticResource BtnPrimary}" Click="BtnPrzedluz_Click"/>
                <Button x:Name="btnEdytuj" Content="✏ Edytuj wersję" Style="{StaticResource Btn}" Click="BtnEdytuj_Click"/>
                <Button x:Name="btnAktywuj" Content="✅ Aktywuj wersję" Style="{StaticResource Btn}" Click="BtnAktywuj_Click"/>
                <Border Width="1" Background="{StaticResource Line}" Margin="6,3,12,3"/>
                <ComboBox x:Name="cbNowyStatus" Width="150">
                    <ComboBoxItem Content="→ Wysłany" Tag="SENT"/>
                    <ComboBoxItem Content="→ Podpisany" Tag="SIGNED"/>
                    <ComboBoxItem Content="→ Wygasły" Tag="EXPIRED"/>
                    <ComboBoxItem Content="→ Wypowiedziany" Tag="TERMINATED"/>
                </ComboBox>
                <Button x:Name="btnStatus" Content="Ustaw status" Style="{StaticResource Btn}" Margin="8,0,0,0" Click="BtnStatus_Click"/>
                <Border Width="1" Background="{StaticResource Line}" Margin="6,3,12,3"/>
                <Button x:Name="btnPodglad" Content="👁 Podgląd" Style="{StaticResource Btn}" Click="BtnPodglad_Click"
                        ToolTip="Podejrzyj treść umowy bez otwierania Worda"/>
                <Button x:Name="btnGenerujWord" Content="📄 Generuj Word" Style="{StaticResource Btn}" Click="BtnGenerujWord_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
