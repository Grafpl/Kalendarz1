<Window x:Class="Kalendarz1.Kontrakty.Views.KontraktKreatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nowy kontrakt z hodowcą" Height="940" Width="1620" MinWidth="1300" MinHeight="720"
        WindowState="Maximized" WindowStartupLocation="CenterOwner" Background="#F3F6F4"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kontrakty/Views/KontraktyTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ═════ UJEDNOLICONE KONTROLKI: jeden rozmiar w całym oknie ═════ -->
            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="Height" Value="44"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="Padding" Value="14,0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                <Setter Property="Height" Value="44"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Padding" Value="14,0"/>
            </Style>
            <Style TargetType="ComboBoxItem">
                <Setter Property="Padding" Value="14,10"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="MinHeight" Value="40"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="{StaticResource Ink}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="b" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource GreenSoft}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="{StaticResource GreenSoft}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="DatePicker" BasedOn="{StaticResource {x:Type DatePicker}}">
                <Setter Property="Height" Value="44"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style TargetType="TextBlock" x:Key="LblBig" BasedOn="{StaticResource Lbl}">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Margin" Value="0,12,0,5"/>
            </Style>
            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <!-- ═════ IKONY (Segoe Fluent Icons / Segoe MDL2 Assets) ═════ -->
            <Style x:Key="Ico" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,8,0"/>
            </Style>
            <Style x:Key="IcoBtn" TargetType="TextBlock" BasedOn="{StaticResource Ico}">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Margin" Value="0,0,6,0"/>
            </Style>

            <!-- ═════ Radio "card" — wybór z kropką i podświetleniem (do konfiskat) ═════ -->
            <Style x:Key="RadioCard" TargetType="RadioButton">
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8"
                                    Padding="{TemplateBinding Padding}" BorderThickness="1" BorderBrush="Transparent"
                                    SnapsToDevicePixels="True">
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <Ellipse Stroke="#B45309" StrokeThickness="2" Fill="White"/>
                                        <Ellipse x:Name="dot" Width="9" Height="9" Fill="#B45309" Visibility="Collapsed"/>
                                    </Grid>
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#FCF1DA"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#FBE9C6"/>
                                    <Setter TargetName="b" Property="BorderBrush" Value="#D9A050"/>
                                    <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═════ Karta z podniesieniem (subtelny cień) ═════ -->
            <Style x:Key="CardElev" TargetType="Border" BasedOn="{StaticResource Card}">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="14" ShadowDepth="2" Direction="270"
                                          Color="#94A3B8" Opacity="0.16"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═════ Kafelek cyklu z hover (subtelna interakcja, 2-kolumnowy grid) ═════ -->
            <Style x:Key="CycleTile" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Margin" Value="0,0,8,8"/>
                <Setter Property="Padding" Value="14,11"/>
                <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="#0D9488"/>
                        <Setter Property="Background" Value="#F0FAF9"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ═════ ListBoxItem z hover/selected akcentem (lista hodowców) ═════ -->
            <Style TargetType="ListBoxItem">
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="BorderBrush" Value="#F1F5F9"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="b" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}" CornerRadius="6">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#F0FDF4"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#DCFCE7"/>
                                    <Setter TargetName="b" Property="BorderBrush" Value="#86EFAC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═════ Pole-miniaturka (Warunki handlowe): subtelny hover na akcent ═════ -->
            <Style x:Key="FieldCard" TargetType="Border">
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="#94A3B8"/>
                        <Setter Property="Background" Value="#FAFBFC"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ═════ Przycisk teal dla cykli (Dodaj wstawienie) ═════ -->
            <Style x:Key="BtnTeal" TargetType="Button" BasedOn="{StaticResource Btn}">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background" Value="#0D9488"/>
                <Setter Property="BorderBrush" Value="#0F766E"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" CornerRadius="9" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                    Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#0F766E"/></Trigger>
                                <Trigger Property="IsPressed" Value="True"><Setter TargetName="bd" Property="Background" Value="#0B5F57"/></Trigger>
                                <Trigger Property="IsEnabled" Value="False"><Setter TargetName="bd" Property="Opacity" Value="0.45"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ════ Header (kompaktowy, 1 linia, z subtelnym cieniem) ════ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="22,7">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#0F172A" Opacity="0.18"/>
            </Border.Effect>
            <Grid>
                <TextBlock x:Name="txtTytulKrok" Text="➕ Nowy kontrakt z hodowcą"
                           Foreground="White" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtStopka" Text="" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="#C8E6C9" FontSize="12"/>
            </Grid>
        </Border>

        <!-- ════ 3 równe kolumny gwiazdkowe ════ -->
        <Grid Grid.Row="1" Margin="16,12,16,4">
            <Grid HorizontalAlignment="Center" MaxWidth="1900">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ COL 1: HODOWCA + PRODUCENT — Producent rozciągnięty do spodu ═══ -->
                <Grid x:Name="col1Panel" Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 🔎 ZNAJDŹ HODOWCĘ (pasek #2E7D32) -->
                    <Border Grid.Row="0" Style="{StaticResource CardElev}" Padding="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#2E7D32" CornerRadius="13,0,0,13"/>
                            <StackPanel Grid.Column="1" Margin="16,16,18,16">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource Ico}" Text="&#xE721;" Foreground="#1B5E20"/>
                                        <TextBlock Text="ZNAJDŹ HODOWCĘ" Style="{StaticResource CardTitle}" Foreground="#1B5E20"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="btnZIstniejacego" Style="{StaticResource BtnLink}"
                                                Visibility="Collapsed" Click="BtnZIstniejacego_Click"
                                                ToolTip="Wybierz z listy kontraktów tego hodowcy (aneks/przedłużenie)">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource IcoBtn}" Text="&#xE71D;"/>
                                                <TextBlock Text="Z istniejącego…" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="btnKopiuj" Style="{StaticResource BtnLink}"
                                                Visibility="Collapsed" Click="BtnKopiuj_Click" Margin="6,0,0,0"
                                                ToolTip="Kopiuj warunki z ostatniego kontraktu hodowcy">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource IcoBtn}" Text="&#xE8C8;"/>
                                                <TextBlock Text="Kopiuj ostatni" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <Border Background="{StaticResource Surface}" CornerRadius="10" BorderBrush="{StaticResource FieldBorder}"
                                        BorderThickness="1" Padding="13,0" Height="44">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource Ico}" Text="&#xE721;" Foreground="{StaticResource Muted}"/>
                                        <TextBox x:Name="txtSzukaj" Width="500" BorderThickness="0" Background="Transparent" FontSize="15"
                                                 VerticalContentAlignment="Center" TextChanged="SzukajHod_Changed"
                                                 ToolTip="Wpisz nazwę, NIP lub ID" Height="44"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="txtCount" FontSize="12" Foreground="{StaticResource Muted}" Margin="2,7,0,4"/>

                                <ListBox x:Name="lstHodowcy" Height="180" SelectionChanged="LstHodowcy_Changed"
                                         Visibility="Collapsed"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22"
                                                        Background="{StaticResource GreenSoft}" Margin="0,0,13,0">
                                                    <TextBlock Text="{Binding Inicjal}" FontSize="19" FontWeight="Bold"
                                                               Foreground="{StaticResource GreenDark}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Nazwa}" FontWeight="SemiBold" FontSize="15"
                                                               Foreground="{StaticResource Ink}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Meta}" FontSize="12.5" Foreground="{StaticResource Muted}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Banner wybranego -->
                                <Border x:Name="bannerWybrany" Visibility="Collapsed" Margin="0,12,0,0"
                                        Background="{StaticResource GreenSoft}" CornerRadius="11" Padding="16,12"
                                        BorderBrush="{StaticResource Green}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="46" Height="46" CornerRadius="23" Background="{StaticResource Green}" Margin="0,0,14,0" VerticalAlignment="Top">
                                            <TextBlock x:Name="txtWybranyInicjal" FontSize="19" FontWeight="Bold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="txtWybranyNazwa" FontSize="15.5" FontWeight="Bold"
                                                       Foreground="{StaticResource GreenDark}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="txtWybranyMeta" FontSize="12.5" Foreground="{StaticResource GreenDark}"
                                                       Opacity="0.85" TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                            <Border x:Name="boxHistoria" Background="#FFFFFF" CornerRadius="7" Padding="9,4" Margin="0,5,0,0"
                                                    BorderBrush="{StaticResource Green}" BorderThickness="1" Visibility="Collapsed"
                                                    HorizontalAlignment="Left">
                                                <TextBlock x:Name="txtWybranyHistoria" FontSize="11.5" FontWeight="SemiBold"
                                                           Foreground="{StaticResource GreenDark}"/>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Button x:Name="btnSprawdzalka"
                                                        Click="BtnSprawdzalka_Click"
                                                        Style="{StaticResource BtnPrimary}" Height="38" Padding="14,0"
                                                        ToolTip="Inteligentny przycisk: edytuje ostatnią umowę zakupu jeśli jest pending, w przeciwnym razie tworzy nową — z prefilowanym hodowcą">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="txtUmowaIco" Style="{StaticResource IcoBtn}" Text="&#xE8A5;"/>
                                                        <TextBlock x:Name="txtUmowaLabel" Text="Nowa umowa zakupu" VerticalAlignment="Center" FontSize="12.5"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="btnHistoriaUmow"
                                                        Click="BtnHistoriaUmow_Click" Margin="4,0,0,0"
                                                        Style="{StaticResource Btn}" Height="38" Padding="10,0"
                                                        ToolTip="Pełna historia umów hodowcy (Sprawdzalka)">
                                                    <TextBlock Style="{StaticResource IcoBtn}" Text="&#xE81C;" Margin="0"/>
                                                </Button>
                                            </StackPanel>
                                            <TextBlock x:Name="txtUmowaInfo" FontSize="11" Foreground="{StaticResource GreenDark}"
                                                       Opacity="0.75" HorizontalAlignment="Right" Margin="0,4,2,0"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="240"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- #3 Banner: hodowca ma już aktywny kontrakt -->
                                <Border x:Name="boxAktywneKontrakty" Visibility="Collapsed" Margin="0,8,0,0"
                                        Background="#FEF3C7" CornerRadius="11" Padding="14,10"
                                        BorderBrush="#F59E0B" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="⚠" FontSize="22" Foreground="#92400E"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="txtAktywneTytul" Text="Hodowca ma aktywny kontrakt"
                                                       FontSize="13.5" FontWeight="Bold" Foreground="#92400E"/>
                                            <TextBlock x:Name="txtAktywneSzczegoly" FontSize="12" Foreground="#92400E"
                                                       Opacity="0.9" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" x:Name="btnZobaczAktywny"
                                                Style="{StaticResource BtnLink}" Click="BtnZIstniejacego_Click"
                                                VerticalAlignment="Center" Margin="10,0,0,0"
                                                ToolTip="Otwórz listę kontraktów hodowcy">
                                            <TextBlock Text="📋  Zobacz/skopiuj" Foreground="#92400E" FontWeight="SemiBold"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 🧑‍🌾 DANE PRODUCENTA (pasek #2E7D32) — rozciągnięta na dół -->
                    <Border Grid.Row="1" Style="{StaticResource CardElev}" Padding="0" Margin="0,12,0,0" VerticalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#2E7D32" CornerRadius="13,0,0,13"/>
                            <StackPanel Grid.Column="1" Margin="16,16,18,16">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Ico}" Text="&#xE77B;" Foreground="#1B5E20"/>
                                    <TextBlock Text="DANE PRODUCENTA" Style="{StaticResource CardTitle}" Foreground="#1B5E20"/>
                                </StackPanel>

                                <TextBlock Text="🧑 Nazwa / imię i nazwisko" Style="{StaticResource LblBig}"/>
                                <TextBox x:Name="txtNazwa"/>

                                <Grid Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.6*"/><ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="🔖 NIP" Style="{StaticResource LblBig}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" x:Name="txtNip" TextChanged="PoleWalid_Changed"/>
                                            <Button Grid.Column="1" x:Name="btnGus" Click="BtnGus_Click"
                                                    Margin="6,0,0,0" Height="44" Padding="12,0" FontSize="13"
                                                    Background="#2563EB" Foreground="White" BorderThickness="0"
                                                    Cursor="Hand" IsEnabled="False"
                                                    ToolTip="Pobierz nazwę, REGON i adres z Białej Listy MF (po NIP)">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🌐" FontSize="14" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="txtGusLabel" Text="GUS" Margin="6,0,0,0"
                                                               VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                        <TextBlock x:Name="hintNip" FontSize="12" Margin="2,3,0,0" Visibility="Collapsed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="🆔 PESEL" Style="{StaticResource LblBig}"/>
                                        <TextBox x:Name="txtPesel" TextChanged="PoleWalid_Changed"/>
                                        <TextBlock x:Name="hintPesel" FontSize="12" Margin="2,3,0,0" Visibility="Collapsed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="🏢 REGON" Style="{StaticResource LblBig}"/>
                                        <TextBox x:Name="txtRegon"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"><TextBlock Text="🪪 Dowód" Style="{StaticResource LblBig}"/><TextBox x:Name="txtDowod"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="📞 Telefon" Style="{StaticResource LblBig}"/><TextBox x:Name="txtTelefon"/></StackPanel>
                                    <StackPanel Grid.Column="4"><TextBlock Text="✉ E-mail" Style="{StaticResource LblBig}"/><TextBox x:Name="txtEmail"/></StackPanel>
                                </Grid>

                                <Grid Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="🏷 Nr gosp. ARiMR" Style="{StaticResource LblBig}"/>
                                        <TextBox x:Name="txtGosp" TextChanged="PoleWalid_Changed"/>
                                        <TextBlock x:Name="hintGosp" FontSize="12" Margin="2,3,0,0" Visibility="Collapsed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="📍 Adres" Style="{StaticResource LblBig}"/>
                                        <TextBox x:Name="txtAdres"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ═══ COL 2: UMOWA + OKRES + WARUNKI — Warunki rozciągnięte do spodu ═══ -->
                <Grid x:Name="col2Panel" Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 📄 UMOWA I OKRES (pasek #2563EB) -->
                    <Border Grid.Row="0" Style="{StaticResource CardElev}" Padding="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#2563EB" CornerRadius="13,0,0,13"/>
                            <StackPanel Grid.Column="1" Margin="16,16,18,16">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Ico}" Text="&#xE8A5;" Foreground="#1D4ED8"/>
                                    <TextBlock Text="UMOWA I OKRES" Style="{StaticResource CardTitle}" Foreground="#1D4ED8"/>
                                </StackPanel>
                                <!-- UKRYTE: Typ kontraktu + Podmiot (defaultowane na ROCZNY / PIORKOWSCY_SC) -->
                                <Grid Visibility="Collapsed">
                                    <ComboBox x:Name="cbTyp">
                                        <ComboBoxItem Content="Roczny" Tag="ROCZNY" IsSelected="True"/>
                                        <ComboBoxItem Content="3-letni" Tag="ARIMR_3LAT"/>
                                        <ComboBoxItem Content="Sezonowy" Tag="SEZONOWY"/>
                                        <ComboBoxItem Content="Wieczny" Tag="WIECZNY"/>
                                        <ComboBoxItem Content="Spot" Tag="SPOT"/>
                                    </ComboBox>
                                    <ComboBox x:Name="cbPodmiot">
                                        <ComboBoxItem Content="Piórkowscy s.c." Tag="PIORKOWSCY_SC" IsSelected="True"/>
                                        <ComboBoxItem Content="Piórkowscy sp. z o.o." Tag="PIORKOWSCY_SPZOO"/>
                                    </ComboBox>
                                </Grid>

                                <!-- DATY + WYPOWIEDZENIE — wszystko w jednej linii (4 kolumny) -->
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="📅 Obowiązuje od" Style="{StaticResource LblBig}"/>
                                        <DatePicker x:Name="dpOd" ToolTip="Domyślnie dziś"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="📅 Obowiązuje do" Style="{StaticResource LblBig}"/>
                                        <DatePicker x:Name="dpDo" ToolTip="Standardowo +1 rok. Pomiń, gdy bezterminowy."/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="✍ Data podpisu" Style="{StaticResource LblBig}"/>
                                        <DatePicker x:Name="dpPodpis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="6">
                                        <TextBlock Text="⏳ Wypowiedzenie (dni)" Style="{StaticResource LblBig}"/>
                                        <TextBox x:Name="txtWypow" Text="90"
                                                 ToolTip="Ile dni wypowiedzenia (typowo 30/60/90)"/>
                                    </StackPanel>
                                </Grid>
                                <CheckBox x:Name="chkBezterm" Content="∞ Bezterminowy" Margin="0,8,0,0" Click="ChkBezterm_Click"
                                          ToolTip="Zaznacz aby kontrakt nie miał daty końca (pole „do&#x201D; zostanie wyłączone)"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 💰 WARUNKI HANDLOWE + ☑ KONFISKATY (pasek #D97706) — rozciągnięta na dół -->
                    <Border Grid.Row="1" Style="{StaticResource CardElev}" Padding="0" Margin="0,12,0,0" VerticalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#D97706" CornerRadius="13,0,0,13"/>
                            <StackPanel Grid.Column="1" Margin="16,16,18,16">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Ico}" Text="&#xE1D0;" Foreground="#B45309"/>
                                    <TextBlock Text="WARUNKI HANDLOWE" Style="{StaticResource CardTitle}" Foreground="#B45309"/>
                                </StackPanel>
                                <!-- 📊 OSTATNIE DOSTAWY — sugerowane warunki z FarmerCalc -->
                                <Border x:Name="panelSugestia" Visibility="Collapsed" Margin="0,4,0,10"
                                        Background="#F8FAFC" CornerRadius="11" Padding="14,11"
                                        BorderBrush="#CBD5E1" BorderThickness="1">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource Ico}" Text="&#xE9D5;" Foreground="#475569"/>
                                                <TextBlock Text="OSTATNIE DOSTAWY (scalone w 10-dniowe okna)" FontSize="11.5" FontWeight="Bold"
                                                           Foreground="#475569" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="txtSugestiaHint" Text="— klik karty zastosuje wszystkie warunki"
                                                           FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"
                                                           Margin="8,0,0,0"/>
                                            </StackPanel>
                                            <Button x:Name="btnZastosujSugestie" Style="{StaticResource Btn}"
                                                    HorizontalAlignment="Right" Click="BtnZastosujSugestie_Click"
                                                    Padding="12,0" Height="32" FontSize="12"
                                                    ToolTip="Zastosuj średni ubytek z 12 miesięcy">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Style="{StaticResource IcoBtn}" Text="&#xE74B;"/>
                                                    <TextBlock Text="Średnia" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                        <ItemsControl x:Name="icDostawy">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="3"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="White" CornerRadius="9" Padding="12,10" Margin="4,0"
                                                            BorderBrush="#E2E8F0" BorderThickness="1" Cursor="Hand"
                                                            ToolTip="Klik = zastosuj ubytek/dodatek/typ ceny/wagę z tej grupy"
                                                            MouseLeftButtonUp="DostawaCard_Click"
                                                            Tag="{Binding}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="White"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#EFF6FF"/>
                                                                        <Setter Property="BorderBrush" Value="#3B82F6"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel>
                                                            <!-- Header: zakres dat + liczba dostaw -->
                                                            <Grid>
                                                                <TextBlock Text="{Binding DataLabel}" FontSize="13" FontWeight="Bold"
                                                                           Foreground="#0F172A" HorizontalAlignment="Left"/>
                                                                <Border Background="#F1F5F9" CornerRadius="10" Padding="7,2"
                                                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding LiczbaLabel}" FontSize="10.5"
                                                                               FontWeight="SemiBold" Foreground="#475569"/>
                                                                </Border>
                                                            </Grid>

                                                            <!-- TYP CENY — najważniejszy, eksponowany -->
                                                            <Border Background="#EEF2FF" CornerRadius="7" Padding="9,7" Margin="0,8,0,8"
                                                                    BorderBrush="#C7D2FE" BorderThickness="1">
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                    <TextBlock Text="💰 " FontSize="14" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding TypCenyLabel}" FontSize="14" FontWeight="Bold"
                                                                               Foreground="#3730A3" VerticalAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                </StackPanel>
                                                            </Border>

                                                            <!-- Cena (zielony) -->
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="💱 Cena" FontSize="11.5" Foreground="#475569"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding CenaLabel}" FontSize="13" FontWeight="Bold"
                                                                           Foreground="#047857" HorizontalAlignment="Right"/>
                                                            </Grid>
                                                            <!-- Dodatek (granat) -->
                                                            <Grid Margin="0,3,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="➕ Dodatek" FontSize="11.5" Foreground="#475569"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding DodatekLabel}" FontSize="13" FontWeight="Bold"
                                                                           Foreground="#1E40AF" HorizontalAlignment="Right"/>
                                                            </Grid>
                                                            <!-- Ubytek (czerwony) -->
                                                            <Grid Margin="0,3,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="🚛 Ubytek" FontSize="11.5" Foreground="#475569"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding UbytekLabel}" FontSize="13" FontWeight="Bold"
                                                                           Foreground="#B91C1C" HorizontalAlignment="Right"/>
                                                            </Grid>
                                                            <!-- Czyja waga (fiolet) -->
                                                            <Grid Margin="0,3,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="⚖ Waga" FontSize="11.5" Foreground="#475569"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding CzyjaWagaLabel}" FontSize="13" FontWeight="Bold"
                                                                           Foreground="#6B21A8" HorizontalAlignment="Right"/>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Border x:Name="boxDostawyPusto" Visibility="Collapsed" Margin="0,2,0,0"
                                                Background="#FAFAFA" CornerRadius="8" Padding="14,12"
                                                BorderBrush="#E5E7EB" BorderThickness="1">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="📭" FontSize="22" HorizontalAlignment="Center" Opacity="0.5"/>
                                                <TextBlock Text="Brak potwierdzonych dostaw w ostatnich 12 miesiącach"
                                                           FontSize="11.5" Foreground="#94A3B8" FontStyle="Italic"
                                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock x:Name="txtSugestia" FontSize="11.5" Foreground="#64748B"
                                                   Margin="2,8,0,0" TextWrapping="Wrap" FontStyle="Italic"/>
                                    </StackPanel>
                                </Border>

                                <!-- 💼 Pola warunków: siatka 2×2 — większe pola, więcej oddechu -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- [0,0] Typ ceny — indygo -->
                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="5"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#4338CA" CornerRadius="10,0,0,10"/>
                                            <StackPanel Grid.Column="1" Margin="14,7,14,12">
                                                <TextBlock FontSize="13" Margin="0,2,0,6">
                                                    <Run Text="💱  " FontSize="15"/>
                                                    <Run Text="Typ ceny" Foreground="#4338CA" FontWeight="SemiBold"/>
                                                </TextBlock>
                                                <ComboBox x:Name="cbTypCeny">
                                                    <ComboBoxItem Content="wolnorynkowa" Tag="wolnorynkowa" IsSelected="True"/>
                                                    <ComboBoxItem Content="rolnicza" Tag="rolnicza"/>
                                                    <ComboBoxItem Content="ministerialna" Tag="ministerialna"/>
                                                    <ComboBoxItem Content="łączona" Tag="laczona"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- [0,1] Dodatek — szmaragd -->
                                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource FieldCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="5"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#047857" CornerRadius="10,0,0,10"/>
                                            <StackPanel Grid.Column="1" Margin="14,7,14,12">
                                                <TextBlock FontSize="13" Margin="0,2,0,6">
                                                    <Run Text="➕  " FontSize="15"/>
                                                    <Run Text="Dodatek (zł/kg)" Foreground="#047857" FontWeight="SemiBold"/>
                                                </TextBlock>
                                                <TextBox x:Name="txtDodatek"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- [1,0] Ubytek — czerwień + 🚛 -->
                                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="5"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#B91C1C" CornerRadius="10,0,0,10"/>
                                            <StackPanel Grid.Column="1" Margin="14,7,14,12">
                                                <TextBlock FontSize="13" Margin="0,2,0,6">
                                                    <Run Text="🚛  " FontSize="15"/>
                                                    <Run Text="Ubytek (%)" Foreground="#B91C1C" FontWeight="SemiBold"/>
                                                </TextBlock>
                                                <TextBox x:Name="txtUbytek" Text="3,0"
                                                         ToolTip="Procent ubytku wagi w transporcie (typowo 2–4%)"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- [1,1] Płatność — fiolet -->
                                    <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource FieldCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="5"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#6B21A8" CornerRadius="10,0,0,10"/>
                                            <StackPanel Grid.Column="1" Margin="14,7,14,12">
                                                <TextBlock FontSize="13" Margin="0,2,0,6">
                                                    <Run Text="💳  " FontSize="15"/>
                                                    <Run Text="Płatność (dni)" Foreground="#6B21A8" FontWeight="SemiBold"/>
                                                </TextBlock>
                                                <TextBox x:Name="txtTermin" Text="45"
                                                         ToolTip="Ile dni od dostawy do zapłaty (domyślnie 45; typowo 14/21/30/45/60)"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Row 3: Rozliczana waga (miniaturka jak inne) + Konfiskaty -->
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- LEWA: Rozliczana waga — granatowy akcent -->
                                    <Border Grid.Column="0" Style="{StaticResource FieldCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="5"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#1E40AF" CornerRadius="10,0,0,10"/>
                                            <StackPanel Grid.Column="1" Margin="14,7,14,12">
                                                <TextBlock FontSize="13" Margin="0,2,0,6">
                                                    <Run Text="⚖  " FontSize="15"/>
                                                    <Run Text="Rozliczana waga" Foreground="#1E40AF" FontWeight="SemiBold"/>
                                                </TextBlock>
                                                <ComboBox x:Name="cbWaga"
                                                          ToolTip="Czyja waga jest podstawą rozliczenia: netto hodowcy (po jego stronie) lub netto ubojni (po naszej)">
                                                    <ComboBoxItem Content="netto hodowcy" Tag="NETTO_HODOWCY" IsSelected="True"/>
                                                    <ComboBoxItem Content="netto ubojni" Tag="NETTO_UBOJNI"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- PRAWA: Konfiskaty i padłe (bursztyn) — radio obok siebie, kompakt -->
                                    <Border Grid.Column="2" Background="#FEF6E7" CornerRadius="10" Padding="14,9,14,11"
                                            BorderBrush="#F2DDB0" BorderThickness="1">
                                        <StackPanel>
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Style="{StaticResource Ico}" Text="&#xE7BA;" Foreground="#B45309"/>
                                                    <TextBlock Text="KONFISKATY I PADŁE — kto pokrywa?"
                                                               FontSize="11.5" FontWeight="Bold" Foreground="#B45309"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,7,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Hodowca (default) -->
                                                <RadioButton Grid.Column="0" x:Name="chkKonfiskatyHodowca" GroupName="KonfPokrywa"
                                                             IsChecked="True" Style="{StaticResource RadioCard}"
                                                             ToolTip="Hodowca bierze koszty konfiskat i padłych na siebie — kwota potrącana z rozliczenia za dostawę">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Style="{StaticResource Ico}" Text="&#xE77B;"
                                                                   FontSize="16" Foreground="#B45309" Margin="0,0,8,0"/>
                                                        <StackPanel>
                                                            <TextBlock Text="Hodowca" FontWeight="SemiBold"
                                                                       FontSize="13" Foreground="#B45309"/>
                                                            <TextBlock Text="potrącane"
                                                                       FontSize="10.5" Foreground="#92400E" Opacity="0.85"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </RadioButton>
                                                <!-- Ubojnia -->
                                                <RadioButton Grid.Column="2" GroupName="KonfPokrywa" Style="{StaticResource RadioCard}"
                                                             ToolTip="Ubojnia bierze koszty konfiskat i padłych na siebie — nie potrącamy hodowcy">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Style="{StaticResource Ico}" Text="&#xE7E6;"
                                                                   FontSize="16" Foreground="#B45309" Margin="0,0,8,0"/>
                                                        <StackPanel>
                                                            <TextBlock Text="Ubojnia" FontWeight="SemiBold"
                                                                       FontSize="13" Foreground="#B45309"/>
                                                            <TextBlock Text="nasz koszt"
                                                                       FontSize="10.5" Foreground="#92400E" Opacity="0.85"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </RadioButton>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ═══ COL 3: CYKLE + SKAN + WALIDACJA + PRZYCISKI — wysokość zsynchronizowana z col 2 ═══ -->
                <Grid Grid.Column="4" VerticalAlignment="Top"
                      Height="{Binding ActualHeight, ElementName=col2Panel}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 🐔 CYKLE WSTAWIEŃ (pasek #0D9488 teal) -->
                    <Border Grid.Row="0" Style="{StaticResource CardElev}" Padding="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#0D9488" CornerRadius="13,0,0,13"/>
                            <DockPanel Grid.Column="1" Margin="16,16,18,16">
                                <Grid DockPanel.Dock="Top">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource Ico}" Text="&#xE787;" Foreground="#0F766E"/>
                                        <TextBlock Text="CYKLE WSTAWIEŃ" Style="{StaticResource CardTitle}" Foreground="#0F766E"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Border Background="#E0F2F0" CornerRadius="12" Padding="12,5" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <TextBlock x:Name="txtKpiCykle" FontSize="12.5" FontWeight="Bold" Foreground="#0F766E"
                                                       Text="0 wstawień"/>
                                        </Border>
                                        <Button Style="{StaticResource BtnTeal}" Click="BtnDodajCykl_Click"
                                                Height="38" Padding="14,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource IcoBtn}" Text="&#xE710;" Foreground="White"/>
                                                <TextBlock Text="Dodaj wstawienie" VerticalAlignment="Center" FontSize="13.5"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource Btn}" Click="BtnWyczyscCykle_Click"
                                                ToolTip="Wyczyść wszystkie wstawienia" Padding="11,0" Height="38" Margin="6,0,0,0">
                                            <TextBlock Style="{StaticResource IcoBtn}" Text="&#xE74D;" Margin="0"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <TextBlock DockPanel.Dock="Top" FontSize="12.5" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,-2,0,10">
                                    Data + sztuki → ubiórka i pełny ubój policzą się same. W dialogu możesz dodać kilka cykli co N dni.
                                </TextBlock>

                                <Border x:Name="boxCyklePusto" Background="{StaticResource Surface}" CornerRadius="10" Padding="14,22"
                                        BorderBrush="{StaticResource FieldBorder}" BorderThickness="1">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource Ico}" Text="&#xE787;" FontSize="32" Foreground="#0F766E" Opacity="0.55" Margin="0,0,0,6"/>
                                        <TextBlock Text="Brak wstawień" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Muted}"
                                                   HorizontalAlignment="Center" Margin="0,6,0,3"/>
                                        <TextBlock Text="Kliknij „Dodaj wstawienie&quot;, aby utworzyć cykl."
                                                   FontSize="11" Foreground="{StaticResource Muted}" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                                    <ItemsControl x:Name="icCykle">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="2"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource CycleTile}">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Border Background="#E0F2F0" CornerRadius="8" Padding="11,5" HorizontalAlignment="Left">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Style="{StaticResource IcoBtn}" Text="&#xE787;" Foreground="#0F766E"/>
                                                                    <TextBlock Text="CYKL " FontSize="11.5" FontWeight="Bold" Foreground="#0F766E"/>
                                                                    <TextBlock Text="{Binding NrCyklu}" FontSize="13.5" FontWeight="Bold" Foreground="#0F766E"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <TextBlock Text="{Binding IloscWstawionaLabel}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                       FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                                        </Grid>

                                                        <Grid Margin="0,12,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="28"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Ico}" Text="&#xE787;" Foreground="#0F766E" Margin="0"/>
                                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Wstawienie" FontSize="12.5"
                                                                       Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding DataWstawieniaLabel}"
                                                                       FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>

                                                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Ico}" Text="&#xF158;" Foreground="#0F766E" Margin="0,6,0,0"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Ubiórka (+33 dni)" FontSize="12.5"
                                                                       Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding DataUbiorkaLabel}"
                                                                       FontSize="13.5" Foreground="{StaticResource Ink}" VerticalAlignment="Center" Margin="0,6,0,0"/>

                                                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Ico}" Text="&#xE73E;" Foreground="#0F766E" Margin="0,6,0,0"/>
                                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Pełny ubój (+42 dni)" FontSize="12.5"
                                                                       Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                                                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding DataUbojuLabel}"
                                                                       FontSize="13.5" FontWeight="Bold" Foreground="#0F766E" VerticalAlignment="Center" Margin="0,6,0,0"/>
                                                        </Grid>

                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,13,0,0">
                                                            <Button Style="{StaticResource Btn}" Tag="{Binding}" Click="BtnEdytujCykl_Click"
                                                                    Padding="13,4" Height="34" ToolTip="Edytuj wstawienie">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Style="{StaticResource IcoBtn}" Text="&#xE70F;"/>
                                                                    <TextBlock Text="Edytuj" VerticalAlignment="Center" FontSize="13"/>
                                                                </StackPanel>
                                                            </Button>
                                                            <Button Style="{StaticResource Btn}" Tag="{Binding}" Click="BtnUsunCyklJeden_Click"
                                                                    Padding="13,4" Height="34" ToolTip="Usuń wstawienie">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Style="{StaticResource IcoBtn}" Text="&#xE74D;"/>
                                                                    <TextBlock Text="Usuń" VerticalAlignment="Center" FontSize="13"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Grid>
                    </Border>

                    <!-- 📎 SKAN / ZAŁĄCZNIK (pasek #94A3B8, drag&drop PDF) -->
                    <Border x:Name="borderSkan" Grid.Row="1" Style="{StaticResource CardElev}" Padding="0" Margin="0,12,0,0"
                            AllowDrop="True" PreviewDragOver="SkanBorder_DragOver" PreviewDragLeave="SkanBorder_DragLeave" Drop="SkanBorder_Drop"
                            ToolTip="Przeciągnij plik PDF tutaj lub kliknij „Wybierz&#x201D;">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="borderSkanStripe" Grid.Column="0" Background="#94A3B8" CornerRadius="13,0,0,13"/>
                            <StackPanel Grid.Column="1" Margin="16,16,18,16">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Ico}" Text="&#xE723;" Foreground="#475569"/>
                                    <TextBlock Text="SKAN / ZAŁĄCZNIK (opcjonalnie)" Style="{StaticResource CardTitle}" Foreground="#475569"/>
                                </StackPanel>
                                <Grid Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/><ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="📋 Typ" Style="{StaticResource LblBig}"/>
                                        <ComboBox x:Name="cbTypZal">
                                            <ComboBoxItem Content="Skan podpisany" Tag="SKAN_PODPISANY" IsSelected="True"/>
                                            <ComboBoxItem Content="Aneks" Tag="ANEKS"/>
                                            <ComboBoxItem Content="Oświadczenie" Tag="OSWIADCZENIE"/>
                                            <ComboBoxItem Content="Korespondencja" Tag="KORESPONDENCJA"/>
                                            <ComboBoxItem Content="Inny" Tag="INNE"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="📂 Plik" Style="{StaticResource LblBig}"/>
                                        <TextBox x:Name="txtSkanPlik" IsReadOnly="True"/>
                                    </StackPanel>
                                    <Button Grid.Column="4" Style="{StaticResource Btn}"
                                            VerticalAlignment="Bottom" Click="BtnWybierzSkan_Click"
                                            Height="44" Padding="14,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource IcoBtn}" Text="&#xE723;"/>
                                            <TextBlock Text="Wybierz" VerticalAlignment="Center" FontSize="13"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- STATUS WALIDACJI (1-linia, kolor wg stanu) -->
                    <Border Grid.Row="2" x:Name="boxWalidacja" Background="#FEE2E2" CornerRadius="10" Padding="14,11" Margin="0,10,0,0"
                            BorderBrush="#FCA5A5" BorderThickness="1" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource Ico}" Text="&#xE7BA;" FontSize="18" Foreground="#991B1B"
                                       VerticalAlignment="Top" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" x:Name="txtWalidacja" Foreground="#991B1B" FontSize="12.5"
                                       FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- PRZYCISKI (pionowo, pod walidacją) -->
                    <StackPanel Grid.Row="3" Margin="0,12,0,0">
                        <Button x:Name="btnZapiszWord"
                                Style="{StaticResource BtnPrimary}" Click="BtnZapiszWord_Click"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Height="48" Padding="14,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IcoBtn}" Text="&#xE74E;" FontSize="15" Foreground="White"/>
                                <TextBlock Text="Zapisz i generuj Word" VerticalAlignment="Center" FontSize="15"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnZapisz"
                                Style="{StaticResource Btn}" Click="BtnZapisz_Click"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Height="44" Margin="0,8,0,0" Padding="14,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IcoBtn}" Text="&#xE74E;"/>
                                <TextBlock Text="Zapisz (bez generowania)" VerticalAlignment="Center" FontSize="13.5"/>
                            </StackPanel>
                        </Button>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="btnPodglad"
                                    Style="{StaticResource Btn}" Click="BtnPodglad_Click"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Height="44" Padding="10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IcoBtn}" Text="&#xE7B3;"/>
                                    <TextBlock Text="Podgląd" VerticalAlignment="Center" FontSize="13"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2"
                                    Style="{StaticResource Btn}" Click="BtnAnuluj_Click"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Height="44" Padding="10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IcoBtn}" Text="&#xE711;"/>
                                    <TextBlock Text="Anuluj" VerticalAlignment="Center" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
