<Window x:Class="Kalendarz1.Sprawozdania.Views.P02Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="P-02 — Sprawozdanie GUS"
        WindowStartupLocation="Manual"
        WindowState="Normal" ResizeMode="CanResize"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13"
        xmlns:local="clr-namespace:Kalendarz1.Sprawozdania.Views">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{x:Static local:P02Window.LoadCmd}" />
        <KeyBinding Key="G" Modifiers="Control" Command="{x:Static local:P02Window.GenerateCmd}" />
        <KeyBinding Key="P" Modifiers="Control" Command="{x:Static local:P02Window.PreviewCmd}" />
        <KeyBinding Key="H" Modifiers="Control" Command="{x:Static local:P02Window.HistoryCmd}" />
        <KeyBinding Key="Left" Modifiers="Control" Command="{x:Static local:P02Window.PrevMonthCmd}" />
        <KeyBinding Key="Right" Modifiers="Control" Command="{x:Static local:P02Window.NextMonthCmd}" />
        <KeyBinding Key="Escape" Command="{x:Static local:P02Window.CloseCmd}" />
    </Window.InputBindings>
    <Window.Resources>
        <!-- Color tokens -->
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7785"/>
        <SolidColorBrush x:Key="TextSubtle" Color="#9BA4B0"/>
        <SolidColorBrush x:Key="CardBg" Color="White"/>
        <SolidColorBrush x:Key="CardBorder" Color="#E2E7ED"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#15803D"/>
        <SolidColorBrush x:Key="RedBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="AmberBrush" Color="#D97706"/>

        <!-- Group tints — production / sales / stocks -->
        <SolidColorBrush x:Key="ProdGroupBg" Color="#ECFDF5"/>
        <SolidColorBrush x:Key="ProdGroupBorder" Color="#A7F3D0"/>
        <SolidColorBrush x:Key="ProdGroupText" Color="#065F46"/>
        <SolidColorBrush x:Key="SprzGroupBg" Color="#EFF6FF"/>
        <SolidColorBrush x:Key="SprzGroupBorder" Color="#BFDBFE"/>
        <SolidColorBrush x:Key="SprzGroupText" Color="#1E40AF"/>
        <SolidColorBrush x:Key="ZapGroupBg" Color="#FFFBEB"/>
        <SolidColorBrush x:Key="ZapGroupBorder" Color="#FDE68A"/>
        <SolidColorBrush x:Key="ZapGroupText" Color="#92400E"/>

        <!-- DataGrid styles -->
        <SolidColorBrush x:Key="DgHeaderBg" Color="#F0F4F8"/>
        <SolidColorBrush x:Key="DgRowBg" Color="White"/>
        <SolidColorBrush x:Key="DgAltRowBg" Color="#FAFBFC"/>
        <SolidColorBrush x:Key="DgRowHoverBg" Color="#F0F7FF"/>

        <!-- Buttons -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="IconBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="MinWidth" Value="38"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <!-- DataGrid column header -->
        <Style x:Key="DgHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource DgHeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <!-- Row hover -->
        <Style x:Key="DgRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource DgRowBg}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DgRowHoverBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Number cell -->
        <Style x:Key="DgNumericCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="DgNumericZeroCellStyle" TargetType="TextBlock" BasedOn="{StaticResource DgNumericCellStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextSubtle}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ Header bar ═══════════ -->
        <Border Grid.Row="0" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFFF" Offset="0"/>
                    <GradientStop Color="#F8FAFC" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="22,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#FEF3C7" CornerRadius="8" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="🏭  P-02" FontSize="14" FontWeight="Bold" Foreground="#92400E"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Meldunek o produkcji wyrobów przemysłowych"
                                   FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Sprawozdanie do Głównego Urzędu Statystycznego — generowanie XML z bazy HANDEL"
                                   FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border x:Name="statusBadge" Background="#FEF3C7" CornerRadius="14"
                            Padding="12,4" Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtStatus" Text="Wybierz miesiąc" FontSize="11"
                                   FontWeight="SemiBold" Foreground="#92400E"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolBtn}" Content="📜  Historia" Click="BtnHistory_Click"
                            ToolTip="Pokaż wszystkie wygenerowane sprawozdania  (Ctrl+H)"/>
                    <Button Style="{StaticResource ToolBtn}" Content="⚙  Konfiguracja" Click="BtnSettings_Click"
                            ToolTip="Konfiguracja modułu (REGON, osoba odpowiedzialna)"/>
                    <Button Style="{StaticResource IconBtn}" Content="✖" Click="BtnClose_Click"
                            ToolTip="Zamknij okno  (Esc)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ Toolbar: period + actions ═══════════ -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1">
            <Grid Margin="22,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#F1F5F9" CornerRadius="6" Padding="2"
                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource IconBtn}" Content="◀" Click="BtnPrevMonth_Click"
                                    Background="Transparent" BorderThickness="0" ToolTip="Poprzedni miesiąc"/>
                            <ComboBox x:Name="cbMiesiac" Width="130" Margin="2,2" Padding="6,4"
                                      SelectionChanged="Picker_Changed" BorderThickness="0" Background="Transparent"/>
                            <ComboBox x:Name="cbRok" Width="78" Margin="2,2" Padding="6,4"
                                      SelectionChanged="Picker_Changed" BorderThickness="0" Background="Transparent"/>
                            <Button Style="{StaticResource IconBtn}" Content="▶" Click="BtnNextMonth_Click"
                                    Background="Transparent" BorderThickness="0" ToolTip="Następny miesiąc"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource PrimaryBtn}" Content="🔄  Pobierz z HANDEL"
                            Click="BtnLoad_Click" MinWidth="180" Margin="10,0,0,0"
                            ToolTip="Pobierz sprzedaż FVS/FKS + produkcję PWU/PWP/PWK za wybrany miesiąc i YTD  (F5)"/>
                    <Button Style="{StaticResource ToolBtn}" Content="🧮  Sugeruj zapasy"
                            Click="BtnSugerujZapasy_Click" MinWidth="160" Margin="8,0,0,0"
                            ToolTip="Otwórz dialog porównania metod liczenia zapasów wyrobów. Symfonia zwykle zostawia 0."/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolBtn}" Content="🔍  Podgląd XML" Click="BtnPreviewXml_Click"
                            ToolTip="Pokaż jak będzie wyglądał XML przed eksportem  (Ctrl+P)"/>
                    <Button Style="{StaticResource PrimaryBtn}" Content="💾  Generuj XML"
                            Click="BtnGenerate_Click" MinWidth="160"
                            ToolTip="Zapisz XML do pliku i wpisz do historii  (Ctrl+G)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ Main content ═══════════ -->
        <Grid Grid.Row="2" Margin="22,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Info pasek z hintem dwukliknięcia -->
            <Border Grid.Row="0" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                    CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Left" Text="💡" FontSize="18" VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#1E40AF">
                            <Run Text="Jednostka: TONA (1000 kg)"/><Run Text="  ·  "/>
                            <Run Text="Klikaj komórki liczbowe, by edytować"/><Run Text="  ·  "/>
                            <Run Text="DWUKLIK na komórkę = pokaż dokumenty źródłowe"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="#1E40AF" Margin="0,3,0,0" TextWrapping="Wrap">
                            <Run Text="Produkcja"/><Run FontWeight="SemiBold" Text=" = "/><Run Text="HM.MG typu PWU+PWP+PWK"/>
                            <Run Text="     ·     "/>
                            <Run Text="Sprzedaż"/><Run FontWeight="SemiBold" Text=" = "/><Run Text="HM.DK typu FVS+FKS"/>
                            <Run Text="     ·     "/>
                            <Run Text="Zapasy"/><Run FontWeight="SemiBold" Text=" = "/><Run Text="0 (wpisz ręcznie, jeśli masz)"/>
                        </TextBlock>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Warning panel: towary bez klasyfikacji -->
            <Border Grid.Row="1" x:Name="brakKlasyfPanel" Background="#FEF3C7" BorderBrush="#FACC15"
                    BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,10"
                    Visibility="Collapsed">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right" Content="Pokaż listę" Padding="12,5"
                            Click="BtnShowBrakKlasyf_Click"/>
                    <TextBlock DockPanel.Dock="Left" Text="⚠" FontSize="18" VerticalAlignment="Center"
                               Margin="0,0,12,0" Foreground="#92400E"/>
                    <TextBlock x:Name="lblBrakKlasyf" VerticalAlignment="Center" FontSize="12"
                               Foreground="#92400E" TextWrapping="Wrap"/>
                </DockPanel>
            </Border>

            <!-- Group headers nad DataGrid (4 sekcje: meta / produkcja / sprzedaż / zapasy) -->
            <Grid Grid.Row="2" Height="30" Background="White">
                <Grid.ColumnDefinitions>
                    <!-- Lp(42) + PKWiU(110) + Nazwa(*) + Jedn(60) — meta -->
                    <ColumnDefinition Width="42"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <!-- Produkcja: MC(120) + YTD(170) = 290 -->
                    <ColumnDefinition Width="290"/>
                    <!-- Sprzedaż: MC(120) + YTD(170) = 290 -->
                    <ColumnDefinition Width="290"/>
                    <!-- Zapasy: W(100) + T(100) = 200 -->
                    <ColumnDefinition Width="200"/>
                    <!-- Kodów(65) -->
                    <ColumnDefinition Width="65"/>
                </Grid.ColumnDefinitions>
                <!-- Lp+PKWiU+Nazwa+Jedn: bez label -->
                <Border Grid.Column="0" Grid.ColumnSpan="4" Background="#FAFBFC"
                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1,1,0,0"
                        CornerRadius="6,0,0,0"/>
                <!-- Produkcja -->
                <Border Grid.Column="4" Background="{StaticResource ProdGroupBg}"
                        BorderBrush="{StaticResource ProdGroupBorder}" BorderThickness="1,1,1,0">
                    <TextBlock Text="PRODUKCJA WYTWORZONA" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource ProdGroupText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0,4"/>
                </Border>
                <!-- Sprzedaż -->
                <Border Grid.Column="5" Background="{StaticResource SprzGroupBg}"
                        BorderBrush="{StaticResource SprzGroupBorder}" BorderThickness="1,1,1,0">
                    <TextBlock Text="PRODUKCJA SPRZEDANA" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource SprzGroupText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0,4"/>
                </Border>
                <!-- Zapasy -->
                <Border Grid.Column="6" Background="{StaticResource ZapGroupBg}"
                        BorderBrush="{StaticResource ZapGroupBorder}" BorderThickness="1,1,1,0">
                    <TextBlock Text="ZAPASY" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource ZapGroupText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0,4"/>
                </Border>
                <!-- Kodów -->
                <Border Grid.Column="7" Background="#FAFBFC"
                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1,1,1,0"
                        CornerRadius="0,6,0,0"/>
            </Grid>

            <!-- DataGrid pozycji + empty state overlay -->
            <Grid Grid.Row="3">
            <Border Background="White" BorderBrush="{StaticResource CardBorder}"
                    BorderThickness="1" CornerRadius="0,0,6,6">
                <DataGrid x:Name="dgPozycje" AutoGenerateColumns="False" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" RowHeight="50"
                          CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="False"
                          CanUserResizeColumns="False"
                          ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                          RowStyle="{StaticResource DgRowStyle}"
                          AlternatingRowBackground="{StaticResource DgAltRowBg}" Background="Transparent"
                          BorderThickness="0" SelectionMode="Single" SelectionUnit="Cell"
                          MouseDoubleClick="DgPozycje_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Lp." Binding="{Binding Lp}" Width="42" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="PKWiU" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid ToolTip="{Binding KodyTooltip}">
                                        <Border Width="4" HorizontalAlignment="Left" Background="{Binding KolorPasek}"/>
                                        <TextBlock Text="{Binding Pkwiu}" FontWeight="Bold"
                                                   VerticalAlignment="Center" Margin="14,0,4,0"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Nazwa wyrobu" Binding="{Binding NazwaWyrobu}" Width="*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="8,4"/>
                                    <Setter Property="FontStyle" Value="Italic"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Jedn." Binding="{Binding JednostkaKod}" Width="60" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSubtle}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- PRODUKCJA — zielone tło -->
                        <DataGridTextColumn x:Name="colProdMc" Header="w miesiącu  (t)"
                                            Binding="{Binding ProdukcjaWMiesiacuTony, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}"
                                            Width="120">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="{StaticResource ProdGroupBg}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="ToolTip" Value="📊 Dwuklik = pokaż dokumenty PWU/PWP za miesiąc"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#A7F3D0"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DgNumericCellStyle}">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="colProdYtd" Header="od początku roku  (t)"
                                            Binding="{Binding ProdukcjaOdPoczatkuRokuTony, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}"
                                            Width="170">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="{StaticResource ProdGroupBg}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="ToolTip" Value="📊 Dwuklik = pokaż dokumenty PWU/PWP od stycznia"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#A7F3D0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DgNumericCellStyle}">
                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- SPRZEDAŻ — niebieskie tło -->
                        <DataGridTextColumn x:Name="colSprzMc" Header="w miesiącu  (t)"
                                            Binding="{Binding SprzedazWMiesiacuTony, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}"
                                            Width="120">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="{StaticResource SprzGroupBg}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="ToolTip" Value="💰 Dwuklik = pokaż faktury FVS/FKS za miesiąc"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#BFDBFE"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DgNumericCellStyle}">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="colSprzYtd" Header="od początku roku  (t)"
                                            Binding="{Binding SprzedazOdPoczatkuRokuTony, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}"
                                            Width="170">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="{StaticResource SprzGroupBg}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="ToolTip" Value="💰 Dwuklik = pokaż faktury FVS/FKS od stycznia"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#BFDBFE"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DgNumericCellStyle}">
                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- ZAPASY — żółte tło -->
                        <DataGridTextColumn Header="wyrobów  (t)"
                                            Binding="{Binding ZapasyWyrobowTony, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}"
                                            Width="100">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="{StaticResource ZapGroupBg}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="ToolTip" Value="Wpisz ręcznie — brak automatycznego obliczania"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DgNumericCellStyle}"/>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="towarów  (t)"
                                            Binding="{Binding ZapasyTowarowTony, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}"
                                            Width="100">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="{StaticResource ZapGroupBg}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="ToolTip" Value="Wpisz ręcznie — brak automatycznego obliczania"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DgNumericCellStyle}"/>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Kodów" Binding="{Binding LiczbaTowarow}" Width="65" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Empty state overlay -->
            <Border x:Name="emptyStateOverlay" Background="#FAFBFC" CornerRadius="0,0,6,6"
                    Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📊" FontSize="56" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSubtle}"/>
                    <TextBlock Text="Brak danych za wybrany miesiąc" FontSize="17"
                               FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                               Margin="0,16,0,6" HorizontalAlignment="Center"/>
                    <TextBlock Text="Kliknij '🔄 Pobierz z HANDEL' lub naciśnij F5"
                               FontSize="12" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <Button Style="{StaticResource PrimaryBtn}" Content="🔄  Pobierz z HANDEL"
                            Click="BtnLoad_Click" MinWidth="200" Padding="18,9"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            </Grid>
        </Grid>

        <!-- ═══════════ Footer ═══════════ -->
        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0" Padding="22,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="lblFooter" VerticalAlignment="Center" FontSize="12"
                           Foreground="{StaticResource TextMuted}"
                           Text="Wybierz miesiąc i kliknij '🔄 Pobierz z HANDEL', aby załadować dane."/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource ProdGroupBg}" BorderBrush="{StaticResource ProdGroupBorder}"
                            BorderThickness="1" CornerRadius="6" Padding="10,5" Margin="6,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏭" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblSumProd" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource ProdGroupText}" Text="Prod: —"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource SprzGroupBg}" BorderBrush="{StaticResource SprzGroupBorder}"
                            BorderThickness="1" CornerRadius="6" Padding="10,5" Margin="6,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblSumSprz" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource SprzGroupText}" Text="Sprz: —"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ Loading overlay ═══════════ -->
        <Grid x:Name="loadingOverlay" Background="#A0FFFFFF" Visibility="Collapsed"
              Grid.RowSpan="4">
            <Border Background="White" CornerRadius="10" Padding="28,18"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="16" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏳" FontSize="24" Margin="0,0,14,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="loadingText" Text="Pobieram dane z HANDEL..."
                               VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
