<Window x:Class="Kalendarz1.Sprawozdania.Views.GusSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Konfiguracja sprawozdań GUS" Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="⚙  Dane jednostki sprawozdawczej"
                   FontSize="17" FontWeight="SemiBold" Margin="0,0,0,14" Foreground="#1F2A36"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="REGON:" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtRegon" Padding="6,4" Margin="0,4" MaxLength="14"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="PKD główny:" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtPkd" Padding="6,4" Margin="0,4" MaxLength="6"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Osoba — imię:" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtImie" Padding="6,4" Margin="0,4"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Osoba — nazwisko:" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtNazwisko" Padding="6,4" Margin="0,4"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Telefon:" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtTelefon" Padding="6,4" Margin="0,4"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Email jednostki:" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="5" Grid.Column="1" x:Name="txtEmailJedn" Padding="6,4" Margin="0,4"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Email osoby:" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox Grid.Row="6" Grid.Column="1" x:Name="txtEmailOsoby" Padding="6,4" Margin="0,4"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Folder eksportu XML:" VerticalAlignment="Center" Margin="0,6"/>
            <DockPanel Grid.Row="7" Grid.Column="1" LastChildFill="True" Margin="0,4">
                <Button DockPanel.Dock="Right" Content="..." Width="32" Click="BtnBrowseFolder_Click"/>
                <TextBox x:Name="txtFolder" Padding="6,4" Margin="0,0,6,0"/>
            </DockPanel>

            <TextBlock Grid.Row="8" Grid.ColumnSpan="2" Margin="0,14,0,0" TextWrapping="Wrap"
                       Foreground="#6B7785" FontSize="11">
                Te dane wchodzą do każdego XML jako pole automatyczne (REGON) lub jako osoba odpowiedzialna.
                Konfiguracja jest per-stanowisko (zapisana w %LOCALAPPDATA%\Kalendarz1\Gus\settings.json).
            </TextBlock>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Anuluj" Padding="18,7" Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button Content="Zapisz" Padding="18,7" Click="BtnSave_Click"
                    Background="#2563EB" Foreground="White" FontWeight="SemiBold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
