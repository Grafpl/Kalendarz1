<Window x:Class="Kalendarz1.Sprawozdania.Views.DokumentyDrillDownDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dokumenty źródłowe"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13"
        Width="1180" Height="720">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7785"/>
        <SolidColorBrush x:Key="TextSubtle" Color="#9BA4B0"/>
        <SolidColorBrush x:Key="CardBorder" Color="#E2E7ED"/>
        <SolidColorBrush x:Key="DgHeaderBg" Color="#F0F4F8"/>
        <SolidColorBrush x:Key="DgAltRowBg" Color="#FAFBFC"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>

        <Style x:Key="DgHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource DgHeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style x:Key="DgNumeric" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <!-- Typ dokumentu — kolorowa "pill" -->
        <Style x:Key="TypPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1" Padding="22,16">
            <StackPanel>
                <TextBlock x:Name="lblTitle" Text="Dokumenty źródłowe" FontSize="18"
                           FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock x:Name="lblSubtitle" Text="" FontSize="12"
                           Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Summary + filter -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1" Padding="22,12">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#DBEAFE" CornerRadius="6" Padding="10,5" Margin="0,0,8,0">
                        <TextBlock x:Name="lblSummary" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#1E40AF" Text=""/>
                    </Border>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📋 Kopiuj" Padding="12,5" Margin="0,0,6,0" Click="BtnCopy_Click"/>
                    <Button Content="💾 CSV" Padding="12,5" Margin="0,0,6,0" Click="BtnCsv_Click"/>
                    <Button Content="Zamknij" Padding="14,5" Click="BtnClose_Click"/>
                </StackPanel>
                <DockPanel LastChildFill="True" Margin="14,0,12,0">
                    <TextBlock Text="🔍 " VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                    <TextBox x:Name="txtFilter" Padding="6,4" VerticalContentAlignment="Center"
                             TextChanged="TxtFilter_TextChanged"
                             ToolTip="Filtruj po nazwie towaru, kodzie, kontrahencie lub numerze dokumentu"/>
                </DockPanel>
            </DockPanel>
        </Border>

        <!-- DataGrid -->
        <Grid Grid.Row="2" Margin="22,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Daily breakdown strip (mini-wykres) -->
            <Border Grid.Row="0" x:Name="dailyStripPanel" Background="White" BorderBrush="{StaticResource CardBorder}"
                    BorderThickness="1" CornerRadius="6,6,0,0" Padding="14,10" Margin="0,0,0,-1"
                    Visibility="Collapsed">
                <StackPanel>
                    <DockPanel LastChildFill="True" Margin="0,0,0,6">
                        <TextBlock DockPanel.Dock="Left" Text="📈 Rozkład dzienny"
                                   FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock x:Name="lblDailyMax" DockPanel.Dock="Right" FontSize="10"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBlock/>
                    </DockPanel>
                    <ItemsControl x:Name="dailyStrip" Height="50">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{Binding Tooltip}" Margin="1,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" VerticalAlignment="Bottom"
                                            Background="{Binding Color}" CornerRadius="2,2,0,0"
                                            Height="{Binding BarHeight}"/>
                                    <TextBlock Grid.Row="1" Text="{Binding DayLabel}" FontSize="8"
                                               Foreground="{StaticResource TextSubtle}"
                                               HorizontalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        <Border Grid.Row="1" Background="White"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="0,0,6,6">
            <DataGrid x:Name="dgDokumenty" AutoGenerateColumns="False" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" RowHeight="32"
                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
                      CanUserSortColumns="True"
                      ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                      AlternatingRowBackground="{StaticResource DgAltRowBg}" Background="Transparent"
                      BorderThickness="0" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data" Binding="{Binding Data, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                    <DataGridTemplateColumn Header="Typ" Width="62">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource TypPill}" Background="{Binding TypBackground}">
                                    <TextBlock Text="{Binding TypDokumentu}" Foreground="{Binding TypForeground}"
                                               FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Numer" Binding="{Binding NumerDokumentu}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Kontrahent" Binding="{Binding Kontrahent}" Width="220">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Kod towaru" Binding="{Binding KodTowaru}" Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Nazwa towaru" Binding="{Binding NazwaTowaru}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Ilość (kg)" Binding="{Binding IloscKg, StringFormat={}{0:N1}}" Width="100" ElementStyle="{StaticResource DgNumeric}"/>
                    <DataGridTextColumn x:Name="colWartosc" Header="Wartość netto (zł)" Binding="{Binding WartoscNetto, StringFormat={}{0:N2}}" Width="140" ElementStyle="{StaticResource DgNumeric}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0" Padding="22,10">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="lblFooter" VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource TextMuted}"
                           Text="Dwuklik na komórkę w P-02 pokazuje dokumenty źródłowe danej liczby."/>
                <TextBlock x:Name="lblFooterRight" DockPanel.Dock="Right" VerticalAlignment="Center"
                           FontSize="11" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
