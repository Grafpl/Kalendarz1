<Window x:Class="Kalendarz1.Sprawozdania.Views.WalidacjaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Walidacja P-02"
        Width="780" Height="540"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7785"/>
        <SolidColorBrush x:Key="CardBorder" Color="#E2E7ED"/>
        <SolidColorBrush x:Key="DgHeaderBg" Color="#F0F4F8"/>
        <SolidColorBrush x:Key="DgAltRowBg" Color="#FAFBFC"/>

        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource DgHeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1" Padding="22,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ikonaStatus" Text="⚠" FontSize="22" VerticalAlignment="Center"
                               Margin="0,0,12,0" Foreground="#D97706"/>
                    <TextBlock x:Name="lblTytul" Text="Wynik walidacji" FontSize="17"
                               FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
                <TextBlock x:Name="lblPodsumowanie" Margin="34,4,0,0" FontSize="12"
                           Foreground="{StaticResource TextMuted}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Margin="22,12"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="6">
            <DataGrid x:Name="dg" AutoGenerateColumns="False" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" RowHeight="32"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      ColumnHeaderStyle="{StaticResource DgHeader}"
                      AlternatingRowBackground="{StaticResource DgAltRowBg}" Background="Transparent"
                      BorderThickness="0" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Typ" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Pill}" Background="{Binding TypBg}">
                                    <TextBlock Text="{Binding TypLabel}" Foreground="{Binding TypFg}"
                                               FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Pole" Binding="{Binding Field}" Width="170">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Komunikat" Binding="{Binding Message}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,4"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0" Padding="22,12">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="btnAnuluj" Content="Anuluj" Padding="18,7" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                    <Button x:Name="btnKontynuuj" Content="Mimo wszystko generuj XML" Padding="18,7" Click="BtnContinue_Click"
                            Background="#2563EB" Foreground="White" FontWeight="SemiBold" BorderThickness="0"/>
                </StackPanel>
                <TextBlock x:Name="lblFooterHint" VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource TextMuted}"
                           Text="💡 Błędy blokują eksport. Ostrzeżenia są tylko informacyjne."/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
