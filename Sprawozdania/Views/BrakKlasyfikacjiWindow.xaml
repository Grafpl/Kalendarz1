<Window x:Class="Kalendarz1.Sprawozdania.Views.BrakKlasyfikacjiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Towary bez klasyfikacji P-02"
        Width="1100" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7785"/>
        <SolidColorBrush x:Key="CardBorder" Color="#E2E7ED"/>
        <SolidColorBrush x:Key="DgHeaderBg" Color="#F0F4F8"/>
        <SolidColorBrush x:Key="DgAltRowBg" Color="#FAFBFC"/>

        <Style x:Key="DgHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource DgHeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style x:Key="DgNumeric" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFBEB" Offset="0"/>
                    <GradientStop Color="#FEF3C7" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Margin="22,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠" FontSize="22" Foreground="#92400E" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Towary bez klasyfikacji P-02" FontSize="18"
                               FontWeight="SemiBold" Foreground="#1F2A36"/>
                </StackPanel>
                <TextBlock TextWrapping="Wrap" Margin="34,4,0,0" FontSize="12" Foreground="#92400E">
                    Te towary mięsne pojawiły się na fakturach FVS/FKS, ale klasyfikator nie potrafił ich przypisać
                    do żadnej z 4 kategorii P-02. Sprawdź reguły w PkwiuKlasyfikator.cs lub uzupełnij HM.TW.sww w Symfonii.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Summary + filter -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1" Padding="22,10">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Left" Background="#FEF3C7" CornerRadius="6" Padding="10,5" Margin="0,0,12,0">
                    <TextBlock x:Name="lblSummary" FontSize="12" FontWeight="SemiBold"
                               Foreground="#92400E"/>
                </Border>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="📋 Kopiuj" Padding="12,5" Margin="0,0,6,0" Click="BtnCopy_Click"/>
                    <Button Content="💾 CSV" Padding="12,5" Click="BtnCsv_Click"/>
                </StackPanel>
                <DockPanel LastChildFill="True" Margin="0,0,12,0">
                    <TextBlock Text="🔍 " VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                    <TextBox x:Name="txtFilter" Padding="6,4" VerticalContentAlignment="Center"
                             TextChanged="TxtFilter_TextChanged"
                             ToolTip="Filtruj po kodzie, nazwie lub SWW"/>
                </DockPanel>
            </DockPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Background="White" Margin="22,12"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="6">
            <DataGrid x:Name="dg" AutoGenerateColumns="False" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" RowHeight="32"
                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
                      CanUserSortColumns="True"
                      ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                      AlternatingRowBackground="{StaticResource DgAltRowBg}" Background="Transparent"
                      BorderThickness="0" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Kod towaru" Binding="{Binding Kod}" Width="220">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Nazwa towaru" Binding="{Binding Nazwa}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Katalog" Binding="{Binding Katalog}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="SWW (PKWiU w Sage)" Binding="{Binding Sww}" Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Sprzedaż (kg)" Binding="{Binding Kg, StringFormat={}{0:N0}}" Width="130" ElementStyle="{StaticResource DgNumeric}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0" Padding="22,10">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="Zamknij" Padding="20,6" Click="BtnClose_Click"/>
                <TextBlock x:Name="lblFooter" VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource TextMuted}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
