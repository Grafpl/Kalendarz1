<Window x:Class="Kalendarz1.Sprawozdania.Views.SprawozdaniaGusHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sprawozdania GUS" Height="720" Width="1080"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7785"/>
        <SolidColorBrush x:Key="TextSubtle" Color="#9BA4B0"/>
        <SolidColorBrush x:Key="CardBg" Color="White"/>
        <SolidColorBrush x:Key="CardBorder" Color="#E2E7ED"/>
        <SolidColorBrush x:Key="CardHover" Color="#2563EB"/>
        <SolidColorBrush x:Key="CardDisabledBg" Color="#F0F2F5"/>
        <SolidColorBrush x:Key="BadgeActiveBg" Color="#DCFCE7"/>
        <SolidColorBrush x:Key="BadgeActiveFg" Color="#15803D"/>
        <SolidColorBrush x:Key="BadgeSoonBg" Color="#FEF3C7"/>
        <SolidColorBrush x:Key="BadgeSoonFg" Color="#92400E"/>
        <SolidColorBrush x:Key="BadgeGenBg" Color="#DBEAFE"/>
        <SolidColorBrush x:Key="BadgeGenFg" Color="#1E40AF"/>

        <Style x:Key="ActiveTileStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,18,18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="10" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource CardHover}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#2563EB" Opacity="0.16" BlurRadius="18" ShadowDepth="2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DisabledTileStyle" TargetType="Border" BasedOn="{StaticResource ActiveTileStyle}">
            <Setter Property="Background" Value="{StaticResource CardDisabledBg}"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="10" ShadowDepth="2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header gradient -->
        <Border Grid.Row="0" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFFF" Offset="0"/>
                    <GradientStop Color="#F8FAFC" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="28,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#FEF3C7" CornerRadius="8" Padding="9,5" VerticalAlignment="Center">
                            <TextBlock Text="📊  GUS" FontSize="14" FontWeight="Bold" Foreground="#92400E"/>
                        </Border>
                        <TextBlock Text="Sprawozdania GUS" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" Margin="14,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Generowanie XML z bazy → Import w Portalu Sprawozdawczym GUS"
                               FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="⚙  Konfiguracja" Click="BtnSettings_Click"
                        Padding="14,8" Background="White" BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1" VerticalAlignment="Center" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Tiles -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,22,10,22">
            <UniformGrid Columns="2" HorizontalAlignment="Stretch">

                <!-- P-02 (active) -->
                <Border Style="{StaticResource ActiveTileStyle}" MouseLeftButtonUp="P02_Click">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" LastChildFill="True">
                            <Border DockPanel.Dock="Right" Background="{StaticResource BadgeActiveBg}"
                                    CornerRadius="6" Padding="9,3" VerticalAlignment="Top">
                                <TextBlock Text="DOSTĘPNE" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BadgeActiveFg}"/>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#FEF3C7" CornerRadius="8" Padding="10,6" VerticalAlignment="Center">
                                    <TextBlock Text="🏭" FontSize="22"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="P-02" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="Co miesiąc" FontSize="10"
                                               Foreground="{StaticResource TextSubtle}"/>
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Grid.Row="1" Text="Meldunek o produkcji wyrobów przemysłowych"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,16,0,6"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Grid.Row="2" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Top">
                            Miesięczne sprawozdanie z produkcji per PKWiU (drób: 10.12.x).
                            Generuje XML zgodny z formatem Symfonii — wgrasz do Portalu Sprawozdawczego.
                        </TextBlock>

                        <!-- Status badge — pokazuje status ostatniego sprawozdania -->
                        <Border Grid.Row="3" Background="#F7F9FB" CornerRadius="6"
                                Padding="12,8" Margin="0,16,0,0">
                            <StackPanel>
                                <DockPanel LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Left" Text="📋 " FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="p02StatusLabel" FontSize="11"
                                               FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                                               Text="Ładuję…"/>
                                </DockPanel>
                                <TextBlock x:Name="p02StatusHint" FontSize="10"
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- R-09U (active) -->
                <Border Style="{StaticResource ActiveTileStyle}" MouseLeftButtonUp="R09U_Click">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" LastChildFill="True">
                            <Border DockPanel.Dock="Right" Background="{StaticResource BadgeActiveBg}"
                                    CornerRadius="6" Padding="9,3" VerticalAlignment="Top">
                                <TextBlock Text="DOSTĘPNE" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BadgeActiveFg}"/>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#FEF3C7" CornerRadius="8" Padding="10,6" VerticalAlignment="Center">
                                    <TextBlock Text="🐔" FontSize="22"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="R-09U" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="Co miesiąc" FontSize="10"
                                               Foreground="{StaticResource TextSubtle}"/>
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>
                        <TextBlock Grid.Row="1" Text="Sprawozdanie o wielkości ubojów"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,16,0,6"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Grid.Row="2" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextMuted}">
                            Miesięczne sprawozdanie o ubojach drobiu (sztuki, waga żywa, waga po uboju, wartość).
                            Dane z LibraNet (FarmerCalc) + HANDEL (faktury żywca).
                        </TextBlock>
                        <Border Grid.Row="3" Background="#F7F9FB" CornerRadius="6"
                                Padding="12,8" Margin="0,16,0,0">
                            <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}">
                                <Run Text="⏰ "/><Run FontWeight="SemiBold" Text="Co miesiąc"/>
                                <Run Text="  ·  ⚠ Generator XML: szkielet (potrzebny wzorzec z Symfonii)"/>
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>

                <!-- DG-1 (disabled) -->
                <Border Style="{StaticResource DisabledTileStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" LastChildFill="True">
                            <Border DockPanel.Dock="Right" Background="{StaticResource BadgeSoonBg}"
                                    CornerRadius="6" Padding="9,3" VerticalAlignment="Top">
                                <TextBlock Text="WKRÓTCE" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BadgeSoonFg}"/>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#FEF3C7" CornerRadius="8" Padding="10,6" VerticalAlignment="Center">
                                    <TextBlock Text="📈" FontSize="22"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="DG-1" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="Co miesiąc" FontSize="10"
                                               Foreground="{StaticResource TextSubtle}"/>
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>
                        <TextBlock Grid.Row="1" Text="Meldunek o działalności gospodarczej"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,16,0,6"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Grid.Row="2" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextMuted}">
                            Miesięczne sprawozdanie o przychodach, zatrudnieniu i kosztach.
                            Dane z HANDEL (FVS) + UNISYSTEM (RCP) + ZPSP (HR).
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- C-01 (disabled) -->
                <Border Style="{StaticResource DisabledTileStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" LastChildFill="True">
                            <Border DockPanel.Dock="Right" Background="{StaticResource BadgeSoonBg}"
                                    CornerRadius="6" Padding="9,3" VerticalAlignment="Top">
                                <TextBlock Text="WKRÓTCE" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BadgeSoonFg}"/>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#FEF3C7" CornerRadius="8" Padding="10,6" VerticalAlignment="Center">
                                    <TextBlock Text="🚛" FontSize="22"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="C-01" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="Co miesiąc" FontSize="10"
                                               Foreground="{StaticResource TextSubtle}"/>
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>
                        <TextBlock Grid.Row="1" Text="Sprawozdanie o handlu hurtowym"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,16,0,6"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Grid.Row="2" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextMuted}">
                            Miesięczne sprawozdanie ze sprzedaży krajowej, importu, eksportu.
                            Rozbicie geograficzne (UE / poza UE) wg kontrahentów.
                        </TextBlock>
                    </Grid>
                </Border>

            </UniformGrid>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0" Padding="28,14">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="📜  Historia" Padding="16,7" Click="BtnHistory_Click"
                        Background="White" BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1" Cursor="Hand"/>
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="11">
                    💡 Dwuklik kafelka — otwórz okno generatora. Każde wygenerowane XML jest zapisane w historii (audyt).
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</Window>
