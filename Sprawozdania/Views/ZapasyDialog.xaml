<Window x:Class="Kalendarz1.Sprawozdania.Views.ZapasyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zapasy wyrobów na koniec okresu"
        Width="1180" Height="780"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7785"/>
        <SolidColorBrush x:Key="TextSubtle" Color="#9BA4B0"/>
        <SolidColorBrush x:Key="CardBorder" Color="#E2E7ED"/>
        <SolidColorBrush x:Key="DgHeaderBg" Color="#F0F4F8"/>
        <SolidColorBrush x:Key="DgAltRowBg" Color="#FAFBFC"/>
        <SolidColorBrush x:Key="ZapGroupBg" Color="#FFFBEB"/>
        <SolidColorBrush x:Key="ZapGroupBorder" Color="#FDE68A"/>
        <SolidColorBrush x:Key="ZapGroupText" Color="#92400E"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>

        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource DgHeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style x:Key="DgNumeric" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <!-- Kafelek PKWiU — klikalny -->
        <Style x:Key="PkwiuTile" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFBEB" Offset="0"/>
                    <GradientStop Color="#FEF3C7" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Margin="22,14">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🧮" FontSize="22" Foreground="#92400E" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Zapasy wyrobów — drill-down per PKWiU" FontSize="17"
                               FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
                <TextBlock x:Name="lblOkres" Margin="34,4,0,0" FontSize="12" Foreground="#92400E"/>
                <TextBlock Margin="34,2,0,0" FontSize="11" Foreground="#92400E" TextWrapping="Wrap">
                    💡 Kliknij kafelek PKWiU żeby zobaczyć które towary się składają · Możesz porównać z Symfonia UI
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Method selector + PKWiU tiles -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1" Padding="22,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Metoda:" VerticalAlignment="Center" FontWeight="SemiBold"
                               Margin="0,0,8,0" Foreground="{StaticResource TextPrimary}"/>
                    <ComboBox x:Name="cbMetoda" Width="450" Padding="8,5" SelectionChanged="Cb_Metoda_Changed">
                        <ComboBoxItem Tag="0" IsSelected="True">
                            <TextBlock><Run Text="A: SM dla M.MROŹN + M.DYST "/><Run FontStyle="Italic" Foreground="#15803D" Text="(rekomendowane — jak Sage UI)"/></TextBlock>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="1"><TextBlock Text="B: SM dla wszystkich mięsnych magazynów"/></ComboBoxItem>
                        <ComboBoxItem Tag="2"><TextBlock Text="C: SM tylko M.DYST"/></ComboBoxItem>
                        <ComboBoxItem Tag="3"><TextBlock Text="D: SM tylko M.MROŹN"/></ComboBoxItem>
                    </ComboBox>
                    <TextBlock x:Name="lblTotalAll" VerticalAlignment="Center" Margin="20,0,0,0"
                               FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                </StackPanel>

                <!-- 4 klikalne kafelki PKWiU -->
                <UniformGrid Rows="1" Columns="5">
                    <Border Style="{StaticResource PkwiuTile}" Tag="ALL" MouseLeftButtonUp="PkwiuTile_Click">
                        <StackPanel>
                            <TextBlock Text="🔍  Wszystkie" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="tileAll" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource PkwiuTile}" Tag="10.12.10-10" MouseLeftButtonUp="PkwiuTile_Click">
                        <Grid>
                            <Border Width="3" HorizontalAlignment="Left" Background="#2563EB"/>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="10.12.10-10  tuszki świeże" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#2563EB" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="tile1010" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource PkwiuTile}" Tag="10.12.10-50" MouseLeftButtonUp="PkwiuTile_Click">
                        <Grid>
                            <Border Width="3" HorizontalAlignment="Left" Background="#16A34A"/>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="10.12.10-50  elementy świeże" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#16A34A" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="tile1050" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource PkwiuTile}" Tag="10.12.20-13" MouseLeftButtonUp="PkwiuTile_Click">
                        <Grid>
                            <Border Width="3" HorizontalAlignment="Left" Background="#06B6D4"/>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="10.12.20-13  tuszki mroż." FontSize="11" FontWeight="SemiBold"
                                           Foreground="#06B6D4" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="tile2013" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource PkwiuTile}" Tag="10.12.20-53" MouseLeftButtonUp="PkwiuTile_Click">
                        <Grid>
                            <Border Width="3" HorizontalAlignment="Left" Background="#7C3AED"/>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="10.12.20-53  elementy mroż." FontSize="11" FontWeight="SemiBold"
                                           Foreground="#7C3AED" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="tile2053" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1" Padding="22,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="lblAktywnyFiltr" VerticalAlignment="Center" FontSize="12"
                           FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"
                           Text="🔍 Filtr: Wszystkie"/>
                <Button Content="✖ Wyczyść filtr" Padding="10,4" Margin="12,0,0,0" Click="BtnClearFilter_Click"
                        Background="Transparent" BorderBrush="{StaticResource CardBorder}"/>
                <TextBlock Text="  ·  " VerticalAlignment="Center" Margin="12,0" Foreground="{StaticResource TextMuted}"/>
                <TextBlock Text="🔎 " VerticalAlignment="Center"/>
                <TextBox x:Name="txtSearch" Width="240" Padding="6,4" VerticalContentAlignment="Center"
                         TextChanged="TxtSearch_TextChanged" ToolTip="Szukaj po kodzie lub nazwie"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="3" Background="White" Margin="22,12"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="6">
            <Grid>
                <DataGrid x:Name="dg" AutoGenerateColumns="False" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" RowHeight="30"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserSortColumns="True"
                          ColumnHeaderStyle="{StaticResource DgHeader}"
                          AlternatingRowBackground="{StaticResource DgAltRowBg}" Background="Transparent"
                          BorderThickness="0" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="PKWiU" Width="115" SortMemberPath="Pkwiu">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Border Width="3" HorizontalAlignment="Left" Background="{Binding KolorPkwiu}"/>
                                        <TextBlock Text="{Binding Pkwiu}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="10,0"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Kod towaru" Binding="{Binding Kod}" Width="210" SortMemberPath="Kod">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Nazwa towaru" Binding="{Binding Nazwa}" Width="*" SortMemberPath="Nazwa">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Mag." Binding="{Binding MagazynNazwa}" Width="85" SortMemberPath="MagazynNazwa">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Kat." Binding="{Binding Katalog}" Width="60" SortMemberPath="Katalog">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSubtle}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Stan dziś (kg)" Binding="{Binding StanDzis, StringFormat={}{0:N0}}" Width="110" SortMemberPath="StanDzis" ElementStyle="{StaticResource DgNumeric}"/>
                        <DataGridTextColumn Header="Zmiana po (kg)" Binding="{Binding ZmianaPoOkresie, StringFormat={}{0:N0}}" Width="120" SortMemberPath="ZmianaPoOkresie">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DgNumeric}">
                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="colStanHist" Header="Stan na koniec mc (kg)" Binding="{Binding StanHistoryczny, StringFormat={}{0:N0}}" Width="160" SortMemberPath="StanHistoryczny">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DgNumeric}">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#15803D"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border x:Name="loadingMini" Background="#80FFFFFF" Visibility="Collapsed">
                    <TextBlock Text="⏳ Liczę…" FontSize="14" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                </Border>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0" Padding="22,12">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="📋 Kopiuj" Padding="14,6" Margin="0,0,6,0" Click="BtnCopy_Click"/>
                    <Button Content="Anuluj" Padding="18,6" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                    <Button Content="✓  Zastosuj do P-02" Padding="18,6" Click="BtnApply_Click"
                            Background="#2563EB" Foreground="White" FontWeight="SemiBold" BorderThickness="0"/>
                </StackPanel>
                <TextBlock x:Name="lblFooterStats" VerticalAlignment="Center" FontSize="12"
                           Foreground="{StaticResource TextMuted}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
