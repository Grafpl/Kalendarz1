<Window x:Class="Kalendarz1.Sprawozdania.Views.MarkAsSentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Oznacz jako wysłane"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13">
    <StackPanel Margin="22">
        <TextBlock Text="✓  Oznacz sprawozdanie jako wysłane" FontSize="16"
                   FontWeight="SemiBold" Foreground="#1F2A36" Margin="0,0,0,4"/>
        <TextBlock x:Name="lblOkres" Text="" FontSize="12" Foreground="#6B7785" Margin="0,0,0,16"/>

        <TextBlock Text="Numer identyfikacyjny w Portalu Sprawozdawczym (opcjonalny):"
                   FontSize="12" Foreground="#374151" Margin="0,0,0,6"/>
        <TextBox x:Name="txtNumer" Padding="8,6" FontFamily="Consolas"
                 ToolTip="np. 'PS/2026/04/123456' lub identyfikator wygenerowany po imporcie"/>

        <TextBlock Text="Po zatwierdzeniu sprawozdanie zniknie z badge'a 'do wysłania' i otrzyma zielony status."
                   FontSize="11" Foreground="#6B7785" Margin="0,10,0,0" TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Anuluj" Padding="18,7" Margin="0,0,8,0" Click="BtnCancel_Click"/>
            <Button Content="✓ Oznacz jako wysłane" Padding="18,7" Click="BtnOk_Click"
                    Background="#15803D" Foreground="White" FontWeight="SemiBold" BorderThickness="0"/>
        </StackPanel>
    </StackPanel>
</Window>
