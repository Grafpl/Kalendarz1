<Window x:Class="Kalendarz1.Sprawozdania.Views.HistoriaSprawozdanGusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historia sprawozdań GUS"
        Width="1180" Height="680"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7785"/>
        <SolidColorBrush x:Key="CardBorder" Color="#E2E7ED"/>
        <SolidColorBrush x:Key="DgHeaderBg" Color="#F0F4F8"/>
        <SolidColorBrush x:Key="DgAltRowBg" Color="#FAFBFC"/>
        <SolidColorBrush x:Key="DgRowHoverBg" Color="#F0F7FF"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>

        <Style x:Key="DgHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource DgHeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style x:Key="DgRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DgRowHoverBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="LinkBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFFF" Offset="0"/>
                    <GradientStop Color="#F8FAFC" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Margin="22,16">
                <TextBlock Text="📜  Historia sprawozdań GUS" FontSize="18"
                           FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="Wszystkie wygenerowane i wysłane sprawozdania (pełny XML zachowany dla audytu)"
                           FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1" Padding="22,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filtr formularza:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{StaticResource TextMuted}"/>
                <ComboBox x:Name="cbFiltrFormularza" Width="140" Padding="8,4"
                          SelectionChanged="Filtr_Changed">
                    <ComboBoxItem Content="(wszystkie)" IsSelected="True" Tag=""/>
                    <ComboBoxItem Content="P-02" Tag="P-02"/>
                    <ComboBoxItem Content="R-09A" Tag="R-09A"/>
                    <ComboBoxItem Content="DG-1" Tag="DG-1"/>
                    <ComboBoxItem Content="C-01" Tag="C-01"/>
                </ComboBox>
                <TextBlock Text="  ·  " Margin="8,0" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                <TextBlock Text="🔍 " VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                <TextBox x:Name="txtFilter" Width="240" Padding="6,4" VerticalContentAlignment="Center"
                         TextChanged="TxtFilter_TextChanged" ToolTip="Filtruj po formularzu, okresie, statusie, osobie"/>
                <Button x:Name="btnRefresh" Style="{StaticResource LinkBtn}" Content="🔄 Odśwież" Margin="12,0,0,0"
                        Click="BtnRefresh_Click"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Background="White" Margin="22,12"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="6">
            <Grid>
                <DataGrid x:Name="dg" AutoGenerateColumns="False" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" RowHeight="44"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserSortColumns="True"
                          ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                          RowStyle="{StaticResource DgRowStyle}"
                          AlternatingRowBackground="{StaticResource DgAltRowBg}" Background="Transparent"
                          BorderThickness="0" IsReadOnly="True" SelectionMode="Single"
                          MouseDoubleClick="Dg_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Wygenerowane" Binding="{Binding GeneratedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="140" SortDirection="Descending"/>
                        <DataGridTemplateColumn Header="Form." Width="74" SortMemberPath="Formularz">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Pill}" Background="#FEF3C7">
                                        <TextBlock Text="{Binding Formularz}" Foreground="#92400E"
                                                   FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Okres" Binding="{Binding OkresText}" Width="105" SortMemberPath="OkresOd">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Status" Width="130" SortMemberPath="Status">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Pill}" Background="{Binding StatusBg}">
                                        <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusFg}"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Pozycji" Binding="{Binding IloscPozycji}" Width="70" SortMemberPath="IloscPozycji">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Sprz. MC (t)" Binding="{Binding SumaWartosc, StringFormat={}{0:N0}}" Width="100" SortMemberPath="SumaWartosc">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Wygenerował" Binding="{Binding GeneratedByImie}" Width="140" SortMemberPath="GeneratedByImie">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Numer w PS" Binding="{Binding NumerWPortalu}" Width="120" SortMemberPath="NumerWPortalu">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Akcje" Width="*" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                        <Button Style="{StaticResource LinkBtn}" Content="📂 Plik"
                                                Click="BtnOpenFile_Click"
                                                ToolTip="{Binding PlikXml}"/>
                                        <Button Style="{StaticResource LinkBtn}" Content="🔍 XML"
                                                Click="BtnViewXml_Click" Margin="6,0,0,0"
                                                ToolTip="Pokaż treść XML"/>
                                        <Button Style="{StaticResource LinkBtn}" Content="✓ Wysłane"
                                                Click="BtnMarkSent_Click" Margin="6,0,0,0"
                                                Visibility="{Binding ShowMarkSent}"
                                                ToolTip="Oznacz jako wysłane do PS (wpisz numer)"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state overlay -->
                <Border x:Name="emptyState" Background="#FAFBFC" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📭" FontSize="48" HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextMuted}"/>
                        <TextBlock Text="Brak sprawozdań w historii" FontSize="16"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                                   Margin="0,12,0,4" HorizontalAlignment="Center"/>
                        <TextBlock Text="Wygeneruj sprawozdanie z poziomu okna P-02"
                                   FontSize="12" Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0" Padding="22,10">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="Zamknij" Padding="20,6" Click="BtnClose_Click"/>
                <TextBlock x:Name="lblFooter" VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource TextMuted}"
                           Text=""/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
