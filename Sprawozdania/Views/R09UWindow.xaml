<Window x:Class="Kalendarz1.Sprawozdania.Views.R09UWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kalendarz1.Sprawozdania.Views"
        Title="R-09U — Sprawozdanie GUS o ubojach"
        WindowStartupLocation="Manual"
        WindowState="Normal" ResizeMode="CanResize"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{x:Static local:R09UWindow.LoadCmd}"/>
        <KeyBinding Key="G" Modifiers="Control" Command="{x:Static local:R09UWindow.GenerateCmd}"/>
        <KeyBinding Key="P" Modifiers="Control" Command="{x:Static local:R09UWindow.PreviewCmd}"/>
        <KeyBinding Key="H" Modifiers="Control" Command="{x:Static local:R09UWindow.HistoryCmd}"/>
        <KeyBinding Key="Left" Modifiers="Control" Command="{x:Static local:R09UWindow.PrevMonthCmd}"/>
        <KeyBinding Key="Right" Modifiers="Control" Command="{x:Static local:R09UWindow.NextMonthCmd}"/>
        <KeyBinding Key="Escape" Command="{x:Static local:R09UWindow.CloseCmd}"/>
    </Window.InputBindings>
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7785"/>
        <SolidColorBrush x:Key="TextSubtle" Color="#9BA4B0"/>
        <SolidColorBrush x:Key="CardBg" Color="White"/>
        <SolidColorBrush x:Key="CardBorder" Color="#E2E7ED"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="DgHeaderBg" Color="#F0F4F8"/>
        <SolidColorBrush x:Key="DgAltRowBg" Color="#FAFBFC"/>

        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource DgHeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFFF" Offset="0"/>
                    <GradientStop Color="#F8FAFC" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="22,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#FEF3C7" CornerRadius="8" Padding="8,4">
                        <TextBlock Text="🐔  R-09U" FontSize="14" FontWeight="Bold" Foreground="#92400E"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Sprawozdanie o wielkości ubojów zwierząt"
                                   FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Miesięczne · drób (brojlery kurze) · dane z LibraNet + HANDEL"
                                   FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border x:Name="statusBadge" Background="#FEF3C7" CornerRadius="14"
                            Padding="12,4" Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtStatus" Text="Wybierz miesiąc" FontSize="11"
                                   FontWeight="SemiBold" Foreground="#92400E"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolBtn}" Content="📜  Historia" Click="BtnHistory_Click"
                            ToolTip="Historia wszystkich sprawozdań GUS (Ctrl+H)"/>
                    <Button Style="{StaticResource ToolBtn}" Content="⚙  Konfiguracja" Click="BtnSettings_Click"
                            ToolTip="REGON, osoba odpowiedzialna, folder eksportu"/>
                    <Button Style="{StaticResource ToolBtn}" Content="✖" MinWidth="38" Click="BtnClose_Click"
                            ToolTip="Zamknij okno (Esc)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1">
            <Grid Margin="22,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#F1F5F9" CornerRadius="6" Padding="2"
                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="◀" Width="32" Background="Transparent" BorderThickness="0"
                                    Click="BtnPrevMonth_Click"/>
                            <ComboBox x:Name="cbMiesiac" Width="130" Padding="6,4" BorderThickness="0"
                                      Background="Transparent" SelectionChanged="Picker_Changed"/>
                            <ComboBox x:Name="cbRok" Width="78" Padding="6,4" BorderThickness="0"
                                      Background="Transparent" SelectionChanged="Picker_Changed"/>
                            <Button Content="▶" Width="32" Background="Transparent" BorderThickness="0"
                                    Click="BtnNextMonth_Click"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource PrimaryBtn}" Content="🔄  Pobierz z baz"
                            Margin="10,0,0,0" MinWidth="170" Click="BtnLoad_Click"
                            ToolTip="Pobierz LumQnt + wagi z FarmerCalc + faktury żywca (F5)"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolBtn}" Content="🔍  Podgląd XML" Click="BtnPreviewXml_Click"
                            ToolTip="Zobacz strukturę XML przed eksportem (Ctrl+P)"/>
                    <Button Style="{StaticResource PrimaryBtn}" Content="💾  Generuj XML"
                            Click="BtnGenerate_Click" MinWidth="160"
                            ToolTip="Walidacja + zapis pliku + historia (Ctrl+G)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stat cards -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1" Padding="22,14">
            <UniformGrid Rows="1" Columns="5">
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="🐔  Sztuki" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                        <TextBlock x:Name="cardSztuki" FontSize="22" FontWeight="Bold" Foreground="#1F2A36" Margin="0,4,0,0"/>
                        <TextBlock x:Name="cardSztukiSub" FontSize="10" Foreground="{StaticResource TextSubtle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="⚖  Waga żywa" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                        <TextBlock x:Name="cardZywa" FontSize="22" FontWeight="Bold" Foreground="#15803D" Margin="0,4,0,0"/>
                        <TextBlock x:Name="cardZywaSub" FontSize="10" Foreground="{StaticResource TextSubtle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="🍖  Po uboju (netto)" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                        <TextBlock x:Name="cardNetto" FontSize="22" FontWeight="Bold" Foreground="#DC2626" Margin="0,4,0,0"/>
                        <TextBlock x:Name="cardNettoSub" FontSize="10" Foreground="{StaticResource TextSubtle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="📊  Wydajność" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                        <TextBlock x:Name="cardWydajnosc" FontSize="22" FontWeight="Bold" Foreground="#7C3AED" Margin="0,4,0,0"/>
                        <TextBlock x:Name="cardWydajnoscSub" FontSize="10" Foreground="{StaticResource TextSubtle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="💰  Wartość żywca" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                        <TextBlock x:Name="cardWartosc" FontSize="22" FontWeight="Bold" Foreground="#1E40AF" Margin="0,4,0,0"/>
                        <TextBlock x:Name="cardWartoscSub" FontSize="10" Foreground="{StaticResource TextSubtle}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>

        <!-- DataGrid pozycji + info pasek -->
        <Grid Grid.Row="3" Margin="22,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                    CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Left" Text="💡" FontSize="18" VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#1E40AF" TextWrapping="Wrap">
                            <Run Text="R-09U dla ubojni · komórki edytowalne · źródła:"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="#1E40AF" Margin="0,3,0,0" TextWrapping="Wrap">
                            <Run Text="Sztuki + masa netto"/><Run FontWeight="SemiBold" Text=" = "/>
                            <Run Text="LibraNet.FarmerCalc (LumQnt + NettoFarmWeight)"/>
                            <Run Text="    ·    "/>
                            <Run Text="Waga żywa + wartość"/><Run FontWeight="SemiBold" Text=" = "/>
                            <Run Text="HANDEL faktury FVZ+FVR+FKZ na kody 67653 (rolnik) + 67654 (vatowiec)"/>
                        </TextBlock>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1">
            <Border Background="White" BorderBrush="{StaticResource CardBorder}"
                    BorderThickness="1" CornerRadius="6">
                <DataGrid x:Name="dg" AutoGenerateColumns="False" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" RowHeight="44"
                          CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="False"
                          ColumnHeaderStyle="{StaticResource DgHeader}"
                          AlternatingRowBackground="{StaticResource DgAltRowBg}" Background="Transparent"
                          BorderThickness="0" SelectionMode="Single" SelectionUnit="Cell"
                          MouseDoubleClick="Dg_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Wiersz / Kategoria" Binding="{Binding KategoriaLabel}" Width="220" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="colR1" Header="r1 — Sztuki" Binding="{Binding LiczbaSztuk, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="8,0"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="colR2" Header="r2 — Waga żywa (kg)" Binding="{Binding WagaZywaKg, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="8,0"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="Foreground" Value="#15803D"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="colR3" Header="r3 — Po uboju brutto (kg)" Binding="{Binding WagaPoubojowaBruttoKg, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="8,0"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="Foreground" Value="#DC2626"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="colR4" Header="r4 — Handlowa netto (kg)" Binding="{Binding WagaHandlowaNettoKg, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="8,0"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="Foreground" Value="#7C3AED"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="colR5" Header="r5 — Wartość (zł)" Binding="{Binding WartoscZl, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="8,0"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="Foreground" Value="#1E40AF"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Empty state overlay -->
            <Border x:Name="emptyStateOverlay" Background="#FAFBFC" CornerRadius="6"
                    Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🐔" FontSize="56" HorizontalAlignment="Center" Foreground="{StaticResource TextSubtle}"/>
                    <TextBlock Text="Brak danych za wybrany miesiąc" FontSize="17"
                               FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                               Margin="0,16,0,6" HorizontalAlignment="Center"/>
                    <TextBlock Text="Kliknij '🔄 Pobierz z baz' lub naciśnij F5"
                               FontSize="12" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <Button Style="{StaticResource PrimaryBtn}" Content="🔄  Pobierz z baz"
                            Click="BtnLoad_Click" MinWidth="200" Padding="18,9"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="4" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0" Padding="22,12">
            <TextBlock x:Name="lblFooter" VerticalAlignment="Center" FontSize="12"
                       Foreground="{StaticResource TextMuted}"
                       Text="⚠ Generator XML — szkielet (do dostrojenia po dostarczeniu wzorca z Symfonii). Liczby są prawdziwe."/>
        </Border>

        <Grid x:Name="loadingOverlay" Background="#A0FFFFFF" Visibility="Collapsed" Grid.RowSpan="5">
            <Border Background="White" CornerRadius="10" Padding="28,18"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏳" FontSize="24" Margin="0,0,14,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="loadingText" Text="Pobieram dane…" VerticalAlignment="Center" FontSize="14"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
