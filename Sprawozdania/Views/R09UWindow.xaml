<Window x:Class="Kalendarz1.Sprawozdania.Views.R09UWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kalendarz1.Sprawozdania.Views"
        Title="R-09U — Sprawozdanie GUS o ubojach"
        WindowStartupLocation="Manual"
        WindowState="Normal" ResizeMode="CanResize"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{x:Static local:R09UWindow.LoadCmd}"/>
        <KeyBinding Key="G" Modifiers="Control" Command="{x:Static local:R09UWindow.GenerateCmd}"/>
        <KeyBinding Key="P" Modifiers="Control" Command="{x:Static local:R09UWindow.PreviewCmd}"/>
        <KeyBinding Key="H" Modifiers="Control" Command="{x:Static local:R09UWindow.HistoryCmd}"/>
        <KeyBinding Key="Left" Modifiers="Control" Command="{x:Static local:R09UWindow.PrevMonthCmd}"/>
        <KeyBinding Key="Right" Modifiers="Control" Command="{x:Static local:R09UWindow.NextMonthCmd}"/>
        <KeyBinding Key="Escape" Command="{x:Static local:R09UWindow.CloseCmd}"/>
    </Window.InputBindings>
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7785"/>
        <SolidColorBrush x:Key="TextSubtle" Color="#9BA4B0"/>
        <SolidColorBrush x:Key="CardBg" Color="White"/>
        <SolidColorBrush x:Key="CardBorder" Color="#E2E7ED"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="DgHeaderBg" Color="#F0F4F8"/>
        <SolidColorBrush x:Key="DgAltRowBg" Color="#FAFBFC"/>
        <SolidColorBrush x:Key="DgRowHoverBg" Color="#F0F7FF"/>

        <!-- Kolory grup -->
        <SolidColorBrush x:Key="GrpD1Bg" Color="#ECFDF5"/>
        <SolidColorBrush x:Key="GrpD1Border" Color="#A7F3D0"/>
        <SolidColorBrush x:Key="GrpD1Text" Color="#065F46"/>
        <SolidColorBrush x:Key="GrpD2Bg" Color="#FEF2F2"/>
        <SolidColorBrush x:Key="GrpD2Border" Color="#FECACA"/>
        <SolidColorBrush x:Key="GrpD2Text" Color="#B91C1C"/>
        <SolidColorBrush x:Key="GrpSurBg" Color="#EFF6FF"/>
        <SolidColorBrush x:Key="GrpSurBorder" Color="#BFDBFE"/>
        <SolidColorBrush x:Key="GrpSurText" Color="#1E40AF"/>

        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource DgHeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="6,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DgRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DgRowHoverBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DgNumeric" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFFF" Offset="0"/>
                    <GradientStop Color="#F8FAFC" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="22,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#FEF3C7" CornerRadius="8" Padding="8,4">
                        <TextBlock Text="🐔  R-09U" FontSize="14" FontWeight="Bold" Foreground="#92400E"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Sprawozdanie o wielkości ubojów zwierząt"
                                   FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Źródło: Specyfikacje surowca › Podsumowanie (FarmerCalc) — brojlery kurze w14"
                                   FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border x:Name="statusBadge" Background="#FEF3C7" CornerRadius="14"
                            Padding="12,4" Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtStatus" Text="Wybierz miesiąc" FontSize="11"
                                   FontWeight="SemiBold" Foreground="#92400E"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolBtn}" Content="📜  Historia" Click="BtnHistory_Click"
                            ToolTip="Historia (Ctrl+H)"/>
                    <Button Style="{StaticResource ToolBtn}" Content="⚙  Konfiguracja" Click="BtnSettings_Click"/>
                    <Button Style="{StaticResource ToolBtn}" Content="✖" MinWidth="38" Click="BtnClose_Click"
                            ToolTip="Zamknij (Esc)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1">
            <Grid Margin="22,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#F1F5F9" CornerRadius="6" Padding="2"
                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="◀" Width="32" Background="Transparent" BorderThickness="0"
                                    Click="BtnPrevMonth_Click" ToolTip="Poprzedni miesiąc (Ctrl+←)"/>
                            <ComboBox x:Name="cbMiesiac" Width="130" Padding="6,4" BorderThickness="0"
                                      Background="Transparent" SelectionChanged="Picker_Changed"/>
                            <ComboBox x:Name="cbRok" Width="78" Padding="6,4" BorderThickness="0"
                                      Background="Transparent" SelectionChanged="Picker_Changed"/>
                            <Button Content="▶" Width="32" Background="Transparent" BorderThickness="0"
                                    Click="BtnNextMonth_Click" ToolTip="Następny miesiąc (Ctrl+→)"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource PrimaryBtn}" Content="🔄  Pobierz z Specyfikacji"
                            Margin="10,0,0,0" MinWidth="200" Click="BtnLoad_Click"
                            ToolTip="Agregacja per dzień z FarmerCalc (F5)"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolBtn}" Content="🔍  Podgląd XML" Click="BtnPreviewXml_Click"
                            ToolTip="(Ctrl+P)"/>
                    <Button Style="{StaticResource PrimaryBtn}" Content="💾  Generuj XML"
                            Click="BtnGenerate_Click" MinWidth="160" ToolTip="(Ctrl+G)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 4 karty z sumami D1 + D2 -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1" Padding="22,12">
            <UniformGrid Rows="1" Columns="4">
                <Border Style="{StaticResource StatCard}" Background="{StaticResource GrpD1Bg}"
                        BorderBrush="{StaticResource GrpD1Border}">
                    <StackPanel>
                        <TextBlock Text="DZIAŁ 1 — Sztuki  (Zdatne + Konfi)" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource GrpD1Text}"/>
                        <TextBlock x:Name="cardD1Szt" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                        <TextBlock x:Name="cardD1SztSub" FontSize="10" Foreground="{StaticResource TextSubtle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Background="{StaticResource GrpD1Bg}"
                        BorderBrush="{StaticResource GrpD1Border}">
                    <StackPanel>
                        <TextBlock Text="DZIAŁ 1 — Waga żywa  (Żywiec + Konfi kg)" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource GrpD1Text}"/>
                        <TextBlock x:Name="cardD1Kg" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                        <TextBlock x:Name="cardD1KgSub" FontSize="10" Foreground="{StaticResource TextSubtle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Background="{StaticResource GrpD2Bg}"
                        BorderBrush="{StaticResource GrpD2Border}">
                    <StackPanel>
                        <TextBlock Text="DZIAŁ 2 — Sztuki  (Padłe + Konfi)" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource GrpD2Text}"/>
                        <TextBlock x:Name="cardD2Szt" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                        <TextBlock x:Name="cardD2SztSub" FontSize="10" Foreground="{StaticResource TextSubtle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Background="{StaticResource GrpD2Bg}"
                        BorderBrush="{StaticResource GrpD2Border}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="DZIAŁ 2 — Waga  (Suma kg = Padłe + Konfi)" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource GrpD2Text}"/>
                        <TextBlock x:Name="cardD2Kg" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                        <TextBlock x:Name="cardD2KgSub" FontSize="10" Foreground="{StaticResource TextSubtle}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>

        <!-- Info pasek -->
        <Border Grid.Row="3" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="0,0,0,1"
                Padding="22,8">
            <TextBlock FontSize="11" Foreground="#1E40AF" TextWrapping="Wrap">
                <Run Text="💡 "/><Run FontWeight="SemiBold" Text="Mapowanie do R-09U:"/>
                <Run Text=" Dział 1.w14 (brojlery kurze)"/><Run Text=" → sztuki = "/><Run FontWeight="SemiBold" Text="Zdatne + Konfi"/><Run Text=", kg = "/><Run FontWeight="SemiBold" Text="Żywiec + Konfi kg"/>
                <Run Text="   ·   Dział 2.w14 → sztuki = "/><Run FontWeight="SemiBold" Text="Padłe + Konfi"/><Run Text=", kg = "/><Run FontWeight="SemiBold" Text="Suma kg"/>
            </TextBlock>
        </Border>

        <!-- Tablica dziennych sum -->
        <Grid Grid.Row="4" Margin="22,12">
            <Border Background="White" BorderBrush="{StaticResource CardBorder}"
                    BorderThickness="1" CornerRadius="6">
                <DataGrid x:Name="dgDni" AutoGenerateColumns="False" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" RowHeight="26"
                          CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="True"
                          ColumnHeaderStyle="{StaticResource DgHeader}"
                          RowStyle="{StaticResource DgRowStyle}"
                          AlternatingRowBackground="{StaticResource DgAltRowBg}" Background="Transparent"
                          BorderThickness="0" IsReadOnly="True" FrozenColumnCount="2">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Data" Binding="{Binding DataText}" Width="60">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="dow" Binding="{Binding DowText}" Width="40">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSubtle}"/>
                                    <Setter Property="FontSize" Value="10"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Surowe kolumny z Podsumowania -->
                        <DataGridTextColumn Header="Zdatne [szt]" Binding="{Binding ZdatneSzt, StringFormat={}{0:N0}}" Width="95" ElementStyle="{StaticResource DgNumeric}"/>
                        <DataGridTextColumn Header="Padłe [szt]" Binding="{Binding PadleSzt, StringFormat={}{0:N0}}" Width="85" ElementStyle="{StaticResource DgNumeric}"/>
                        <DataGridTextColumn Header="Konfi [szt]" Binding="{Binding KonfiSzt, StringFormat={}{0:N0}}" Width="85" ElementStyle="{StaticResource DgNumeric}"/>
                        <DataGridTextColumn Header="Konfi [kg]" Binding="{Binding KonfiKg, StringFormat={}{0:N0}}" Width="85" ElementStyle="{StaticResource DgNumeric}"/>
                        <DataGridTextColumn Header="Padłe [kg]" Binding="{Binding PadleKg, StringFormat={}{0:N0}}" Width="85" ElementStyle="{StaticResource DgNumeric}"/>
                        <DataGridTextColumn Header="Żywiec [kg]" Binding="{Binding ZywiecKg, StringFormat={}{0:N0}}" Width="105" ElementStyle="{StaticResource DgNumeric}"/>
                        <DataGridTextColumn Header="Suma [kg]" Binding="{Binding SumaKg, StringFormat={}{0:N0}}" Width="90" ElementStyle="{StaticResource DgNumeric}"/>

                        <!-- D1 / D2 obliczone -->
                        <DataGridTextColumn Header="D1 szt" Binding="{Binding D1_Sztuki, StringFormat={}{0:N0}}" Width="90">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="{StaticResource GrpD1Bg}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DgNumeric}">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="D1 kg" Binding="{Binding D1_Kg, StringFormat={}{0:N0}}" Width="100">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="{StaticResource GrpD1Bg}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DgNumeric}">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{StaticResource GrpD1Text}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="D2 szt" Binding="{Binding D2_Sztuki, StringFormat={}{0:N0}}" Width="80">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="{StaticResource GrpD2Bg}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DgNumeric}">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="D2 kg" Binding="{Binding D2_Kg, StringFormat={}{0:N0}}" Width="90">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="{StaticResource GrpD2Bg}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DgNumeric}">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{StaticResource GrpD2Text}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Empty state -->
            <Border x:Name="emptyStateOverlay" Background="#FAFBFC" CornerRadius="6" Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🐔" FontSize="56" HorizontalAlignment="Center" Foreground="{StaticResource TextSubtle}"/>
                    <TextBlock Text="Brak danych za wybrany miesiąc" FontSize="17"
                               FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                               Margin="0,16,0,6" HorizontalAlignment="Center"/>
                    <TextBlock Text="Kliknij '🔄 Pobierz z Specyfikacji' lub naciśnij F5"
                               FontSize="12" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <Button Style="{StaticResource PrimaryBtn}" Content="🔄  Pobierz z Specyfikacji"
                            Click="BtnLoad_Click" MinWidth="220" Padding="18,9"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Mini tabela R-09U Dział 1+2 (gotowe wartości do XML) -->
        <Border Grid.Row="5" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0" Padding="22,12">
            <StackPanel>
                <TextBlock Text="📋 Wartości do wpisania w R-09U (w14 brojlery kurze)"
                           FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                           Margin="0,0,0,8"/>
                <Border BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="6">
                    <DataGrid x:Name="dgWynik" AutoGenerateColumns="False" HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal" RowHeight="38"
                              CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="False"
                              ColumnHeaderStyle="{StaticResource DgHeader}"
                              Background="Transparent" BorderThickness="0" IsReadOnly="True"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dział" Binding="{Binding Dzial}" Width="220">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="10,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Sztuki  (r1)" Binding="{Binding Sztuki, StringFormat={}{0:N0}}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DgNumeric}">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="14"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Waga żywa kg  (r2)" Binding="{Binding Kg, StringFormat={}{0:N0}}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DgNumeric}">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Foreground" Value="#15803D"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Wzór" Binding="{Binding Wzor}" Width="320">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="10,0"/>
                                        <Setter Property="FontStyle" Value="Italic"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="6" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0" Padding="22,10">
            <TextBlock x:Name="lblFooter" VerticalAlignment="Center" FontSize="11"
                       Foreground="{StaticResource TextMuted}"
                       Text="💡 Default: poprzedni miesiąc. Tabela powyżej = każdy dzień miesiąca z agregatami i wartościami R-09U."/>
        </Border>

        <Grid x:Name="loadingOverlay" Background="#A0FFFFFF" Visibility="Collapsed" Grid.RowSpan="7">
            <Border Background="White" CornerRadius="10" Padding="28,18"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏳" FontSize="24" Margin="0,0,14,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="loadingText" Text="Pobieram dane…" VerticalAlignment="Center" FontSize="14"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
