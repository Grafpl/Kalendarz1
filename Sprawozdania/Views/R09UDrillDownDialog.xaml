<Window x:Class="Kalendarz1.Sprawozdania.Views.R09UDrillDownDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="R-09U — Drill-down"
        Width="1180" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2A36"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7785"/>
        <SolidColorBrush x:Key="TextSubtle" Color="#9BA4B0"/>
        <SolidColorBrush x:Key="CardBorder" Color="#E2E7ED"/>
        <SolidColorBrush x:Key="DgHeaderBg" Color="#F0F4F8"/>
        <SolidColorBrush x:Key="DgAltRowBg" Color="#FAFBFC"/>

        <Style x:Key="DgHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource DgHeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style x:Key="DgNumeric" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
        <Style x:Key="TypPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1" Padding="22,16">
            <StackPanel>
                <TextBlock x:Name="lblTitle" Text="" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBlock x:Name="lblSubtitle" Text="" FontSize="12"
                           Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1" Padding="22,12">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Left" Background="#DBEAFE" CornerRadius="6" Padding="10,5">
                    <TextBlock x:Name="lblSummary" FontSize="12" FontWeight="SemiBold" Foreground="#1E40AF"/>
                </Border>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="📋 Kopiuj" Padding="12,5" Margin="0,0,6,0" Click="BtnCopy_Click"/>
                    <Button Content="💾 CSV" Padding="12,5" Margin="0,0,6,0" Click="BtnCsv_Click"/>
                    <Button Content="Zamknij" Padding="14,5" Click="BtnClose_Click"/>
                </StackPanel>
                <DockPanel LastChildFill="True" Margin="14,0,12,0">
                    <TextBlock Text="🔍 " VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                    <TextBox x:Name="txtFilter" Padding="6,4" VerticalContentAlignment="Center"
                             TextChanged="TxtFilter_TextChanged"/>
                </DockPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Background="White" Margin="22,12"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="6">
            <!-- DataGrid dla partii FarmerCalc -->
            <DataGrid x:Name="dgPartie" AutoGenerateColumns="False" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" RowHeight="30"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      CanUserSortColumns="True"
                      ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                      AlternatingRowBackground="{StaticResource DgAltRowBg}" Background="Transparent"
                      BorderThickness="0" IsReadOnly="True" Visibility="Collapsed">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data" Binding="{Binding Data, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                    <DataGridTextColumn Header="Nr partii" Binding="{Binding LpDostawy}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Hodowca" Binding="{Binding Hodowca}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Sztuki (r1)" Binding="{Binding Sztuki, StringFormat={}{0:N0}}" Width="100" ElementStyle="{StaticResource DgNumeric}"/>
                    <DataGridTextColumn Header="Farm kg (r2)" Binding="{Binding WagaFarmKg, StringFormat={}{0:N0}}" Width="120" ElementStyle="{StaticResource DgNumeric}"/>
                    <DataGridTextColumn Header="Ubojnia kg (r3)" Binding="{Binding WagaUbojniaKg, StringFormat={}{0:N0}}" Width="130" ElementStyle="{StaticResource DgNumeric}"/>
                    <DataGridTextColumn Header="Cena zł/kg" Binding="{Binding CenaZlKg, StringFormat={}{0:N2}}" Width="100" ElementStyle="{StaticResource DgNumeric}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- DataGrid dla faktur (overlay tej samej Border) -->
        <Border Grid.Row="2" x:Name="frameFaktury" Background="White" Margin="22,12"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="6"
                Visibility="Collapsed">
            <DataGrid x:Name="dgFaktury" AutoGenerateColumns="False" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" RowHeight="32"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      CanUserSortColumns="True"
                      ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                      AlternatingRowBackground="{StaticResource DgAltRowBg}" Background="Transparent"
                      BorderThickness="0" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data" Binding="{Binding Data, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                    <DataGridTemplateColumn Header="Typ" Width="62">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource TypPill}" Background="{Binding TypBg}">
                                    <TextBlock Text="{Binding TypDk}" Foreground="{Binding TypFg}"
                                               FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Numer" Binding="{Binding Numer}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Kontrahent" Binding="{Binding Kontrahent}" Width="220">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Kod" Binding="{Binding KodTowaru}" Width="140"/>
                    <DataGridTextColumn Header="Nazwa" Binding="{Binding NazwaTowaru}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="6,0"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Kg" Binding="{Binding Kg, StringFormat={}{0:N1}}" Width="100" ElementStyle="{StaticResource DgNumeric}"/>
                    <DataGridTextColumn Header="Wartość netto" Binding="{Binding Wartosc, StringFormat={}{0:N2}}" Width="140" ElementStyle="{StaticResource DgNumeric}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0" Padding="22,10">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="lblFooter" VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource TextMuted}"
                           Text="💡 Drill-down R-09U — dane z LibraNet (FarmerCalc) lub HANDEL (faktury żywca)."/>
                <TextBlock x:Name="lblFooterRight" DockPanel.Dock="Right" VerticalAlignment="Center"
                           FontSize="11" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
