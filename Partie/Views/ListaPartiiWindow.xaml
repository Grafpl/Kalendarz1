<Window x:Class="Kalendarz1.Partie.Views.ListaPartiiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kalendarz1.Partie.Views"
        Title="Lista Partii Ubojowych - ZPSP"
        Width="1500" Height="900"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <TabControl x:Name="MainTabs" FontFamily="Segoe UI" FontSize="13" Padding="0">
        <TabItem Header="  Produkcja dzis  " Padding="12,6">
            <local:ProdukcjaDzisWidok/>
        </TabItem>
        <TabItem Header="  Lista partii  " Padding="12,6">
            <local:WidokPartie/>
        </TabItem>
    </TabControl>
</Window>
