<Window x:Class="Kalendarz1.Partie.Windows.NowaPartiaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nowa partia ubojowa"
        Width="480" Height="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimaryBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="BgTertiaryBrush" Color="#334155"/>
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#27AE60"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#334155"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>

        <Style x:Key="FieldInput" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentGreenBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2ECC71"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#475569"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgPrimaryBrush}" CornerRadius="10" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" Color="Black" Opacity="0.4" BlurRadius="15"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#27AE60" CornerRadius="10,10,0,0" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="+ NOWA PARTIA UBOJOWA" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="txtInfo" Text="" FontSize="11" Foreground="#A9DFBF" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <Border Grid.Row="1" Background="{StaticResource BgSecondaryBrush}" Padding="20,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Harmonogram info (visible when created from harmonogram) -->
                        <Border x:Name="borderHarmonogram" Background="#1A3D1A" CornerRadius="6" Padding="12,8"
                                Margin="0,0,0,8" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Z HARMONOGRAMU DOSTAW" FontSize="10" FontWeight="Bold"
                                           Foreground="#27AE60" Margin="0,0,0,4"/>
                                <TextBlock x:Name="txtHarmonogramInfo" Foreground="#A9DFBF" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Dzial *" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="cmbDzial" Style="{StaticResource FieldInput}">
                            <ComboBoxItem Content="1A - Rozbior" Tag="1A" IsSelected="True"/>
                            <ComboBoxItem Content="0E - Ekspedycja" Tag="0E"/>
                            <ComboBoxItem Content="0K - Mag. zwrotow" Tag="0K"/>
                        </ComboBox>

                        <TextBlock Text="Dostawca *" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="cmbDostawca" Style="{StaticResource FieldInput}"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  DisplayMemberPath="Display" SelectedValuePath="ID"/>

                        <TextBlock Text="Nr partii (auto-generowany)" Style="{StaticResource FieldLabel}"/>
                        <TextBlock x:Name="txtNrPartii" Text="(zostanie wygenerowany automatycznie)"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"
                                   FontFamily="Consolas" FontWeight="Bold" Margin="0,4,0,0"/>

                        <!-- Harmonogram details -->
                        <StackPanel x:Name="panelHarmDetails" Visibility="Collapsed">
                            <Border Height="1" Background="{StaticResource BgTertiaryBrush}" Margin="0,10"/>
                            <TextBlock Text="DANE Z HARMONOGRAMU" FontSize="10" FontWeight="Bold"
                                       Foreground="#D4AF37" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Sztuki dekl.:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtHarmSztuki" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Waga dekl.:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtHarmWaga" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Typ ceny:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtHarmTypCeny" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Cena:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtHarmCena" Foreground="#D4AF37" FontSize="12" FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>

                        <TextBlock x:Name="txtOtwarcie" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" Margin="0,16,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="{StaticResource BgSecondaryBrush}" CornerRadius="0,0,10,10" Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Anuluj" Style="{StaticResource CancelButton}" Click="BtnCancel_Click" Margin="0,0,6,0"/>
                    <Button Grid.Column="1" x:Name="BtnUtworzPartie" Content="UTWORZ PARTIE"
                            Style="{StaticResource ActionButton}" Click="BtnUtworzPartie_Click" Margin="6,0,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
