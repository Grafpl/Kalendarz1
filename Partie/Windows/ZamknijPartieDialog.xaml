<Window x:Class="Kalendarz1.Partie.Windows.ZamknijPartieDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zamkniecie partii"
        Width="560" Height="620"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimaryBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="BgTertiaryBrush" Color="#334155"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#334155"/>
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#E67E22"/>

        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>

        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgPrimaryBrush}" CornerRadius="10" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" Color="Black" Opacity="0.4" BlurRadius="15"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#E67E22" CornerRadius="10,10,0,0" Padding="16,14">
                <StackPanel>
                    <TextBlock x:Name="txtHeader" Text="ZAMKNIECIE PARTII" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="txtSubHeader" FontSize="12" Foreground="#FDEBD0" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <Border Grid.Row="1" Background="{StaticResource BgSecondaryBrush}" Padding="20,12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Info podstawowe -->
                        <TextBlock Text="INFORMACJE" Foreground="{StaticResource AccentOrangeBrush}" FontWeight="Bold" FontSize="12" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Dostawca:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtDostawca" Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Data otwarcia:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtDataOtwarcia" Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Otworzyl:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtOtworzyl" Style="{StaticResource InfoValue}"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BgTertiaryBrush}" Margin="0,10"/>

                        <!-- Produkcja -->
                        <TextBlock Text="PODSUMOWANIE PRODUKCJI" Foreground="{StaticResource AccentOrangeBrush}" FontWeight="Bold" FontSize="12" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Wydano z rozbioru:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtWydano" Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Przyjeto na eksp.:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtPrzyjeto" Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Na stanie:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtNaStanie" Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Wydajnosc:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtWydajnosc" Style="{StaticResource InfoValue}"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BgTertiaryBrush}" Margin="0,10"/>

                        <!-- QC CHECKLIST -->
                        <TextBlock Text="KONTROLA JAKOSCI - CHECKLIST" Foreground="#D4AF37" FontWeight="Bold" FontSize="12" Margin="0,0,0,6"/>
                        <ItemsControl x:Name="ChecklistItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" Margin="0,2" CornerRadius="4"
                                            BorderThickness="1" BorderBrush="#334155">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1E293B"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOK}" Value="True">
                                                        <Setter Property="Background" Value="#1A3D1A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                                        <Setter Property="Background" Value="#3D3A1A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontSize="14" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#x2716;"/>
                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                <Setter Property="Text" Value="&#x2714;"/>
                                                                <Setter Property="Foreground" Value="#27AE60"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                                                <Setter Property="Foreground" Value="#D4AF37"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Grid.Column="1" Margin="4,0">
                                                <TextBlock Text="{Binding Nazwa}" Foreground="#E2E8F0" FontSize="12" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Opis}" Foreground="#64748B" FontSize="10"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Status}"
                                                       VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#94A3B8"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Warning -->
                        <Border x:Name="borderWarning" Background="#7D6608" CornerRadius="6" Padding="10,8" Margin="0,12,0,0" Visibility="Collapsed">
                            <TextBlock x:Name="txtWarning" Foreground="#F7DC6F" FontSize="12" TextWrapping="Wrap"/>
                        </Border>

                        <!-- QC Status summary -->
                        <Border x:Name="borderQCSummary" CornerRadius="6" Padding="10,8" Margin="0,8,0,0">
                            <TextBlock x:Name="txtQCSummary" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Komentarz -->
                        <TextBlock Text="Komentarz zamkniecia:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,12,0,4"/>
                        <TextBox x:Name="txtKomentarz" Background="{StaticResource BgTertiaryBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1" Padding="8,6" FontSize="12" Height="50"
                                 TextWrapping="Wrap" AcceptsReturn="True" CaretBrush="White"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="{StaticResource BgSecondaryBrush}" CornerRadius="0,0,10,10" Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Anuluj" Background="#475569" Style="{StaticResource ActionButton}" Click="BtnCancel_Click" Margin="0,0,6,0"/>
                    <Button Grid.Column="1" x:Name="BtnZamknij" Content="ZAMKNIJ PARTIE"
                            Background="#E67E22" Style="{StaticResource ActionButton}" Click="BtnZamknij_Click" Margin="6,0,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
