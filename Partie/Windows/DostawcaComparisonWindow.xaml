<Window x:Class="Kalendarz1.Partie.Windows.DostawcaComparisonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        Title="Porownanie dostawcow - ZPSP"
        Width="1200" Height="700"
        WindowStartupLocation="CenterOwner"
        WindowState="Normal">
    <Grid Background="#F0F3F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#8E44AD" Height="50">
            <DockPanel Margin="16,0">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtOkres" Foreground="#D7BDE2" FontSize="12" VerticalAlignment="Center"
                               FontFamily="Segoe UI"/>
                </StackPanel>
                <TextBlock Text="POROWNANIE DOSTAWCOW" FontSize="16" FontWeight="Bold"
                           Foreground="White" FontFamily="Segoe UI" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Grid -->
        <dxg:GridControl x:Name="gridComparison" Grid.Row="1" Margin="8"
                         AutoGenerateColumns="None" SelectionMode="Row">
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="False" ShowGroupPanel="False"
                               AllowSorting="True" ShowAutoFilterRow="True"
                               ShowFixedTotalSummary="True" BestFitMode="AllRows"/>
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="CustomerID" Header="ID" Width="70"/>
                <dxg:GridColumn FieldName="CustomerName" Header="Dostawca" Width="200"/>
                <dxg:GridColumn FieldName="IloscPartii" Header="Partii" Width="65">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="SrWydajnosc" Header="Sr. wydajnosc %" Width="120" SortOrder="Descending">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" DisplayFormat="N1"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="SrKlasaB" Header="Sr. klasa B %" Width="110">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" DisplayFormat="N1"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="SrTempRampa" Header="Sr. temp rampa" Width="110">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" DisplayFormat="N1"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="SumKg" Header="Suma kg" Width="100">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" DisplayFormat="N0"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="SumSzt" Header="Suma szt" Width="90">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" DisplayFormat="N0"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="SrPadle" Header="Sr. padle" Width="80">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings HorizontalContentAlignment="Right" DisplayFormat="N1"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="CustomerID" DisplayFormat="Dostawcow: {0}"/>
                <dxg:GridSummaryItem SummaryType="Sum" FieldName="SumKg" DisplayFormat="Razem: {0:N0} kg"/>
                <dxg:GridSummaryItem SummaryType="Sum" FieldName="IloscPartii" DisplayFormat="Partii: {0}"/>
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>

        <!-- Loading -->
        <Border x:Name="LoadingOverlay" Grid.Row="1" Background="#80FFFFFF" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Ladowanie danych..." FontFamily="Segoe UI" FontSize="13"
                           Foreground="#34495E" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#2C3E50" Height="28">
            <TextBlock x:Name="TxtFooter" Text="" Foreground="#BDC3C7"
                       FontFamily="Segoe UI" FontSize="11" VerticalAlignment="Center" Margin="12,0"/>
        </Border>
    </Grid>
</Window>
