<Window x:Class="Kalendarz1.Transport.TransportZmianyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zmiany w zamowieniach - Akceptacja" Width="1050" Height="650"
        MinWidth="750" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F3F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Height="52">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00838F" Offset="0"/>
                    <GradientStop Color="#00695C" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel Margin="16,0">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Akceptuj zaznaczone" Style="{StaticResource ActionBtn}"
                            Background="#27AE60" Click="BtnAccept_Click"/>
                    <Button Content="Odrzuc zaznaczone" Style="{StaticResource ActionBtn}"
                            Background="#E74C3C" Click="BtnReject_Click"/>
                    <Border Width="1" Background="#4DB6AC" Margin="8,10"/>
                    <Button Content="Akceptuj wszystkie" Style="{StaticResource ActionBtn}"
                            Background="#2E7D32" Click="BtnAcceptAll_Click"/>
                    <Border Width="1" Background="#4DB6AC" Margin="8,10"/>
                    <Button Content="Wykryj nowe" Style="{StaticResource ActionBtn}"
                            Background="#F57C00" Click="BtnDetect_Click"
                            ToolTip="Skanuj nowe zamowienia do zaakceptowania"/>
                    <Button Content="Odswiez" Style="{StaticResource ActionBtn}"
                            Background="Transparent" Click="BtnRefresh_Click"/>
                </StackPanel>
                <TextBlock Text="Zmiany w zamowieniach" FontFamily="Segoe UI" FontSize="16"
                           FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1" Padding="16,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filtr:" FontFamily="Segoe UI" FontSize="11" Foreground="#7F8C8D"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <RadioButton x:Name="RbOczekuje" Content="Oczekujace" FontFamily="Segoe UI" FontSize="11"
                             IsChecked="True" Margin="0,0,12,0" Checked="Filter_Changed"
                             VerticalAlignment="Center"/>
                <RadioButton x:Name="RbWszystkie" Content="Wszystkie" FontFamily="Segoe UI" FontSize="11"
                             Margin="0,0,12,0" Checked="Filter_Changed"
                             VerticalAlignment="Center"/>
                <RadioButton x:Name="RbZaakceptowane" Content="Zaakceptowane" FontFamily="Segoe UI" FontSize="11"
                             Margin="0,0,12,0" Checked="Filter_Changed"
                             VerticalAlignment="Center"/>
                <RadioButton x:Name="RbOdrzucone" Content="Odrzucone" FontFamily="Segoe UI" FontSize="11"
                             Checked="Filter_Changed" VerticalAlignment="Center"/>
                <Border Width="1" Background="#DEE2E6" Margin="16,2"/>
                <TextBlock x:Name="TxtCount" FontFamily="Segoe UI" FontSize="11" Foreground="#E74C3C"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Data Grid -->
        <ListView x:Name="ListZmiany" Grid.Row="2" Margin="12" BorderThickness="0"
                  Background="White" SelectionMode="Extended">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID Zam." Width="65"
                                    DisplayMemberBinding="{Binding ZamowienieId}"/>
                    <GridViewColumn Header="Klient" Width="160"
                                    DisplayMemberBinding="{Binding KlientNazwa}"/>
                    <GridViewColumn Header="Typ zmiany" Width="140"
                                    DisplayMemberBinding="{Binding TypLabel}"/>
                    <GridViewColumn Header="Opis" Width="220"
                                    DisplayMemberBinding="{Binding Opis}"/>
                    <GridViewColumn Header="Stare" Width="90"
                                    DisplayMemberBinding="{Binding StareWartosc}"/>
                    <GridViewColumn Header="Nowe" Width="90"
                                    DisplayMemberBinding="{Binding NowaWartosc}"/>
                    <GridViewColumn Header="Zglosil" Width="90"
                                    DisplayMemberBinding="{Binding ZgloszonePrzez}"/>
                    <GridViewColumn Header="Kiedy" Width="100"
                                    DisplayMemberBinding="{Binding TimeAgo}"/>
                    <GridViewColumn Header="Status" Width="90"
                                    DisplayMemberBinding="{Binding StatusZmiany}"/>
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusZmiany}" Value="Oczekuje">
                            <Setter Property="Background" Value="#FFF8E1"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StatusZmiany}" Value="Zaakceptowano">
                            <Setter Property="Background" Value="#E8F5E9"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StatusZmiany}" Value="Odrzucono">
                            <Setter Property="Background" Value="#FFEBEE"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="#00838F" Height="26">
            <TextBlock x:Name="TxtStatus" Text="Gotowe" Foreground="#B2DFDB"
                       FontFamily="Segoe UI" FontSize="10" VerticalAlignment="Center" Margin="16,0"/>
        </Border>
    </Grid>
</Window>
