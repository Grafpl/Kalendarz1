<Window x:Class="Kalendarz1.Transport.TransportHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kalendarz1.Transport"
        xmlns:plan="clr-namespace:Kalendarz1.Transport.Views"
        xmlns:mapaFloty="clr-namespace:Kalendarz1.MapaFloty"
        Title="Centrum Transportu - ZPSP"
        Width="1500" Height="900"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#f7f8fa">
    <Window.Resources>
        <!-- Polish++ — styling TabItem z accent line gdy selected -->
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#546e7a"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#1565c0"/>
                            </Border.BorderBrush>
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#fff"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="0,0,0,3"/>
                                <Setter Property="Foreground" Value="#1a237e"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#1565c0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <TabControl x:Name="HubTabs" TabStripPlacement="Top" Background="#f7f8fa" BorderThickness="0">
        <TabItem Header="📋 Planowanie">
            <plan:TransportPlanowanieView/>
        </TabItem>

        <TabItem Header="⚙ Zmiany do akceptacji">
            <local:TransportZmianyView/>
        </TabItem>

        <TabItem Header="🗺️ Mapa Floty LIVE">
            <mapaFloty:MapaFlotyView x:Name="FlotaView"/>
        </TabItem>
    </TabControl>
</Window>
