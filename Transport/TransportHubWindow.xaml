<Window x:Class="Kalendarz1.Transport.TransportHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Kalendarz1.Transport"
        xmlns:mapaFloty="clr-namespace:Kalendarz1.MapaFloty"
        Title="Centrum Transportu - ZPSP"
        Width="1500" Height="900"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#f7f8fa">
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    <TabControl x:Name="HubTabs" TabStripPlacement="Top" Background="#f7f8fa" BorderThickness="0">
        <TabItem Header="📋 Planowanie">
            <Grid x:Name="PlanowanieTab" Background="White">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="600">
                    <TextBlock Text="📋 Planowanie Transportu"
                               FontSize="26" FontWeight="Bold" Foreground="#1a237e"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#546e7a"
                               TextAlignment="Center" Margin="0,0,0,24">
                        Pełen edytor kursów transportowych (kalendarz, ładunki, pakowanie, przydziały).
                        Otwiera klasyczne okno WinForms TransportMainFormImproved.
                    </TextBlock>
                    <Button Content="🚚 Otwórz pełny edytor kursów" Click="BtnOtworzPlanowanie_Click"
                            Background="#1565c0" Foreground="White" BorderThickness="0"
                            Padding="28,12" FontSize="14" FontWeight="Bold" Cursor="Hand"
                            HorizontalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#90a4ae"
                               TextAlignment="Center" Margin="0,16,0,0">
                        Faza 7 MVP — pełna konwersja edytora kursów do WPF w roadmap'ie.
                    </TextBlock>
                </StackPanel>
            </Grid>
        </TabItem>

        <TabItem Header="⚙ Zmiany do akceptacji">
            <local:TransportZmianyView/>
        </TabItem>

        <TabItem Header="🗺️ Mapa Floty LIVE">
            <mapaFloty:MapaFlotyView x:Name="FlotaView"/>
        </TabItem>
    </TabControl>
</Window>
