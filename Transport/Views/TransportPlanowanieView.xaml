<UserControl x:Class="Kalendarz1.Transport.Views.TransportPlanowanieView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#f7f8fa">
    <UserControl.Resources>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Toolbar — header + data + akcje ═══ -->
        <Border Grid.Row="0" Background="White" Padding="16,10" BorderBrush="#e4e6ea" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📋 Planowanie kursów" FontSize="18" FontWeight="Bold" Foreground="#1a237e" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    <Button Content="◀" Click="BtnPrev_Click" ToolTip="Poprzedni dzień (Ctrl+Left)"
                            Style="{StaticResource ToolBtn}" Background="#eceff1" Foreground="#546e7a" FontSize="14" Padding="10,4"/>
                    <DatePicker x:Name="DataKursu" Width="140" FontSize="12" VerticalAlignment="Center"
                                SelectedDateChanged="DataKursu_Changed" Margin="4,0"/>
                    <Button Content="Dziś" Click="BtnDzis_Click"
                            Style="{StaticResource ToolBtn}" Background="#e8eaf6" Foreground="#3949ab"/>
                    <Button Content="▶" Click="BtnNext_Click" ToolTip="Następny dzień (Ctrl+Right)"
                            Style="{StaticResource ToolBtn}" Background="#eceff1" Foreground="#546e7a" FontSize="14" Padding="10,4"/>
                    <TextBlock x:Name="DayNameText" Foreground="#90a4ae" FontSize="12" VerticalAlignment="Center" Margin="14,0,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="🚚 Nowy kurs" Click="BtnNowy_Click"
                            Style="{StaticResource ToolBtn}" Background="#2e7d32" Foreground="White"/>
                    <Button Content="📝 Edytuj" Click="BtnEdytuj_Click" x:Name="BtnEdytuj"
                            Style="{StaticResource ToolBtn}" Background="#1565c0" Foreground="White" IsEnabled="False"/>
                    <Button Content="❌ Usuń" Click="BtnUsun_Click" x:Name="BtnUsun"
                            Style="{StaticResource ToolBtn}" Background="#c62828" Foreground="White" IsEnabled="False"/>
                    <Button Content="🔄" Click="BtnRefresh_Click" ToolTip="Odśwież (F5)"
                            Style="{StaticResource ToolBtn}" Background="#eceff1" Foreground="#546e7a" FontSize="14" Padding="10,4"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ KPI stat row ═══ -->
        <Border Grid.Row="1" Background="White" Padding="16,8" BorderBrush="#e4e6ea" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Border Background="#e8eaf6" CornerRadius="6" Padding="12,5" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Kursów: " Foreground="#3949ab" FontSize="12"/>
                        <TextBlock x:Name="KpiKursy" Text="0" Foreground="#1a237e" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Background="#e8f5e9" CornerRadius="6" Padding="12,5" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Z kierowcą: " Foreground="#388e3c" FontSize="12"/>
                        <TextBlock x:Name="KpiZKierowca" Text="0" Foreground="#1b5e20" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Background="#fff3e0" CornerRadius="6" Padding="12,5" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Wymaga przydziału: " Foreground="#e65100" FontSize="12"/>
                        <TextBlock x:Name="KpiBezZasobow" Text="0" Foreground="#bf360c" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Background="#fce4ec" CornerRadius="6" Padding="12,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Suma palet: " Foreground="#c2185b" FontSize="12"/>
                        <TextBlock x:Name="KpiPalety" Text="0" Foreground="#880e4f" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══ DataGrid kursów ═══ -->
        <DataGrid Grid.Row="2" x:Name="KursyGrid" Margin="16,12,16,12"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  RowBackground="White" AlternatingRowBackground="#fafafa"
                  BorderThickness="0" FontSize="12"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  IsReadOnly="True"
                  SelectionChanged="KursyGrid_SelectionChanged"
                  MouseDoubleClick="KursyGrid_DoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding KursID}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#1a237e"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="8,4"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Godziny" Binding="{Binding GodzinyDisplay}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Padding" Value="8,4"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Trasa" Binding="{Binding Trasa}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Padding" Value="8,4"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Kierowca" Binding="{Binding KierowcaNazwa}" Width="160">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Padding" Value="8,4"/><Setter Property="Foreground" Value="#37474f"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Pojazd" Binding="{Binding PojazdRejestracja}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Padding" Value="8,4"/><Setter Property="Foreground" Value="#37474f"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Wypełnienie" Binding="{Binding WypelnienieDisplay}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Padding" Value="8,4"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Padding" Value="8,4"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ═══ Status bar ═══ -->
        <Border Grid.Row="3" Background="White" Padding="16,6" BorderBrush="#e4e6ea" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="StatusText" Foreground="#78909c" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="💡 Double-click na kurs = edycja" Foreground="#b0bec5" FontSize="11"
                           DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
