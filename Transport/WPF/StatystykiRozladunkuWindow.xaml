<Window x:Class="Kalendarz1.Transport.WPF.StatystykiRozladunkuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 Statystyki rozładunku — uczone z Webfleet GPS"
        Width="1100" Height="720"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" FontSize="12"
        Background="#F3F4F6">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="14">
            <StackPanel>
                <TextBlock Text="📊 Statystyki rozładunku per klient" FontSize="16" FontWeight="Bold" Foreground="#166534"/>
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#6B7280" Margin="0,6,0,0">
                    Dane uczone automatycznie z historii GPS Webfleet (12 miesięcy). Pojazd stoi (≤5 km/h) i jest ≤2 km od klienta → wizyta.
                    Filtrowane: 5–180 min, w godz. 05:00–23:00 (omijane noclegi i pauzy kierowców).
                    <LineBreak/>
                    <Run FontStyle="Italic">Wymagana min. liczba prób (3). Po Odśwież: wiarygodne mediany zapisują się do karty odbiorcy jako oficjalne czasy rozładunku.</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1,0,1,1" CornerRadius="0,0,6,6" Padding="14,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="TxtSzukaj" Width="260" Padding="8,6" Margin="0,0,16,0"
                             TextChanged="TxtSzukaj_Changed"
                             ToolTip="Filtruj po nazwie/skrócie klienta"/>

                    <CheckBox x:Name="ChkTylkoWiarygodne" Content="Tylko wiarygodne (≥3 wizyty)"
                              VerticalAlignment="Center" Margin="0,0,16,0" IsChecked="True"
                              Checked="Filtr_Changed" Unchecked="Filtr_Changed"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button x:Name="BtnOdswiez" Content="🔄 Odśwież z Webfleet (12 miesięcy)" Padding="12,6"
                            Click="BtnOdswiez_Click" Background="#059669" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"
                            ToolTip="Pobierz tracks GPS z 12 miesięcy + przelicz mediany + zapisz wiarygodne do karty odbiorcy (10-30 min)"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN: lewa = lista klientów; prawa = mini-stat -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                <DataGrid x:Name="GridStatystyki" AutoGenerateColumns="False"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          BorderThickness="0" CanUserAddRows="False" CanUserDeleteRows="False"
                          IsReadOnly="True" Background="White" RowBackground="White"
                          AlternatingRowBackground="#F9FAFB" RowHeight="32">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Klient" Binding="{Binding Nazwa}" Width="*"
                                            FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="Mediana" Binding="{Binding MedianaDisplay}" Width="100"/>
                        <DataGridTextColumn Header="Wizyt" Binding="{Binding LiczbaProb}" Width="80"/>
                        <DataGridTextColumn Header="Zaufanie" Binding="{Binding ZaufanieDisplay}" Width="120"/>
                        <DataGridTextColumn Header="Ostatni refresh" Binding="{Binding RefreshDisplay}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Prawa: sumaryczne statystyki -->
            <Border Grid.Column="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="📈 Podsumowanie" FontWeight="SemiBold" FontSize="13" Foreground="#374151" Margin="0,0,0,12"/>

                        <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="KLIENTÓW Z ESTYMACJĄ" FontSize="10" Foreground="#065F46"/>
                                <TextBlock x:Name="TxtLiczbaKlientow" Text="—" FontSize="20" FontWeight="Bold" Foreground="#064E3B"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#EFF6FF" BorderBrush="#93C5FD" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="WIARYGODNYCH (≥3 wizyty)" FontSize="10" Foreground="#1E40AF"/>
                                <TextBlock x:Name="TxtLiczbaWiarygodnych" Text="—" FontSize="20" FontWeight="Bold" Foreground="#1E3A8A"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFFBEB" BorderBrush="#FCD34D" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="ŚREDNIA MEDIANA" FontSize="10" Foreground="#78350F"/>
                                <TextBlock x:Name="TxtSredniaMediana" Text="—" FontSize="20" FontWeight="Bold" Foreground="#92400E"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F3F4F6" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="RANGE MIN ↔ MAX" FontSize="10" Foreground="#374151"/>
                                <TextBlock x:Name="TxtRange" Text="—" FontSize="14" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Separator Margin="0,8"/>

                        <TextBlock Text="🏆 TOP 5 — najdłużej rozładowywani" FontWeight="SemiBold" FontSize="12" Foreground="#374151" Margin="0,8,0,6"/>
                        <StackPanel x:Name="PanelTop5"/>

                        <TextBlock Text="⚡ TOP 5 — najkrócej" FontWeight="SemiBold" FontSize="12" Foreground="#374151" Margin="0,12,0,6"/>
                        <StackPanel x:Name="PanelDol5"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="12,6" Margin="0,12,0,0">
            <DockPanel>
                <TextBlock x:Name="TxtStatus" Text="Ładowanie..." Foreground="#6B7280" FontSize="11" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="Zamknij" Padding="14,6" Click="BtnZamknij_Click"
                        Background="#E5E7EB" Foreground="#374151" BorderThickness="0" Cursor="Hand"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
