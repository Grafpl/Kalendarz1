<Window x:Class="Kalendarz1.Transport.WPF.EdytorKursuWpfWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:Kalendarz1.Transport.WPF.Controls"
        Title="Edytor kursu (WPF)" Height="840" Width="1320"
        MinHeight="650" MinWidth="1080"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8" FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kalendarz1;component/Transport/WPF/Theme/TransportWpfStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="DataGrid">
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserDeleteRows" Value="False"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#F0F2F4"/>
                <Setter Property="RowBackground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="SelectionUnit" Value="FullRow"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="RowHeight" Value="32"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="440"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════ LEWA: karta kursu (cała wysokość) ═══════════════ -->
        <Border Grid.Column="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- alert zmiany -->
                    <RowDefinition Height="Auto"/>   <!-- panel zmiany (collapsed) -->
                    <RowDefinition Height="Auto"/>   <!-- header -->
                    <RowDefinition Height="Auto"/>   <!-- packing -->
                    <RowDefinition Height="*"/>      <!-- ladunki -->
                    <RowDefinition Height="Auto"/>   <!-- przyciski -->
                </Grid.RowDefinitions>

                <!-- ── ALERT: zmiany zamówień do akceptacji (kompakt) ── -->
                <Border x:Name="AlertZmianyBar" Grid.Row="0" Visibility="Collapsed"
                        Background="#FFF7E0" BorderBrush="#F59E0B" BorderThickness="0,0,0,2" Padding="14,6"
                        CornerRadius="10,10,0,0">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🔔" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="AlertText" FontWeight="SemiBold" Foreground="#8A4A00" VerticalAlignment="Center" FontSize="12.5"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Button x:Name="BtnPokazZmiany" Content="Pokaż ▼" Style="{StaticResource BtnGhost}" Height="26" Margin="0,0,6,0"
                                    Padding="10,3" Click="BtnPokazZmiany_Click"/>
                            <Button x:Name="BtnAkceptujWszystkie" Style="{StaticResource BtnPrimary}" Height="26" Padding="10,3" Click="BtnAkceptujWszystkie_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✓" Foreground="White" FontWeight="Bold" Margin="0,0,5,0"/>
                                    <TextBlock x:Name="BtnAkceptujWszystkieText" Text="Akceptuj wszystkie" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ── PANEL ZMIAN (3-kolumnowe karty 2-wierszowe, grupowanie po kliencie) ── -->
                <Border x:Name="PanelZmiany" Grid.Row="1" Visibility="Collapsed" MaxHeight="280"
                        Background="#FFFCF2" BorderBrush="#F0E0B0" BorderThickness="0,0,0,1" Padding="8,8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ListaZmian">
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.Panel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </GroupStyle.Panel>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="#EEF1F4" Padding="10,4" Margin="0,6,0,4" CornerRadius="3">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="3" Background="#F59E0B" CornerRadius="2" Margin="0,0,8,0"/>
                                                <TextBlock Text="🏢" FontSize="11.5" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#37474F" FontSize="11.5" VerticalAlignment="Center"/>
                                                <Border Background="#FFE9C0" CornerRadius="8" Padding="6,1" Margin="9,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ItemCount}" Foreground="#8A4A00" FontSize="10" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" BorderBrush="#E5E8EB" BorderThickness="1" CornerRadius="5" Margin="0,0,5,5">
                                    <Grid MinHeight="50">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Fill="{Binding AkcentBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TypEmoji}" FontSize="18"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   ToolTip="{Binding TypLabel}"/>
                                        <!-- TYP — drugorzędny -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0,12,0">
                                            <TextBlock Text="{Binding TypLabel}" Foreground="{Binding AkcentBrush}"
                                                       FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="140"/>
                                            <Border Background="{Binding AkcentSoft}" CornerRadius="8" Padding="5,0" Margin="5,0,0,0"
                                                    Visibility="{Binding ScaloneVis}" ToolTip="{Binding ScaloneTooltip}" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ScaloneText}" Foreground="{Binding AkcentBrush}" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <!-- WARTOŚCI — DOMINUJĄCE, obok siebie, duża czcionka -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Background="#F4F6F8" CornerRadius="4" Padding="8,2">
                                                <TextBlock Text="{Binding Stare}" Foreground="#5b6776" FontSize="14" FontFamily="Consolas" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="90"/>
                                            </Border>
                                            <TextBlock Text="→" Foreground="#9aa0b0" Margin="6,0" VerticalAlignment="Center" FontSize="15" FontWeight="Bold"/>
                                            <Border Background="#E0F2F1" CornerRadius="4" Padding="8,2">
                                                <TextBlock Text="{Binding Nowa}" Foreground="#00695C" FontSize="14" FontFamily="Consolas" FontWeight="Bold" TextTrimming="CharacterEllipsis" MaxWidth="90"/>
                                            </Border>
                                            <TextBlock Text="{Binding DeltaText}" Foreground="{Binding DeltaBrush}"
                                                       FontWeight="Bold" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="4" Text="{Binding ZglosilDisplay}" Foreground="#8893a0"
                                                   FontSize="10.5" VerticalAlignment="Center" Margin="10,0,10,0" TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                                            <Button Content="✓" Tag="{Binding}" Click="BtnAkceptujJedno_Click" ToolTip="Akceptuj zmianę"
                                                    Background="#E7F4E8" BorderBrush="#9ECAA0" BorderThickness="1" Foreground="#2E7D32"
                                                    Width="30" Height="28" Margin="0,0,4,0" FontWeight="Bold" FontSize="14" Cursor="Hand"/>
                                            <Button Content="✗" Tag="{Binding}" Click="BtnOdrzucJedno_Click" ToolTip="Odrzuć zmianę"
                                                    Background="#FDECEC" BorderBrush="#E5A0A0" BorderThickness="1" Foreground="#C62828"
                                                    Width="30" Height="28" FontWeight="Bold" FontSize="14" Cursor="Hand"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </ScrollViewer>
                </Border>


                <!-- ── HEADER (skrócony) ── -->
                <Border Grid.Row="2" Background="{StaticResource Surface}" Padding="18,13" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- tytuł -->
                            <RowDefinition Height="Auto"/>   <!-- pola -->
                            <RowDefinition Height="Auto"/>   <!-- trasa -->
                        </Grid.RowDefinitions>

                        <!-- tytuł -->
                        <DockPanel Grid.Row="0" Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,2,10,2"/>
                                <TextBlock x:Name="TytulText" Text="Nowy kurs" Style="{StaticResource T.Title}"/>
                            </StackPanel>
                            <TextBlock x:Name="InfoText" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       Foreground="{StaticResource InkMuted}" FontSize="11" VerticalAlignment="Center" TextAlignment="Right"/>
                        </DockPanel>

                        <!-- pola w jednym rzędzie (zawijane) -->
                        <WrapPanel Grid.Row="1">
                            <StackPanel Margin="0,0,26,12">
                                <TextBlock Text="KIEROWCA  (🟢 wolny · 🟡 ma 1 kurs · 🔴 ma 2+ kursy)" Style="{StaticResource T.Section}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CmbKierowca" Width="248" Height="32" TextSearch.TextPath="PelneNazwisko"
                                          IsEditable="True" IsTextSearchEnabled="True">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Background" Value="{Binding Tlo}"/>
                                            <Setter Property="Padding" Value="6,4"/>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Wskaznik}" FontSize="11" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Display}" FontSize="12"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Margin="0,0,26,12">
                                <TextBlock Text="POJAZD  (🟢 wolny · 🟡 ma 1 kurs · 🔴 ma 2+ kursy)" Style="{StaticResource T.Section}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CmbPojazd" Width="218" Height="32" TextSearch.TextPath="Opis"
                                          IsEditable="True" IsTextSearchEnabled="True"
                                          SelectionChanged="CmbPojazd_SelectionChanged">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Background" Value="{Binding Tlo}"/>
                                            <Setter Property="Padding" Value="6,4"/>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Wskaznik}" FontSize="11" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Display}" FontSize="12"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Margin="0,0,26,12">
                                <TextBlock Text="DATA" Style="{StaticResource T.Section}" Margin="0,0,0,4"/>
                                <DatePicker x:Name="DataKursu" Width="132" Height="32" SelectedDateChanged="DataKursu_Changed"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="GODZINY  (wyjazd → powrót)" Style="{StaticResource T.Section}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="TxtWyjazd" Style="{StaticResource Input}" Width="110" Height="40"
                                             Text="06:00" TextAlignment="Center"
                                             FontSize="20" FontWeight="SemiBold" FontFamily="Consolas"
                                             MaxLength="5"
                                             LostFocus="TxtGodzina_LostFocus"
                                             PreviewTextInput="TxtGodzina_PreviewTextInput"
                                             ToolTip="Wpisz godzinę: 06:00, 6:00, 600, 6 — sformatuje się do HH:mm"/>
                                    <TextBlock Text="→" Foreground="{StaticResource InkMuted}" VerticalAlignment="Center" Margin="10,0,10,0" FontSize="18"/>
                                    <TextBox x:Name="TxtPowrot" Style="{StaticResource Input}" Width="110" Height="40"
                                             Text="18:00" TextAlignment="Center"
                                             FontSize="20" FontWeight="SemiBold" FontFamily="Consolas"
                                             MaxLength="5"
                                             LostFocus="TxtGodzina_LostFocus"
                                             PreviewTextInput="TxtGodzina_PreviewTextInput"
                                             ToolTip="Wpisz godzinę: 18:00, 18, 1830 — sformatuje się do HH:mm"/>
                                    <Button x:Name="BtnSzacujPowrot" Content="🔮 Szacuj" Style="{StaticResource BtnGhost}" Height="40" Margin="10,0,0,0"
                                            Click="BtnSzacujPowrot_Click"
                                            ToolTip="Oszacuj godzinę powrotu. System uczy się czasów z Webfleet automatycznie w tle."/>
                                </StackPanel>
                                <TextBlock x:Name="SzacunekHint" Foreground="{StaticResource InkMuted}" FontSize="10.5"
                                           Margin="0,4,0,0" TextWrapping="Wrap" MaxWidth="360"/>
                            </StackPanel>
                        </WrapPanel>

                        <!-- trasa (pełna szerokość) -->
                        <StackPanel Grid.Row="2">
                            <TextBlock Text="TRASA" Style="{StaticResource T.Section}" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtTrasa" Grid.Column="0" Style="{StaticResource Input}"/>
                                <Button Grid.Column="1" Content="auto" Style="{StaticResource BtnGhost}" Height="32" Margin="8,0,0,0"
                                        Click="BtnAutoTrasa_Click" ToolTip="Złóż trasę z nazw klientów"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── PASEK PAKOWANIA (skrócony) ── -->
                <Border Grid.Row="3" Background="{StaticResource Surface}" Padding="16,8" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" VerticalAlignment="Center">
                            <Border Height="22" Background="#EAEDF0" CornerRadius="11"/>
                            <Border x:Name="PaskoFill" Height="22" Background="#43a047" CornerRadius="11"
                                    HorizontalAlignment="Left" Width="0"/>
                            <TextBlock x:Name="PaskoText" Text="0%" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontWeight="Bold" Foreground="#1F2733"/>
                        </Grid>
                        <TextBlock x:Name="PaletyText" Grid.Column="1" Text="0 / 33 palet" VerticalAlignment="Center"
                                   Margin="16,0,0,0" FontWeight="SemiBold" Foreground="{StaticResource InkSecondary}"/>
                    </Grid>
                </Border>

                <!-- ── ŁADUNKI ── -->
                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource SurfaceAlt}" Padding="12,8" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,1,8,1"/>
                                <TextBlock Text="ŁADUNKI W KURSIE" FontWeight="Bold" Foreground="{StaticResource InkPrimary}" FontSize="12.5" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <Button Content="Sortuj" Style="{StaticResource BtnGhost}" Click="BtnSortuj_Click" ToolTip="Sortuj po godzinie awizacji"/>
                                <Button Style="{StaticResource BtnIcon}" Tag="&#xE70E;" Width="32" Click="BtnGora_Click" ToolTip="W górę"/>
                                <Button Style="{StaticResource BtnIcon}" Tag="&#xE70D;" Width="32" Click="BtnDol_Click" ToolTip="W dół"/>
                                <Button Style="{StaticResource BtnIconDanger}" Tag="&#xE74D;" Width="32" Click="BtnUsunLadunek_Click" ToolTip="Usuń z kursu"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <DataGrid x:Name="LadunkiGrid" Margin="4" AllowDrop="True" MouseDoubleClick="LadunkiGrid_DoubleClick">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Edytuj uwagi" Click="MiEdytujUwagi_Click"/>
                                    <Separator/>
                                    <MenuItem Header="W górę" Click="BtnGora_Click"/>
                                    <MenuItem Header="W dół" Click="BtnDol_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Usuń z kursu" Click="BtnUsunLadunek_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Kolejnosc}" Width="38">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="Foreground" Value="#8A95A3"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Klient" Binding="{Binding NazwaDisplay}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#26323C"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Awiz." Binding="{Binding AwizacjaDisplay}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="Foreground" Value="{StaticResource Accent}"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Pojemniki" Binding="{Binding PojemnikiDisplay}" Width="86">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Uwagi" Binding="{Binding Uwagi}" Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#8A95A3"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border x:Name="DropHintLad" Visibility="Collapsed" IsHitTestVisible="False"
                                Background="#1400838F" BorderBrush="{StaticResource Accent}" BorderThickness="2" CornerRadius="8" Margin="2">
                            <Border Background="{StaticResource Accent}" CornerRadius="6" Padding="14,8"
                                    VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Icon}" Text="&#xE70D;" Foreground="White" FontSize="14" Margin="0,0,7,0"/>
                                    <TextBlock Text="Upuść tutaj, aby dodać do kursu" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                </StackPanel>
                            </Border>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ── PRZYCISKI ── -->
                <Border Grid.Row="5" Background="{StaticResource Surface}" Padding="16,12" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" CornerRadius="0,0,10,10">
                    <DockPanel>
                        <TextBlock x:Name="StatusText" Foreground="{StaticResource InkMuted}" FontSize="11.5" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Button Content="Anuluj" Style="{StaticResource BtnGhost}" Width="110" Height="40" Margin="0,0,10,0" Click="BtnAnuluj_Click"/>
                            <Button x:Name="BtnZapisz" Style="{StaticResource BtnPrimary}" Width="190" Height="40" FontSize="14" Click="BtnZapisz_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Icon}" Text="&#xE8FB;" Foreground="White" FontSize="15" Margin="0,0,8,0"/>
                                    <TextBlock Text="ZAPISZ KURS" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════ PRAWA: WOLNE ZAMÓWIENIA (cała wysokość) ═══════════════ -->
        <Border Grid.Column="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="14,11" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,1,8,1"/>
                            <TextBlock Text="WOLNE ZAMÓWIENIA" FontWeight="Bold" Foreground="{StaticResource InkPrimary}" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border DockPanel.Dock="Right" Background="{StaticResource AccentSoft}" CornerRadius="11" Padding="10,2" VerticalAlignment="Center">
                            <TextBlock x:Name="WolneCountText" Text="0" Foreground="{StaticResource AccentDark}" FontWeight="Bold"/>
                        </Border>
                    </DockPanel>
                </Border>
                <Border Grid.Row="1" Background="{StaticResource SurfaceAlt}" Padding="10,6" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Style="{StaticResource BtnPrimary}" Padding="10,4" Click="BtnDodajWolne_Click"
                                ToolTip="Dodaj zaznaczone (Ctrl+klik = wiele) do tego kursu">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource Icon}" Text="&#xE710;" Foreground="White" FontSize="13" Margin="0,0,5,0"/>
                                <TextBlock Text="Dodaj" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button DockPanel.Dock="Right" Style="{StaticResource BtnIcon}" Tag="&#xE72C;" Width="28" Height="26"
                                Margin="0,0,6,0" Click="BtnOdswiezWolne_Click" ToolTip="Pobierz wolne ponownie (z bieżącą datą)"/>
                        <TextBlock Text="Dzień uboju" Foreground="{StaticResource InkMuted}" FontSize="11" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>
                <ListBox x:Name="WolneGrid" Grid.Row="2" Margin="4" BorderThickness="0"
                         Background="Transparent" SelectionMode="Extended"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="WolneGrid_DoubleClick">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Dodaj do kursu" Click="BtnDodajWolne_Click"/>
                            <MenuItem Header="Odbiór własny (zdejmij z transportu)" Click="MiWlasnyOdbior_Click"/>
                            <Separator/>
                            <MenuItem Header="Odśwież" Click="BtnOdswiezWolne_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd" Background="White" CornerRadius="6" Padding="8,6"
                                                Margin="2,2" BorderBrush="#eceef2" BorderThickness="1">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#F0F8F8"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#E0F2F1"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#80CBC4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="#EEF1F4" Padding="10,6" Margin="0,6,0,2" CornerRadius="4">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,0,8,0"/>
                                            <TextBlock Style="{StaticResource Icon}" Text="&#xE787;" FontSize="12" Foreground="{StaticResource Accent}" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name, StringFormat='{}{0:dd.MM ddd}'}" Language="pl-PL"
                                                       FontWeight="Bold" Foreground="{StaticResource InkPrimary}" FontSize="12.5" VerticalAlignment="Center"/>
                                            <Border Background="{StaticResource AccentSoft}" CornerRadius="8" Padding="7,1" Margin="9,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ItemCount}" Foreground="{StaticResource AccentDark}" FontSize="10.5" FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Text="zam." Foreground="{StaticResource InkMuted}" FontSize="10.5" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ToolTip="{Binding Tooltip}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ctrl:AvatarControl Grid.Column="0" UserId="{Binding HandlowiecId}" DisplayName="{Binding Handlowiec}"
                                                    Diameter="30" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding KlientNazwa}" FontWeight="SemiBold" Foreground="#26323c"
                                                   FontSize="12.5" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                        <Border Background="#E0F2F1" BorderBrush="#00838F" BorderThickness="1" CornerRadius="8" Padding="5,0" Margin="6,0,0,0"
                                                Visibility="{Binding CzestaParaVis}" ToolTip="Klient często jeździ razem z odbiorcami w tym kursie (90 dni)" VerticalAlignment="Center">
                                            <TextBlock Text="🤝 razem" FontSize="9" Foreground="#00695C" FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding WolnePodtytul}" Foreground="#8893a0" FontSize="10.5" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Border Grid.Column="2" Width="1" Background="#eceef2" Margin="9,4"/>
                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="9,0,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding GodzAwizacji}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding OdbiorDisplay}" Foreground="#9aa0b0" FontSize="9.5" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,0,0">
                                        <Border Background="#E0F2F1" CornerRadius="3" Padding="5,1" Margin="0,0,4,0">
                                            <TextBlock Text="{Binding KgDisplay}" FontSize="10.5" Foreground="#00695C" FontWeight="Bold"/>
                                        </Border>
                                        <Border Background="#ECEFF1" CornerRadius="3" Padding="5,1" Margin="0,0,4,0">
                                            <TextBlock Text="{Binding PojemnikiDisplay}" FontSize="10" Foreground="#546E7A" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Background="#ECEFF1" CornerRadius="3" Padding="5,1">
                                            <TextBlock Text="{Binding PaletyDisplay, StringFormat='{}{0} pal'}" FontSize="10" Foreground="#546E7A" FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>
