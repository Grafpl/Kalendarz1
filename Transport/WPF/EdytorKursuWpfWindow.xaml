<Window x:Class="Kalendarz1.Transport.WPF.EdytorKursuWpfWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:Kalendarz1.Transport.WPF.Controls"
        Title="Edytor kursu (WPF)" Height="840" Width="1300"
        MinHeight="650" MinWidth="1060"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8" FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kalendarz1;component/Transport/WPF/Theme/TransportWpfStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="DataGrid">
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserDeleteRows" Value="False"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#F0F2F4"/>
                <Setter Property="RowBackground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="SelectionUnit" Value="FullRow"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="RowHeight" Value="32"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- packing -->
            <RowDefinition Height="*"/>      <!-- ladunki + wolne -->
            <RowDefinition Height="Auto"/>   <!-- przyciski -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER (jasny, akcent turkus) ═══ -->
        <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="18,14" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.ColumnSpan="2" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,2,10,2"/>
                        <TextBlock x:Name="TytulText" Text="Nowy kurs" Style="{StaticResource T.Title}"/>
                    </StackPanel>
                    <TextBlock x:Name="InfoText" DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Foreground="{StaticResource InkMuted}" FontSize="11" VerticalAlignment="Center" TextAlignment="Right"/>
                </DockPanel>

                <!-- Kierowca + Pojazd -->
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="KIEROWCA" Style="{StaticResource T.Section}" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="CmbKierowca" Width="210" Height="30" DisplayMemberPath="PelneNazwisko"
                                      IsEditable="True" IsTextSearchEnabled="True"/>
                            <Button Style="{StaticResource BtnIcon}" Tag="&#xE710;" Foreground="{StaticResource Accent}"
                                    Width="32" Height="30" Margin="5,0,0,0" Click="BtnNowyKierowca_Click" ToolTip="Nowy kierowca"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="POJAZD" Style="{StaticResource T.Section}" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="CmbPojazd" Width="180" Height="30" DisplayMemberPath="Opis"
                                      IsEditable="True" IsTextSearchEnabled="True"
                                      SelectionChanged="CmbPojazd_SelectionChanged"/>
                            <Button Style="{StaticResource BtnIcon}" Tag="&#xE710;" Foreground="{StaticResource Accent}"
                                    Width="32" Height="30" Margin="5,0,0,0" Click="BtnNowyPojazd_Click" ToolTip="Nowy pojazd"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Data + godziny + trasa -->
                <StackPanel Grid.Row="1" Grid.Column="1">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="DATA" Style="{StaticResource T.Section}" Margin="0,0,0,3"/>
                            <DatePicker x:Name="DataKursu" Width="120" Height="30" SelectedDateChanged="DataKursu_Changed"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,6,0">
                            <TextBlock Text="WYJAZD" Style="{StaticResource T.Section}" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtWyjazd" Width="60" Height="30" Text="06:00" VerticalContentAlignment="Center" TextAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="→" Foreground="{StaticResource InkMuted}" VerticalAlignment="Bottom" Margin="0,0,6,5" FontSize="15"/>
                        <StackPanel>
                            <TextBlock Text="POWRÓT" Style="{StaticResource T.Section}" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtPowrot" Width="60" Height="30" Text="18:00" VerticalContentAlignment="Center" TextAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="TRASA" Style="{StaticResource T.Section}" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="TxtTrasa" Width="270" Height="30" VerticalContentAlignment="Center"/>
                        <Button Content="auto" Style="{StaticResource BtnGhost}" Height="30" Margin="6,0,0,0"
                                Click="BtnAutoTrasa_Click" ToolTip="Złóż trasę z nazw klientów"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ PASEK PAKOWANIA ═══ -->
        <Border Grid.Row="1" Background="{StaticResource Surface}" Padding="18,10" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Border Height="24" Background="#EAEDF0" CornerRadius="12"/>
                    <Border x:Name="PaskoFill" Height="24" Background="#43a047" CornerRadius="12"
                            HorizontalAlignment="Left" Width="0"/>
                    <TextBlock x:Name="PaskoText" Text="0%" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontWeight="Bold" Foreground="#1F2733"/>
                </Grid>
                <TextBlock x:Name="PaletyText" Grid.Column="1" Text="0 / 33 palet" VerticalAlignment="Center"
                           Margin="16,0,0,0" FontWeight="SemiBold" Foreground="{StaticResource InkSecondary}"/>
            </Grid>
        </Border>

        <!-- ═══ ŁADUNKI (lewa) + WOLNE (prawa) ═══ -->
        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ŁADUNKI -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="12,9" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,1,8,1"/>
                                <TextBlock Text="ŁADUNKI W KURSIE" FontWeight="Bold" Foreground="{StaticResource InkPrimary}" FontSize="12.5" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <Button Content="Sortuj" Style="{StaticResource BtnGhost}" Click="BtnSortuj_Click" ToolTip="Sortuj po godzinie awizacji"/>
                                <Button Style="{StaticResource BtnIcon}" Tag="&#xE70E;" Width="32" Click="BtnGora_Click" ToolTip="W górę"/>
                                <Button Style="{StaticResource BtnIcon}" Tag="&#xE70D;" Width="32" Click="BtnDol_Click" ToolTip="W dół"/>
                                <Button Style="{StaticResource BtnIconDanger}" Tag="&#xE74D;" Width="32" Click="BtnUsunLadunek_Click" ToolTip="Usuń z kursu"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <DataGrid x:Name="LadunkiGrid" Margin="4" AllowDrop="True" MouseDoubleClick="LadunkiGrid_DoubleClick">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Edytuj uwagi" Click="MiEdytujUwagi_Click"/>
                                    <Separator/>
                                    <MenuItem Header="W górę" Click="BtnGora_Click"/>
                                    <MenuItem Header="W dół" Click="BtnDol_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Usuń z kursu" Click="BtnUsunLadunek_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Kolejnosc}" Width="38">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="Foreground" Value="#8A95A3"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Klient" Binding="{Binding NazwaDisplay}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#26323C"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Awiz." Binding="{Binding AwizacjaDisplay}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="Foreground" Value="{StaticResource Accent}"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Pojemniki" Binding="{Binding PojemnikiDisplay}" Width="86">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Uwagi" Binding="{Binding Uwagi}" Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#8A95A3"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <!-- strefa upuszczania ładunków -->
                        <Border x:Name="DropHintLad" Visibility="Collapsed" IsHitTestVisible="False"
                                Background="#1400838F" BorderBrush="{StaticResource Accent}" BorderThickness="2" CornerRadius="8" Margin="2">
                            <Border Background="{StaticResource Accent}" CornerRadius="6" Padding="14,8"
                                    VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Icon}" Text="&#xE70D;" Foreground="White" FontSize="14" Margin="0,0,7,0"/>
                                    <TextBlock Text="Upuść tutaj, aby dodać do kursu" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                </StackPanel>
                            </Border>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- WOLNE ZAMÓWIENIA -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="14,11" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,1,8,1"/>
                                <TextBlock Text="WOLNE ZAMÓWIENIA" FontWeight="Bold" Foreground="{StaticResource InkPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border DockPanel.Dock="Right" Background="{StaticResource AccentSoft}" CornerRadius="11" Padding="10,2" VerticalAlignment="Center">
                                <TextBlock x:Name="WolneCountText" Text="0" Foreground="{StaticResource AccentDark}" FontWeight="Bold"/>
                            </Border>
                        </DockPanel>
                    </Border>
                    <Border Grid.Row="1" Background="{StaticResource SurfaceAlt}" Padding="10,8" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource Surface}" CornerRadius="6" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Icon}" Text="&#xE721;" FontSize="13" Foreground="{StaticResource InkMuted}" Margin="0,0,5,0"/>
                                    <TextBox x:Name="TxtSzukaj" Width="120" Height="26" BorderThickness="0" Background="Transparent"
                                             VerticalContentAlignment="Center" TextChanged="TxtSzukaj_TextChanged"/>
                                </StackPanel>
                            </Border>
                            <RadioButton x:Name="RbUboj" Content="Ubój" IsChecked="True" Margin="10,0,8,0"
                                         VerticalAlignment="Center" GroupName="DataTyp" Checked="DataTyp_Changed"/>
                            <RadioButton x:Name="RbOdbior" Content="Odbiór" VerticalAlignment="Center"
                                         GroupName="DataTyp" Checked="DataTyp_Changed"/>
                            <Button Style="{StaticResource BtnIcon}" Tag="&#xE72C;" Width="30" Height="28"
                                    Margin="8,0,0,0" Click="BtnOdswiezWolne_Click" ToolTip="Odśwież"/>
                            <Button Style="{StaticResource BtnPrimary}" Padding="10,5" Margin="6,0,0,0" Click="BtnDodajWolne_Click" ToolTip="Dodaj zaznaczone do kursu">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Icon}" Text="&#xE710;" Foreground="White" FontSize="13" Margin="0,0,5,0"/>
                                    <TextBlock Text="Dodaj" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                    <ListBox x:Name="WolneGrid" Grid.Row="2" Margin="4" BorderThickness="0"
                             Background="Transparent" SelectionMode="Extended"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="WolneGrid_DoubleClick">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Dodaj do kursu" Click="BtnDodajWolne_Click"/>
                                <MenuItem Header="Odbiór własny (zdejmij z transportu)" Click="MiWlasnyOdbior_Click"/>
                                <Separator/>
                                <MenuItem Header="Odśwież" Click="BtnOdswiezWolne_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bd" Background="White" CornerRadius="6" Padding="8,6"
                                                    Margin="2,2" BorderBrush="#eceef2" BorderThickness="1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#F0F8F8"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#E0F2F1"/>
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="#80CBC4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="#EEF1F4" Padding="10,6" Margin="0,6,0,2" CornerRadius="4">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,0,8,0"/>
                                                <TextBlock Style="{StaticResource Icon}" Text="&#xE787;" FontSize="12" Foreground="{StaticResource Accent}" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Name, StringFormat='{}{0:dd.MM ddd}'}" Language="pl-PL"
                                                           FontWeight="Bold" Foreground="{StaticResource InkPrimary}" FontSize="12.5" VerticalAlignment="Center"/>
                                                <Border Background="{StaticResource AccentSoft}" CornerRadius="8" Padding="7,1" Margin="9,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ItemCount}" Foreground="{StaticResource AccentDark}" FontSize="10.5" FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Text="zam." Foreground="{StaticResource InkMuted}" FontSize="10.5" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{Binding Tooltip}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ctrl:AvatarControl Grid.Column="0" UserId="{Binding HandlowiecId}" DisplayName="{Binding Handlowiec}"
                                                        Diameter="30" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding KlientNazwa}" FontWeight="SemiBold" Foreground="#26323c"
                                                   FontSize="12.5" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding WolnePodtytul}" Foreground="#8893a0" FontSize="10.5" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Width="1" Background="#eceef2" Margin="9,4"/>
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="9,0,0,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding GodzAwizacji}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding OdbiorDisplay}" Foreground="#9aa0b0" FontSize="9.5" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,0,0">
                                            <Border Background="#ECEFF1" CornerRadius="3" Padding="5,1" Margin="0,0,4,0">
                                                <TextBlock Text="{Binding PojemnikiDisplay}" FontSize="10" Foreground="#546E7A" FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Background="#ECEFF1" CornerRadius="3" Padding="5,1">
                                                <TextBlock Text="{Binding PaletyDisplay, StringFormat='{}{0} pal'}" FontSize="10" Foreground="#546E7A" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ PRZYCISKI ═══ -->
        <Border Grid.Row="3" Background="{StaticResource Surface}" Padding="16,12" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="StatusText" Foreground="{StaticResource InkMuted}" FontSize="11.5" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="Anuluj" Style="{StaticResource BtnGhost}" Width="110" Height="40" Margin="0,0,10,0" Click="BtnAnuluj_Click"/>
                    <Button x:Name="BtnZapisz" Style="{StaticResource BtnPrimary}" Width="190" Height="40" FontSize="14" Click="BtnZapisz_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="&#xE8FB;" Foreground="White" FontSize="15" Margin="0,0,8,0"/>
                            <TextBlock Text="ZAPISZ KURS" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
