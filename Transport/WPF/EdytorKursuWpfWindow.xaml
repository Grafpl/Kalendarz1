<Window x:Class="Kalendarz1.Transport.WPF.EdytorKursuWpfWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:Kalendarz1.Transport.WPF.Controls"
        Title="Edytor kursu (WPF)" Height="840" Width="1300"
        MinHeight="650" MinWidth="1060"
        WindowStartupLocation="CenterOwner"
        Background="#eef1f5" FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/Kalendarz1;component/Transport/WPF/Theme/TransportWpfStyles.xaml"/>
        </ResourceDictionary.MergedDictionaries>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.85"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#f6f8fa"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="RowHeight" Value="30"/>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- packing -->
            <RowDefinition Height="*"/>      <!-- ladunki + wolne -->
            <RowDefinition Height="Auto"/>   <!-- przyciski -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#2b2d42" Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.ColumnSpan="2" Margin="0,0,0,10">
                    <TextBlock x:Name="TytulText" Text="🚚 Nowy kurs" Foreground="White" FontSize="17" FontWeight="Bold"/>
                    <TextBlock x:Name="InfoText" DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Foreground="#9aa0b8" FontSize="11" VerticalAlignment="Center" TextAlignment="Right"/>
                </DockPanel>

                <!-- Kierowca + Pojazd -->
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="KIEROWCA" Foreground="#9aa0b8" FontSize="10.5" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="CmbKierowca" Width="210" Height="30" DisplayMemberPath="PelneNazwisko"
                                      IsEditable="True" IsTextSearchEnabled="True"/>
                            <Button Content="＋" Style="{StaticResource Btn}" Background="#2e7d32" Foreground="White"
                                    Width="32" Height="30" Margin="6,0,0,0" Click="BtnNowyKierowca_Click" ToolTip="Nowy kierowca"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="POJAZD" Foreground="#9aa0b8" FontSize="10.5" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="CmbPojazd" Width="180" Height="30" DisplayMemberPath="Opis"
                                      IsEditable="True" IsTextSearchEnabled="True"
                                      SelectionChanged="CmbPojazd_SelectionChanged"/>
                            <Button Content="＋" Style="{StaticResource Btn}" Background="#00838f" Foreground="White"
                                    Width="32" Height="30" Margin="6,0,0,0" Click="BtnNowyPojazd_Click" ToolTip="Nowy pojazd"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Data + godziny + trasa -->
                <StackPanel Grid.Row="1" Grid.Column="1">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="DATA" Foreground="#9aa0b8" FontSize="10.5" FontWeight="SemiBold" Margin="0,0,0,3"/>
                            <DatePicker x:Name="DataKursu" Width="120" Height="30" SelectedDateChanged="DataKursu_Changed"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,6,0">
                            <TextBlock Text="WYJAZD" Foreground="#9aa0b8" FontSize="10.5" FontWeight="SemiBold" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtWyjazd" Width="60" Height="30" Text="06:00" VerticalContentAlignment="Center" TextAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="→" Foreground="#9aa0b8" VerticalAlignment="Bottom" Margin="0,0,6,6" FontSize="15"/>
                        <StackPanel>
                            <TextBlock Text="POWRÓT" Foreground="#9aa0b8" FontSize="10.5" FontWeight="SemiBold" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtPowrot" Width="60" Height="30" Text="18:00" VerticalContentAlignment="Center" TextAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="TRASA" Foreground="#9aa0b8" FontSize="10.5" FontWeight="SemiBold" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="TxtTrasa" Width="270" Height="30" VerticalContentAlignment="Center"/>
                        <Button Content="auto" Style="{StaticResource Btn}" Background="#455a64" Foreground="White"
                                Height="30" Margin="6,0,0,0" Click="BtnAutoTrasa_Click" ToolTip="Złóż trasę z nazw klientów"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ PASEK PAKOWANIA ═══ -->
        <Border Grid.Row="1" Background="White" Padding="18,10" BorderBrush="#e4e6ea" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Border Height="26" Background="#e0e0e0" CornerRadius="13"/>
                    <Border x:Name="PaskoFill" Height="26" Background="#43a047" CornerRadius="13"
                            HorizontalAlignment="Left" Width="0"/>
                    <TextBlock x:Name="PaskoText" Text="0%" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontWeight="Bold" Foreground="#37474f"/>
                </Grid>
                <TextBlock x:Name="PaletyText" Grid.Column="1" Text="0 / 33 palet" VerticalAlignment="Center"
                           Margin="16,0,0,0" FontWeight="SemiBold" Foreground="#546e7a"/>
            </Grid>
        </Border>

        <!-- ═══ ŁADUNKI (lewa) + WOLNE (prawa) ═══ -->
        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ŁADUNKI -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="#e4e6ea" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#eceff1" Padding="12,8" CornerRadius="8,8,0,0">
                        <DockPanel>
                            <TextBlock Text="📦 Ładunki w kursie" FontWeight="Bold" Foreground="#37474f" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <Button Content="⇅ Sortuj" Style="{StaticResource Btn}" Background="#cfd8dc" Foreground="#37474f"
                                        Margin="2,0" Click="BtnSortuj_Click" ToolTip="Sortuj po godzinie awizacji"/>
                                <Button Content="▲" Style="{StaticResource Btn}" Background="#cfd8dc" Foreground="#37474f"
                                        Width="34" Margin="2,0" Click="BtnGora_Click" ToolTip="W górę"/>
                                <Button Content="▼" Style="{StaticResource Btn}" Background="#cfd8dc" Foreground="#37474f"
                                        Width="34" Margin="2,0" Click="BtnDol_Click" ToolTip="W dół"/>
                                <Button Content="✖ Usuń" Style="{StaticResource Btn}" Background="#c62828" Foreground="White"
                                        Margin="6,0,0,0" Click="BtnUsunLadunek_Click"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <DataGrid x:Name="LadunkiGrid" Grid.Row="1" AllowDrop="True"
                              MouseDoubleClick="LadunkiGrid_DoubleClick">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="✏ Edytuj uwagi" Click="MiEdytujUwagi_Click"/>
                                <Separator/>
                                <MenuItem Header="▲ W górę" Click="BtnGora_Click"/>
                                <MenuItem Header="▼ W dół" Click="BtnDol_Click"/>
                                <Separator/>
                                <MenuItem Header="✖ Usuń z kursu" Click="BtnUsunLadunek_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Kolejnosc}" Width="40"/>
                            <DataGridTextColumn Header="Klient" Binding="{Binding NazwaDisplay}" Width="*"/>
                            <DataGridTextColumn Header="Awiz." Binding="{Binding AwizacjaDisplay}" Width="60"/>
                            <DataGridTextColumn Header="Pojemniki" Binding="{Binding PojemnikiDisplay}" Width="90"/>
                            <DataGridTextColumn Header="Uwagi" Binding="{Binding Uwagi}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- WOLNE ZAMÓWIENIA -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" BorderBrush="#e4e6ea" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#7b1fa2" Padding="12,8" CornerRadius="8,8,0,0">
                        <DockPanel>
                            <TextBlock Text="🧾 Wolne zamówienia" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock x:Name="WolneCountText" Text="0" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       Foreground="#e1bee7" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <Border Grid.Row="1" Background="#faf5fc" Padding="10,8" BorderBrush="#eee" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="TxtSzukaj" Width="160" Height="28" VerticalContentAlignment="Center"
                                     TextChanged="TxtSzukaj_TextChanged"/>
                            <RadioButton x:Name="RbUboj" Content="Ubój" IsChecked="True" Margin="12,0,6,0"
                                         VerticalAlignment="Center" GroupName="DataTyp" Checked="DataTyp_Changed"/>
                            <RadioButton x:Name="RbOdbior" Content="Odbiór" VerticalAlignment="Center"
                                         GroupName="DataTyp" Checked="DataTyp_Changed"/>
                            <Button Content="🔄" Style="{StaticResource Btn}" Background="#eceff1" Foreground="#546e7a"
                                    Margin="10,0,0,0" Click="BtnOdswiezWolne_Click" ToolTip="Odśwież"/>
                            <Button Content="⮕ Dodaj" Style="{StaticResource Btn}" Background="#2e7d32" Foreground="White"
                                    Margin="6,0,0,0" Click="BtnDodajWolne_Click"/>
                        </StackPanel>
                    </Border>
                    <ListBox x:Name="WolneGrid" Grid.Row="2" Margin="4" BorderThickness="0"
                             Background="Transparent" SelectionMode="Extended"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="WolneGrid_DoubleClick">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="⮕ Dodaj do kursu" Click="BtnDodajWolne_Click"/>
                                <MenuItem Header="🚗 Odbiór własny (zdejmij z transportu)" Click="MiWlasnyOdbior_Click"/>
                                <Separator/>
                                <MenuItem Header="🔄 Odśwież" Click="BtnOdswiezWolne_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bd" Background="White" CornerRadius="6" Padding="8,6"
                                                    Margin="2,2" BorderBrush="#eceef2" BorderThickness="1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#f7f1fb"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#ede7f6"/>
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="#b39ddb"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="#e8eaf6" Padding="10,6" Margin="0,6,0,2" CornerRadius="4">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="3" Background="#3949ab" CornerRadius="2" Margin="0,0,8,0"/>
                                                <TextBlock Text="📅" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding Name, StringFormat='{}{0:dd.MM ddd}'}" Language="pl-PL"
                                                           FontWeight="Bold" Foreground="#1a237e" FontSize="12.5" VerticalAlignment="Center"/>
                                                <Border Background="#c5cae9" CornerRadius="8" Padding="7,1" Margin="9,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ItemCount}" Foreground="#283593" FontSize="10.5" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{Binding Tooltip}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#ede7f6" CornerRadius="5" Padding="7,3"
                                            VerticalAlignment="Center" Margin="0,0,9,0" MinWidth="60">
                                        <StackPanel>
                                            <TextBlock Text="{Binding OdbiorDisplay}" Foreground="#5e35b1" FontWeight="SemiBold" FontSize="10" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding GodzAwizacji}" Foreground="#7b1fa2" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ctrl:AvatarControl Grid.Column="1" UserId="{Binding HandlowiecId}" DisplayName="{Binding Handlowiec}"
                                                        Diameter="34" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding KlientNazwa}" FontWeight="SemiBold" Foreground="#26323c"
                                                   FontSize="12.5" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding WolnePodtytul}" Foreground="#8893a0" FontSize="10.5" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0">
                                        <TextBlock HorizontalAlignment="Right" Text="{Binding PojemnikiDisplay}" FontWeight="Bold" FontSize="12.5" Foreground="#37474f"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="10.5" Foreground="#90a4ae" Text="{Binding PaletyDisplay, StringFormat='{}{0} pal.'}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ PRZYCISKI ═══ -->
        <Border Grid.Row="3" Background="White" Padding="16,12" BorderBrush="#e4e6ea" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="StatusText" Foreground="#90a4ae" FontSize="11.5" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="Anuluj" Style="{StaticResource Btn}" Background="#eceff1" Foreground="#546e7a"
                            Width="110" Height="40" Margin="0,0,10,0" Click="BtnAnuluj_Click"/>
                    <Button x:Name="BtnZapisz" Content="✔ ZAPISZ KURS" Style="{StaticResource Btn}"
                            Background="#2e7d32" Foreground="White" Width="180" Height="40" FontSize="14"
                            Click="BtnZapisz_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
