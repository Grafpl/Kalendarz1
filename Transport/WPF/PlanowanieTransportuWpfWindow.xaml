<Window x:Class="Kalendarz1.Transport.WPF.PlanowanieTransportuWpfWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:Kalendarz1.Transport.WPF.Controls"
        Title="Planowanie Transportu (WPF) — ZPSP" Height="860" Width="1480"
        MinHeight="640" MinWidth="1080"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="#eef1f5" FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/Kalendarz1;component/Transport/WPF/Theme/TransportWpfStyles.xaml"/>
        </ResourceDictionary.MergedDictionaries>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="13,7"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.85"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- toolbar -->
            <RowDefinition Height="Auto"/>   <!-- kpi -->
            <RowDefinition Height="*"/>      <!-- content -->
            <RowDefinition Height="Auto"/>   <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ TOOLBAR ═══ -->
        <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,9" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource BtnIcon}" Tag="&#xE76B;" Click="BtnPrev_Click" ToolTip="Poprzedni dzień (Ctrl+←)"/>
                    <DatePicker x:Name="DataKursu" Width="132" FontSize="13" VerticalAlignment="Center"
                                SelectedDateChanged="DataKursu_Changed" Margin="2,0"/>
                    <Button Style="{StaticResource BtnIcon}" Tag="&#xE76C;" Click="BtnNext_Click" ToolTip="Następny dzień (Ctrl+→)"/>
                    <Button Content="Dziś" Click="BtnDzis_Click" Style="{StaticResource BtnGhost}" Margin="4,0,0,0"/>
                    <TextBlock x:Name="DayNameText" Style="{StaticResource T.Data}" Foreground="{StaticResource Accent}"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource BtnPrimary}" Click="BtnNowy_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="&#xE710;" Foreground="White" FontSize="15" Margin="0,0,7,0"/>
                            <TextBlock Text="Nowy kurs" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnEdytuj" Style="{StaticResource BtnIcon}" Tag="&#xE70F;" Click="BtnEdytuj_Click"
                            IsEnabled="False" Margin="8,0,0,0" ToolTip="Edytuj kurs (Enter)"/>
                    <Button x:Name="BtnUsun" Style="{StaticResource BtnIconDanger}" Tag="&#xE74D;" Click="BtnUsun_Click"
                            IsEnabled="False" ToolTip="Usuń kurs (Delete)"/>
                    <Border Width="1" Background="{StaticResource Line}" Margin="8,4"/>
                    <Button Style="{StaticResource BtnIcon}" Tag="&#xE72C;" Click="BtnRefresh_Click" ToolTip="Odśwież (F5)"/>
                    <ToggleButton x:Name="TglAuto" Click="TglAuto_Click" Cursor="Hand" Background="Transparent"
                                  Foreground="{StaticResource InkSecondary}" VerticalAlignment="Center"
                                  ToolTip="Auto-odświeżanie co 45 s">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource Icon}" Text="&#xE72C;" FontSize="14" Foreground="{TemplateBinding Foreground}" Margin="0,0,5,0"/>
                                        <TextBlock Text="Auto" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12.5" Foreground="{TemplateBinding Foreground}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="{StaticResource HoverBg}"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ PASEK STANU DNIA ═══ -->
        <Border Grid.Row="1" Background="{StaticResource Surface}" Padding="18,8" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- filtr po prawej -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource SurfaceAlt}" CornerRadius="6" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="&#xE721;" FontSize="13" Foreground="{StaticResource InkMuted}" Margin="0,0,5,0"/>
                            <TextBox x:Name="TxtFiltrKursy" Width="150" Height="26" BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center" TextChanged="FiltrKursyTekst_Changed" ToolTip="Filtruj: trasa / kierowca / pojazd"/>
                        </StackPanel>
                    </Border>
                    <CheckBox x:Name="ChkWymaga" Content="tylko wymagające uwagi" Margin="12,0,0,0"
                              VerticalAlignment="Center" Foreground="{StaticResource WarnFg}" Click="FiltrKursy_Changed"/>
                </StackPanel>
                <!-- statystyki dnia -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock x:Name="KpiKursy" Text="0" FontSize="17" FontWeight="Bold" Foreground="{StaticResource InkPrimary}"/>
                        <TextBlock Text="KURSÓW" Style="{StaticResource T.Section}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock x:Name="KpiZKierowca" Text="0" FontSize="17" FontWeight="Bold" Foreground="{StaticResource OkFg}"/>
                        <TextBlock Text="Z KIEROWCĄ" Style="{StaticResource T.Section}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock x:Name="KpiBezZasobow" Text="0" FontSize="17" FontWeight="Bold" Foreground="{StaticResource WarnFg}"/>
                        <TextBlock Text="BEZ PRZYDZIAŁU" Style="{StaticResource T.Section}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock x:Name="KpiPalety" Text="0" FontSize="17" FontWeight="Bold" Foreground="{StaticResource InkPrimary}"/>
                        <TextBlock Text="PALET" Style="{StaticResource T.Section}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock x:Name="KpiWolne" Text="0" FontSize="17" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                        <TextBlock Text="WOLNYCH" Style="{StaticResource T.Section}"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ CONTENT: (kursy + podgląd) | wolne zamówienia ═══ -->
        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.9*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.15*" MinWidth="430"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEWA: lista kursów ── -->
            <Grid Grid.Column="0">
                <Border Background="White" CornerRadius="8" BorderBrush="#e4e6ea" BorderThickness="1">
                    <DataGrid x:Name="KursyGrid" Margin="4" AllowDrop="True"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              RowBackground="White"
                              BorderThickness="0" FontSize="12" IsReadOnly="True"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              SelectionChanged="KursyGrid_SelectionChanged"
                              MouseDoubleClick="KursyGrid_DoubleClick">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="{Binding RowBg}"/>
                                <Setter Property="Height" Value="46"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#eef3fb"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#d6e4ff"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="📝 Edytuj kurs" Click="BtnEdytuj_Click"/>
                                <MenuItem Header="🧑‍✈ Szybki przydział kierowcy/pojazdu" Click="MiPrzydzial_Click"/>
                                <Separator/>
                                <MenuItem Header="🗑 Usuń kurs" Click="BtnUsun_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Wyj." Binding="{Binding GodzWyjazduDisplay}" Width="54">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Kierowca" Binding="{Binding KierowcaDisplay}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{Binding KierowcaFg}"/><Setter Property="FontWeight" Value="{Binding KierowcaWaga}"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Pojazd" Binding="{Binding PojazdDisplay}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{Binding PojazdFg}"/><Setter Property="FontWeight" Value="{Binding PojazdWaga}"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Trasa" Binding="{Binding Trasa}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="TextTrimming" Value="CharacterEllipsis"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Pal" Binding="{Binding Pal}" Width="42">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Poj" Binding="{Binding Poj}" Width="50">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="KG" Binding="{Binding KgDisplay}" Width="66">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#37474f"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Wyp.%" Binding="{Binding WypDisplay}" Width="56">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="{Binding WypelnienieFg}"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Utworzył" Width="166">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <ctrl:AvatarControl UserId="{Binding UtworzylId}" DisplayName="{Binding UtworzylName}" Diameter="30" Margin="0,0,7,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding UtworzylName}" FontWeight="SemiBold" Foreground="#28323f" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding UtworzylDataDisplay}" Foreground="#8e9aa6" FontSize="10"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Handl." Width="138">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ToolTip="{Binding HandlowcyTooltip}">
                                            <ItemsControl ItemsSource="{Binding HandlowcyAvatars}" VerticalAlignment="Center">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <ctrl:AvatarControl UserId="{Binding Id}" DisplayName="{Binding Name}" Diameter="26" Margin="0,0,-7,0"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="{Binding HandlowcyText}" VerticalAlignment="Center" Margin="11,0,0,0" FontSize="11" Foreground="#37474f" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
                <TextBlock x:Name="KursyEmpty" Visibility="Collapsed" IsHitTestVisible="False"
                           Text="📭  Brak kursów na ten dzień.&#x0a;Dodaj nowy kurs lub przeciągnij tu wolne zamówienie."
                           Foreground="#90a4ae" FontSize="13.5" TextAlignment="Center"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- ── PRAWA: WOLNE ZAMÓWIENIA (wierne oryginałowi) ── -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" BorderBrush="#e4e6ea" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- header -->
                        <RowDefinition Height="Auto"/>   <!-- toolbar -->
                        <RowDefinition Height="*"/>      <!-- grid -->
                        <RowDefinition Height="Auto"/>   <!-- akcja -->
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#7b1fa2" Padding="14,10" CornerRadius="8,8,0,0">
                        <DockPanel>
                            <StackPanel>
                                <TextBlock Text="🧾 WOLNE ZAMÓWIENIA" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                <TextBlock x:Name="WolneSubtitle" Text="zamówienia bez przypisanego kursu"
                                           Foreground="#e1bee7" FontSize="10.5" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border DockPanel.Dock="Right" Background="#9c27b0" CornerRadius="12" Padding="10,3" VerticalAlignment="Center">
                                <TextBlock x:Name="WolneCountText" Text="0" Foreground="White" FontWeight="Bold"/>
                            </Border>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Background="#faf5fc" Padding="10,8" BorderBrush="#eee" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="TxtSzukaj" Width="150" Height="28" VerticalContentAlignment="Center"
                                         TextChanged="TxtSzukaj_TextChanged" ToolTip="Szukaj klient / handlowiec"/>
                                <RadioButton x:Name="RbUboj" Content="Ubój" IsChecked="True" Margin="12,0,6,0"
                                             VerticalAlignment="Center" GroupName="DataTyp" Checked="DataTyp_Changed"/>
                                <RadioButton x:Name="RbOdbior" Content="Odbiór" VerticalAlignment="Center"
                                             GroupName="DataTyp" Checked="DataTyp_Changed"/>
                                <Button Content="🔄" Style="{StaticResource Btn}" Background="#eceff1" Foreground="#546e7a"
                                        Margin="10,0,0,0" Click="BtnOdswiezWolne_Click" ToolTip="Odśwież wolne"/>
                            </StackPanel>
                            <TextBlock x:Name="WolneSuma" Text="" Foreground="#7b1fa2" FontSize="11" Margin="2,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <ListBox x:Name="WolneGrid" Grid.Row="2" Margin="4" BorderThickness="0"
                             Background="Transparent" SelectionMode="Extended"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="WolneGrid_DoubleClick">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="➕ Dodaj do zaznaczonego kursu" Click="BtnDodajDoKursu_Click"/>
                                <MenuItem Header="🚗 Odbiór własny (zdejmij z transportu)" Click="MiWlasnyOdbior_Click"/>
                                <Separator/>
                                <MenuItem Header="🔄 Odśwież" Click="BtnOdswiezWolne_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bd" Background="White" CornerRadius="6" Padding="8,6"
                                                    Margin="2,2" BorderBrush="#eceef2" BorderThickness="1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#f7f1fb"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#ede7f6"/>
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="#b39ddb"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="#e8eaf6" Padding="10,6" Margin="0,6,0,2" CornerRadius="4">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="3" Background="#3949ab" CornerRadius="2" Margin="0,0,8,0"/>
                                                <TextBlock Text="📅" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding Name, StringFormat='{}{0:dd.MM ddd}'}" Language="pl-PL"
                                                           FontWeight="Bold" Foreground="#1a237e" FontSize="12.5" VerticalAlignment="Center"/>
                                                <Border Background="#c5cae9" CornerRadius="8" Padding="7,1" Margin="9,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ItemCount}" Foreground="#283593" FontSize="10.5" FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Text="zam." Foreground="#5c6bc0" FontSize="10.5" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{Binding Tooltip}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ctrl:AvatarControl Grid.Column="0" UserId="{Binding HandlowiecId}" DisplayName="{Binding Handlowiec}"
                                                        Diameter="30" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding KlientNazwa}" FontWeight="SemiBold" Foreground="#26323c"
                                                   FontSize="12.5" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding WolnePodtytul}" Foreground="#8893a0" FontSize="10.5" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Width="1" Background="#eceef2" Margin="9,4"/>
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="9,0,0,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="🕐" FontSize="10" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding GodzAwizacji}" FontWeight="Bold" FontSize="12.5" Foreground="#7b1fa2" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding OdbiorDisplay}" Foreground="#9aa0b0" FontSize="9.5" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,0,0">
                                            <Border Background="#e8f0fe" CornerRadius="3" Padding="5,1" Margin="0,0,4,0">
                                                <TextBlock Text="{Binding PojemnikiDisplay}" FontSize="10" Foreground="#1967d2" FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Background="#fef3e0" CornerRadius="3" Padding="5,1">
                                                <TextBlock Text="{Binding PaletyDisplay, StringFormat='{}{0} pal'}" FontSize="10" Foreground="#b06000" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Grid.Row="2" x:Name="WolneEmpty" Visibility="Collapsed" IsHitTestVisible="False"
                               Text="✅  Brak wolnych zamówień.&#x0a;Wszystko przypisane do kursów."
                               Foreground="#9575cd" FontSize="13" TextAlignment="Center"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <Border Grid.Row="3" Background="#faf5fc" Padding="10,8" BorderBrush="#eee" BorderThickness="0,1,0,0">
                        <DockPanel>
                            <TextBlock x:Name="DodajHint" DockPanel.Dock="Top" Foreground="#9575cd" FontSize="10.5"
                                       Text="Wybierz kurs po lewej, zaznacz zamówienia i kliknij Dodaj" Margin="0,0,0,6"/>
                            <Button x:Name="BtnDodajDoKursu" Content="➕ Dodaj do zaznaczonego kursu"
                                    Style="{StaticResource Btn}" Background="#2e7d32" Foreground="White"
                                    Height="36" IsEnabled="False" Click="BtnDodajDoKursu_Click"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="3" Background="White" Padding="16,6" BorderBrush="#e4e6ea" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="StatusText" Foreground="#78909c" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="💡 Dwuklik na kurs = edycja · dwuklik na wolne = dodaj do wybranego kursu"
                           Foreground="#b0bec5" FontSize="11" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
