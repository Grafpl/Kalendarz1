<Window x:Class="Kalendarz1.Transport.WPF.PlanowanieTransportuWpfWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:Kalendarz1.Transport.WPF.Controls"
        Title="Planowanie Transportu (WPF) — ZPSP" Height="860" Width="1480"
        MinHeight="640" MinWidth="1080"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="#F4F6F8" FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/Kalendarz1;component/Transport/WPF/Theme/TransportWpfStyles.xaml"/>
        </ResourceDictionary.MergedDictionaries>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="13,7"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.85"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="440"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════ LEWA: top + lista kursów ═══════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- top card -->
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>      <!-- kursy -->
                <RowDefinition Height="Auto"/>   <!-- status -->
            </Grid.RowDefinitions>

            <!-- ── TOP CARD: nawigacja + akcje + statystyki (skrócone) ── -->
            <Border Grid.Row="0" Style="{StaticResource Card}">
                <StackPanel>
                    <DockPanel Margin="12,7">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource BtnIcon}" Tag="&#xE76B;" Click="BtnPrev_Click" ToolTip="Poprzedni dzień"/>
                            <DatePicker x:Name="DataKursu" Width="132" FontSize="13" VerticalAlignment="Center"
                                        SelectedDateChanged="DataKursu_Changed" Margin="2,0"/>
                            <Button Style="{StaticResource BtnIcon}" Tag="&#xE76C;" Click="BtnNext_Click" ToolTip="Następny dzień"/>
                            <Button Content="Dziś" Click="BtnDzis_Click" Style="{StaticResource BtnGhost}" Margin="4,0,0,0"/>
                            <TextBlock x:Name="DayNameText" Style="{StaticResource T.Data}" Foreground="{StaticResource Accent}"
                                       VerticalAlignment="Center" Margin="16,0,18,0"/>
                            <Border Background="{StaticResource SurfaceAlt}" CornerRadius="6" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="2" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton x:Name="TglWidokLista" Content="Lista" IsChecked="True" Click="WidokLista_Click" Style="{StaticResource SegToggle}"/>
                                    <ToggleButton x:Name="TglWidokTimeline" Content="Timeline" Click="WidokTimeline_Click" Style="{StaticResource SegToggle}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Style="{StaticResource BtnPrimary}" Click="BtnNowy_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Icon}" Text="&#xE710;" Foreground="White" FontSize="15" Margin="0,0,7,0"/>
                                    <TextBlock Text="Nowy kurs" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnEdytuj" Style="{StaticResource BtnIcon}" Tag="&#xE70F;" Click="BtnEdytuj_Click"
                                    IsEnabled="False" Margin="8,0,0,0" ToolTip="Edytuj kurs (Enter)"/>
                            <Button x:Name="BtnUsun" Style="{StaticResource BtnIconDanger}" Tag="&#xE74D;" Click="BtnUsun_Click"
                                    IsEnabled="False" ToolTip="Usuń kurs (Delete)"/>
                            <Border Width="1" Background="{StaticResource Line}" Margin="8,4"/>
                            <Button Style="{StaticResource BtnIcon}" Tag="&#xE72C;" Click="BtnRefresh_Click" ToolTip="Odśwież (F5)"/>
                            <ToggleButton x:Name="TglAuto" Click="TglAuto_Click" Cursor="Hand" Background="Transparent"
                                          Foreground="{StaticResource InkSecondary}" VerticalAlignment="Center"
                                          ToolTip="Auto-odświeżanie co 45 s">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource Icon}" Text="&#xE72C;" FontSize="14" Foreground="{TemplateBinding Foreground}" Margin="0,0,5,0"/>
                                                <TextBlock Text="Auto" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12.5" Foreground="{TemplateBinding Foreground}"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="{StaticResource HoverBg}"/></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </StackPanel>
                    </DockPanel>
                    <Border Height="1" Background="{StaticResource Line}"/>
                    <DockPanel Margin="14,6">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{StaticResource SurfaceAlt}" CornerRadius="6" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Icon}" Text="&#xE721;" FontSize="13" Foreground="{StaticResource InkMuted}" Margin="0,0,5,0"/>
                                    <TextBox x:Name="TxtFiltrKursy" Width="150" Height="26" BorderThickness="0" Background="Transparent"
                                             VerticalContentAlignment="Center" TextChanged="FiltrKursyTekst_Changed" ToolTip="Filtruj: trasa / kierowca / pojazd"/>
                                </StackPanel>
                            </Border>
                            <CheckBox x:Name="ChkWymaga" Content="tylko wymagające uwagi" Margin="12,0,0,0"
                                      VerticalAlignment="Center" Foreground="{StaticResource WarnFg}" Click="FiltrKursy_Changed"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Margin="0,0,22,0">
                                <TextBlock x:Name="KpiKursy" Text="0" FontSize="16" FontWeight="Bold" Foreground="{StaticResource InkPrimary}"/>
                                <TextBlock Text="KURSÓW" Style="{StaticResource T.Section}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,22,0">
                                <TextBlock x:Name="KpiZKierowca" Text="0" FontSize="16" FontWeight="Bold" Foreground="{StaticResource OkFg}"/>
                                <TextBlock Text="Z KIEROWCĄ" Style="{StaticResource T.Section}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,22,0">
                                <TextBlock x:Name="KpiBezZasobow" Text="0" FontSize="16" FontWeight="Bold" Foreground="{StaticResource WarnFg}"/>
                                <TextBlock Text="BEZ PRZYDZIAŁU" Style="{StaticResource T.Section}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,22,0">
                                <TextBlock x:Name="KpiPalety" Text="0" FontSize="16" FontWeight="Bold" Foreground="{StaticResource InkPrimary}"/>
                                <TextBlock Text="PALET" Style="{StaticResource T.Section}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock x:Name="KpiWolne" Text="0" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                                <TextBlock Text="WOLNYCH" Style="{StaticResource T.Section}"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ── KURSY (Lista) / TIMELINE ── -->
            <Grid Grid.Row="2">
                <Grid x:Name="PanelLista">
                <Border Style="{StaticResource Card}">
                    <DataGrid x:Name="KursyGrid" Margin="2,4,4,4" AllowDrop="True"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F0F2F4" RowBackground="White"
                              BorderThickness="0" FontSize="12" IsReadOnly="True"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              SelectionChanged="KursyGrid_SelectionChanged"
                              MouseDoubleClick="KursyGrid_DoubleClick">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="{Binding RowBg}"/>
                                <Setter Property="Height" Value="48"/>
                                <Setter Property="ToolTip" Value="{Binding WierszTooltip}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type DataGridRow}">
                                            <Border x:Name="rb" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Rectangle Grid.Column="0" Fill="{Binding StatusAccent}"/>
                                                    <DataGridCellsPresenter Grid.Column="1"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="rb" Property="Background" Value="#F0F4F5"/></Trigger>
                                                <Trigger Property="IsSelected" Value="True"><Setter TargetName="rb" Property="Background" Value="#D2EEF0"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Edytuj kurs" Click="BtnEdytuj_Click"/>
                                <MenuItem Header="Szybki przydział kierowcy/pojazdu" Click="MiPrzydzial_Click"/>
                                <Separator/>
                                <MenuItem Header="Usuń kurs" Click="BtnUsun_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Wyj." Binding="{Binding GodzWyjazduDisplay}" Width="56">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="13"/><Setter Property="Foreground" Value="#1F2733"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Kierowca / pojazd" Width="158">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource Icon}" Text="&#xE77B;" FontSize="11.5" Foreground="{Binding KierowcaFg}" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding KierowcaDisplay}" Foreground="{Binding KierowcaFg}" FontWeight="{Binding KierowcaWaga}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Style="{StaticResource Icon}" Text="&#xE804;" FontSize="11.5" Foreground="{Binding PojazdFg}" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding PojazdDisplay}" Foreground="{Binding PojazdFg}" FontWeight="{Binding PojazdWaga}" FontSize="11.5" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Trasa" Binding="{Binding Trasa}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="TextTrimming" Value="CharacterEllipsis"/><Setter Property="FontSize" Value="12.5"/><Setter Property="Foreground" Value="#1F2733"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Ładunek" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding LadunekLinia1}" FontSize="12.5" FontWeight="SemiBold" Foreground="#37474F"/>
                                            <TextBlock Text="{Binding KgDisplay2}" FontSize="11" Foreground="#8A95A3"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Wypełnienie" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding WypDisplay}" FontWeight="Bold" FontSize="13" Foreground="{Binding WypelnienieFg}"/>
                                            <Border Width="78" Height="5" Background="#EAEDF0" CornerRadius="2.5" Margin="0,3,0,0" HorizontalAlignment="Left">
                                                <Border Background="{Binding WypelnienieFg}" CornerRadius="2.5" HorizontalAlignment="Left" Width="{Binding WypBarWidth}"/>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Handl." Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ToolTip="{Binding HandlowcyTooltip}">
                                            <ItemsControl ItemsSource="{Binding HandlowcyAvatars}" VerticalAlignment="Center">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <ctrl:AvatarControl UserId="{Binding Id}" DisplayName="{Binding Name}" Diameter="26" Margin="0,0,-7,0"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="{Binding HandlowcyText}" VerticalAlignment="Center" Margin="11,0,0,0" FontSize="10.5" Foreground="#546e7a" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Aktywność" Width="180" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ToolTip="{Binding WierszTooltip}">
                                            <!-- stacked avatars: twórca (duży) + modyfikator (mały, prawy-dolny róg) -->
                                            <Grid Width="34" Height="34" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <ctrl:AvatarControl UserId="{Binding UtworzylId}" DisplayName="{Binding UtworzylName}"
                                                                    Diameter="32" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                                <Border Visibility="{Binding ZmienilVis}" Width="20" Height="20"
                                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                        Background="White" CornerRadius="10" Margin="0,0,-2,-2"
                                                        ToolTip="{Binding ZmienilDisplay}">
                                                    <ctrl:AvatarControl UserId="{Binding ZmienilId}" DisplayName="{Binding ZmienilName}" Diameter="16"/>
                                                </Border>
                                            </Grid>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding UtworzylDisplay}" FontSize="11" Foreground="#37474F"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                                                <TextBlock Text="{Binding ZmienilDisplay}" Visibility="{Binding ZmienilVis}"
                                                           FontSize="10" Foreground="{StaticResource InkMuted}"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="130" Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
                <TextBlock x:Name="KursyEmpty" Visibility="Collapsed" IsHitTestVisible="False"
                           Text="Brak kursów na ten dzień.&#x0a;Dodaj nowy kurs lub przeciągnij tu wolne zamówienie."
                           Foreground="#90a4ae" FontSize="13.5" TextAlignment="Center"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <!-- strefa upuszczania (widoczna podczas przeciągania wolnego zamówienia) -->
                <Border x:Name="DropHint" Visibility="Collapsed" IsHitTestVisible="False"
                        Background="#1400838F" BorderBrush="{StaticResource Accent}" BorderThickness="2" CornerRadius="10">
                    <Border Background="{StaticResource Accent}" CornerRadius="6" Padding="16,9"
                            VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="&#xE70D;" Foreground="White" FontSize="14" Margin="0,0,7,0"/>
                            <TextBlock Text="Upuść na kurs, aby przypisać" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </Border>
                </Grid>
                <ContentControl x:Name="PanelTimeline" Visibility="Collapsed"/>
            </Grid>

            <!-- ── STATUS ── -->
            <DockPanel Grid.Row="3" Margin="6,7,6,0">
                <TextBlock x:Name="StatusText" Foreground="{StaticResource InkMuted}" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="Dwuklik na kurs = edycja · przeciągnij wolne zamówienie na kurs"
                           Foreground="#B0BEC5" FontSize="11" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
        </Grid>

        <!-- ═══════════════ PRAWA: WOLNE ZAMÓWIENIA (cała wysokość) ═══════════════ -->
        <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- header -->
                        <RowDefinition Height="Auto"/>   <!-- toolbar -->
                        <RowDefinition Height="*"/>      <!-- grid -->
                        <RowDefinition Height="Auto"/>   <!-- akcja -->
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="14,12" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                        <DockPanel>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,1,8,1"/>
                                    <TextBlock Text="WOLNE ZAMÓWIENIA" Foreground="{StaticResource InkPrimary}" FontWeight="Bold" FontSize="13.5"/>
                                </StackPanel>
                                <TextBlock x:Name="WolneSubtitle" Text="bez przypisanego kursu — przeciągnij na kurs"
                                           Foreground="{StaticResource InkMuted}" FontSize="10.5" Margin="11,2,0,0"/>
                            </StackPanel>
                            <Border DockPanel.Dock="Right" Background="{StaticResource AccentSoft}" CornerRadius="11" Padding="11,3" VerticalAlignment="Center">
                                <TextBlock x:Name="WolneCountText" Text="0" Foreground="{StaticResource AccentDark}" FontWeight="Bold" FontSize="13"/>
                            </Border>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource SurfaceAlt}" Padding="10,8" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{StaticResource Surface}" CornerRadius="6" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource Icon}" Text="&#xE721;" FontSize="13" Foreground="{StaticResource InkMuted}" Margin="0,0,5,0"/>
                                        <TextBox x:Name="TxtSzukaj" Width="138" Height="26" BorderThickness="0" Background="Transparent"
                                                 VerticalContentAlignment="Center" TextChanged="TxtSzukaj_TextChanged" ToolTip="Szukaj klient / handlowiec"/>
                                    </StackPanel>
                                </Border>
                                <RadioButton x:Name="RbUboj" Content="Ubój" IsChecked="True" Margin="12,0,8,0"
                                             VerticalAlignment="Center" GroupName="DataTyp" Checked="DataTyp_Changed"/>
                                <RadioButton x:Name="RbOdbior" Content="Odbiór" VerticalAlignment="Center"
                                             GroupName="DataTyp" Checked="DataTyp_Changed"/>
                                <Button Style="{StaticResource BtnIcon}" Tag="&#xE72C;" Width="30" Height="28"
                                        Margin="8,0,0,0" Click="BtnOdswiezWolne_Click" ToolTip="Odśwież wolne"/>
                            </StackPanel>
                            <TextBlock x:Name="WolneSuma" Text="" Foreground="{StaticResource InkMuted}" FontSize="11" Margin="2,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <ListBox x:Name="WolneGrid" Grid.Row="2" Margin="4" BorderThickness="0"
                             Background="Transparent" SelectionMode="Extended"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="WolneGrid_DoubleClick">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="➕ Dodaj do zaznaczonego kursu" Click="BtnDodajDoKursu_Click"/>
                                <MenuItem Header="🚗 Odbiór własny (zdejmij z transportu)" Click="MiWlasnyOdbior_Click"/>
                                <Separator/>
                                <MenuItem Header="🔄 Odśwież" Click="BtnOdswiezWolne_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bd" Background="White" CornerRadius="6" Padding="8,6"
                                                    Margin="2,2" BorderBrush="#eceef2" BorderThickness="1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#f7f1fb"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#ede7f6"/>
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="#b39ddb"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="#EEF1F4" Padding="10,6" Margin="0,6,0,2" CornerRadius="4">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,0,8,0"/>
                                                <TextBlock Style="{StaticResource Icon}" Text="&#xE787;" FontSize="12" Foreground="{StaticResource Accent}" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Name, StringFormat='{}{0:dd.MM ddd}'}" Language="pl-PL"
                                                           FontWeight="Bold" Foreground="{StaticResource InkPrimary}" FontSize="12.5" VerticalAlignment="Center"/>
                                                <Border Background="{StaticResource AccentSoft}" CornerRadius="8" Padding="7,1" Margin="9,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ItemCount}" Foreground="{StaticResource AccentDark}" FontSize="10.5" FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Text="zam." Foreground="{StaticResource InkMuted}" FontSize="10.5" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ToolTip="{Binding Tooltip}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ctrl:AvatarControl Grid.Column="0" UserId="{Binding HandlowiecId}" DisplayName="{Binding Handlowiec}"
                                                        Diameter="30" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding KlientNazwa}" FontWeight="SemiBold" Foreground="#26323c"
                                                   FontSize="12.5" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding WolnePodtytul}" Foreground="#8893a0" FontSize="10.5" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Width="1" Background="#eceef2" Margin="9,4"/>
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="9,0,0,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding GodzAwizacji}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding OdbiorDisplay}" Foreground="#9aa0b0" FontSize="9.5" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,0,0">
                                            <Border Background="#ECEFF1" CornerRadius="3" Padding="5,1" Margin="0,0,4,0">
                                                <TextBlock Text="{Binding PojemnikiDisplay}" FontSize="10" Foreground="#546E7A" FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Background="#ECEFF1" CornerRadius="3" Padding="5,1">
                                                <TextBlock Text="{Binding PaletyDisplay, StringFormat='{}{0} pal'}" FontSize="10" Foreground="#546E7A" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Grid.Row="2" x:Name="WolneEmpty" Visibility="Collapsed" IsHitTestVisible="False"
                               Text="✅  Brak wolnych zamówień.&#x0a;Wszystko przypisane do kursów."
                               Foreground="#9575cd" FontSize="13" TextAlignment="Center"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <Border Grid.Row="3" Background="{StaticResource SurfaceAlt}" Padding="10,8" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" CornerRadius="0,0,10,10">
                        <DockPanel>
                            <TextBlock x:Name="DodajHint" DockPanel.Dock="Top" Foreground="{StaticResource InkMuted}" FontSize="10.5"
                                       Text="Wybierz kurs po lewej, zaznacz zamówienia i kliknij Dodaj" Margin="0,0,0,6"/>
                            <Button x:Name="BtnDodajDoKursu" Style="{StaticResource BtnPrimary}" Height="38"
                                    IsEnabled="False" Click="BtnDodajDoKursu_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Icon}" Text="&#xE710;" Foreground="White" FontSize="14" Margin="0,0,7,0"/>
                                    <TextBlock Text="Dodaj do zaznaczonego kursu" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Window>
