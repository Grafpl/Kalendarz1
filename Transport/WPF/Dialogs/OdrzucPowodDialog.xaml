<Window x:Class="Kalendarz1.Transport.WPF.Dialogs.OdrzucPowodDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Odrzucenie zmiany" Height="320" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F4F6F8" FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kalendarz1;component/Transport/WPF/Theme/TransportWpfStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="ChipBtn" TargetType="Button">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#E5E8EB"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,4"/>
                <Setter Property="Margin" Value="0,0,6,6"/>
                <Setter Property="FontSize" Value="11.5"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Foreground" Value="#37474F"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#FFEEEE"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#C62828"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="White" CornerRadius="0" Margin="0">
        <Grid Margin="22,18,22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="✗" Foreground="#C62828" FontSize="20" FontWeight="Bold" Margin="0,0,8,0"/>
                <TextBlock Text="Odrzucenie zmiany" FontSize="16" FontWeight="SemiBold" Foreground="#26323c" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock x:Name="TxtKontekst" Grid.Row="1" Foreground="#5b6776" FontSize="11.5" Margin="0,0,0,14"/>

            <TextBlock Grid.Row="2" Text="SZYBKI POWÓD" FontSize="10" FontWeight="SemiBold" Foreground="#8893a0" Margin="0,0,0,6"/>
            <WrapPanel Grid.Row="3">
                <Button Content="Skontaktuję się z handlowcem" Click="BtnChip_Click" Style="{StaticResource ChipBtn}"/>
                <Button Content="Wymaga rozmowy z kierowcą" Click="BtnChip_Click" Style="{StaticResource ChipBtn}"/>
                <Button Content="Niezgodne z planem" Click="BtnChip_Click" Style="{StaticResource ChipBtn}"/>
                <Button Content="Pomyłka handlowca" Click="BtnChip_Click" Style="{StaticResource ChipBtn}"/>
            </WrapPanel>

            <TextBlock Grid.Row="4" Text="lub własny tekst (opcjonalnie):" FontSize="10.5" Foreground="#8893a0" Margin="0,10,0,4" VerticalAlignment="Top"/>
            <TextBox x:Name="TxtPowod" Grid.Row="4" Margin="0,24,0,0" Style="{StaticResource Input}" Height="56"
                     AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" Padding="8,5"/>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="Anuluj" Click="BtnAnuluj_Click" Style="{StaticResource BtnGhost}" Width="90" Height="34" Margin="0,0,8,0"/>
                <Button Content="✗ Odrzuć" Click="BtnOdrzuc_Click" Background="#C62828" Foreground="White" BorderBrush="#C62828" BorderThickness="1"
                        Width="120" Height="34" FontWeight="SemiBold" Cursor="Hand" IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
