<Window x:Class="Kalendarz1.Transport.WPF.Dialogs.NowyKierowcaWpfDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nowy kierowca" Height="290" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#f7f8fa" FontFamily="Segoe UI" FontSize="13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2563eb" Padding="18,14">
            <TextBlock Text="➕ Dodaj kierowcę" Foreground="White" FontSize="16" FontWeight="Bold"/>
        </Border>

        <StackPanel Grid.Row="1" Margin="22,18,22,10">
            <TextBlock Text="Imię *" Foreground="#546e7a" Margin="0,0,0,3"/>
            <TextBox x:Name="TxtImie" Padding="6,5" Margin="0,0,0,12"/>
            <TextBlock Text="Nazwisko *" Foreground="#546e7a" Margin="0,0,0,3"/>
            <TextBox x:Name="TxtNazwisko" Padding="6,5" Margin="0,0,0,12"/>
            <TextBlock Text="Telefon" Foreground="#546e7a" Margin="0,0,0,3"/>
            <TextBox x:Name="TxtTelefon" Padding="6,5"/>
        </StackPanel>

        <Border Grid.Row="2" Background="White" Padding="16,12" BorderBrush="#e4e6ea" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Anuluj" Width="90" Height="34" Margin="0,0,8,0"
                        Click="BtnAnuluj_Click" Background="#eceff1" BorderThickness="0" Cursor="Hand"/>
                <Button Content="✔ Zapisz" Width="110" Height="34"
                        Click="BtnZapisz_Click" Background="#2e7d32" Foreground="White"
                        FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
