<Window x:Class="Kalendarz1.Transport.WPF.Dialogs.NowyKierowcaWpfDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nowy kierowca" Height="300" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F4F6F8" FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kalendarz1;component/Transport/WPF/Theme/TransportWpfStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="18,14" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,1,10,1"/>
                <TextBlock Text="Nowy kierowca" Style="{StaticResource T.Title}" FontSize="16"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="22,16,22,10">
            <TextBlock Text="IMIĘ *" Style="{StaticResource T.Section}" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtImie" Padding="7,6" Margin="0,0,0,12"/>
            <TextBlock Text="NAZWISKO *" Style="{StaticResource T.Section}" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtNazwisko" Padding="7,6" Margin="0,0,0,12"/>
            <TextBlock Text="TELEFON" Style="{StaticResource T.Section}" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtTelefon" Padding="7,6"/>
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource Surface}" Padding="16,12" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Anuluj" Style="{StaticResource BtnGhost}" Width="90" Height="36" Margin="0,0,8,0" Click="BtnAnuluj_Click"/>
                <Button Style="{StaticResource BtnPrimary}" Width="120" Height="36" Click="BtnZapisz_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Icon}" Text="&#xE8FB;" Foreground="White" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="Zapisz" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
