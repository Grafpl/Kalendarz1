<Window x:Class="Kalendarz1.Transport.WPF.Dialogs.NowyPojazdWpfDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nowy pojazd" Height="350" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F4F6F8" FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kalendarz1;component/Transport/WPF/Theme/TransportWpfStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="18,14" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,1,10,1"/>
                <TextBlock Text="Nowy pojazd" Style="{StaticResource T.Title}" FontSize="16"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="22,16,22,10">
            <TextBlock Text="REJESTRACJA *" Style="{StaticResource T.Section}" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtRejestracja" Padding="7,6" Margin="0,0,0,12" CharacterCasing="Upper"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="MARKA" Style="{StaticResource T.Section}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtMarka" Padding="7,6"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="MODEL" Style="{StaticResource T.Section}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtModel" Padding="7,6"/>
                </StackPanel>
            </Grid>
            <TextBlock Text="LICZBA PALET (H1)" Style="{StaticResource T.Section}" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtPalety" Padding="7,6" Text="33"/>
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource Surface}" Padding="16,12" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Anuluj" Style="{StaticResource BtnGhost}" Width="90" Height="36" Margin="0,0,8,0" Click="BtnAnuluj_Click"/>
                <Button Style="{StaticResource BtnPrimary}" Width="120" Height="36" Click="BtnZapisz_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Icon}" Text="&#xE8FB;" Foreground="White" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="Zapisz" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
