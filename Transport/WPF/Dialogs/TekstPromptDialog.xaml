<Window x:Class="Kalendarz1.Transport.WPF.Dialogs.TekstPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edycja" Height="220" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#f7f8fa" FontFamily="Segoe UI" FontSize="13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#37474f" Padding="16,12">
            <TextBlock x:Name="TytulText" Text="Edycja" Foreground="White" FontSize="15" FontWeight="Bold"/>
        </Border>
        <StackPanel Grid.Row="1" Margin="20,16,20,8">
            <TextBlock x:Name="EtykietaText" Text="Wartość:" Foreground="#546e7a" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtWartosc" Padding="7,6" MinHeight="34" AcceptsReturn="True" TextWrapping="Wrap"/>
        </StackPanel>
        <Border Grid.Row="2" Background="White" Padding="16,12" BorderBrush="#e4e6ea" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Anuluj" Width="90" Height="34" Margin="0,0,8,0"
                        Click="BtnAnuluj_Click" Background="#eceff1" BorderThickness="0" Cursor="Hand"/>
                <Button Content="✔ OK" Width="100" Height="34" Click="BtnOk_Click"
                        Background="#2e7d32" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
