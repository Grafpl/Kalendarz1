<Window x:Class="Kalendarz1.Transport.WPF.Dialogs.TekstPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edycja" Height="230" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F4F6F8" FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kalendarz1;component/Transport/WPF/Theme/TransportWpfStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,13" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,1,10,1"/>
                <TextBlock x:Name="TytulText" Text="Edycja" Style="{StaticResource T.Title}" FontSize="15"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="1" Margin="20,14,20,8">
            <TextBlock x:Name="EtykietaText" Text="Wartość:" Style="{StaticResource T.Section}" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtWartosc" Padding="8,7" MinHeight="36" AcceptsReturn="True" TextWrapping="Wrap"/>
        </StackPanel>
        <Border Grid.Row="2" Background="{StaticResource Surface}" Padding="16,12" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Anuluj" Style="{StaticResource BtnGhost}" Width="90" Height="36" Margin="0,0,8,0" Click="BtnAnuluj_Click"/>
                <Button Style="{StaticResource BtnPrimary}" Width="110" Height="36" Click="BtnOk_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Icon}" Text="&#xE8FB;" Foreground="White" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="OK" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
