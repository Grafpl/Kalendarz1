<Window x:Class="Kalendarz1.Transport.WPF.Dialogs.SzybkiPrzydzialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Szybki przydział" Height="260" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F4F6F8" FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kalendarz1;component/Transport/WPF/Theme/TransportWpfStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,13" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,1,10,1"/>
                <TextBlock x:Name="TytulText" Text="Przydziel kierowcę i pojazd" Style="{StaticResource T.Title}" FontSize="15"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="1" Margin="20,16,20,8">
            <TextBlock Text="KIEROWCA" Style="{StaticResource T.Section}" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbKierowca" Height="32" DisplayMemberPath="PelneNazwisko"
                      IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,0,12"/>
            <TextBlock Text="POJAZD" Style="{StaticResource T.Section}" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbPojazd" Height="32" DisplayMemberPath="Opis"
                      IsEditable="True" IsTextSearchEnabled="True"/>
        </StackPanel>
        <Border Grid.Row="2" Background="{StaticResource Surface}" Padding="16,12" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Anuluj" Style="{StaticResource BtnGhost}" Width="90" Height="36" Margin="0,0,8,0" Click="BtnAnuluj_Click"/>
                <Button Style="{StaticResource BtnPrimary}" Width="130" Height="36" Click="BtnOk_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Icon}" Text="&#xE8FB;" Foreground="White" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="Przydziel" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
