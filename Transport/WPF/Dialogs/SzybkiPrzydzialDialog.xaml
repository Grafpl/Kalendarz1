<Window x:Class="Kalendarz1.Transport.WPF.Dialogs.SzybkiPrzydzialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Szybki przydział" Height="250" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#f7f8fa" FontFamily="Segoe UI" FontSize="13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#1565c0" Padding="16,12">
            <TextBlock x:Name="TytulText" Text="🧑‍✈ Przydziel kierowcę i pojazd" Foreground="White" FontSize="15" FontWeight="Bold"/>
        </Border>
        <StackPanel Grid.Row="1" Margin="20,16,20,8">
            <TextBlock Text="Kierowca" Foreground="#546e7a" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbKierowca" Height="32" DisplayMemberPath="PelneNazwisko"
                      IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,0,12"/>
            <TextBlock Text="Pojazd" Foreground="#546e7a" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbPojazd" Height="32" DisplayMemberPath="Opis"
                      IsEditable="True" IsTextSearchEnabled="True"/>
        </StackPanel>
        <Border Grid.Row="2" Background="White" Padding="16,12" BorderBrush="#e4e6ea" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Anuluj" Width="90" Height="34" Margin="0,0,8,0"
                        Click="BtnAnuluj_Click" Background="#eceff1" BorderThickness="0" Cursor="Hand"/>
                <Button Content="✔ Przydziel" Width="120" Height="34" Click="BtnOk_Click"
                        Background="#1565c0" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
