<Window x:Class="Kalendarz1.Transport.WPF.Windows.HistoriaZmianKursuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historia zmian kursu" Height="640" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8" FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kalendarz1;component/Transport/WPF/Theme/TransportWpfStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{StaticResource Card}" Margin="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="18,14" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                <DockPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="3" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,2,10,2"/>
                        <TextBlock Text="📜 Historia zmian kursu" Style="{StaticResource T.Title}"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtKursMeta" DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Foreground="{StaticResource InkMuted}" FontSize="11.5" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Background="{StaticResource SurfaceAlt}" Padding="14,9" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Filtruj status:" Foreground="{StaticResource InkMuted}" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <RadioButton x:Name="RbWszystkie" Content="Wszystkie" IsChecked="True" GroupName="StatF" Checked="Filtr_Changed" Margin="0,0,12,0"/>
                    <RadioButton x:Name="RbOczekuje" Content="Oczekuje" GroupName="StatF" Checked="Filtr_Changed" Margin="0,0,12,0"/>
                    <RadioButton x:Name="RbZaakcept" Content="Zaakceptowane" GroupName="StatF" Checked="Filtr_Changed" Margin="0,0,12,0"/>
                    <RadioButton x:Name="RbOdrzuc" Content="Odrzucone" GroupName="StatF" Checked="Filtr_Changed"/>
                    <TextBlock x:Name="TxtLicznik" Foreground="{StaticResource InkMuted}" FontSize="11" VerticalAlignment="Center" Margin="20,0,0,0"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="14,10">
                <ItemsControl x:Name="ListaHistorii">
                    <ItemsControl.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="#EEF1F4" Padding="10,5" Margin="0,8,0,4" CornerRadius="3">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="3" Background="#F59E0B" CornerRadius="2" Margin="0,0,8,0"/>
                                            <TextBlock Text="🏢" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#37474F" FontSize="12" VerticalAlignment="Center"/>
                                            <Border Background="#FFE9C0" CornerRadius="8" Padding="6,1" Margin="9,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ItemCount}" Foreground="#8A4A00" FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ItemsControl.GroupStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="#E5E8EB" BorderThickness="1" CornerRadius="5" Margin="0,0,0,4">
                                <Grid MinHeight="40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="{Binding StatusKolor}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TypEmoji}" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="{Binding TypLabel}"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="2,4,8,4">
                                        <TextBlock Text="{Binding TypLabel}" Foreground="{Binding AkcentBrush}"
                                                   FontWeight="SemiBold" FontSize="11.5" VerticalAlignment="Center" MaxWidth="170" TextTrimming="CharacterEllipsis"/>
                                        <Border Background="#F4F6F8" CornerRadius="3" Padding="5,1" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding Stare}" Foreground="#5b6776" FontSize="10.5" FontFamily="Consolas"/>
                                        </Border>
                                        <TextBlock Text="→" Foreground="#9aa0b0" Margin="4,0" VerticalAlignment="Center" FontSize="11"/>
                                        <Border Background="#E0F2F1" CornerRadius="3" Padding="5,1">
                                            <TextBlock Text="{Binding Nowa}" Foreground="#00695C" FontSize="10.5" FontFamily="Consolas" FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding ZglosilLinia}" Foreground="#8893a0" FontSize="10.5" HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding ZdecydowalLinia}" Foreground="#8893a0" FontSize="10.5" HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding KomentarzLinia}" Foreground="#8893a0" FontSize="10" HorizontalAlignment="Right"
                                                   FontStyle="Italic" MaxWidth="280" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Border Grid.Column="4" Background="{Binding StatusTloMiekkie}" CornerRadius="10" Padding="8,3"
                                            HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusKolor}" FontSize="10.5" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="3" Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="14,10" CornerRadius="0,0,10,10">
                <DockPanel>
                    <TextBlock x:Name="TxtStatus" Foreground="{StaticResource InkMuted}" FontSize="11" VerticalAlignment="Center"/>
                    <Button Content="Zamknij" Click="BtnZamknij_Click" DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Style="{StaticResource BtnGhost}" Width="120" Height="32"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
