<UserControl x:Class="Kalendarz1.Transport.WPF.Views.TimelineDniaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Kalendarz1.Transport.WPF.Controls"
             FontFamily="Segoe UI" Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Kalendarz1;component/Transport/WPF/Theme/TransportWpfStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- sterowanie -->
            <RowDefinition Height="Auto"/>   <!-- nagłówek godzin -->
            <RowDefinition Height="*"/>      <!-- wiersze -->
            <RowDefinition Height="Auto"/>   <!-- pasek drag -->
        </Grid.RowDefinitions>

        <!-- ── STEROWANIE ── -->
        <DockPanel Grid.Row="0" Margin="10,6,10,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="OŚ CZASU DNIA" Style="{StaticResource T.Section}" VerticalAlignment="Center"/>
                <TextBlock x:Name="NazwaDnia" Foreground="{StaticResource Accent}" FontWeight="SemiBold" FontSize="13" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox x:Name="ChkUkryjWolnych" Content="Ukryj kierowców bez kursu" VerticalAlignment="Center"
                          Foreground="{StaticResource InkSecondary}" Click="ChkUkryjWolnych_Click"/>
                <TextBlock Text="Zoom" Foreground="{StaticResource InkMuted}" FontSize="11" VerticalAlignment="Center" Margin="18,0,6,0"/>
                <Slider x:Name="ZoomSlider" Minimum="24" Maximum="64" Value="38" Width="120" VerticalAlignment="Center"
                        TickFrequency="2" IsSnapToTickEnabled="True" ValueChanged="ZoomSlider_Changed"/>
            </StackPanel>
        </DockPanel>

        <!-- ── NAGŁÓWEK GODZIN ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Line}" BorderThickness="0,1,1,1">
                <TextBlock Text="KIEROWCA" Style="{StaticResource T.Section}" VerticalAlignment="Center" Margin="14,0,0,0"/>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,1">
                <ScrollViewer x:Name="HeaderScroll" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                    <Canvas x:Name="HeaderCanvas" Height="26"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── BODY ── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ScrollViewer Grid.Column="0" x:Name="LeftScroll" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled"
                          BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0">
                <ItemsControl x:Name="LeftRows">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Height="50" Padding="12,4" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ctrl:AvatarControl DisplayName="{Binding PelneNazwisko}" Diameter="32" Margin="0,0,9,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding PelneNazwisko}" FontWeight="SemiBold" Foreground="{StaticResource InkPrimary}"
                                                   FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Foreground="{StaticResource InkMuted}" FontSize="10.5" TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding PojazdRej, Mode=OneWay}"/><Run Text="  ·  "/><Run Text="{Binding LiczbaKursow, Mode=OneWay}"/><Run Text=" kurs."/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <ScrollViewer Grid.Column="1" x:Name="MainScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          ScrollChanged="MainScroll_ScrollChanged">
                <Canvas x:Name="TimelineCanvas" Background="Transparent" AllowDrop="True"/>
            </ScrollViewer>
        </Grid>

        <!-- ── PASEK STATUSU DRAG ── -->
        <Border Grid.Row="3" x:Name="DragStatusBar" Visibility="Collapsed" Background="{StaticResource AccentSoft}"
                BorderBrush="{StaticResource Accent}" BorderThickness="0,1,0,0" Padding="14,7">
            <TextBlock x:Name="DragStatusText" Foreground="{StaticResource AccentDark}" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</UserControl>
