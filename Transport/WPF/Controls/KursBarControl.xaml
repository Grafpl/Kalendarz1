<UserControl x:Class="Kalendarz1.Transport.WPF.Controls.KursBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" SnapsToDevicePixels="True" Cursor="Hand">
    <Border x:Name="Pasek" CornerRadius="0,4,4,0" Padding="6,2" BorderThickness="3,0,0,0">
        <DockPanel LastChildFill="True">
            <Border x:Name="BadgeWypelnienie" DockPanel.Dock="Right" CornerRadius="8" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="TxtBadge" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
            </Border>
            <TextBlock x:Name="TxtTrasa" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
        </DockPanel>
        <Border.ToolTip>
            <ToolTip>
                <StackPanel MinWidth="190">
                    <TextBlock x:Name="TtTrasa" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock x:Name="TtCzas" Foreground="#5B6776" Margin="0,2,0,0"/>
                    <TextBlock x:Name="TtKP" Foreground="#5B6776"/>
                    <TextBlock x:Name="TtMetryki" Foreground="#5B6776"/>
                    <TextBlock x:Name="TtKonflikt" Foreground="#C62828" FontWeight="SemiBold" Visibility="Collapsed"/>
                    <TextBlock x:Name="TtUtw" Foreground="#8A95A3" FontSize="11" Margin="0,3,0,0"/>
                    <TextBlock x:Name="TtZmieniony" Foreground="#8A95A3" FontSize="11" Visibility="Collapsed"/>
                </StackPanel>
            </ToolTip>
        </Border.ToolTip>
    </Border>
</UserControl>
