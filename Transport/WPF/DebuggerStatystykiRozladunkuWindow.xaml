<Window x:Class="Kalendarz1.Transport.WPF.DebuggerStatystykiRozladunkuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔍 Debugger statystyk rozładunku — surowe dane"
        Width="1200" Height="800"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" FontSize="12"
        Background="#F3F4F6">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1F2937" CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="🔍 Debugger — co system widzi i czego nie wychwytuje"
                           FontSize="15" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Każda zakładka pobiera dane LIVE z 192.168.0.109 (LibraNet/TransportPL) i Webfleet API. Skopiuj raport (przycisk poniżej) i wklej w czacie z Claude."
                           FontSize="11" Foreground="#D1D5DB" Margin="0,3,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- TABS -->
        <TabControl Grid.Row="1" Background="White" BorderBrush="#E5E7EB">

            <!-- ════════════ ZAKŁADKA 1: INWENTARYZACJA ════════════ -->
            <TabItem Header="📋 1. Inwentaryzacja danych">
                <DockPanel Margin="12">
                    <Border DockPanel.Dock="Top" Background="#FEF3C7" BorderBrush="#FDE68A"
                            BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#78350F">
                            <Run FontWeight="Bold">Pokazuje liczby:</Run>
                            ile klientów z GPS, ile pojazdów zmapowanych do Webfleet, ile wpisów w EstymacjeRozladunku.
                            Jeśli „Klientów z GPS" = 0 → potrzeba geokodowania. Jeśli „Pojazdów z ObjectNo" = 0 → mapowanie WebfleetVehicleMapping nie zrobione.
                        </TextBlock>
                    </Border>

                    <Button DockPanel.Dock="Top" x:Name="BtnInwent" Content="▶ Uruchom inwentaryzację"
                            Padding="12,6" HorizontalAlignment="Left" Margin="0,0,0,10"
                            Background="#059669" Foreground="White" BorderThickness="0" Cursor="Hand"
                            FontWeight="SemiBold" Click="BtnInwent_Click"/>

                    <TextBox x:Name="TxtInwent" IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" Background="#0F172A" Foreground="#E2E8F0"
                             Padding="10" BorderThickness="0"
                             Text="(kliknij ▶ Uruchom inwentaryzację)"/>
                </DockPanel>
            </TabItem>

            <!-- ════════════ ZAKŁADKA 2: TEST 1 DNIA Z WEBFLEET ════════════ -->
            <TabItem Header="🛰️ 2. Webfleet — test 1 dnia">
                <DockPanel Margin="12">
                    <Border DockPanel.Dock="Top" Background="#DBEAFE" BorderBrush="#93C5FD"
                            BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#1E3A8A">
                            <Run FontWeight="Bold">Co robi:</Run>
                            Pobiera tracks z Webfleet dla wybranego pojazdu × dnia. Pokazuje wszystkie postoje (speed≤5),
                            dla każdego: najbliższy klient + odległość. Jeśli żaden klient nie jest bliżej niż 3,5 km → wizyty nie ma.
                            Postoje >3,5 km od jakiegokolwiek klienta to typowo: parkingi MOP, baza, korki, stacje paliw.
                        </TextBlock>
                    </Border>

                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Pojazd:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="CmbPojazd1" Grid.Column="1" Width="220" Padding="6,4" Margin="0,0,12,0"/>
                        <TextBlock Text="Data:" VerticalAlignment="Center" Margin="0,0,6,0" Grid.Column="2"/>
                        <DatePicker x:Name="DtData1" Grid.Column="3" Width="140" Margin="0,0,12,0"/>
                        <Button x:Name="BtnTestDzien" Grid.Column="4" Content="▶ Pobierz tracks + analizuj"
                                Padding="12,6" Background="#059669" Foreground="White" BorderThickness="0"
                                Cursor="Hand" FontWeight="SemiBold" Click="BtnTestDzien_Click"/>
                    </Grid>

                    <TextBox x:Name="TxtTestDzien" IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" Background="#0F172A" Foreground="#E2E8F0"
                             Padding="10" BorderThickness="0"
                             Text="(wybierz pojazd i datę, kliknij ▶)"/>
                </DockPanel>
            </TabItem>

            <!-- ════════════ ZAKŁADKA 3: DRILL KLIENTA ════════════ -->
            <TabItem Header="🎯 3. Drill konkretnego klienta">
                <DockPanel Margin="12">
                    <Border DockPanel.Dock="Top" Background="#FCE7F3" BorderBrush="#F9A8D4"
                            BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#831843">
                            <Run FontWeight="Bold">Co robi:</Run>
                            Sprawdza KONKRETNEGO klienta. Pyta Webfleet o tracks WSZYSTKICH pojazdów × wybrane dni
                            i pokazuje najbliższe podejście każdego pojazdu w okolicy klienta (do 10 km).
                            Jeśli nie było żadnego punktu GPS <![CDATA[<]]> 10 km — pojazdy w ogóle tam nie jeździły.
                            Jeśli były ale za daleko — GPS karty jest mocno nieaktualny.
                            Jeśli były blisko ale nie złapane jako wizyta → algorytm odrzucił (postój zbyt krótki/długi, poza godz. roboczymi).
                        </TextBlock>
                    </Border>

                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Klient:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="CmbKlient" Grid.Column="1" Padding="6,4" Margin="0,0,12,0"
                                  IsEditable="True" StaysOpenOnEdit="True"/>
                        <TextBlock Text="Dni wstecz:" VerticalAlignment="Center" Margin="0,0,6,0" Grid.Column="2"/>
                        <ComboBox x:Name="CmbDniWstecz" Grid.Column="3" Width="80" Padding="6,4" Margin="0,0,12,0">
                            <ComboBoxItem Content="7"/>
                            <ComboBoxItem Content="14"/>
                            <ComboBoxItem Content="30" IsSelected="True"/>
                            <ComboBoxItem Content="60"/>
                            <ComboBoxItem Content="90"/>
                        </ComboBox>
                        <Button x:Name="BtnDrill" Grid.Column="4" Content="▶ Sprawdź klienta"
                                Padding="12,6" Background="#DB2777" Foreground="White" BorderThickness="0"
                                Cursor="Hand" FontWeight="SemiBold" Click="BtnDrill_Click"/>
                    </Grid>

                    <TextBox x:Name="TxtDrill" IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" Background="#0F172A" Foreground="#E2E8F0"
                             Padding="10" BorderThickness="0"
                             Text="(wybierz klienta i kliknij ▶ — pobranie 30 dni × wszystkie pojazdy może zająć 2-5 min)"/>
                </DockPanel>
            </TabItem>

            <!-- ════════════ ZAKŁADKA 4: SKAN ZAKRESU ════════════ -->
            <TabItem Header="📅 4. Skan zakresu — wszystkie auta × wszyscy klienci">
                <DockPanel Margin="12">
                    <Border DockPanel.Dock="Top" Background="#D1FAE5" BorderBrush="#6EE7B7"
                            BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#065F46">
                            <Run FontWeight="Bold">Co robi:</Run>
                            Iteruje WSZYSTKIE zmapowane pojazdy × WSZYSTKIE dni w zakresie. Wykrywa wizyty u każdego klienta z GPS.
                            Pokazuje per pojazd × dzień: co zrobił + listę klientów + tabelę zbiorczą per klient z liczbą wizyt + medianą.
                            Na końcu: lista KLIENTÓW Z GPS których nikt nigdy nie odwiedził w tym zakresie.
                            <LineBreak/>
                            <Run FontStyle="Italic">Uwaga: 30 dni × 10 pojazdów = 300 zapytań do Webfleet, ~2–5 min.</Run>
                        </TextBlock>
                    </Border>

                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Od:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker x:Name="DtOd4" Grid.Column="1" Width="140" Margin="0,0,12,0"/>
                        <TextBlock Text="Do:" VerticalAlignment="Center" Margin="0,0,6,0" Grid.Column="2"/>
                        <DatePicker x:Name="DtDo4" Grid.Column="3" Width="140" Margin="0,0,12,0"/>
                        <Button x:Name="BtnSkanZakresu" Grid.Column="4" Content="▶ Skanuj zakres"
                                Padding="12,6" Background="#059669" Foreground="White" BorderThickness="0"
                                Cursor="Hand" FontWeight="SemiBold" Click="BtnSkanZakresu_Click"
                                Margin="0,0,8,0"/>
                        <Button x:Name="BtnCzyscCache" Grid.Column="5" Content="🗑 Wyczyść cache"
                                Padding="10,6" Background="#6B7280" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="BtnCzyscCache_Click" HorizontalAlignment="Left"
                                ToolTip="Wyczyść cache tracks w pamięci sesji (wymuś ponowne pobranie z API)"/>
                    </Grid>

                    <TextBox x:Name="TxtSkan" IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" Background="#0F172A" Foreground="#E2E8F0"
                             Padding="10" BorderThickness="0"
                             Text="(wybierz zakres dat i kliknij ▶)"/>
                </DockPanel>
            </TabItem>
        </TabControl>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="1"
                CornerRadius="6" Padding="12,8" Margin="0,10,0,0">
            <DockPanel>
                <TextBlock x:Name="TxtStatus" Text="Gotowy." VerticalAlignment="Center"
                           Foreground="#6B7280" FontSize="11"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnZapisz" Content="💾 Zapisz do pliku" Padding="12,6"
                            Background="#7C3AED" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Margin="0,0,8,0" Click="BtnZapisz_Click"
                            ToolTip="Zapisuje raport jako .txt w wybranej lokalizacji"/>
                    <Button x:Name="BtnKopiuj" Content="📋 Kopiuj raport" Padding="12,6"
                            Background="#3B82F6" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Margin="0,0,8,0" Click="BtnKopiuj_Click"
                            ToolTip="Kopiuje zawartość aktywnej zakładki do schowka"/>
                    <Button x:Name="BtnZamknij" Content="Zamknij" Padding="12,6"
                            Background="#E5E7EB" Foreground="#374151" BorderThickness="0" Cursor="Hand"
                            Click="BtnZamknij_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
