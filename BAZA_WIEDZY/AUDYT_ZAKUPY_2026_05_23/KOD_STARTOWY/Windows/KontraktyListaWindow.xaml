<!--
════════════════════════════════════════════════════════════════════════════
KontraktyListaWindow.xaml — główne okno listy kontraktów
Część 4 audytu (2026-05-23)
Target: Kontrakty/Windows/KontraktyListaWindow.xaml(.cs)

Wzorzec: jak SprawdzalkaUmowWindow.xaml (legacy "lista per dostawa") —
ale tutaj 1 wiersz = 1 kontrakt (encja w dbo.Kontrakty).
════════════════════════════════════════════════════════════════════════════
-->
<Window x:Class="Kalendarz1.Kontrakty.Windows.KontraktyListaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📜 Kontrakty Hodowców"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#5C8A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="ChipButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#ECEFF1"/>
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
        <Style x:Key="ChipActive" TargetType="Button" BasedOn="{StaticResource ChipButton}">
            <Setter Property="Background" Value="#5C8A3A"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- BANNER POD ASIĘ -->
        <Border DockPanel.Dock="Top" Background="#E3F2FD" BorderBrush="#1976D2"
                BorderThickness="0,0,0,2" Padding="14,10">
            <TextBlock Foreground="#1976D2" FontSize="12" TextWrapping="Wrap">
                💡 <Bold>Asia, to Twój moduł.</Bold> Filtruj statusy przez chipy → wybierz kontrakt → prawy klik na akcje.
                Pełna instrukcja: <Italic>BAZA_WIEDZY\INSTRUKCJE_ASIA\01_pierwszy_tydzien_straznika_kontraktow.md</Italic>
            </TextBlock>
        </Border>

        <!-- TOP TOOLBAR -->
        <Border DockPanel.Dock="Top" Background="White" Padding="14,10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="btnNowy" Content="➕ Nowy kontrakt" Style="{StaticResource PrimaryButton}"
                            Click="BtnNowy_Click" ToolTip="Ctrl+N"/>
                    <Button x:Name="btnPrzedluz" Content="🔄 Przedłuż" Style="{StaticResource PrimaryButton}"
                            Click="BtnPrzedluz_Click"/>
                    <Button x:Name="btnGenerujWord" Content="📄 Generuj Word" Style="{StaticResource PrimaryButton}"
                            Click="BtnGenerujWord_Click"/>
                    <Button x:Name="btnDodajSkan" Content="📎 Dodaj skan PDF" Style="{StaticResource PrimaryButton}"
                            Click="BtnDodajSkan_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="btnDashboardArimr" Content="🎯 Dashboard ARiMR"
                            Style="{StaticResource PrimaryButton}" Background="#1976D2"
                            Click="BtnDashboardArimr_Click"/>
                    <Button x:Name="btnExportArimr" Content="📤 Export PDF audytu"
                            Style="{StaticResource PrimaryButton}" Background="#607D8B"
                            Click="BtnExportArimr_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FILTRY -->
        <Border DockPanel.Dock="Top" Background="#FAFAFA" Padding="14,8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="txtSearch" Width="220" Padding="6,4" FontSize="12"
                             ToolTip="Szukaj po numerze lub nazwie hodowcy (Ctrl+F)"
                             TextChanged="TxtSearch_TextChanged"/>

                    <Button x:Name="chipActive" Content="✅ Aktywne" Style="{StaticResource ChipActive}"
                            Margin="14,0,4,0" Click="ChipActive_Click"/>
                    <Button x:Name="chipExpiring" Content="⏰ Wygasające" Style="{StaticResource ChipButton}"
                            Click="ChipExpiring_Click"/>
                    <Button x:Name="chipExpired" Content="❌ Wygasłe" Style="{StaticResource ChipButton}"
                            Click="ChipExpired_Click"/>
                    <Button x:Name="chipArimr" Content="🎯 Tylko ARiMR" Style="{StaticResource ChipButton}"
                            Click="ChipArimr_Click"/>
                </StackPanel>

                <TextBlock Grid.Column="1" x:Name="txtStats" Text="0 kontraktów"
                           FontSize="12" Foreground="#607D8B" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="dgKontrakty" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  BorderThickness="0" Background="#F5F7FA"
                  RowHeight="34" FontSize="12"
                  MouseDoubleClick="DgKontrakty_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nr" Binding="{Binding NumerKontraktu}" Width="65"
                                     ElementStyle="{StaticResource ResourceKey={x:Null}}"/>
                <DataGridTextColumn Header="Hodowca" Binding="{Binding NazwaHodowcySnapshot}" Width="220"/>
                <DataGridTextColumn Header="Typ" Binding="{Binding TypKontraktu}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Od" Binding="{Binding DataObowiazujeOd, StringFormat='dd.MM.yyyy'}" Width="90"/>
                <DataGridTextColumn Header="Do" Binding="{Binding DataObowiazujeDo, StringFormat='dd.MM.yyyy'}" Width="90"/>
                <DataGridTextColumn Header="Dni do" Binding="{Binding DniDoWygasniecia}" Width="60"/>
                <DataGridTextColumn Header="Ubytek %" Binding="{Binding ProcentUbytku, StringFormat='F2'}" Width="70"/>
                <DataGridTextColumn Header="Typ ceny" Binding="{Binding TypCeny}" Width="110"/>
                <DataGridTextColumn Header="Cena zł/kg" Binding="{Binding Cena, StringFormat='F2'}" Width="80"/>
                <DataGridTextColumn Header="ARiMR" Binding="{Binding LiczySieDoArimr}" Width="55"/>
                <DataGridTextColumn Header="Utworzył" Binding="{Binding UtworzylUserId}" Width="80"/>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="✏ Edytuj" Click="MenuEdit_Click" FontWeight="SemiBold"/>
                    <MenuItem Header="🔄 Utwórz przedłużenie" Click="MenuExtend_Click"/>
                    <MenuItem Header="📄 Generuj Word" Click="MenuGenerateWord_Click"/>
                    <MenuItem Header="📎 Dodaj skan PDF" Click="MenuAddScan_Click"/>
                    <Separator/>
                    <MenuItem Header="📑 Zmień status → SENT (wysłana)" Click="MenuStatusSent_Click"/>
                    <MenuItem Header="✅ Zmień status → SIGNED (podpisana)" Click="MenuStatusSigned_Click"/>
                    <MenuItem Header="🟢 Zmień status → ACTIVE (aktywna)" Click="MenuStatusActive_Click"/>
                    <Separator/>
                    <MenuItem Header="❌ Wypowiedz kontrakt" Click="MenuTerminate_Click" Foreground="#E74C3C"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </DockPanel>
</Window>
