<Window x:Class="Kalendarz1.DashboardPrzychodu.Windows.DeliveryDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Kalendarz1.DashboardPrzychodu.Converters"
        Title="Szczegoly dostawy"
        Height="820" Width="750"
        MinHeight="600" MinWidth="650"
        WindowStartupLocation="CenterOwner"
        Background="#1c1917"
        ResizeMode="CanResize">

    <Window.Resources>
        <SolidColorBrush x:Key="BgMain" Color="#1c1917"/>
        <SolidColorBrush x:Key="BgPanel" Color="#292524"/>
        <SolidColorBrush x:Key="BgSection" Color="#373230"/>
        <SolidColorBrush x:Key="Amber" Color="#fbbf24"/>
        <SolidColorBrush x:Key="AmberDark" Color="#f59e0b"/>
        <SolidColorBrush x:Key="Green" Color="#22c55e"/>
        <SolidColorBrush x:Key="Red" Color="#ef4444"/>
        <SolidColorBrush x:Key="Yellow" Color="#fbbf24"/>
        <SolidColorBrush x:Key="Cyan" Color="#60a5fa"/>
        <SolidColorBrush x:Key="Purple" Color="#c084fc"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#e7e5e4"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#a8a29e"/>
        <SolidColorBrush x:Key="TextMuted" Color="#78716c"/>
        <SolidColorBrush x:Key="BorderDark" Color="#44403c"/>

        <conv:NullToDashConverter x:Key="NullToDashConv"/>
        <conv:OdchylenieToColorConverter x:Key="OdchToColorConv"/>

        <!-- Wiersz danych: etykieta | wartosc -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Amber}"/>
            <Setter Property="Margin" Value="0,14,0,6"/>
        </Style>
        <Style x:Key="CalcRow" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgSection}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="180,2,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,16">

                <!-- ===== NAGLOWEK ===== -->
                <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource Amber}">
                    <Run Text="DOSTAWA #"/><Run Text="{Binding NrKursu, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0">
                    <Run Text="{Binding Hodowca, Mode=OneWay}"/>
                    <Run Text="  |  "/>
                    <Run Text="{Binding Data, Mode=OneWay, StringFormat='dd.MM.yyyy (dddd)'}"/>
                    <Run Text="  |  Status: "/>
                    <Run Text="{Binding StatusText, Mode=OneWay}"/>
                </TextBlock>

                <!-- ============ SEKCJA 1: IDENTYFIKACJA ============ -->
                <Border BorderBrush="{StaticResource AmberDark}" BorderThickness="0,0,0,1" Margin="0,14,0,6" Padding="0,0,0,4">
                    <TextBlock Style="{StaticResource SectionHeader}" Margin="0">i  IDENTYFIKACJA</TextBlock>
                </Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Hodowca:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Hodowca, Mode=OneWay}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Hodowca (skrot):" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding HodowcaSkrot, Mode=OneWay}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Nr kursu (CarLp):" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NrKursu, Mode=OneWay}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Data:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Data, Mode=OneWay, StringFormat='dd.MM.yyyy'}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="LP dostawy:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LpDostawy, Mode=OneWay, TargetNullValue='-'}" Style="{StaticResource ValueStyle}"
                               ToolTip="Klucz powiazania z HarmonogramDostaw.Lp"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="ID (FarmerCalc):" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ID, Mode=OneWay}" Style="{StaticResource ValueStyle}"/>
                </Grid>

                <!-- ============ SEKCJA 2: PLAN ============ -->
                <Border BorderBrush="{StaticResource AmberDark}" BorderThickness="0,0,0,1" Margin="0,14,0,6" Padding="0,0,0,4">
                    <TextBlock Style="{StaticResource SectionHeader}" Margin="0">P  PLAN Z HARMONOGRAMU</TextBlock>
                </Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Plan lacznie [szt]:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PlanSztukiLacznie, Mode=OneWay, StringFormat=N0}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Plan lacznie [kg]:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PlanKgLacznie, Mode=OneWay, StringFormat=N0}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Aut planowanych:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AutaPlanowane, Mode=OneWay}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Waga deklar. [kg/szt]:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding WagaDeklHarmonogram, Mode=OneWay, StringFormat=N3, TargetNullValue='-'}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Plan na to auto [kg]:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding KgPlanNaAuto, Mode=OneWay, StringFormat=N0}" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource Cyan}"/>
                </Grid>

                <!-- ============ SEKCJA 3: WAZENIE ============ -->
                <Border BorderBrush="{StaticResource AmberDark}" BorderThickness="0,0,0,1" Margin="0,14,0,6" Padding="0,0,0,4">
                    <TextBlock Style="{StaticResource SectionHeader}" Margin="0">W  WAZENIE - DANE RZECZYWISTE</TextBlock>
                </Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Status:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding StatusText, Mode=OneWay}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Brutto (pelne) [kg]:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Brutto, Mode=OneWay, StringFormat=N0}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Tara (puste) [kg]:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Tara, Mode=OneWay, StringFormat=N0}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Netto = Brutto - Tara [kg]:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding KgRzeczywiste, Mode=OneWay, StringFormat=N0}" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource Green}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Sztuki rzeczywiste:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SztukiRzeczywiste, Mode=OneWay, StringFormat=N0}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Sztuki Excel (AVILOG):" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SztukiExcel, Mode=OneWay, StringFormat=N0}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Padle / Konfiskaty:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource ValueStyle}">
                        <Run Text="{Binding Padle, Mode=OneWay, StringFormat=N0}"/><Run Text=" / "/><Run Text="{Binding Konfiskaty, Mode=OneWay, StringFormat=N0}"/>
                    </TextBlock>
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Przyjazd / Wazenie:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource ValueStyle}">
                        <Run Text="{Binding PrzyjazdDisplay, Mode=OneWay}"/><Run Text="  /  "/><Run Text="{Binding GodzinaWazeniaDisplay, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Kto wazyl:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding KtoWazyl, Mode=OneWay, TargetNullValue='-'}" Style="{StaticResource ValueStyle}"/>
                </Grid>

                <!-- ============ SEKCJA 4: SREDNIA WAGA ============ -->
                <Border BorderBrush="{StaticResource AmberDark}" BorderThickness="0,0,0,1" Margin="0,14,0,6" Padding="0,0,0,4">
                    <TextBlock Style="{StaticResource SectionHeader}" Margin="0">S  SREDNIA WAGA SZTUKI</TextBlock>
                </Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Waga deklarowana:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WagaDeklHarmonogram, Mode=OneWay, StringFormat='{}{0:N3} kg', TargetNullValue='-'}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Waga rzeczywista:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SredniaWagaRzeczywistaCalc, Mode=OneWay, StringFormat='{}{0:N3} kg', TargetNullValue='-'}" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource Green}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Odchylenie wagi:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueStyle}">
                        <Run Text="{Binding OdchylenieWagiDisplay, Mode=OneWay}"/><Run Text="  "/><Run Text="{Binding WagaTrend, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>

                <!-- ============ SEKCJA 5: ODCHYLENIE (2 METRYKI - #2) ============ -->
                <Border BorderBrush="{StaticResource AmberDark}" BorderThickness="0,0,0,1" Margin="0,14,0,6" Padding="0,0,0,4">
                    <TextBlock Style="{StaticResource SectionHeader}" Margin="0">O  ODCHYLENIE OD PLANU</TextBlock>
                </Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="vs plan-na-auto:" Style="{StaticResource LabelStyle}"
                               ToolTip="Odchylenie wzgledem planu dispatchera dla tego auta"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding OdchylenieVsPlanAutoDisplay, Mode=OneWay}" Style="{StaticResource ValueStyle}"
                               Foreground="{Binding Poziom, Converter={StaticResource OdchToColorConv}}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="vs deklaracja hodowcy:" Style="{StaticResource LabelStyle}"
                               ToolTip="Odchylenie wzgledem wagi deklarowanej przez hodowce (wykrywanie klamstw)"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding OdchylenieVsDeklHodowcaDisplay, Mode=OneWay}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ocena:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Poziom, Mode=OneWay}" Style="{StaticResource ValueStyle}"
                               Foreground="{Binding Poziom, Converter={StaticResource OdchToColorConv}}"/>
                </Grid>

                <!-- ============ SEKCJA 6: POSTEP HARMONOGRAMU ============ -->
                <Border BorderBrush="{StaticResource AmberDark}" BorderThickness="0,0,0,1" Margin="0,14,0,6" Padding="0,0,0,4">
                    <TextBlock Style="{StaticResource SectionHeader}" Margin="0">>  POSTEP HARMONOGRAMU HODOWCY</TextBlock>
                </Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Aut ogolem:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AutaOgolem, Mode=OneWay}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Aut zwazonych:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AutaZwazone, Mode=OneWay}" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource Green}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Aut czekajacych:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AutaCzekajacych, Mode=OneWay}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Postep:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PostepDisplay, Mode=OneWay}" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource Cyan}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Zwazono [kg]:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding KgZwazoneSuma, Mode=OneWay, StringFormat=N0}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Pozostalo [kg]:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding KgPozostalo, Mode=OneWay, StringFormat=N0}" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource Cyan}"/>
                </Grid>

                <!-- ============ SEKCJA 7: TUSZKI ============ -->
                <Border BorderBrush="{StaticResource AmberDark}" BorderThickness="0,0,0,1" Margin="0,14,0,6" Padding="0,0,0,4">
                    <TextBlock Style="{StaticResource SectionHeader}" Margin="0">T  TUSZKI - PROGNOZA PRODUKCJI (78%)</TextBlock>
                </Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Wydajnosc:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="78%" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource TextSecondary}"
                               ToolTip="Staly wspolczynnik: z 1 kg zywca powstaje 0.78 kg tuszki"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tuszki plan [kg]:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TuszkiPlanKg, Mode=OneWay, StringFormat=N0}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Tuszki rzecz. [kg]:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TuszkiRzeczywisteKg, Mode=OneWay, StringFormat=N0, TargetNullValue='-'}" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource Green}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Waga tuszki [kg]:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding WagaTuszkiKg, Mode=OneWay, StringFormat=N3, TargetNullValue='-'}" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource Purple}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Szt/pojemnik (15kg):" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SztukWPojemniku, Mode=OneWay, StringFormat=N2, TargetNullValue='-'}" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource Purple}"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Rozmiar:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding RozmiarDisplay, Mode=OneWay}" Style="{StaticResource ValueStyle}"
                               Foreground="{StaticResource Purple}"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- ===== FOOTER ===== -->
        <Border Grid.Row="1" Background="{StaticResource BgPanel}" Padding="24,10"
                BorderBrush="{StaticResource BorderDark}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCopy" Content="Kopiuj do schowka" Padding="15,7"
                        Background="{StaticResource BorderDark}" Foreground="{StaticResource TextPrimary}"
                        BorderThickness="0" Cursor="Hand" FontSize="12" Margin="0,0,8,0"
                        Click="BtnCopy_Click"/>
                <Button x:Name="BtnClose" Content="Zamknij" Padding="20,7"
                        Background="{StaticResource AmberDark}" Foreground="{StaticResource BgMain}"
                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold" FontSize="12"
                        Click="BtnClose_Click" IsDefault="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
