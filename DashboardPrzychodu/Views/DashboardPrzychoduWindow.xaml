<Window x:Class="Kalendarz1.DashboardPrzychodu.Views.DashboardPrzychoduWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Kalendarz1.DashboardPrzychodu.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Dashboard Przychodu Zywca - LIVE"
        Height="900" Width="1400"
        MinHeight="700" MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#1c1917">

    <Window.Resources>
        <!-- ============================================ -->
        <!-- PALETA KOLORÓW - WARM INDUSTRIAL -->
        <!-- ============================================ -->

        <!-- TŁA -->
        <Color x:Key="BgMain">#1c1917</Color>
        <Color x:Key="BgPanel">#292524</Color>
        <Color x:Key="BgDark">#44403c</Color>
        <Color x:Key="BgDarker">#57534e</Color>

        <!-- TEKST -->
        <Color x:Key="TextPrimary">#e7e5e4</Color>
        <Color x:Key="TextSecondary">#a8a29e</Color>
        <Color x:Key="TextMuted">#78716c</Color>

        <!-- AKCENTY -->
        <Color x:Key="Amber">#f59e0b</Color>
        <Color x:Key="AmberLight">#fbbf24</Color>
        <Color x:Key="Green">#22c55e</Color>
        <Color x:Key="Red">#ef4444</Color>
        <Color x:Key="RedDark">#7f1d1d</Color>
        <Color x:Key="Blue">#60a5fa</Color>
        <Color x:Key="Purple">#c084fc</Color>

        <!-- BRUSHE -->
        <SolidColorBrush x:Key="BgMainBrush" Color="{StaticResource BgMain}"/>
        <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanel}"/>
        <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
        <SolidColorBrush x:Key="BgDarkerBrush" Color="{StaticResource BgDarker}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
        <SolidColorBrush x:Key="AmberBrush" Color="{StaticResource Amber}"/>
        <SolidColorBrush x:Key="AmberLightBrush" Color="{StaticResource AmberLight}"/>
        <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource Green}"/>
        <SolidColorBrush x:Key="RedBrush" Color="{StaticResource Red}"/>
        <SolidColorBrush x:Key="RedDarkBrush" Color="{StaticResource RedDark}"/>
        <SolidColorBrush x:Key="BlueBrush" Color="{StaticResource Blue}"/>
        <SolidColorBrush x:Key="PurpleBrush" Color="{StaticResource Purple}"/>

        <!-- Kompatybilność wsteczna -->
        <SolidColorBrush x:Key="StatusOKBrush" Color="{StaticResource Green}"/>
        <SolidColorBrush x:Key="StatusWarningBrush" Color="{StaticResource AmberLight}"/>
        <SolidColorBrush x:Key="StatusErrorBrush" Color="{StaticResource Red}"/>

        <!-- KONWERTERY -->
        <conv:StatusToBackgroundConverter x:Key="StatusToBackgroundConverter"/>
        <conv:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <conv:OdchylenieToColorConverter x:Key="OdchylenieToColorConverter"/>
        <conv:OdchylenieToIconConverter x:Key="OdchylenieToIconConverter"/>
        <conv:OdchylenieToBarColorConverter x:Key="OdchylenieToBarColorConverter"/>
        <conv:ProblemToRowBackgroundConverter x:Key="ProblemToRowBackgroundConverter"/>
        <conv:StatusToIconConverter x:Key="StatusToIconConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:NullToDashConverter x:Key="NullToDashConverter"/>
        <conv:TrendToColorConverter x:Key="TrendToColorConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <conv:AlertToColorConverter x:Key="AlertToColorConverter"/>

        <!-- ============================================ -->
        <!-- STYLE PRZYCISKÓW -->
        <!-- ============================================ -->

        <!-- Przycisk Amber (główny akcent) -->
        <Style x:Key="BtnAmber" TargetType="Button">
            <Setter Property="Background" Value="#f59e0b"/>
            <Setter Property="Foreground" Value="#1c1917"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#fbbf24"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Przycisk Sidebar -->
        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background" Value="#1c1917"/>
            <Setter Property="Foreground" Value="#a8a29e"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#44403c"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#292524"/>
                    <Setter Property="Foreground" Value="#e7e5e4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Przycisk Bottom Bar -->
        <Style x:Key="BottomBtn" TargetType="Button">
            <Setter Property="Background" Value="#44403c"/>
            <Setter Property="Foreground" Value="#a8a29e"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#57534e"/>
                    <Setter Property="Foreground" Value="#e7e5e4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BottomBtnDanger" TargetType="Button" BasedOn="{StaticResource BottomBtn}">
            <Setter Property="Background" Value="#7f1d1d"/>
            <Setter Property="Foreground" Value="#fca5a5"/>
        </Style>

        <!-- ============================================ -->
        <!-- STYLE DATAGRID -->
        <!-- ============================================ -->

        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#292524"/>
            <Setter Property="Foreground" Value="#fbbf24"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="BorderThickness" Value="0,0,1,2"/>
            <Setter Property="BorderBrush" Value="#f59e0b"/>
        </Style>

        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding HodowcaKolorTlo}"/>
            <Setter Property="Foreground" Value="#e7e5e4"/>
            <Setter Property="BorderThickness" Value="4,0,0,0"/>
            <Setter Property="BorderBrush" Value="{Binding HodowcaKolor}"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#44403c"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3a3633"/>
                </Trigger>
                <DataTrigger Binding="{Binding JestProblem}" Value="True">
                    <Setter Property="Background" Value="#3a1f1f"/>
                </DataTrigger>
                <!-- Separator grup hodowców: grubsza linia na górze pierwszego wiersza nowej grupy -->
                <DataTrigger Binding="{Binding PierwszyWierszGrupy}" Value="True">
                    <Setter Property="BorderThickness" Value="4,3,0,0"/>
                    <Setter Property="BorderBrush" Value="{Binding HodowcaKolor}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#44403c"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#e7e5e4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternationCount" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1c1917"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="ColumnHeaderHeight" Value="40"/>
        </Style>

        <!-- ============================================ -->
        <!-- CONTEXT MENUS -->
        <!-- ============================================ -->

        <!-- Menu Logo -->
        <ContextMenu x:Key="LogoContextMenu" Background="#292524" BorderBrush="#44403c" Foreground="#e7e5e4">
            <MenuItem Header="Wybierz logo firmy" IsEnabled="False" Foreground="#78716c"/>
            <Separator Background="#44403c"/>
            <MenuItem Header="🏭  Fabryka (domyślne)" Click="Logo_SetEmoji" Tag="🏭"/>
            <MenuItem Header="🐔  Kurczak" Click="Logo_SetEmoji" Tag="🐔"/>
            <MenuItem Header="🍗  Udko kurczaka" Click="Logo_SetEmoji" Tag="🍗"/>
            <MenuItem Header="🐓  Kogut" Click="Logo_SetEmoji" Tag="🐓"/>
            <MenuItem Header="🥩  Mięso" Click="Logo_SetEmoji" Tag="🥩"/>
            <Separator Background="#44403c"/>
            <MenuItem Header="📁  Wybierz z pliku..." Click="Logo_SelectFile"/>
        </ContextMenu>

        <!-- Menu Ikon KPI -->
        <ContextMenu x:Key="IconContextMenu" Background="#292524" BorderBrush="#44403c" Foreground="#e7e5e4">
            <MenuItem x:Name="IconMenuTitle" Header="Wybierz ikonę" IsEnabled="False" Foreground="#78716c"/>
            <Separator Background="#44403c"/>
            <MenuItem Header="🐔  Kurczak" Click="Icon_SetEmoji" Tag="🐔"/>
            <MenuItem Header="🍗  Udko" Click="Icon_SetEmoji" Tag="🍗"/>
            <MenuItem Header="📦  Paczka" Click="Icon_SetEmoji" Tag="📦"/>
            <MenuItem Header="📊  Wykres" Click="Icon_SetEmoji" Tag="📊"/>
            <MenuItem Header="📈  Trend ↑" Click="Icon_SetEmoji" Tag="📈"/>
            <MenuItem Header="📉  Trend ↓" Click="Icon_SetEmoji" Tag="📉"/>
            <MenuItem Header="✓   Check" Click="Icon_SetEmoji" Tag="✓"/>
            <MenuItem Header="✅  Green check" Click="Icon_SetEmoji" Tag="✅"/>
            <MenuItem Header="⏳  Klepsydra" Click="Icon_SetEmoji" Tag="⏳"/>
            <MenuItem Header="⚖️  Waga" Click="Icon_SetEmoji" Tag="⚖️"/>
            <MenuItem Header="🎯  Cel" Click="Icon_SetEmoji" Tag="🎯"/>
            <MenuItem Header="💰  Pieniądze" Click="Icon_SetEmoji" Tag="💰"/>
        </ContextMenu>

        <!-- DatePicker style -->
        <Style x:Key="DarkDatePicker" TargetType="DatePicker">
            <Setter Property="Background" Value="#292524"/>
            <Setter Property="Foreground" Value="#e7e5e4"/>
            <Setter Property="BorderBrush" Value="#44403c"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="10"/>
            <Style.Resources>
                <Style TargetType="DatePickerTextBox">
                    <Setter Property="Background" Value="#292524"/>
                    <Setter Property="Foreground" Value="#e7e5e4"/>
                    <Setter Property="CaretBrush" Value="#e7e5e4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DatePickerTextBox">
                                <Border Background="#292524" CornerRadius="3" Padding="4,2">
                                    <ScrollViewer x:Name="PART_ContentHost" Background="Transparent"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

    </Window.Resources>

    <!-- ============================================ -->
    <!-- GŁÓWNY LAYOUT - 4 WIERSZE -->
    <!-- ============================================ -->
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>    <!-- MAIN (Sidebar + Table) -->
            <RowDefinition Height="26"/>   <!-- BOTTOM BAR -->
        </Grid.RowDefinitions>

        <!-- ============================================ -->
        <!-- ROW 0: MAIN CONTENT (Sidebar + Table) -->
        <!-- ============================================ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="820"/>  <!-- Sidebar - jeszcze szerszy z navigacja -->
                <ColumnDefinition Width="*"/>    <!-- Table -->
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,4,0">
                <StackPanel>

                    <!-- ====== NAWIGACJA (kompaktowa, na samej górze) ====== -->
                    <Border Background="#292524" CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                        <StackPanel>
                            <!-- Linia 1: Logo + tytuł + LIVE + Odśwież + Auto-refresh -->
                            <Grid Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border x:Name="LogoBox" Width="36" Height="36" Background="#44403c"
                                            CornerRadius="5" Cursor="Hand" MouseRightButtonUp="LogoBox_RightClick">
                                        <TextBlock x:Name="LogoIcon" Text="🏭" FontSize="20"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="PRZYCHÓD ŻYWCA" FontSize="16" FontWeight="Bold"
                                               Foreground="#fbbf24" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    <Border Background="#f59e0b" CornerRadius="7" Padding="7,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="● LIVE" FontSize="9" FontWeight="Bold" Foreground="#1c1917"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="🔄 Odśwież" Style="{StaticResource BtnAmber}" Click="BtnRefresh_Click"
                                            FontSize="13" Padding="14,7"/>
                                    <TextBlock FontSize="12" Foreground="#a8a29e" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <Run Text="Auto: "/><Run x:Name="txtAutoRefresh" Text="30s" Foreground="#fbbf24" FontWeight="Bold"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>

                            <!-- Linia 2: Data -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📅" FontSize="16" VerticalAlignment="Center"/>
                                <DatePicker x:Name="dpData" SelectedDate="{x:Static sys:DateTime.Today}"
                                            Width="160" FontSize="13" Style="{StaticResource DarkDatePicker}"
                                            Margin="6,0,0,0"/>
                                <TextBlock x:Name="txtDataDisplay" Text="" FontSize="12"
                                           Foreground="#a8a29e" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- HARMONOGRAMY - karty -->
                    <Border Background="#292524" CornerRadius="5" Padding="8,6" Margin="0,0,0,6">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="📦 HARMONOGRAMY" FontSize="11" FontWeight="Bold" Foreground="#f59e0b"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="⚖️ " FontSize="10" Foreground="#78716c"/>
                                    <TextBlock x:Name="txtSrWagaPlanSidebar" Text="-" FontSize="10" FontWeight="SemiBold" Foreground="#a8a29e"/>
                                    <TextBlock Text=" → " FontSize="10" Foreground="#57534e"/>
                                    <TextBlock x:Name="txtSrWagaRzeczSidebar" Text="-" FontSize="10" FontWeight="Bold" Foreground="#22c55e"/>
                                    <TextBlock Text=" kg" FontSize="9" Foreground="#57534e"/>
                                </StackPanel>
                            </Grid>

                            <ItemsControl x:Name="icHarmonogramy">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="5" Margin="0,0,4,4" MinWidth="240" MaxWidth="252"
                                                Background="#1c1917"
                                                ToolTip="{Binding Hodowca, Mode=OneWay}">
                                            <!-- Pulsowanie aktywnej karty - kolorowe obramowanie -->
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="#44403c"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding JestAktywna}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{Binding HodowcaKolor}"/>
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <!-- Kolorowy pasek akcentu po lewej -->
                                                <Border Width="4" HorizontalAlignment="Left"
                                                        CornerRadius="6,0,0,6"
                                                        Background="{Binding HodowcaKolor, Mode=OneWay}"/>

                                                <StackPanel Margin="9,6,7,6">
                                                    <!-- Nagłówek: Hodowca (pełna szerokość) + badge'e w prawym górnym rogu -->
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                            <!-- Kropka statusu -->
                                                            <Ellipse Width="7" Height="7" Margin="0,0,4,0"
                                                                     Fill="{Binding StatusDotColor, Mode=OneWay}"
                                                                     Opacity="{Binding StatusDotOpacity, Mode=OneWay}"
                                                                     VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Hodowca, Mode=OneWay}" FontSize="11" FontWeight="Bold"
                                                                       Foreground="{Binding HodowcaKolor, Mode=OneWay}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" Background="{Binding HodowcaKolor, Mode=OneWay}" CornerRadius="2"
                                                                Padding="4,0,4,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding TrendDisplay, Mode=OneWay}" FontSize="9" FontWeight="Bold"
                                                                       Foreground="#1c1917"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- REALNI HODOWCY (pokazujemy gdy rozni sie od planowanego) -->
                                                    <Border Background="#292524" CornerRadius="2" Padding="5,2" Margin="0,0,0,4"
                                                            Visibility="{Binding MaRoznychRealnych, Converter={StaticResource BoolToVisibilityConverter}}"
                                                            ToolTip="{Binding RealniHodowcy}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="👥" FontSize="9" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding RealniHodowcyDisplay, Mode=OneWay}" FontSize="9" FontWeight="SemiBold"
                                                                       Foreground="#fbbf24" TextTrimming="CharacterEllipsis" MaxWidth="195"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Plan vs Rzecz - 2 kolumny -->
                                                    <Grid Margin="0,0,0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="PLAN" FontSize="7" Foreground="#78716c" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding KgPlanDisplay, Mode=OneWay}" FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="#a8a29e"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="→" Foreground="#57534e" FontSize="11"
                                                                   VerticalAlignment="Bottom" Margin="5,0,5,1"/>
                                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                            <TextBlock Text="RZECZ" FontSize="7" Foreground="#78716c" FontWeight="SemiBold"
                                                                       HorizontalAlignment="Right"/>
                                                            <TextBlock Text="{Binding KgRzeczDisplay, Mode=OneWay}" FontSize="13" FontWeight="Bold"
                                                                       Foreground="#e7e5e4" HorizontalAlignment="Right"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- CENTRALNE: Odchylenie kg i odchylenie waga (focus karty) -->
                                                    <Border Background="#0a0a0a" CornerRadius="3" Padding="6,4" Margin="0,1,0,4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="1"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Lewa: ODCHYL.KG -->
                                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                                <TextBlock Text="ODCHYL. KG" FontSize="7" Foreground="#78716c" FontWeight="SemiBold"
                                                                           HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{Binding OdchylenieKgDisplay, Mode=OneWay}" FontSize="13" FontWeight="Bold"
                                                                           Foreground="{Binding OdchylenieKgBrush, Mode=OneWay}"
                                                                           HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                            <!-- Separator pionowy -->
                                                            <Rectangle Grid.Column="1" Fill="#44403c" Width="1" Margin="0,2"/>
                                                            <!-- Prawa: ODCHYL.WAGA -->
                                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                                <TextBlock Text="ODCHYL. WAGA" FontSize="7" Foreground="#78716c" FontWeight="SemiBold"
                                                                           HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{Binding OdchylenieWagiDisplay, Mode=OneWay}" FontSize="13" FontWeight="Bold"
                                                                           Foreground="{Binding OdchylenieWagiBrush, Mode=OneWay}"
                                                                           HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Waga: dek → rzecz (mała linia kontekstowa) -->
                                                    <Grid Margin="0,0,0,4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="⚖ " FontSize="9" Foreground="#57534e"/>
                                                            <TextBlock Text="{Binding SredniaWagaPlanDisplay, Mode=OneWay}" FontSize="9"
                                                                       Foreground="#78716c"/>
                                                            <TextBlock Text="→" FontSize="9" Foreground="#57534e" Margin="4,0,4,0"/>
                                                            <TextBlock Text="{Binding SredniaWagaRzeczDisplay, Mode=OneWay}" FontSize="9" FontWeight="Bold"
                                                                       Foreground="#e7e5e4"/>
                                                            <TextBlock Text=" kg" FontSize="8" Foreground="#57534e"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- Pasek postępu + auta -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ProgressBar Grid.Column="0" Value="{Binding RealizacjaProc, Mode=OneWay}" Maximum="100"
                                                                     Height="4" Background="#292524" Foreground="{Binding HodowcaKolor, Mode=OneWay}"
                                                                     VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding PostepDisplay, Mode=OneWay}" FontSize="9" FontWeight="SemiBold"
                                                                   Foreground="#78716c" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- TUSZKI - PROGNOZA -->
                    <Border Background="#292524" CornerRadius="5" Padding="8,8" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="🍗 TUSZKI - PROGNOZA" FontSize="10" FontWeight="Bold"
                                       Foreground="#c084fc" Margin="0,0,0,6"/>

                            <!-- Główne wartości - DUŻE -->
                            <UniformGrid Columns="3" Margin="0,0,0,8">
                                <Border Background="#1c1917" CornerRadius="4" Padding="8,10" Margin="0,0,3,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="PLAN" FontSize="9" Foreground="#78716c" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtTuszkiPlanSidebar" Text="-"
                                                   FontSize="22" FontWeight="Bold" Foreground="#a8a29e" HorizontalAlignment="Center"/>
                                        <TextBlock Text="kg" FontSize="9" Foreground="#57534e" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#1c1917" CornerRadius="4" Padding="8,10" Margin="3,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="RZECZ" FontSize="9" Foreground="#78716c" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtTuszkiRzeczSidebar" Text="-"
                                                   FontSize="22" FontWeight="Bold" Foreground="#c084fc" HorizontalAlignment="Center"/>
                                        <TextBlock Text="kg" FontSize="9" Foreground="#57534e" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="borderTuszkiOdchylenie" Background="#1c1917" CornerRadius="4" Padding="8,10" Margin="3,0,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="ODCHYL" FontSize="9" Foreground="#78716c" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtTuszkiOdchylenieSidebar" Text="-"
                                                   FontSize="22" FontWeight="Bold" Foreground="#78716c" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="txtTuszkiOdchylenieProcSidebar" Text="" FontSize="10" Foreground="#57534e" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Alert redukcji zamówień -->
                            <Border x:Name="borderRedukcjaSidebar" Background="#7f1d1d" CornerRadius="4" Padding="8,6" Margin="0,0,0,6"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠️" FontSize="12" Margin="0,0,4,0"/>
                                        <TextBlock x:Name="txtRedukcjaAlertSidebar" Text="REDUKCJA ZAMÓWIEŃ"
                                                   FontSize="10" FontWeight="Bold" Foreground="#fca5a5"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtRedukcjaKgSidebar" Text="" FontSize="11" FontWeight="Bold"
                                               Foreground="#fbbf24" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Klasy A/B - Plan, Rzecz, Fakt z % - WIĘKSZE -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Nagłówki -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="KLASA A" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#22c55e" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="KLASA B" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#fbbf24" HorizontalAlignment="Center" Margin="0,0,0,4"/>

                                <!-- Klasa A - Plan/Rzecz/Fakt z % -->
                                <Border Grid.Row="1" Grid.Column="0" Background="#1c1917" CornerRadius="4" Padding="8,8" Margin="0,0,3,0">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="Plan:" FontSize="10" Foreground="#78716c"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock x:Name="txtKlasaAPlanSidebar" Text="-" FontSize="13" FontWeight="SemiBold" Foreground="#a8a29e"/>
                                                <TextBlock x:Name="txtKlasaAPlanProcSidebar" Text="" FontSize="9" Foreground="#78716c" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,4,0,0">
                                            <TextBlock Text="Rzecz:" FontSize="10" Foreground="#78716c"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock x:Name="txtKlasaASidebar" Text="-" FontSize="13" FontWeight="Bold" Foreground="#22c55e"/>
                                                <TextBlock x:Name="txtKlasaAProcSidebar" Text="" FontSize="9" Foreground="#78716c" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,4,0,0">
                                            <TextBlock Text="Fakt:" FontSize="10" Foreground="#78716c"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock x:Name="txtKlasaAFaktSidebar" Text="-" FontSize="13" FontWeight="Bold" Foreground="#60a5fa"
                                                           ToolTip="Faktyczny przychód z systemu Symfonia (sPWU)"/>
                                                <TextBlock x:Name="txtKlasaAFaktProcSidebar" Text="" FontSize="9" Foreground="#78716c" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Klasa B - Plan/Rzecz/Fakt z % -->
                                <Border Grid.Row="1" Grid.Column="1" Background="#1c1917" CornerRadius="4" Padding="8,8" Margin="3,0,0,0">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="Plan:" FontSize="10" Foreground="#78716c"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock x:Name="txtKlasaBPlanSidebar" Text="-" FontSize="13" FontWeight="SemiBold" Foreground="#a8a29e"/>
                                                <TextBlock x:Name="txtKlasaBPlanProcSidebar" Text="" FontSize="9" Foreground="#78716c" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,4,0,0">
                                            <TextBlock Text="Rzecz:" FontSize="10" Foreground="#78716c"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock x:Name="txtKlasaBSidebar" Text="-" FontSize="13" FontWeight="Bold" Foreground="#fbbf24"/>
                                                <TextBlock x:Name="txtKlasaBProcSidebar" Text="" FontSize="9" Foreground="#78716c" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,4,0,0">
                                            <TextBlock Text="Fakt:" FontSize="10" Foreground="#78716c"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock x:Name="txtKlasaBFaktSidebar" Text="-" FontSize="13" FontWeight="Bold" Foreground="#60a5fa"
                                                           ToolTip="Faktyczny przychód z systemu Symfonia (sPWU)"/>
                                                <TextBlock x:Name="txtKlasaBFaktProcSidebar" Text="" FontSize="9" Foreground="#78716c" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Trend i auta -->
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Auta: " FontSize="10" Foreground="#78716c"/>
                                    <TextBlock x:Name="txtAutaSidebar" Text="0/0" FontSize="10" FontWeight="SemiBold" Foreground="#a8a29e"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Trend: " FontSize="10" Foreground="#78716c"/>
                                    <TextBlock x:Name="txtTrendSidebar" Text="0%" FontSize="10" FontWeight="SemiBold" Foreground="#fbbf24"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- HISTORIA ZMIAN DEKLARACJI - dzisiejsze zmiany w HarmonogramDostaw dla dzis. dostaw, 3 kolumny -->
                    <Border Background="#292524" CornerRadius="5" Padding="8,6" Margin="0,6,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📝 HISTORIA DEKLARACJI" FontSize="11" FontWeight="Bold" Foreground="#fbbf24"/>
                                    <TextBlock x:Name="txtHistoriaCount" Text="(0)" FontSize="10" Foreground="#78716c" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Sztuki / Waga śr. / Auta — zmiany z dziś" FontSize="9" Foreground="#78716c"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Lista zmian: 3 KOLUMNY, scroll w pionie -->
                            <Border Background="#1c1917" CornerRadius="4" Padding="4" MaxHeight="320">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="icHistoriaZmian">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="3"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#292524" CornerRadius="3" Padding="6,5" Margin="2"
                                                        ToolTip="{Binding Tooltip}">
                                                    <StackPanel>
                                                        <!-- Linia 1: HH:mm + badge pola -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                            <TextBlock Text="{Binding TimeDisplay}"
                                                                       FontSize="10" FontWeight="SemiBold" Foreground="#fbbf24"
                                                                       VerticalAlignment="Center"/>
                                                            <Border Background="#44403c" CornerRadius="2" Padding="4,1" Margin="6,0,0,0"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding FieldShort}" FontSize="9" FontWeight="Bold" Foreground="#e7e5e4"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <!-- Linia 2: hodowca (trim) -->
                                                        <TextBlock Text="{Binding Hodowca}" FontSize="10" FontWeight="SemiBold"
                                                                   Foreground="#a8a29e" TextTrimming="CharacterEllipsis"/>
                                                        <!-- Linia 3: old → new -->
                                                        <TextBlock Text="{Binding ZmianaDisplay}" FontSize="11" FontWeight="Bold"
                                                                   Foreground="#60a5fa" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- TABLE SECTION -->
            <Border Grid.Column="1" Background="#292524" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>   <!-- Header -->
                        <RowDefinition Height="*"/>    <!-- DataGrid -->
                        <RowDefinition Height="Auto"/> <!-- SUMA -->
                    </Grid.RowDefinitions>

                    <!-- TABLE HEADER -->
                    <Border Grid.Row="0" Background="#44403c" CornerRadius="5,5,0,0" Padding="12,0">
                        <Grid VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="SZCZEGÓŁY DOSTAW" FontSize="12" FontWeight="Bold" Foreground="#fbbf24"/>
                                <TextBlock x:Name="txtLiczbaWynikow" Text=" (0 wyników)" FontSize="11" Foreground="#78716c"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="txtLastUpdate" Text="-" FontSize="10" Foreground="#78716c"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- DATAGRID -->
                    <DataGrid Grid.Row="1" x:Name="dgDostawy"
                              Style="{StaticResource ModernDataGrid}"
                              ColumnHeaderStyle="{StaticResource DgHeader}"
                              CellStyle="{StaticResource DgCell}"
                              RowStyle="{StaticResource DgRow}"
                              VirtualizingPanel.IsVirtualizing="True"
                              MouseDoubleClick="DataGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <!-- Kolorowy pasek -->
                            <DataGridTemplateColumn Width="5" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="5" Margin="-6,0,0,0"
                                                Background="{Binding Poziom, Converter={StaticResource OdchylenieToBarColorConverter}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="LP" Binding="{Binding NrKursu}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="HODOWCA" Width="*" MinWidth="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Hodowca}"
                                                   Foreground="{Binding HodowcaKolor}"
                                                   FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="14" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- PLAN NA AUTO -->
                            <DataGridTemplateColumn Header="PLAN" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding KgPlanNaAuto, StringFormat=N0}" Foreground="#a8a29e"
                                                       FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text=" (R)" Foreground="#f59e0b" FontSize="11" FontWeight="Bold"
                                                       Visibility="{Binding CzyOstatnieAuto, Converter={StaticResource BoolToVisibilityConverter}}"
                                                       ToolTip="Reszta z harmonogramu"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="RZECZ" Width="105">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding KgRzeczywiste, StringFormat=N0}" HorizontalAlignment="Right"
                                                   Foreground="#fbbf24"
                                                   VerticalAlignment="Center" FontWeight="Bold" FontSize="15"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- ODCH.PLAN: vs plan-na-auto (dispatching POV). Tooltip pokazuje OBIE metryki. -->
                            <DataGridTemplateColumn Header="ODCH.PLAN" Width="130"
                                                    ToolTipService.ToolTip="Odchylenie wzgledem planu dispatchera na to auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding OdchylenieVsPlanAutoDisplay}"
                                                   Foreground="{Binding Poziom, Converter={StaticResource OdchylenieToColorConverter}}"
                                                   VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                                   ToolTip="{Binding OdchylenieFullTooltip}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- POZOSTALO Z HARMONOGRAMU - tylko na ostatnim wierszu hodowcy -->
                            <DataGridTemplateColumn Header="POZOST." Width="115">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center"
                                                    Visibility="{Binding OstatniWierszHodowcy, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Foreground="{Binding PozostaloKolor}" FontSize="13" FontWeight="SemiBold">
                                                <Run Text="{Binding KgPozostalo, StringFormat=N0}"/><Run Text=" kg"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- POSTEP HARMONOGRAMU - tylko na ostatnim wierszu hodowcy -->
                            <DataGridTemplateColumn Header="POST." Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center"
                                                    Visibility="{Binding OstatniWierszHodowcy, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="{Binding PostepDisplay}" FontSize="12" Foreground="#a8a29e" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                            <ProgressBar Value="{Binding PostepProc, Mode=OneWay}" Maximum="100"
                                                         Height="4" Background="#44403c" Foreground="#22c55e" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="W.DEK" Width="85">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SredniaWagaPlanCalc, StringFormat=N2}"
                                                   Foreground="#a8a29e" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="W.RZ" Width="85"
                                                    ToolTipService.ToolTip="Srednia waga rzeczywista [kg/szt] = Netto / SztRzecz">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SredniaWagaRzeczywistaCalc, StringFormat='{}{0:N2}', TargetNullValue='-', FallbackValue='-'}"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- TUSZKI -->
                            <DataGridTemplateColumn Header="TUSZKI" Width="95">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TuszkiRzeczywisteKg, Converter={StaticResource NullToDashConverter}}"
                                                   Foreground="#c084fc" FontSize="13" FontWeight="SemiBold"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- ROZM. i Status icon usuniete na zyczenie usera -->

                            <DataGridTextColumn Header="GODZ" Binding="{Binding PrzyjazdDisplay}" Width="85">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#a8a29e"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- WIERSZ SUMA -->
                    <Border Grid.Row="2" Background="#92400e" Padding="8,12"
                            CornerRadius="0,0,5,5" BorderThickness="0,2,0,0" BorderBrush="#f59e0b">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>   <!-- LP -->
                                <ColumnDefinition Width="*" MinWidth="160"/>  <!-- HODOWCA -->
                                <ColumnDefinition Width="110"/>  <!-- PLAN -->
                                <ColumnDefinition Width="105"/>  <!-- RZECZ -->
                                <ColumnDefinition Width="130"/>  <!-- ODCH.PLAN -->
                                <ColumnDefinition Width="115"/>  <!-- POZOSTAŁO -->
                                <ColumnDefinition Width="90"/>   <!-- POSTĘP -->
                                <ColumnDefinition Width="85"/>   <!-- W.DEK -->
                                <ColumnDefinition Width="85"/>   <!-- W.RZ -->
                                <ColumnDefinition Width="95"/>   <!-- TUSZKI -->
                                <ColumnDefinition Width="85"/>   <!-- GODZ -->
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="SUMA" FontSize="14" FontWeight="Bold" Foreground="#fbbf24"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="txtSumaDostawy" Text="0 dostaw" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#fed7aa" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="txtSumaPlan" Text="0" FontSize="15" FontWeight="Bold"
                                       Foreground="#ffffff" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" x:Name="txtSumaRzecz" Text="0" FontSize="15" FontWeight="Bold"
                                       Foreground="#22c55e" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" x:Name="txtSumaOdchylenie" Text="-" FontSize="14" FontWeight="Bold"
                                       Foreground="#fbbf24" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       ToolTip="Suma odchylen vs plan-na-auto"/>
                            <StackPanel Grid.Column="5" VerticalAlignment="Center">
                                <TextBlock x:Name="txtSumaPozostaloKg" Text="-" Foreground="#60a5fa" FontSize="13" FontWeight="Bold"/>
                                <TextBlock x:Name="txtSumaPozostaloTuszki" Text="-" Foreground="#c084fc" FontSize="11"/>
                            </StackPanel>
                            <TextBlock Grid.Column="6" Text="-" FontSize="13" Foreground="#fed7aa" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="7" x:Name="txtSumaWagaPlan" Text="-" FontSize="13" Foreground="#fed7aa"
                                       FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="8" x:Name="txtSumaSrWaga" Text="-" FontSize="13" FontWeight="Bold"
                                       Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="9" x:Name="txtSumaTuszkiRzecz" Text="-" FontSize="15" FontWeight="Bold"
                                       Foreground="#c084fc" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="10" Text="-" FontSize="13" Foreground="#fed7aa" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ============================================ -->
        <!-- ROW 1: BOTTOM BAR (26px) -->
        <!-- ============================================ -->
        <Border Grid.Row="1" Background="#292524" CornerRadius="5" Padding="10,0" Margin="0,4,0,0">
            <Grid VerticalAlignment="Center">
                <!-- LEGENDA -->
                <StackPanel Orientation="Horizontal">
                    <Rectangle Width="8" Height="8" Fill="#22c55e" RadiusX="2" RadiusY="2"/>
                    <TextBlock Text=" OK (±2%)" FontSize="8" Foreground="#78716c" Margin="0,0,10,0"/>
                    <Rectangle Width="8" Height="8" Fill="#fbbf24" RadiusX="2" RadiusY="2"/>
                    <TextBlock Text=" Uwaga (±5%)" FontSize="8" Foreground="#78716c" Margin="0,0,10,0"/>
                    <Rectangle Width="8" Height="8" Fill="#ef4444" RadiusX="2" RadiusY="2"/>
                    <TextBlock Text=" Problem (>5%)" FontSize="8" Foreground="#78716c" Margin="0,0,10,0"/>
                    <TextBlock Text="|" Foreground="#44403c" Margin="5,0"/>
                    <TextBlock Text="Dwuklik = szczegóły  |  PPM na ikonach = zmień" FontSize="8" Foreground="#78716c"/>
                </StackPanel>

                <!-- PRAWY PANEL -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock FontSize="9" Foreground="#78716c" VerticalAlignment="Center">
                        <Run Text="Akt: "/><Run x:Name="txtAutoRefreshFooter" Text="-" Foreground="#fbbf24"/>
                    </TextBlock>
                    <Button Content="🧮 Plan?" Style="{StaticResource BottomBtn}" Click="BtnPlanWyjasnij_Click" Margin="12,0,0,0"
                            ToolTip="Pokaż dokładnie skąd wzięła się kolumna PLAN dla każdego wiersza"/>
                    <Button Content="📋 Excel" Style="{StaticResource BottomBtn}" Click="BtnExportExcel_Click" Margin="4,0,0,0"/>
                    <Button Content="🖨️ Drukuj" Style="{StaticResource BottomBtn}" Click="BtnPrint_Click" Margin="4,0,0,0"/>
                    <Button Content="🔧 DIAG" Style="{StaticResource BottomBtnDanger}" Click="BtnDiagnose_Click" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- OVERLAY ŁADOWANIA -->
        <!-- ============================================ -->
        <Border x:Name="loadingOverlay" Grid.RowSpan="2" Background="#CC1c1917" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Ellipse x:Name="spinnerEllipse" Width="40" Height="40" StrokeThickness="3"
                         Stroke="#f59e0b" StrokeDashArray="3,2">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="spinnerRotate" CenterX="20" CenterY="20"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="spinnerRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <TextBlock x:Name="txtLoadingMessage" Text="Aktualizacja..." Foreground="#e7e5e4" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <!-- ============================================ -->
        <!-- OVERLAY BŁĘDU -->
        <!-- ============================================ -->
        <Border x:Name="errorOverlay" Grid.RowSpan="2" Background="#CC1c1917" Visibility="Collapsed">
            <Border Background="#292524" CornerRadius="8" Padding="25,20" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400">
                <StackPanel>
                    <TextBlock Text="Błąd połączenia" FontSize="16" FontWeight="Bold" Foreground="#ef4444" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock x:Name="txtErrorMessage" Text="" Foreground="#a8a29e" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,15"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Spróbuj ponownie" Style="{StaticResource BtnAmber}" Click="BtnRetry_Click" Padding="15,6" Margin="0,0,8,0"/>
                        <Button Content="Kopiuj błąd" Click="BtnCopyError_Click" Padding="15,6" Cursor="Hand"
                                Background="#44403c" Foreground="#d6d3d1" BorderThickness="0" FontSize="11">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</Window>
