<Window x:Class="Kalendarz1.DOA.DOAWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:Kalendarz1.AnalitykaPelna.Services"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="DOA — Padłe w transporcie" Height="820" Width="1320"
        WindowStartupLocation="CenterScreen" Background="White"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Surface" Color="#F8FAFC"/>
        <svc:HexToBrushConverter x:Key="HexToBrush"/>

        <DropShadowEffect x:Key="CardShadow" Color="#0F172A" BlurRadius="14" ShadowDepth="2" Opacity="0.10"/>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#EFF6FF"/></Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StatusRow" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Setter Property="Background" Value="{Binding TloKolor, Converter={StaticResource HexToBrush}, Mode=OneWay}"/>
        </Style>
        <Style x:Key="BtnFlat" TargetType="Button">
            <Setter Property="Background" Value="#EEF2F7"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Opacity" Value="0.86"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="b" Property="Opacity" Value="0.72"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="b" Property="Opacity" Value="0.5"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🐔 DOA — padłe w transporcie" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Analiza danych ze Specyfikacji Drobiu. Norma: cel poniżej 0,2% — max 0,5%."
                               FontSize="11.5" Foreground="{StaticResource TextMuted}" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="📥 Eksport CSV (Ctrl+E)" Style="{StaticResource BtnFlat}"
                        Click="BtnCsv_Click" ToolTip="Zapisz ranking hodowców do pliku CSV"/>
            </Grid>
        </Border>

        <!-- ═══ DATY + PRESETY ═══ -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1" Padding="24,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Zakres:" VerticalAlignment="Center" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}" Margin="0,0,8,0"/>
                <DatePicker x:Name="dpOd" Width="120" Margin="0,0,4,0" SelectedDateChanged="DateChanged"
                            ToolTip="Data początkowa zakresu"/>
                <TextBlock Text="—" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" Margin="2,0"/>
                <DatePicker x:Name="dpDo" Width="120" Margin="4,0,12,0" SelectedDateChanged="DateChanged"
                            ToolTip="Data końcowa zakresu"/>
                <Button Content="7 dni" Style="{StaticResource BtnFlat}" Click="Preset7_Click" Margin="0,0,4,0"/>
                <Button Content="30 dni" Style="{StaticResource BtnFlat}" Click="Preset30_Click" Margin="0,0,4,0"/>
                <Button Content="Ten miesiąc" Style="{StaticResource BtnFlat}" Click="PresetTenMies_Click" Margin="0,0,4,0"/>
                <Button Content="Poprzedni mies." Style="{StaticResource BtnFlat}" Click="PresetPoprMies_Click" Margin="0,0,4,0"/>
                <Button Content="Rok" Style="{StaticResource BtnFlat}" Click="PresetRok_Click" Margin="0,0,12,0"/>
                <Button x:Name="btnOdswiez" Content="↻ Odśwież (F5)" Background="#2563EB" Foreground="White"
                        Style="{StaticResource BtnFlat}" Click="BtnOdswiez_Click"
                        ToolTip="Wczytaj ponownie z bazy"/>
            </StackPanel>
        </Border>

        <!-- ═══ KPI + TREND ═══ -->
        <Grid Grid.Row="2" Margin="20,16,20,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#EFF6FF" CornerRadius="12" Padding="16,14" Margin="0,0,5,0"
                    Effect="{StaticResource CardShadow}"
                    ToolTip="Średni % padłych w całym wybranym okresie. Cel branżowy: poniżej 0,2%.">
                <StackPanel>
                    <TextBlock Text="ŚREDNIE DOA" FontSize="10.5" Foreground="#1E40AF" FontWeight="SemiBold"/>
                    <TextBlock x:Name="kpiSrednie" Text="—" FontSize="26" FontWeight="Bold" Foreground="#1E3A8A"/>
                    <TextBlock x:Name="kpiSrednieDelta" Text="" FontSize="11" Foreground="#475569"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#FEF2F2" CornerRadius="12" Padding="16,14" Margin="5,0"
                    Effect="{StaticResource CardShadow}"
                    ToolTip="Suma sztuk padłych vs zadeklarowanych przez hodowców.">
                <StackPanel>
                    <TextBlock Text="PADŁE / ZADEKL." FontSize="10.5" Foreground="#991B1B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="kpiPadle" Text="—" FontSize="22" FontWeight="Bold" Foreground="#7F1D1D"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#FFFBEB" CornerRadius="12" Padding="16,14" Margin="5,0"
                    Effect="{StaticResource CardShadow}"
                    ToolTip="Liczba hodowców, których średnie DOA przekracza 0,5% (maks. dopuszczalne).">
                <StackPanel>
                    <TextBlock Text="POWYŻEJ NORMY" FontSize="10.5" Foreground="#92400E" FontWeight="SemiBold"/>
                    <TextBlock x:Name="kpiAlerty" Text="—" FontSize="26" FontWeight="Bold" Foreground="#78350F"/>
                    <TextBlock Text="hodowców" FontSize="10.5" Foreground="#92400E"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="#F0FDF4" CornerRadius="12" Padding="16,14" Margin="5,0,5,0"
                    Effect="{StaticResource CardShadow}"
                    ToolTip="Liczba dostaw (rekordów FarmerCalc) w wybranym okresie.">
                <StackPanel>
                    <TextBlock Text="DOSTAW" FontSize="10.5" Foreground="#166534" FontWeight="SemiBold"/>
                    <TextBlock x:Name="kpiDostaw" Text="—" FontSize="26" FontWeight="Bold" Foreground="#14532D"/>
                    <TextBlock Text="w okresie" FontSize="10.5" Foreground="#166534"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="White" CornerRadius="12" Padding="14,10" Margin="5,0,0,0"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                    Effect="{StaticResource CardShadow}"
                    ToolTip="Średnie DOA dzień po dniu w wybranym okresie.">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="TREND DOA W OKRESIE (% dziennie)" FontSize="10.5"
                               Foreground="#64748B" FontWeight="SemiBold"/>
                    <lvc:CartesianChart Grid.Row="1" x:Name="chartTrend" Height="74" Margin="0,4,0,0">
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis ShowLabels="False"/>
                        </lvc:CartesianChart.AxisY>
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis x:Name="axisTrendX" ShowLabels="False"/>
                        </lvc:CartesianChart.AxisX>
                    </lvc:CartesianChart>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ INSIGHT BOX (auto-wniosek) ═══ -->
        <Border Grid.Row="3" x:Name="boxInsight" Background="#FFFBEB" BorderBrush="#FCD34D"
                BorderThickness="1" CornerRadius="10" Margin="20,4,20,8" Padding="14,10"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="txtInsightIcon" Text="💡" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="txtInsight" FontSize="13" Foreground="#78350F" TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ═══ RANKING + DOSTAWY ═══ -->
        <Grid Grid.Row="4" Margin="20,4,20,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1" CornerRadius="12" Effect="{StaticResource CardShadow}">
                <DockPanel>
                    <!-- Tytuł + szybkie filtry -->
                    <DockPanel DockPanel.Dock="Top" Margin="14,12,14,4" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Text="🏆 Ranking hodowców" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" x:Name="btnFiltrNajlepsi" Content="Najlepsi 5"
                                Style="{StaticResource BtnFlat}" Margin="4,0,0,0" Click="FiltrNajlepsi_Click"
                                ToolTip="TOP 5 z najniższym DOA (min. 3 dostawy)"/>
                        <Button DockPanel.Dock="Right" x:Name="btnFiltrAlerty" Content="Tylko alerty"
                                Style="{StaticResource BtnFlat}" Margin="4,0,0,0" Click="FiltrAlerty_Click"
                                ToolTip="Tylko hodowcy powyżej normy (>0,5%)"/>
                        <Button DockPanel.Dock="Right" x:Name="btnFiltrWszyscy" Content="Wszyscy"
                                Style="{StaticResource BtnFlat}" Background="#2563EB" Foreground="White"
                                Click="FiltrWszyscy_Click" ToolTip="Pokaż wszystkich"/>
                    </DockPanel>
                    <!-- Wyszukiwarka + licznik -->
                    <Grid DockPanel.Dock="Top" Margin="14,2,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox x:Name="txtSzukaj" Height="30" Padding="28,0,8,0" FontSize="12.5"
                                     VerticalContentAlignment="Center" BorderBrush="#CBD5E1"
                                     TextChanged="TxtSzukaj_TextChanged"
                                     ToolTip="Wpisz część nazwy hodowcy"/>
                            <TextBlock Text="🔍" FontSize="14" Margin="8,0,0,0"
                                       VerticalAlignment="Center" Foreground="#94A3B8"
                                       IsHitTestVisible="False"/>
                            <TextBlock x:Name="txtSzukajWatermark" Text="Szukaj hodowcy..."
                                       FontSize="12.5" Margin="32,0,0,0"
                                       VerticalAlignment="Center" Foreground="#94A3B8"
                                       IsHitTestVisible="False"/>
                        </Grid>
                        <TextBlock Grid.Column="1" x:Name="txtRankingInfo" VerticalAlignment="Center"
                                   Margin="12,0,0,0" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    </Grid>
                    <Grid>
                        <DataGrid x:Name="dgRanking" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="None"
                                  BorderThickness="0" RowHeight="34" FontSize="12.5"
                                  CanUserSortColumns="True" CanUserResizeColumns="True"
                                  RowStyle="{StaticResource StatusRow}"
                                  SelectionChanged="DgRanking_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Pozycja}" Width="34"/>
                                <DataGridTextColumn Header="Hodowca" Binding="{Binding Hodowca}" Width="*"/>
                                <DataGridTextColumn Header="Dostaw" Binding="{Binding LiczbaPartii}" Width="55"/>
                                <DataGridTextColumn Header="Padłe / Zadekl." Binding="{Binding PadleFormatted}" Width="110"/>
                                <DataGridTextColumn Header="DOA %" Binding="{Binding ProcentFormatted}" Width="70"/>
                                <DataGridTemplateColumn Header="Trend" Width="85" SortMemberPath="TrendDOAPP">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TrendFormatted}" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                                       Foreground="{Binding TrendKolor, Converter={StaticResource HexToBrush}, Mode=OneWay}"
                                                       ToolTip="Zmiana DOA vs poprzedni okres (zielony = poprawa, czerwony = pogorszenie)"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <!-- Empty state -->
                        <Border x:Name="emptyRanking" Background="White" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="📭" FontSize="44" HorizontalAlignment="Center" Foreground="#CBD5E1"/>
                                <TextBlock Text="Brak hodowców w tym okresie" FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}" Margin="0,8,0,4"/>
                                <TextBlock Text="Spróbuj większego zakresu lub sprawdź czy w Specyfikacji Drobiu wpisywane są padłe (DeclI2)."
                                           FontSize="11.5" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                                           HorizontalAlignment="Center" MaxWidth="320" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1" CornerRadius="12" Effect="{StaticResource CardShadow}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="14,12,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="📋 Dostawy" FontWeight="Bold" FontSize="14"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock x:Name="txtFiltrInfo" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="btnClearFilter" Content="✕ Wyczyść filtr (Esc)"
                                Style="{StaticResource BtnFlat}" Background="#FEE2E2" Foreground="#991B1B"
                                Visibility="Collapsed" Click="BtnClearFilter_Click"
                                ToolTip="Pokaż wszystkie dostawy (skrót: Esc)"/>
                    </Grid>
                    <Grid>
                        <DataGrid x:Name="dgRekordy" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="None"
                                  BorderThickness="0" RowHeight="32" FontSize="12.5"
                                  CanUserSortColumns="True" CanUserResizeColumns="True"
                                  RowStyle="{StaticResource StatusRow}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data" Binding="{Binding DataFormatted}" Width="85"/>
                                <DataGridTextColumn Header="LP" Binding="{Binding CarLp}" Width="40"/>
                                <DataGridTextColumn Header="Hodowca" Binding="{Binding Hodowca}" Width="*"/>
                                <DataGridTextColumn Header="Padłe / Zad." Binding="{Binding SztukiFormatted}" Width="110"/>
                                <DataGridTextColumn Header="DOA %" Binding="{Binding ProcentFormatted}" Width="70"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border x:Name="emptyRekordy" Background="White" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="📭" FontSize="44" HorizontalAlignment="Center" Foreground="#CBD5E1"/>
                                <TextBlock Text="Brak dostaw w tym okresie" FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}" Margin="0,8,0,4"/>
                                <TextBlock x:Name="txtEmptyRekordyHint"
                                           Text="Wybierz inny zakres dat lub sprawdź czy są wpisy w Specyfikacji."
                                           FontSize="11.5" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                                           HorizontalAlignment="Center" MaxWidth="320" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="5" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0" Padding="20,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtStatus" Grid.Column="0" FontSize="11.5" Foreground="{StaticResource TextMuted}"
                           Text="Gotowy." VerticalAlignment="Center"/>
                <TextBlock x:Name="txtSkroty" Grid.Column="1" FontSize="10.5" Foreground="{StaticResource TextMuted}"
                           Text="Skróty: F5 = odśwież • Esc = wyczyść filtr • Ctrl+E = eksport CSV"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ LOADING OVERLAY (zasłania zakładki 2-4) ═══ -->
        <Border x:Name="loadingOverlay" Grid.Row="2" Grid.RowSpan="3" Background="#CCFFFFFF"
                Visibility="Collapsed">
            <Border Background="White" CornerRadius="14" Padding="32,20"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                    Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏳" FontSize="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Ładowanie danych..." FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
