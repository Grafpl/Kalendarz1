<Window x:Class="Kalendarz1.SkrzynkaZakupu.Views.MailReaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Wiadomość" Height="700" Width="900" MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterScreen" Background="White"
        FontFamily="Segoe UI" UseLayoutRounding="True">
    <Window.Resources>
        <SolidColorBrush x:Key="Brand" Color="#2E7D32"/>
        <SolidColorBrush x:Key="BrandSoft" Color="#E8F5E9"/>
        <SolidColorBrush x:Key="Line" Color="#E5E9EF"/>
        <SolidColorBrush x:Key="TextSub" Color="#475569"/>
        <SolidColorBrush x:Key="TextMute" Color="#94A3B8"/>
        <Style x:Key="Act" TargetType="Button">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}" BorderBrush="{StaticResource Line}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="{StaticResource BrandSoft}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="20,16,20,14" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock x:Name="TxtTemat" Text="" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" Foreground="#0F172A"/>
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="Avatar" Grid.Column="0" Width="42" Height="42" CornerRadius="21" Background="#78909C" Margin="0,0,12,0">
                        <TextBlock x:Name="Inicjaly" Text="" Foreground="White" FontWeight="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtOd" FontSize="13.5" FontWeight="SemiBold" Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="TxtDo" FontSize="11.5" Foreground="{StaticResource TextMute}" TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtData" Grid.Column="2" FontSize="11.5" Foreground="{StaticResource TextMute}" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Padding="20,10" Background="#FBFCFD" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource Act}" Content="↩️  Odpowiedz" Click="BtnReply_Click"/>
                <Button Style="{StaticResource Act}" Content="↩️↩️  Wszystkim" Click="BtnReplyAll_Click"/>
                <Button Style="{StaticResource Act}" Content="➡️  Przekaż" Click="BtnForward_Click"/>
                <Button Style="{StaticResource Act}" Content="🖨️  Drukuj" Click="BtnPrint_Click"/>
            </StackPanel>
        </Border>

        <ItemsControl x:Name="LstZalaczniki" Grid.Row="2" Margin="20,12,20,0">
            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Margin="0,0,8,8" Padding="0" Tag="{Binding}" Click="Zalacznik_Click" Cursor="Hand" BorderThickness="0" Background="Transparent">
                        <Border Background="#F1F5F9" CornerRadius="8" Padding="11,8" BorderBrush="{StaticResource Line}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📎" FontSize="14" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding FileName, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSub}" VerticalAlignment="Center"/>
                                <TextBlock Text="⬇" FontSize="13" Margin="9,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brand}"/>
                            </StackPanel>
                        </Border>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <wv2:WebView2 x:Name="WebBody" Grid.Row="3" Margin="6,8,6,6"/>
    </Grid>
</Window>
