<Window x:Class="Kalendarz1.SkrzynkaZakupu.Views.WyborFolderuDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Przenieś do folderu" Height="380" Width="340"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F1F5F9" FontFamily="Segoe UI" UseLayoutRounding="True">
    <Window.Resources>
        <SolidColorBrush x:Key="Brand" Color="#2E7D32"/>
        <SolidColorBrush x:Key="BrandDark" Color="#1B5E20"/>
        <SolidColorBrush x:Key="BrandSoft" Color="#E8F5E9"/>
        <SolidColorBrush x:Key="Line" Color="#E5E9EF"/>

        <Style x:Key="FolderItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" CornerRadius="8" Background="Transparent" Padding="10,9">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#EEF2F7"/></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="bd" Property="Background" Value="{StaticResource BrandSoft}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Primary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brand}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="{StaticResource BrandDark}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Ghost" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8" BorderBrush="{StaticResource Line}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#F1F5F9"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Wybierz folder docelowy" FontWeight="Bold" FontSize="14" Foreground="#0F172A" Margin="2,0,0,10"/>
        <Border Grid.Row="1" Background="White" CornerRadius="10" BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="6">
            <ListBox x:Name="LstFoldery" BorderThickness="0" Background="Transparent"
                     ItemContainerStyle="{StaticResource FolderItemStyle}" MouseDoubleClick="LstFoldery_DoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Ikona}" FontSize="14" Margin="0,0,9,0"/>
                            <TextBlock Text="{Binding DisplayName}" FontSize="13" Foreground="#475569" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Style="{StaticResource Ghost}" Content="Anuluj" Width="84" Height="36" Margin="0,0,8,0" Click="BtnAnuluj_Click"/>
            <Button Style="{StaticResource Primary}" Content="Przenieś" Width="100" Height="36" Click="BtnOk_Click"/>
        </StackPanel>
    </Grid>
</Window>
